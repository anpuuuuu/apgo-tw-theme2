{%- comment -%}
  APGO · Car Care PDP — Mobile Sticky Buy Bar

  B1: collapsed bar (price + 加入購物車 + 前往結帳).
  B2 (this revision): added swipe-up sheet revealing mini cart, drag handle
                      gestures, backdrop + close interactions.

  Structure:
    .apgo-cc-buybar                       — root, fixed bottom on mobile
      .apgo-cc-buybar__backdrop           — full-screen dim overlay (open state)
      .apgo-cc-buybar__panel              — slide-up container
        .apgo-cc-buybar__sheet            — expandable mini cart (max-height: 0 → auto)
          .apgo-cc-buybar__sheet-head     — 下拉收起 (left) + chip (right)
          .apgo-cc-buybar__cart-title     — 「購物車」label
          .apgo-cc-buybar__items          — JS-populated cart line list
          .apgo-cc-buybar__subtotal-row   — 小計 (含運)
        .apgo-cc-buybar__bar              — always-visible bottom CTA bar
          .apgo-cc-buybar__handle         — drag handle (toggle/swipe)
          .apgo-cc-buybar__price          — current variant price
          .apgo-cc-buybar__actions        — 加入購物車 + 前往結帳

  When .is-open is added to root:
    - sheet slides up (max-height + opacity)
    - backdrop fades in
    - handle rotates / hides visually
{%- endcomment -%}

<aside class="apgo-cc-buybar" data-apgo-cc-buybar aria-label="加入購物車">
  <div class="apgo-cc-buybar__backdrop" data-apgo-cc-buybar-backdrop aria-hidden="true"></div>

  <div class="apgo-cc-buybar__panel">
    {%- comment -%} ---- Expandable sheet ---- {%- endcomment -%}
    <div class="apgo-cc-buybar__sheet" data-apgo-cc-buybar-sheet aria-hidden="true">
      <div class="apgo-cc-buybar__sheet-head">
        <button type="button"
                class="apgo-cc-buybar__collapse"
                data-apgo-cc-buybar-close
                aria-label="收起購物車預覽">
          <svg class="apgo-cc-buybar__collapse-icon" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <polyline points="6 9 12 15 18 9"/>
          </svg>
          <span>下拉收起</span>
        </button>
        <span class="apgo-cc-buybar__chip" data-apgo-cc-buybar-chip>
          <span><span data-apgo-cc-buybar-count>0</span> 件</span>
          <span class="apgo-cc-buybar__chip-sep" aria-hidden="true">·</span>
          <span data-apgo-cc-buybar-chip-total>NT$ 0</span>
        </span>
      </div>

      <div class="apgo-cc-buybar__cart-title">購物車</div>

      <div class="apgo-cc-buybar__items" data-apgo-cc-buybar-items>
        {%- comment -%} populated by JS from /cart.js {%- endcomment -%}
        <p class="apgo-cc-buybar__empty" data-apgo-cc-buybar-empty>購物車是空的</p>
      </div>

      <div class="apgo-cc-buybar__subtotal-row">
        <span class="apgo-cc-buybar__subtotal-label">小計 (含運)</span>
        <span class="apgo-cc-buybar__subtotal-val" data-apgo-cc-buybar-subtotal>
          {{ 0 | money }}
        </span>
      </div>
    </div>

    {%- comment -%} ---- Bottom CTA bar (always visible on mobile) ----
      Top row replaces the old drag-line: hint text on the left ("上滑查看
      購物車") + an orange chip on the right showing item count + cart
      total. Tapping anywhere on this row toggles the sheet; swipe gesture
      is wired in JS on the same element.
    {%- endcomment -%}
    <div class="apgo-cc-buybar__bar">
      <button type="button"
              class="apgo-cc-buybar__top"
              data-apgo-cc-buybar-handle
              aria-label="展開購物車預覽">
        <span class="apgo-cc-buybar__top-hint" data-apgo-cc-buybar-hint>
          上滑查看購物車
        </span>
        <span class="apgo-cc-buybar__chip" data-apgo-cc-buybar-chip>
          <span><span data-apgo-cc-buybar-count>0</span> 件</span>
          <span class="apgo-cc-buybar__chip-sep" aria-hidden="true">·</span>
          <span data-apgo-cc-buybar-chip-total>{{ 0 | money }}</span>
        </span>
      </button>
      <div class="apgo-cc-buybar__actions">
        <button type="button"
                class="apgo-cc-buybar__btn apgo-cc-buybar__btn--add"
                data-apgo-cc-buybar-add
                {% if product.available == false %}disabled{% endif %}>
          {%- if product.available -%}加入購物車{%- else -%}已售完{%- endif -%}
        </button>
        <button type="button"
                class="apgo-cc-buybar__btn apgo-cc-buybar__btn--buy"
                data-apgo-cc-buybar-checkout>
          立即購買
        </button>
      </div>
    </div>
  </div>
</aside>

{%- comment -%}
  ============================================================================
  Purchase Modal (mobile-only)
  ----------------------------------------------------------------------------
  Triggered by 加入購物車 or 立即購買 in the buybar. Slides up full-screen,
  shows: image + price (top) → variant chips → qty stepper → single CTA at
  the bottom. CTA label and behaviour swap based on which buybar button
  opened it ('add' vs 'buy' mode).

  Chip + qty changes inside the modal sync back into the in-panel form's
  hidden inputs / radios so apgo-cc-pdp.js's existing variant-switch logic
  fires (price + variant id update). Submitting the modal CTA submits the
  in-panel form via /cart/add.js.

  Inspired by apgo_product_page_v3.liquid's .apgo-variant-modal pattern,
  but using our cc-* tokens + .apgo-cc-pdp__chip / __qty for consistency
  with the in-panel display.
  Hidden on desktop via CSS — buybar itself is hidden on desktop already.
{%- endcomment -%}
<div class="apgo-cc-purchase" data-apgo-cc-purchase aria-hidden="true">
  <div class="apgo-cc-purchase__backdrop" data-apgo-cc-purchase-close></div>
  <div class="apgo-cc-purchase__sheet" role="dialog" aria-modal="true" aria-label="商品選擇">
    {%- comment -%} Floating close button (no header bar — popup style) {%- endcomment -%}
    <button type="button"
            class="apgo-cc-purchase__close"
            data-apgo-cc-purchase-close
            aria-label="關閉">×</button>

    {%- comment -%}
      Hidden mode label kept for JS to read/write a screen-reader-only
      title; user-facing modal has no header title now.
    {%- endcomment -%}
    <span class="visually-hidden" data-apgo-cc-purchase-mode-label>加入購物車</span>

    <div class="apgo-cc-purchase__body">
      {%- comment -%}
        Image (left) + price (right) — horizontal row. Compare-at price
        renders below current when on sale.
      {%- endcomment -%}
      <div class="apgo-cc-purchase__preview">
        {%- if product.featured_media -%}
          <img class="apgo-cc-purchase__img"
               src="{{ product.featured_media | image_url: width: 600 }}"
               alt="{{ product.featured_media.alt | default: product.title }}"
               data-apgo-cc-purchase-img>
        {%- else -%}
          <div class="apgo-cc-purchase__img apgo-cc-purchase__img--blank" aria-hidden="true"></div>
        {%- endif -%}
        <div class="apgo-cc-purchase__price-area">
          <span class="apgo-cc-purchase__price" data-apgo-cc-purchase-price>
            {{ product.selected_or_first_available_variant.price | money }}
          </span>
          {%- if product.compare_at_price > product.price -%}
            <span class="apgo-cc-purchase__compare">{{ product.compare_at_price | money }}</span>
          {%- endif -%}
        </div>
      </div>

      {%- comment -%}
        Variant options — same chip markup as the in-panel form. Inputs
        carry data-apgo-cc-modal-option-input so JS can sync them with
        the in-panel hidden form's radios.

        Skip the whole block when product has no real options (Shopify's
        synthetic "Title = Default Title" placeholder otherwise leaks
        through into the modal as an ugly single-chip row).
      {%- endcomment -%}
      {%- if product.options_with_values.size > 0 and product.has_only_default_variant == false -%}
        <div class="apgo-cc-purchase__options" data-apgo-cc-purchase-options>
          {%- for option in product.options_with_values -%}
            <div class="apgo-cc-pdp__option-group apgo-cc-purchase__option-group"
                 data-option-position="{{ option.position }}">
              <div class="apgo-cc-pdp__option-label">
                <span class="apgo-cc-pdp__option-name">{{ option.name }}</span>
              </div>
              <div class="apgo-cc-pdp__option-chips">
                {%- for value in option.values -%}
                  <label class="apgo-cc-pdp__chip {% if option.selected_value == value %}is-active{% endif %}">
                    <input type="radio"
                           name="apgo-cc-purchase-options[{{ option.name | escape }}]"
                           value="{{ value | escape }}"
                           data-apgo-cc-modal-option-input
                           data-option-name="{{ option.name | escape }}"
                           {% if option.selected_value == value %}checked{% endif %}>
                    <span>{{ value }}</span>
                  </label>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- comment -%} Qty stepper (same markup as in-panel) {%- endcomment -%}
      <div class="apgo-cc-pdp__qty-row apgo-cc-purchase__qty-row">
        <span class="apgo-cc-pdp__qty-label">數量</span>
        <div class="apgo-cc-pdp__qty">
          <button type="button" data-apgo-cc-purchase-qty="down" aria-label="減少">−</button>
          <input type="number" value="1" min="1" data-apgo-cc-purchase-qty-input>
          <button type="button" data-apgo-cc-purchase-qty="up" aria-label="增加">+</button>
        </div>
      </div>
    </div>

    {%- comment -%} Footer with single CTA — label + behaviour set by JS {%- endcomment -%}
    <footer class="apgo-cc-purchase__footer">
      <button type="button"
              class="apgo-cc-buybar__btn apgo-cc-buybar__btn--buy apgo-cc-purchase__cta"
              data-apgo-cc-purchase-cta>
        <span data-apgo-cc-purchase-cta-label>加入購物車</span>
      </button>
    </footer>
  </div>
</div>
