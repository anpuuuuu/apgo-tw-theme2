{% comment %}
  图片懒加载优化 Snippet
  使用方法:
  {% render 'lazy-image',
    image: product.featured_image,
    alt: product.title,
    width: 800,
    class: 'product-image',
    sizes: '(min-width: 768px) 50vw, 100vw'
  %}
{% endcomment %}

{%- liquid
  assign image_alt = alt | default: image.alt | escape
  assign image_width = width | default: 800
  assign image_class = class | default: 'lazy-image'
  assign image_sizes = sizes | default: '100vw'
  assign loading_type = loading | default: 'lazy'

  # 生成不同尺寸的图片URL用于响应式加载
  assign img_url_small = image | image_url: width: 400
  assign img_url_medium = image | image_url: width: 800
  assign img_url_large = image | image_url: width: 1200
  assign img_url_xlarge = image | image_url: width: 1600
-%}

{%- if image -%}
  <img
    src="{{ image | image_url: width: image_width }}"
    srcset="
      {{ img_url_small }} 400w,
      {{ img_url_medium }} 800w,
      {{ img_url_large }} 1200w,
      {{ img_url_xlarge }} 1600w
    "
    sizes="{{ image_sizes }}"
    alt="{{ image_alt }}"
    class="{{ image_class }}"
    width="{{ image.width }}"
    height="{{ image.height }}"
    loading="{{ loading_type }}"
    decoding="async"
    {%- if forloop.first or loading_type == 'eager' -%}
      fetchpriority="high"
    {%- else -%}
      fetchpriority="low"
    {%- endif -%}
  >
{%- else -%}
  <div class="{{ image_class }} placeholder-image" style="background: #f5f5f5;">
    {%- comment -%} 占位图 {%- endcomment -%}
  </div>
{%- endif -%}
