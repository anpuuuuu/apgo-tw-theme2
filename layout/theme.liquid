{% include 'shogun-content-handler' %}
<!doctype html>
<html
  class="no-js{% if request.design_mode %} shopify-design-mode{% endif %}"
  lang="{{ request.locale.iso_code }}"
>
  {% if request.path contains '/policies/' %}
    <style>
      /* 內容容器整體文字 */ #MainContent, #MainContent .rte, #MainContent .rte * { color: #ffffff !important; }
            /* 連結顏色（可自訂） */
      #MainContent a {
        color: #f08418 !important;
        text-decoration-color: #f08418 !important;
      }
      #MainContent a:hover {
        color: #ff9a3c !important;
        text-decoration-color: #ff9a3c !important;
      }

      /* 若某些 section 有白底，讓它透明/繼承背景 */
      #MainContent .section,
      #MainContent .color-scheme {
        background: transparent !important;
      }
    </style>
    
  {% endif %}
  <head>
        <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    {%- render 'stylesheets' -%}

    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    <link
      rel="expect"
      href="#MainContent"
      blocking="render"
      id="view-transition-render-blocker"
    >

    {%- render 'meta-tags' -%}
    {%- render 'seo-schema' -%}
    {%- render 'performance-optimization' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
    {% render 'abpilot-ui-sdk' %}

	
  {% render 'shogun-head' %}

  {%- comment -%}
    Collection page Car Care Colors skin — only loads on collection templates
    so the warm-cream/dark-gray palette cannot leak into PDP, cart, or
    homepage. See docs/CAR_CARE_REDESIGN_PLAN.md (Phase 1).

    Tactical (previous skin) load is preserved as a commented block below
    in case we ever need to revert. Files in assets/ + sections/ are kept
    on disk too. See docs/COLLECTION_TACTICAL_PLAN.md (SUPERSEDED).
  {%- endcomment -%}
  {%- comment -%} Car Care Colors loads on collection pages AND on apgo-v2 product templates {%- endcomment -%}
  {%- assign apgo_cc_active = false -%}
  {%- if template.name == 'collection' -%}{%- assign apgo_cc_active = true -%}{%- endif -%}
  {%- if template.suffix == 'apgo-v2' -%}{%- assign apgo_cc_active = true -%}{%- endif -%}
  {%- if apgo_cc_active -%}
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    {{ 'apgo-carcare.css' | asset_url | stylesheet_tag }}
    {%- if template.suffix == 'apgo-v2' -%}
      <script src="{{ 'apgo-cc-pdp.js' | asset_url }}" defer></script>
      <script src="{{ 'apgo-cc-buybar.js' | asset_url }}" defer></script>
    {%- endif -%}
    {%- if template.name == 'collection' -%}
      <script src="{{ 'apgo-cc-quick-add.js' | asset_url }}" defer></script>
    {%- endif -%}
    {%- comment -%}
      ARCHIVED tactical load (superseded 2026-04-28):
      <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,700;0,900;1,900&family=JetBrains+Mono:wght@700;800;900&display=swap" rel="stylesheet">
      {{ 'apgo-tactical.css' | asset_url | stylesheet_tag }}
      <script src="{{ 'apgo-tactical.js' | asset_url }}" defer></script>
    {%- endcomment -%}
  {%- endif -%}

  {%- if template.suffix == 'apgo-v1s-plus' -%}
    {%- comment -%}
      Critical paint-prevention styles — inlined so they apply on the very first
      frame, before external CSS finishes loading. Stops the promo bar + tactical
      hub from flashing their default dark bg before our scoped overrides hit.
    {%- endcomment -%}
    <style id="apgo-v1s-plus-critical">
      /* --------------------------------------------------------------
         Promo bar (戰術廣播條) — on first paint, before Tailwind CDN is
         ready, the <a> has no flex/padding classes applied so it stacks
         tall and shows its inline background-color (#050505) as a big
         black block, then collapses ("small black") once Tailwind paints.
         Fix: hide the entire section until JS removes .apgo-promo--hidden
         (that handler already runs after DOMContentLoaded + Tailwind).
         --------------------------------------------------------------- */
      #apgo-promo-bar.apgo-promo--hidden {
        visibility: hidden !important;
        height: 0 !important;
        overflow: hidden !important;
      }
      /* Also neutralize the <a>'s inline bg-color with a more specific
         attribute selector so even if the hide above is bypassed, the
         element paints cream not black. */
      #apgo-promo-bar a[style],
      #apgo-promo-bar a[class*="tw-bg-"] {
        background: #fdfaf2 !important;
        background-color: #fdfaf2 !important;
      }

      /* Tactical Hub — their scoped rule #apgo-hub-<id> beats our class
         selector, so we target the id-prefix pattern to match specificity. */
      [id^="apgo-hub-"],
      .apgo-widget-container {
        --dt-bg-screen: #fdfaf2 !important;
        --dt-bg-surface: #fdfaf2 !important;
        --dt-bg-input: #f2ece0 !important;
        --dt-border: #d9d3c3 !important;
      }
      [id^="shopify-section-apgo_tactical_hub"] {
        background: transparent !important;
      }

      /* Announcement + header — color-scheme CSS vars */
      announcement-bar-component,
      header-component,
      .header,
      .announcement-bar {
        --color-background: 253, 250, 242;
        --color-foreground: 45, 46, 40;
        background: #fdfaf2 !important;
      }
    </style>
    {{ 'apgo-pdp.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'apgo-pdp.js' | asset_url }}" defer></script>
    {%- comment -%}
      Bundle picker JS — only loads when this product has the
      apgo.bundle_enabled metafield turned on. See
      docs/V1S_PLUS_BUNDLE_PLAN.md (Phase B).
    {%- endcomment -%}
    {%- if product.metafields.apgo.bundle_enabled -%}
      <script src="{{ 'apgo-bundle.js' | asset_url }}" defer></script>
    {%- endif -%}
  {%- endif -%}
</head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}{% if template.suffix != blank %} template-suffix-{{ template.suffix }}{% endif %}{% if template.name == 'collection' or template.suffix == 'apgo-v2' %} apgo-cc-skin{% endif %}" data-shop-host="{{ shop.permanent_domain }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    {% comment %} 本機預覽時強制留在 127.0.0.1/localhost，不跳轉到線上商店 {% endcomment %}
    <script>
    (function() {
      var host = typeof window !== 'undefined' ? window.location.hostname : '';
      if (host !== '127.0.0.1' && host !== 'localhost') return;
      var shopHost = document.body && document.body.getAttribute('data-shop-host');
      if (!shopHost) return;
      function toPreviewUrl(url) {
        try {
          var u = typeof url === 'string' ? url : (url && url.href);
          if (!u || u.indexOf('http') !== 0) return null;
          var a = document.createElement('a');
          a.href = u;
          if (a.hostname !== shopHost) return null;
          return window.location.origin + (a.pathname || '/') + (a.search || '');
        } catch (e) { return null; }
      }
      function rewriteLinks() {
        var n = 0;
        document.querySelectorAll('a[href^="http"]').forEach(function(a) {
          var to = toPreviewUrl(a.href);
          if (to) {
            a.setAttribute('data-preview-rewritten', '1');
            a.href = to;
            n++;
          }
        });
        document.querySelectorAll('form[action^="http"]').forEach(function(f) {
          var to = toPreviewUrl(f.action);
          if (to) {
            f.setAttribute('data-preview-rewritten', '1');
            f.action = to;
            n++;
          }
        });
        if (n > 0 && typeof fetch !== 'undefined') {
          // #region agent log
          fetch('http://127.0.0.1:7936/ingest/5f767d82-ba44-49e5-a88e-d8d894c8c7d7',{method:'POST',headers:{'Content-Type':'application/json','X-Debug-Session-Id':'bc1222'},body:JSON.stringify({sessionId:'bc1222',location:'theme.liquid:preview-rewrite',message:'links_rewritten_to_preview',data:{count:n},timestamp:Date.now(),hypothesisId:'A'})}).catch(function(){});
          // #endregion
        }
      }
      document.addEventListener('click', function(e) {
        var a = e.target && e.target.closest ? e.target.closest('a') : null;
        if (!a || !a.href) return;
        var to = toPreviewUrl(a.href);
        if (to) {
          e.preventDefault();
          // #region agent log
          if (typeof fetch !== 'undefined') fetch('http://127.0.0.1:7936/ingest/5f767d82-ba44-49e5-a88e-d8d894c8c7d7',{method:'POST',headers:{'Content-Type':'application/json','X-Debug-Session-Id':'bc1222'},body:JSON.stringify({sessionId:'bc1222',location:'theme.liquid:preview-click',message:'click_kept_on_preview',data:{to:to},timestamp:Date.now(),hypothesisId:'B'})}).catch(function(){});
          // #endregion
          window.location.assign(to);
        }
      }, true);
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', rewriteLinks);
      } else {
        rewriteLinks();
      }
      setTimeout(rewriteLinks, 500);
      setTimeout(rewriteLinks, 2000);
    })();
    </script>
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script
      src="{{ 'critical.js' | asset_url }}"
      type="module"
      async
      blocking="render"
    >
      
    </script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}
<!-- ============================================ -->
<!-- APGO Cart Recovery (L2) v1.1 -->
<!-- 跳轉登入後還原 cart + 廣告歸因 -->
<!-- 貼進 layout/theme.liquid body 結束標籤前 -->
<!-- ============================================ -->
<script>
(function() {
  'use strict';

  const RECOVERY_API = 'https://cr.apgo.tw';
  const ATTR_KEYS = ['utm_source','utm_medium','utm_campaign','utm_content','utm_term','fbclid','gclid','ttclid'];
  const DEBUG = false; // 灰度測試期 true,上線後改 false

  function log(...args) { if (DEBUG) console.log('[recovery]', ...args); }
  function warn(...args) { console.warn('[recovery]', ...args); }

  function getGaCid() {
    const m = document.cookie.match(/_ga=GA1\.\d+\.([\d.]+)/);
    return m ? m[1] : null;
  }

  // === A: 進站時抓 first-touch 歸因到 sessionStorage ===
  function captureAttribution() {
    const u = new URLSearchParams(location.search);
    const incoming = {};
    for (const k of ATTR_KEYS) {
      const v = u.get(k);
      if (v) incoming[k] = v;
    }
    if (!Object.keys(incoming).length) return;
    const existing = JSON.parse(sessionStorage.getItem('apgo_attribution') || '{}');
    // first-touch:已有的不蓋,保留最早來源
    const merged = { ...incoming, ...existing };
    sessionStorage.setItem('apgo_attribution', JSON.stringify(merged));
    log('attribution captured', merged);
  }

  // === B: 攔截 LINE 登入按鈕點擊,塞 cr=short_id 到 return_to ===
  function interceptLoginButtons() {
    document.addEventListener('click', async (e) => {
      // ⚠️ Selector 適配:若 B1 觀察 DOM 結構不同,調整這裡
      const target = e.target.closest('a[href*="/account/login"]');
      if (!target) return;

      const text = (target.textContent || '').trim();
      const isLineLogin = text.includes('LINE') || target.classList.contains('m-bottom-sheet-btn');
      // 過濾:右上角 person icon 等非 LINE 登入連結不攔截
      if (!isLineLogin) return;

      e.preventDefault();
      e.stopPropagation();

      try {
        const cart = await fetch('/cart.js').then(r => r.json());
        const payload = {
          cart_token: cart.token,
          line_items: cart.items.map(i => ({ id: i.variant_id, quantity: i.quantity })),
          attribution: JSON.parse(sessionStorage.getItem('apgo_attribution') || '{}'),
          ga_cid: getGaCid(),
          page_from: location.pathname,
          ts: Date.now(),
        };
        log('saving payload', payload);

        const res = await fetch(`${RECOVERY_API}/save`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error('save failed ' + res.status);
        const { id } = await res.json();
        log('got short_id', id);

        // 改寫 return_to:塞 cr= 進去
        const url = new URL(target.href, location.origin);
        const returnTo = url.searchParams.get('return_to') || '/cart';
        const newReturnTo = returnTo + (returnTo.includes('?') ? '&' : '?') + `cr=${id}`;
        url.searchParams.set('return_to', newReturnTo);
        log('redirecting to', url.toString());
        location.href = url.toString();
      } catch (err) {
        warn('save failed, fallback to normal login', err);
        // 失敗就走原本 href,使用者體驗不會更差
        location.href = target.href;
      }
    }, true); // capture phase,確保比其他 listener 早跑
  }

  // === C: 著陸頁讀 ?cr=,拿回 payload,還原 cart + 歸因 ===
  async function tryRecover() {
    const params = new URLSearchParams(location.search);
    const shortId = params.get('cr');
    if (!shortId) return;
    log('attempting recovery for', shortId);

    let payload;
    try {
      const res = await fetch(`${RECOVERY_API}/recover?id=${encodeURIComponent(shortId)}`);
      if (!res.ok) {
        log('recover not ok', res.status);
        return;
      }
      payload = await res.json();
      log('recovered payload', payload);
    } catch (err) {
      warn('recover network failed', err);
      return;
    }

    // 1. 還原 cart(只在當前 cart 是空時)
    let didRestore = false;
    try {
      const currentCart = await fetch('/cart.js').then(r => r.json());
      const needRestore = currentCart.item_count === 0 && payload.line_items?.length > 0;
      if (needRestore) {
        for (const item of payload.line_items) {
          await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(item),
          });
        }
        didRestore = true;
        log('cart restored, items=', payload.line_items.length);
      }
    } catch (err) { warn('cart restore failed', err); }

    // 2. 還原歸因 sessionStorage
    if (payload.attribution && Object.keys(payload.attribution).length) {
      sessionStorage.setItem('apgo_attribution', JSON.stringify(payload.attribution));
    }

    // 3. 清掉 cr=,塞回 utm_* 到 URL,location.replace 觸發 GA4/Pixel 重讀
    const cleanUrl = new URL(location.href);
    cleanUrl.searchParams.delete('cr');
    for (const [k, v] of Object.entries(payload.attribution || {})) {
      cleanUrl.searchParams.set(k, v);
    }
    cleanUrl.searchParams.set('cart_recovered', didRestore ? '1' : '0');
    log('redirecting to clean url', cleanUrl.toString());
    location.replace(cleanUrl.toString());
  }

  function run() {
    captureAttribution();
    interceptLoginButtons();
    tryRecover();
  }
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', run);
  } else {
    run();
  }
})();
</script>
  </body>
  
</html>
