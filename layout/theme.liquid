{% include 'shogun-content-handler' %}
<!doctype html>
<html
  class="no-js{% if request.design_mode %} shopify-design-mode{% endif %}"
  lang="{{ request.locale.iso_code }}"
>
  {% if request.path contains '/policies/' %}
    <style>
      /* 內容容器整體文字 */ #MainContent, #MainContent .rte, #MainContent .rte * { color: #ffffff !important; }
            /* 連結顏色（可自訂） */
      #MainContent a {
        color: #f08418 !important;
        text-decoration-color: #f08418 !important;
      }
      #MainContent a:hover {
        color: #ff9a3c !important;
        text-decoration-color: #ff9a3c !important;
      }

      /* 若某些 section 有白底，讓它透明/繼承背景 */
      #MainContent .section,
      #MainContent .color-scheme {
        background: transparent !important;
      }
    </style>
    
  {% endif %}
  <head>
        <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    {%- render 'stylesheets' -%}

    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {% comment %} This a way to wait for main content to load when navigating to a new page so that the view transitions can work consistently {% endcomment %}
    <link
      rel="expect"
      href="#MainContent"
      blocking="render"
      id="view-transition-render-blocker"
    >

    {%- render 'meta-tags' -%}
    {%- render 'seo-schema' -%}
    {%- render 'performance-optimization' -%}
    {%- render 'fonts' -%}
    {%- render 'scripts' -%}
    {%- render 'theme-styles-variables' -%}
    {%- render 'color-schemes' -%}

    {% if request.design_mode %}
      {%- render 'theme-editor' -%}
    {% endif %}

    {{ content_for_header }}
    {% render 'abpilot-ui-sdk' %}

	
  {% render 'shogun-head' %}

  {%- comment -%}
    Collection page Car Care Colors skin — only loads on collection templates
    so the warm-cream/dark-gray palette cannot leak into PDP, cart, or
    homepage. See docs/CAR_CARE_REDESIGN_PLAN.md (Phase 1).

    Tactical (previous skin) load is preserved as a commented block below
    in case we ever need to revert. Files in assets/ + sections/ are kept
    on disk too. See docs/COLLECTION_TACTICAL_PLAN.md (SUPERSEDED).
  {%- endcomment -%}
  {%- comment -%} Car Care Colors loads on collection, search, AND apgo-v2 product templates {%- endcomment -%}
  {%- assign apgo_cc_active = false -%}
  {%- if template.name == 'collection' -%}{%- assign apgo_cc_active = true -%}{%- endif -%}
  {%- if template.name == 'search' -%}{%- assign apgo_cc_active = true -%}{%- endif -%}
  {%- if template.suffix == 'apgo-v2' -%}{%- assign apgo_cc_active = true -%}{%- endif -%}
  {%- if apgo_cc_active -%}
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500&family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    {{ 'apgo-carcare.css' | asset_url | stylesheet_tag }}
    {%- if template.suffix == 'apgo-v2' -%}
      <script src="{{ 'apgo-cc-pdp.js' | asset_url }}" defer></script>
      <script src="{{ 'apgo-cc-buybar.js' | asset_url }}" defer></script>
    {%- endif -%}
    {%- if template.name == 'collection' or template.name == 'search' -%}
      <script src="{{ 'apgo-cc-quick-add.js' | asset_url }}" defer></script>
    {%- endif -%}
    {%- comment -%}
      ARCHIVED tactical load (superseded 2026-04-28):
      <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,400;0,700;0,900;1,900&family=JetBrains+Mono:wght@700;800;900&display=swap" rel="stylesheet">
      {{ 'apgo-tactical.css' | asset_url | stylesheet_tag }}
      <script src="{{ 'apgo-tactical.js' | asset_url }}" defer></script>
    {%- endcomment -%}
  {%- endif -%}

  {%- if template.suffix == 'apgo-v1s-plus' -%}
    {%- comment -%}
      Critical paint-prevention styles — inlined so they apply on the very first
      frame, before external CSS finishes loading. Stops the promo bar + tactical
      hub from flashing their default dark bg before our scoped overrides hit.
    {%- endcomment -%}
    <style id="apgo-v1s-plus-critical">
      /* --------------------------------------------------------------
         Promo bar (戰術廣播條) — on first paint, before Tailwind CDN is
         ready, the <a> has no flex/padding classes applied so it stacks
         tall and shows its inline background-color (#050505) as a big
         black block, then collapses ("small black") once Tailwind paints.
         Fix: hide the entire section until JS removes .apgo-promo--hidden
         (that handler already runs after DOMContentLoaded + Tailwind).
         --------------------------------------------------------------- */
      #apgo-promo-bar.apgo-promo--hidden {
        visibility: hidden !important;
        height: 0 !important;
        overflow: hidden !important;
      }
      /* Also neutralize the <a>'s inline bg-color with a more specific
         attribute selector so even if the hide above is bypassed, the
         element paints cream not black. */
      #apgo-promo-bar a[style],
      #apgo-promo-bar a[class*="tw-bg-"] {
        background: #fdfaf2 !important;
        background-color: #fdfaf2 !important;
      }

      /* Tactical Hub — their scoped rule #apgo-hub-<id> beats our class
         selector, so we target the id-prefix pattern to match specificity. */
      [id^="apgo-hub-"],
      .apgo-widget-container {
        --dt-bg-screen: #fdfaf2 !important;
        --dt-bg-surface: #fdfaf2 !important;
        --dt-bg-input: #f2ece0 !important;
        --dt-border: #d9d3c3 !important;
      }
      [id^="shopify-section-apgo_tactical_hub"] {
        background: transparent !important;
      }

      /* Announcement + header — color-scheme CSS vars */
      announcement-bar-component,
      header-component,
      .header,
      .announcement-bar {
        --color-background: 253, 250, 242;
        --color-foreground: 45, 46, 40;
        background: #fdfaf2 !important;
      }
    </style>
    {{ 'apgo-pdp.css' | asset_url | stylesheet_tag }}
    <script src="{{ 'apgo-pdp.js' | asset_url }}" defer></script>
    {%- comment -%}
      Bundle picker JS — only loads when this product has the
      apgo.bundle_enabled metafield turned on. See
      docs/V1S_PLUS_BUNDLE_PLAN.md (Phase B).
    {%- endcomment -%}
    {%- if product.metafields.apgo.bundle_enabled -%}
      <script src="{{ 'apgo-bundle.js' | asset_url }}" defer></script>
    {%- endif -%}
  {%- endif -%}
</head>

  <body class="page-width-{{ settings.page_width }} card-hover-effect-{{ settings.card_hover_effect }}{% if template.suffix != blank %} template-suffix-{{ template.suffix }}{% endif %}{% if template.name == 'collection' or template.name == 'search' or template.suffix == 'apgo-v2' %} apgo-cc-skin{% endif %}{% if template.name == 'search' %} apgo-cc-search{% endif %}" data-shop-host="{{ shop.permanent_domain }}">
    {% render 'skip-to-content-link', href: '#MainContent', text: 'accessibility.skip_to_text' %}
    {% comment %} 本機預覽時強制留在 127.0.0.1/localhost，不跳轉到線上商店 {% endcomment %}
    <script>
    (function() {
      var host = typeof window !== 'undefined' ? window.location.hostname : '';
      if (host !== '127.0.0.1' && host !== 'localhost') return;
      var shopHost = document.body && document.body.getAttribute('data-shop-host');
      if (!shopHost) return;
      function toPreviewUrl(url) {
        try {
          var u = typeof url === 'string' ? url : (url && url.href);
          if (!u || u.indexOf('http') !== 0) return null;
          var a = document.createElement('a');
          a.href = u;
          if (a.hostname !== shopHost) return null;
          return window.location.origin + (a.pathname || '/') + (a.search || '');
        } catch (e) { return null; }
      }
      function rewriteLinks() {
        var n = 0;
        document.querySelectorAll('a[href^="http"]').forEach(function(a) {
          var to = toPreviewUrl(a.href);
          if (to) {
            a.setAttribute('data-preview-rewritten', '1');
            a.href = to;
            n++;
          }
        });
        document.querySelectorAll('form[action^="http"]').forEach(function(f) {
          var to = toPreviewUrl(f.action);
          if (to) {
            f.setAttribute('data-preview-rewritten', '1');
            f.action = to;
            n++;
          }
        });
        if (n > 0 && typeof fetch !== 'undefined') {
          // #region agent log
          fetch('http://127.0.0.1:7936/ingest/5f767d82-ba44-49e5-a88e-d8d894c8c7d7',{method:'POST',headers:{'Content-Type':'application/json','X-Debug-Session-Id':'bc1222'},body:JSON.stringify({sessionId:'bc1222',location:'theme.liquid:preview-rewrite',message:'links_rewritten_to_preview',data:{count:n},timestamp:Date.now(),hypothesisId:'A'})}).catch(function(){});
          // #endregion
        }
      }
      document.addEventListener('click', function(e) {
        var a = e.target && e.target.closest ? e.target.closest('a') : null;
        if (!a || !a.href) return;
        var to = toPreviewUrl(a.href);
        if (to) {
          e.preventDefault();
          // #region agent log
          if (typeof fetch !== 'undefined') fetch('http://127.0.0.1:7936/ingest/5f767d82-ba44-49e5-a88e-d8d894c8c7d7',{method:'POST',headers:{'Content-Type':'application/json','X-Debug-Session-Id':'bc1222'},body:JSON.stringify({sessionId:'bc1222',location:'theme.liquid:preview-click',message:'click_kept_on_preview',data:{to:to},timestamp:Date.now(),hypothesisId:'B'})}).catch(function(){});
          // #endregion
          window.location.assign(to);
        }
      }, true);
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', rewriteLinks);
      } else {
        rewriteLinks();
      }
      setTimeout(rewriteLinks, 500);
      setTimeout(rewriteLinks, 2000);
    })();
    </script>
    <div id="header-group">
      {% sections 'header-group' %}
    </div>

    <script
      src="{{ 'critical.js' | asset_url }}"
      type="module"
      async
      blocking="render"
    >
      
    </script>

    <main
      id="MainContent"
      class="content-for-layout"
      role="main"
      data-page-transition-enabled="{{ settings.page_transition_enabled }}"
      data-product-transition="{{ settings.transition_to_main_product }}"
      data-template="{{ template }}"
    >
      {{ content_for_layout }}
    </main>

    {% sections 'footer-group' %}

    {% render 'search-modal' %}

    {% if settings.quick_add or settings.mobile_quick_add %}
      {% render 'quick-add-modal' %}
    {% endif %}
<!-- ============================================ -->
<!-- APGO Cart Recovery (L2) v2.0 -->
<!-- 跳轉登入後還原 cart + 廣告歸因 + User Journey 追蹤 -->
<!-- 貼進 layout/theme.liquid body 結束標籤前 -->
<!-- ============================================ -->
<script>
(function() {
  'use strict';

  const RECOVERY_API = 'https://cr.apgo.tw';
  const ATTR_KEYS = ['utm_source','utm_medium','utm_campaign','utm_content','utm_term','fbclid','gclid','ttclid'];
  const SESSION_TIMEOUT_MS = 30 * 60 * 1000;
  const TRACK_BATCH_INTERVAL_MS = 3000;
  const DEBUG = true; // 灰度測試期 true,上線後改 false

  function log() { if (DEBUG) console.log.apply(console, ['[recovery]'].concat([].slice.call(arguments))); }
  function warn() { console.warn.apply(console, ['[recovery]'].concat([].slice.call(arguments))); }

  // === UUID / ID 管理 ===
  function uuid() {
    if (window.crypto && crypto.randomUUID) return crypto.randomUUID();
    return 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {
      var r = Math.random() * 16 | 0;
      var v = c === 'x' ? r : (r & 0x3 | 0x8);
      return v.toString(16);
    });
  }

  function getDeviceId() {
    var id;
    try {
      id = localStorage.getItem('apgo_device_id');
      if (!id) {
        id = 'dev_' + uuid();
        localStorage.setItem('apgo_device_id', id);
      }
    } catch (e) {
      id = id || 'dev_' + uuid(); // private mode fallback (ephemeral)
    }
    return id;
  }

  function getSessionId() {
    var id, lastActive = 0, now = Date.now();
    try {
      id = localStorage.getItem('apgo_session_id');
      lastActive = Number(localStorage.getItem('apgo_session_last_active') || 0);
    } catch (e) {}
    if (!id || now - lastActive > SESSION_TIMEOUT_MS) {
      id = 'sess_' + uuid();
      try { localStorage.setItem('apgo_session_id', id); } catch (e) {}
    }
    try { localStorage.setItem('apgo_session_last_active', String(now)); } catch (e) {}
    return id;
  }

  function getGaCid() {
    var m = document.cookie.match(/_ga=GA1\.\d+\.([\d.]+)/);
    return m ? m[1] : null;
  }

  // === Attribution (first-touch) ===
  function captureAttribution() {
    var u = new URLSearchParams(location.search);
    var incoming = {};
    for (var i = 0; i < ATTR_KEYS.length; i++) {
      var k = ATTR_KEYS[i];
      var v = u.get(k);
      if (v) incoming[k] = v;
    }
    if (!Object.keys(incoming).length) return;
    var existing = {};
    try { existing = JSON.parse(sessionStorage.getItem('apgo_attribution') || '{}'); } catch (e) {}
    var merged = Object.assign({}, incoming, existing); // first-touch
    try { sessionStorage.setItem('apgo_attribution', JSON.stringify(merged)); } catch (e) {}
    log('attribution captured', merged);
  }

  function getAttribution() {
    try { return JSON.parse(sessionStorage.getItem('apgo_attribution') || '{}'); }
    catch (e) { return {}; }
  }

  // === Event Queue + Batched Beacon ===
  var queue = [];

  function track(type, props) {
    var ev = { type: type, url: location.pathname, ts: Date.now() };
    if (props) for (var k in props) if (Object.prototype.hasOwnProperty.call(props, k)) ev[k] = props[k];
    queue.push(ev);
    log('track', type, props || {});
  }

  function flush(useBeacon) {
    if (!queue.length) return;
    var events = queue.splice(0, queue.length);
    var payload = {
      session_id: getSessionId(),
      device_id: getDeviceId(),
      events: events,
      attribution: getAttribution(),
    };
    var body = JSON.stringify(payload);
    var url = RECOVERY_API + '/track';
    if (useBeacon && navigator.sendBeacon) {
      try {
        navigator.sendBeacon(url, new Blob([body], { type: 'application/json' }));
        return;
      } catch (e) { /* fall through */ }
    }
    try {
      fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: body,
        keepalive: true,
      }).catch(function() {});
    } catch (e) { /* ignore */ }
  }

  setInterval(function() { flush(false); }, TRACK_BATCH_INTERVAL_MS);
  window.addEventListener('beforeunload', function() { flush(true); });
  window.addEventListener('pagehide', function() { flush(true); });

  // === interceptLoginButtons (現有 + v2 加 session/device id) ===
  function interceptLoginButtons() {
    document.addEventListener('click', async function(e) {
      var target = e.target.closest('a[href*="/account/login"]');
      if (!target) return;
      var text = (target.textContent || '').trim();
      var isLineLogin = text.indexOf('LINE') !== -1 || target.classList.contains('m-bottom-sheet-btn');
      if (!isLineLogin) return;

      e.preventDefault();
      e.stopPropagation();

      try {
        var cart = await fetch('/cart.js').then(function(r) { return r.json(); });
        var payload = {
          cart_token: cart.token,
          line_items: cart.items.map(function(i) { return { id: i.variant_id, quantity: i.quantity }; }),
          attribution: getAttribution(),
          ga_cid: getGaCid(),
          page_from: location.pathname,
          ts: Date.now(),
          session_id: getSessionId(),    // v2
          device_id: getDeviceId(),      // v2
        };
        log('saving payload', payload);

        var res = await fetch(RECOVERY_API + '/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload),
        });
        if (!res.ok) throw new Error('save failed ' + res.status);
        var data = await res.json();
        var id = data.id;
        log('got short_id', id);

        var u = new URL(target.href, location.origin);
        var returnTo = u.searchParams.get('return_to') || '/cart';
        var newReturnTo = returnTo + (returnTo.indexOf('?') !== -1 ? '&' : '?') + 'cr=' + id;
        u.searchParams.set('return_to', newReturnTo);
        log('redirecting to', u.toString());
        location.href = u.toString();
      } catch (err) {
        warn('save failed, fallback to normal login', err);
        location.href = target.href;
      }
    }, true);
  }

  // === tryRecover (現有 + v2 加 session/device id in query) ===
  async function tryRecover() {
    var params = new URLSearchParams(location.search);
    var shortId = params.get('cr');
    if (!shortId) return;
    log('attempting recovery for', shortId);

    var payload;
    try {
      var u = new URL(RECOVERY_API + '/recover');
      u.searchParams.set('id', shortId);
      u.searchParams.set('session_id', getSessionId());   // v2
      u.searchParams.set('device_id', getDeviceId());     // v2
      var res = await fetch(u.toString());
      if (!res.ok) {
        log('recover not ok', res.status);
        return;
      }
      payload = await res.json();
      log('recovered payload', payload);
    } catch (err) {
      warn('recover network failed', err);
      return;
    }

    var didRestore = false;
    try {
      var currentCart = await fetch('/cart.js').then(function(r) { return r.json(); });
      var needRestore = currentCart.item_count === 0 && payload.line_items && payload.line_items.length > 0;
      if (needRestore) {
        for (var i = 0; i < payload.line_items.length; i++) {
          var item = payload.line_items[i];
          await fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(item),
          });
        }
        didRestore = true;
        log('cart restored, items=', payload.line_items.length);
      }
    } catch (err) { warn('cart restore failed', err); }

    if (payload.attribution && Object.keys(payload.attribution).length) {
      try { sessionStorage.setItem('apgo_attribution', JSON.stringify(payload.attribution)); } catch (e) {}
    }

    var cleanUrl = new URL(location.href);
    cleanUrl.searchParams.delete('cr');
    var attrEntries = Object.entries(payload.attribution || {});
    for (var j = 0; j < attrEntries.length; j++) {
      cleanUrl.searchParams.set(attrEntries[j][0], attrEntries[j][1]);
    }
    cleanUrl.searchParams.set('cart_recovered', didRestore ? '1' : '0');
    log('redirecting to clean url', cleanUrl.toString());
    location.replace(cleanUrl.toString());
  }

  // === v2 Auto Event Listeners ===
  function setupAutoEvents() {
    // page_view on SPA history.pushState
    try {
      var _ps = history.pushState;
      history.pushState = function() {
        _ps.apply(this, arguments);
        track('page_view');
      };
      window.addEventListener('popstate', function() { track('page_view'); });
    } catch (e) {}

    // view_item on /products/
    if (/^\/products\//.test(location.pathname)) {
      var priceMeta = document.querySelector('meta[property="og:price:amount"], meta[property="product:price:amount"]');
      var price = priceMeta ? Number(priceMeta.content) : 0;
      track('view_item', { value: price });
    }

    // view_cart on /cart
    if (location.pathname === '/cart' || location.pathname === '/cart/') {
      fetch('/cart.js').then(function(r) { return r.json(); }).then(function(c) {
        track('view_cart', { value: (c.total_price || 0) / 100 });
      }).catch(function() { track('view_cart'); });
    }

    // add_to_cart / remove_from_cart via fetch hook (capture Shopify cart API)
    var _origFetch = window.fetch;
    window.fetch = function(input, init) {
      var u = (typeof input === 'string') ? input : (input && input.url) || '';
      var isAddCart = u.indexOf('/cart/add') !== -1;
      var isChangeCart = u.indexOf('/cart/change') !== -1 || u.indexOf('/cart/update') !== -1;
      var result = _origFetch.apply(this, arguments);
      try {
        if (isAddCart || isChangeCart) {
          result.then(function(res) {
            if (!res.ok) return;
            res.clone().json().then(function(data) {
              if (isAddCart) {
                track('add_to_cart', { value: (data.line_price || data.total_price || 0) / 100 });
              } else if (isChangeCart) {
                // 若 quantity=0 視為 remove
                try {
                  var initBody = init && init.body ? init.body : null;
                  if (typeof initBody === 'string' && /quantity"\s*:\s*0/.test(initBody)) {
                    track('remove_from_cart');
                  }
                } catch (ee) {}
              }
            }).catch(function() {});
          }).catch(function() {});
        }
      } catch (e) {}
      return result;
    };

    // begin_checkout on click 主結帳按鈕
    document.addEventListener('click', function(e) {
      var btn = e.target.closest('#checkout-standalone, [data-checkout-trigger], button[name="checkout"]');
      if (!btn) return;
      fetch('/cart.js').then(function(r) { return r.json(); }).then(function(c) {
        track('begin_checkout', { value: (c.total_price || 0) / 100 });
      }).catch(function() { track('begin_checkout'); });
    }, true);

    // scroll_depth 50 / 80
    var scrolledMax = 0;
    window.addEventListener('scroll', function() {
      var maxScroll = document.body.scrollHeight - window.innerHeight;
      if (maxScroll <= 0) return;
      var pct = Math.round((window.scrollY / maxScroll) * 100);
      if (pct >= 50 && scrolledMax < 50) { scrolledMax = 50; track('scroll_depth_50'); }
      if (pct >= 80 && scrolledMax < 80) { scrolledMax = 80; track('scroll_depth_80'); }
    }, { passive: true });
  }

  // === Init ===
  function run() {
    captureAttribution();
    track('session_start');
    track('page_view');
    interceptLoginButtons();
    setupAutoEvents();
    tryRecover();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', run);
  } else {
    run();
  }
})();
</script>
  </body>
  
</html>
