{%- comment -%}
  APGO · Badge 輪播
  内容區頂部的自動輪播 banner 帶。1-5 張圖，橫向 slide 自動輪播。
  圖片高度「不限制」（height:auto，由圖片決定）。

  叠加模式（overlay）：banner 以絕對定位浮在下一個區塊（hero）上方，
  且「底邊」錨定在一條基準線（floor，從 hero 頂端往下 N px）。
  → 圖片再高也只會「往上長」（高出 hero 頂部），底邊永遠不會越過基準線、
    不會壓到 hero 的標題文字。基準線請拖到 hero 標題上方。
  關閉叠加 → 變回獨立一條 banner（正常佔位、不錨定）。
  單張時靜態不輪播；0 張時整個 section 不顯示。
{%- endcomment -%}

{%- liquid
  assign banners = section.blocks | where: 'type', 'banner'
  assign shown = 0
  for b in banners
    if b.settings.image != blank
      assign shown = shown | plus: 1
    endif
  endfor
-%}

{%- if shown > 0 -%}
  {%- comment -%}
    Overlap is applied to the SHOPIFY SECTION WRAPPER (#shopify-section-…),
    not the inner element — a negative margin on the inner div is trapped
    inside the wrapper and won't pull the next section (hero) up. Targeting
    the wrapper reliably overlaps the hero by `overlap` px; z-index keeps the
    banner painted over it. Tall banners still push the hero down naturally.
  {%- endcomment -%}
  {%- if section.settings.overlay_on_hero -%}
    <style>
      #shopify-section-{{ section.id }} {
        position: relative;
        z-index: 10;
        margin-bottom: -{{ section.settings.overlap }}px;
      }
      @media (max-width: 749px) {
        #shopify-section-{{ section.id }} {
          margin-bottom: -{{ section.settings.overlap_mobile }}px;
        }
      }
    </style>
  {%- endif -%}
  <section
    class="apgo-cc-badge{% if section.settings.overlay_on_hero %} apgo-cc-badge--overlay{% endif %}"
    data-apgo-cc-badge
    data-autoplay="{{ section.settings.autoplay }}"
    data-interval="{{ section.settings.interval | times: 1000 }}"
    aria-label="{{ section.settings.aria_label | default: '優惠輪播' | escape }}"
    style="
      --badge-pad: {{ section.settings.side_padding }}px;
      --badge-radius: {{ section.settings.radius }}px;
      --badge-maxw: {% if section.settings.max_width > 0 %}{{ section.settings.max_width }}px{% else %}100%{% endif %};
      --badge-overlap: {{ section.settings.overlap }}px;
      --badge-overlap-mobile: {{ section.settings.overlap_mobile }}px;
      --badge-gap-top: {{ section.settings.gap_top }}px;
      --badge-gap-bottom: {{ section.settings.gap_bottom }}px;
      --badge-border-w: {{ section.settings.border_width }}px;
      --badge-border-color: {{ section.settings.border_color }};
    "
  >
    <div class="apgo-cc-badge__inner">
      <div class="apgo-cc-badge__track" data-apgo-cc-badge-track>
        {%- for block in banners -%}
          {%- if block.settings.image == blank -%}{%- continue -%}{%- endif -%}
          {%- capture img -%}
            <img
              class="apgo-cc-badge__img"
              src="{{ block.settings.image | image_url: width: 1600 }}"
              srcset="{{ block.settings.image | image_url: width: 800 }} 800w, {{ block.settings.image | image_url: width: 1200 }} 1200w, {{ block.settings.image | image_url: width: 1600 }} 1600w"
              sizes="100vw"
              alt="{{ block.settings.alt | escape }}"
              loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
              draggable="false"
            >
          {%- endcapture -%}
          {%- if block.settings.link != blank -%}
            <a class="apgo-cc-badge__slide" href="{{ block.settings.link }}" data-badge-slide {{ block.shopify_attributes }}>{{ img }}</a>
          {%- else -%}
            <div class="apgo-cc-badge__slide" data-badge-slide {{ block.shopify_attributes }}>{{ img }}</div>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if shown > 1 and section.settings.show_dots -%}
        <div class="apgo-cc-badge__dots" data-apgo-cc-badge-dots>
          {%- for i in (1..shown) -%}
            <button type="button" class="apgo-cc-badge__dot{% if forloop.first %} is-active{% endif %}" data-badge-dot="{{ forloop.index0 }}" aria-label="第 {{ forloop.index }} 張"></button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </section>

  <script>
  (function () {
    function initBadge(root) {
      if (!root || root.dataset.badgeReady) return;
      root.dataset.badgeReady = '1';
      var track = root.querySelector('[data-apgo-cc-badge-track]');
      var slides = root.querySelectorAll('[data-badge-slide]');
      var dots = root.querySelectorAll('[data-badge-dot]');
      if (!track) return;
      var raf = 0;
      function current() { return track.clientWidth ? Math.round(track.scrollLeft / track.clientWidth) : 0; }
      function goTo(i) { track.scrollTo({ left: i * track.clientWidth, behavior: 'smooth' }); }
      function updateDots() {
        var i = current();
        for (var d = 0; d < dots.length; d++) dots[d].classList.toggle('is-active', d === i);
      }
      track.addEventListener('scroll', function () {
        if (!raf) raf = requestAnimationFrame(function () { raf = 0; updateDots(); });
      }, { passive: true });
      for (var d = 0; d < dots.length; d++) {
        (function (dot) {
          dot.addEventListener('click', function () {
            goTo(parseInt(dot.getAttribute('data-badge-dot'), 10) || 0);
            restart();
          });
        })(dots[d]);
      }
      window.addEventListener('resize', function () { goTo(current()); });

      var autoplay = root.getAttribute('data-autoplay') === 'true';
      var interval = parseInt(root.getAttribute('data-interval') || '4000', 10);
      if (interval < 1500) interval = 1500;
      var timer = null, paused = false;
      function next() {
        if (slides.length < 2) return;
        var i = current();
        goTo((i + 1) % slides.length);
      }
      function start() { if (autoplay && slides.length > 1 && !timer) timer = setInterval(function () { if (!paused) next(); }, interval); }
      function stop() { if (timer) { clearInterval(timer); timer = null; } }
      function restart() { stop(); start(); }
      root.addEventListener('pointerenter', function () { paused = true; });
      root.addEventListener('pointerleave', function () { paused = false; });
      root.addEventListener('touchstart', function () { paused = true; }, { passive: true });
      root.addEventListener('touchend', function () { paused = false; }, { passive: true });
      start();
    }
    function initAll(r) { (r || document).querySelectorAll('[data-apgo-cc-badge]').forEach(initBadge); }
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () { initAll(); });
    } else { initAll(); }
    if (window.Shopify && Shopify.designMode) {
      document.addEventListener('shopify:section:load', function (e) { initAll(e.target); });
    }
  })();
  </script>
{%- endif -%}

{% stylesheet %}
    .apgo-cc-badge {
      position: relative;
      width: 100%;
      margin-top: var(--badge-gap-top, 0px);
      margin-bottom: var(--badge-gap-bottom, 0px);
      padding-left: var(--badge-pad, 0px);
      padding-right: var(--badge-pad, 0px);
      box-sizing: border-box;
      z-index: 10;
    }
    .apgo-cc-badge__inner {
      max-width: var(--badge-maxw, 100%);
      margin-left: auto;
      margin-right: auto;
      position: relative;
    }
    /* Overlay overlap is applied on the section WRAPPER via the inline
       <style> above (#shopify-section-…). The banner stays in flow so it
       never covers the header; the wrapper's negative margin presses it onto
       the hero, and a tall banner still pushes the hero down. */
    .apgo-cc-badge__track {
      display: flex;
      width: 100%;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scroll-behavior: smooth;
      scrollbar-width: none;
      overscroll-behavior-x: contain;
      border-radius: var(--badge-radius, 0px);
      border: var(--badge-border-w, 0px) solid var(--badge-border-color, transparent);
    }
    .apgo-cc-badge__track::-webkit-scrollbar { display: none; }
    .apgo-cc-badge__slide {
      flex: 0 0 100%;
      scroll-snap-align: center;
      scroll-snap-stop: always;
      display: block;
      line-height: 0;
    }
    .apgo-cc-badge__img {
      width: 100%;
      height: auto;            /* image decides its own height — no constraint */
      display: block;
      user-select: none;
      -webkit-user-drag: none;
      pointer-events: none;
    }
    .apgo-cc-badge__dots {
      position: absolute;
      left: 0; right: 0; bottom: 10px;
      display: flex; justify-content: center; align-items: center; gap: 7px;
      z-index: 2;
      pointer-events: none;
    }
    .apgo-cc-badge__dot {
      pointer-events: auto;
      width: 7px; height: 7px;
      padding: 0; border: 0;
      border-radius: 999px;
      background: rgba(255,255,255,.55);
      box-shadow: 0 1px 3px rgba(0,0,0,.35);
      cursor: pointer;
      transition: width .25s ease, background .2s ease;
    }
    .apgo-cc-badge__dot.is-active {
      width: 18px;
      background: #fff;
    }
{% endstylesheet %}

{% schema %}
{
  "name": "APGO · Badge 輪播",
  "tag": "section",
  "class": "apgo-cc-badge-section",
  "settings": [
    { "type": "paragraph", "content": "新增 1–5 個「Banner」block，每個上傳一張圖。圖片高度不限制（由圖片決定）。叠加模式下，banner 底邊固定在「底部基準線」，圖片越高就往上長、不會壓到下方文字。" },
    { "type": "checkbox", "id": "autoplay", "label": "自動輪播", "default": true },
    { "type": "range", "id": "interval", "label": "輪播間隔（秒）", "min": 2, "max": 8, "step": 1, "default": 4 },
    { "type": "checkbox", "id": "show_dots", "label": "顯示圓點指示器", "default": true },
    { "type": "header", "content": "版面" },
    { "type": "range", "id": "max_width", "label": "最大寬度（px，0 = 滿版）", "min": 0, "max": 1600, "step": 20, "default": 1040 },
    { "type": "range", "id": "side_padding", "label": "左右邊距（px）", "min": 0, "max": 60, "step": 2, "default": 16 },
    { "type": "range", "id": "radius", "label": "圓角（px）", "min": 0, "max": 24, "step": 2, "default": 14 },
    { "type": "range", "id": "border_width", "label": "邊框寬度（px，0 = 無邊框）", "min": 0, "max": 6, "step": 1, "default": 1 },
    { "type": "color", "id": "border_color", "label": "邊框顏色", "default": "#3d4148" },
    { "type": "header", "content": "叠加（浮在下方 hero 上）" },
    { "type": "checkbox", "id": "overlay_on_hero", "label": "壓在下方 hero 上（叠加模式）", "default": true, "info": "開啟：banner 壓在下方 hero 上，超出的高度自動把 hero 往下推（不會蓋到上方 header）。關閉：變回獨立一條。" },
    { "type": "range", "id": "overlap", "label": "桌機：壓進 hero 的深度（px）", "min": 0, "max": 400, "step": 10, "default": 120, "info": "banner 底部壓進 hero 多少。數字越大壓得越深。banner 比這個高的部分會把 hero 往下推、不會蓋到 header。" },
    { "type": "range", "id": "overlap_mobile", "label": "手機：壓進 hero 的深度（px）", "min": 0, "max": 300, "step": 10, "default": 60 },
    { "type": "header", "content": "非叠加模式間距" },
    { "type": "range", "id": "gap_top", "label": "上方間距（px）", "min": 0, "max": 40, "step": 2, "default": 0 },
    { "type": "range", "id": "gap_bottom", "label": "下方間距（px）", "min": 0, "max": 40, "step": 2, "default": 0 },
    { "type": "text", "id": "aria_label", "label": "無障礙標籤", "default": "優惠輪播" }
  ],
  "blocks": [
    {
      "type": "banner",
      "name": "Banner",
      "limit": 5,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "圖片" },
        { "type": "url", "id": "link", "label": "連結（選填，點擊跳轉）" },
        { "type": "text", "id": "alt", "label": "替代文字（選填，無障礙用）" }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "APGO · Badge 輪播",
      "blocks": [ { "type": "banner" }, { "type": "banner" } ]
    }
  ],
  "enabled_on": {
    "templates": ["index"]
  }
}
{% endschema %}
