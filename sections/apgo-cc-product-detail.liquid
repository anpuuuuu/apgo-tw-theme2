{%- comment -%}
  APGO · Car Care Colors — Product Detail (v2 template)
  Phase 4 of docs/CAR_CARE_REDESIGN_PLAN.md.

  Source: merged-detail.jsx + mobile-detail.jsx (Claude Design bundle).

  This is the MINIMUM-VIABLE skeleton: 2-col layout (gallery + info), variant
  picker, add-to-cart, 5-tab area. Only the 商品描述 tab is wired to real data
  (product.description). The other 4 tabs render a "尚未設定" placeholder so
  the visual lands first; Phase 5 will swap them for metaobject-driven data.

  Bundle widget (right rail in the desktop mock) is deferred to Phase 6.
{%- endcomment -%}

<section class="apgo-cc-pdp" data-apgo-cc-pdp data-section-id="{{ section.id }}">

  {%- comment -%} Breadcrumb {%- endcomment -%}
  {%- if section.settings.show_breadcrumb -%}
    <nav class="apgo-cc-pdp__breadcrumb" aria-label="麵包屑">
      <a href="/collections/all">全部商品</a>
      <span aria-hidden="true">›</span>
      {%- if collection -%}
        <a href="{{ collection.url }}">{{ collection.title }}</a>
        <span aria-hidden="true">›</span>
      {%- endif -%}
      <span class="apgo-cc-pdp__breadcrumb-current">{{ product.title }}</span>
    </nav>
  {%- endif -%}

  <div class="apgo-cc-pdp__main">

    {%- comment -%}
      ---------- Gallery ----------
      Two display modes for the secondary images (multi-image products):
        show_thumbs == true  → row of thumbnail buttons below main image
        show_thumbs == false → small orange dot indicators inside the
                               main image (bottom-center, slideshow style)
      Both modes use the same [data-apgo-cc-thumb] hook so the existing
      JS click-swap works. Dots carry the larger image URL on a data
      attribute (no nested <img> to read from).
    {%- endcomment -%}
    <div class="apgo-cc-pdp__gallery">
      <div class="apgo-cc-pdp__gallery-main">
        {%- if product.featured_media -%}
          <img
            class="apgo-cc-pdp__gallery-img"
            src="{{ product.featured_media | image_url: width: 1200 }}"
            alt="{{ product.featured_media.alt | default: product.title }}"
            data-apgo-cc-main-img
            loading="eager"
          >
        {%- else -%}
          <div class="apgo-cc-pdp__gallery-placeholder">尚未上傳商品圖</div>
        {%- endif -%}
        {%- if product.compare_at_price > product.price -%}
          <span class="apgo-cc-pdp__sale-tag">特價</span>
        {%- endif -%}

        {%- if product.media.size > 1 and section.settings.show_thumbs == false -%}
          <div class="apgo-cc-pdp__gallery-dots" role="tablist" aria-label="圖片切換">
            {%- for m in product.media -%}
              <button
                type="button"
                class="apgo-cc-pdp__gallery-dot{% if forloop.first %} is-active{% endif %}"
                data-apgo-cc-thumb
                data-apgo-cc-thumb-src="{{ m | image_url: width: 1200 }}"
                aria-label="顯示第 {{ forloop.index }} 張圖"
              ></button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
      {%- if product.media.size > 1 and section.settings.show_thumbs -%}
        <div class="apgo-cc-pdp__gallery-thumbs">
          {%- for m in product.media -%}
            <button
              type="button"
              class="apgo-cc-pdp__gallery-thumb {% if forloop.first %}is-active{% endif %}"
              data-apgo-cc-thumb
              aria-label="顯示第 {{ forloop.index }} 張圖"
            >
              <img
                src="{{ m | image_url: width: 200 }}"
                alt="{{ m.alt | default: product.title }}"
                loading="lazy"
              >
            </button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} ---------- Info column ---------- {%- endcomment -%}
    <div class="apgo-cc-pdp__info">
      {%- if section.settings.kicker != blank -%}
        <div class="apgo-cc-pdp__kicker">{{ section.settings.kicker }}</div>
      {%- endif -%}
      <h1 class="apgo-cc-pdp__title">{{ product.title }}</h1>
      {%- if product.metafields.apgo.subtitle != blank -%}
        <p class="apgo-cc-pdp__subtitle">{{ product.metafields.apgo.subtitle }}</p>
      {%- endif -%}

      {%- comment -%} Rating row (placeholder until reviews wired in Phase 6) {%- endcomment -%}
      {%- if section.settings.show_rating -%}
        <div class="apgo-cc-pdp__rating">
          <span class="apgo-cc-pdp__stars" aria-hidden="true">★★★★★</span>
          <strong>{{ section.settings.rating_score | default: '4.9' }}</strong>
          <span class="apgo-cc-pdp__rating-meta">· {{ section.settings.rating_count | default: '312' }} 則評價</span>
        </div>
      {%- endif -%}

      {%- comment -%}
        Price card — two styles per Mobile-Detail-Spec §1.4
          Style A (compare_at > price): boxed, with "限時特價" label and
            "省 NT$ X" pill (spec calls for amount, not %).
          Style B (no compare): plain large orange price, no chrome.
        Countdown timer (spec §5.1) needs apgo.active_campaign metafield;
        deferred until that's wired.
      {%- endcomment -%}
      <div class="apgo-cc-pdp__price-card{% if product.compare_at_price > product.price %} apgo-cc-pdp__price-card--sale{% endif %}">
        {%- if product.compare_at_price > product.price -%}
          {%- assign save_amount = product.compare_at_price | minus: product.price -%}
          {%- comment -%}
            2-row layout per design:
              row 1: 限時特價 (label, full width)
              row 2: [NT$ price] [<s>NT$ compare</s>] ...... [省 NT$ X]
            Countdown timer (剩 23:14:08) reserved for row 1 right side,
            deferred until apgo.active_campaign metafield + JS tick wire up.
          {%- endcomment -%}
          <div class="apgo-cc-pdp__price-top">
            <span class="apgo-cc-pdp__price-label">限時特價</span>
          </div>
          <div class="apgo-cc-pdp__price-bottom">
            <span class="apgo-cc-pdp__price-current" data-apgo-cc-price>{{ product.price | money }}</span>
            <span class="apgo-cc-pdp__price-compare">{{ product.compare_at_price | money }}</span>
            <span class="apgo-cc-pdp__price-save">省 {{ save_amount | money }}</span>
          </div>
        {%- else -%}
          <span class="apgo-cc-pdp__price-current" data-apgo-cc-price>{{ product.price | money }}</span>
        {%- endif -%}
      </div>

      {%- comment -%}
        §1.5 促銷 ICON 列 — orange/green/blue/red/neutral pills.
        Driven entirely by section settings so admin toggles in editor;
        each blank slot is skipped so admin can use 1, 2, or 3.
      {%- endcomment -%}
      {%- if section.settings.show_promo_pills -%}
        {%- assign p1 = section.settings.promo_pill_1_text -%}
        {%- assign p2 = section.settings.promo_pill_2_text -%}
        {%- assign p3 = section.settings.promo_pill_3_text -%}
        {%- if p1 != blank or p2 != blank or p3 != blank -%}
          <div class="apgo-cc-pdp__promos">
            {%- if p1 != blank -%}
              <span class="apgo-cc-pdp__promo apgo-cc-pdp__promo--{{ section.settings.promo_pill_1_color }}">{{ p1 }}</span>
            {%- endif -%}
            {%- if p2 != blank -%}
              <span class="apgo-cc-pdp__promo apgo-cc-pdp__promo--{{ section.settings.promo_pill_2_color }}">{{ p2 }}</span>
            {%- endif -%}
            {%- if p3 != blank -%}
              <span class="apgo-cc-pdp__promo apgo-cc-pdp__promo--{{ section.settings.promo_pill_3_color }}">{{ p3 }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endif -%}

      {%- comment -%} Variant picker + add-to-cart form {%- endcomment -%}
      <form action="/cart/add" method="post" enctype="multipart/form-data" class="apgo-cc-pdp__form">
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-apgo-cc-variant-id>

        {%- for option in product.options_with_values -%}
          <div class="apgo-cc-pdp__option-group" data-apgo-cc-option-group data-option-position="{{ option.position }}">
            <div class="apgo-cc-pdp__option-label">
              <span class="apgo-cc-pdp__option-name">{{ option.name }}</span>
              <span class="apgo-cc-pdp__option-current" data-apgo-cc-option-current>{{ option.selected_value }}</span>
            </div>
            <div class="apgo-cc-pdp__option-chips">
              {%- for value in option.values -%}
                <label class="apgo-cc-pdp__chip {% if option.selected_value == value %}is-active{% endif %}">
                  <input
                    type="radio"
                    name="options[{{ option.name | escape }}]"
                    value="{{ value | escape }}"
                    data-apgo-cc-option-input
                    {% if option.selected_value == value %}checked{% endif %}
                  >
                  <span>{{ value }}</span>
                </label>
              {%- endfor -%}
            </div>
          </div>
        {%- endfor -%}

        <div class="apgo-cc-pdp__qty-row">
          {%- comment -%}
            數量 label is hidden on desktop (kept matching the original
            stepper-only layout) and shown on mobile alongside the stepper
            in a label-left / control-right row per Mobile-Detail-Spec.
          {%- endcomment -%}
          <span class="apgo-cc-pdp__qty-label">數量</span>
          <div class="apgo-cc-pdp__qty">
            <button type="button" data-apgo-cc-qty="down" aria-label="減少">−</button>
            <input type="number" name="quantity" value="1" min="1" data-apgo-cc-qty-input>
            <button type="button" data-apgo-cc-qty="up" aria-label="增加">+</button>
          </div>
        </div>

        {%- comment -%}
          §1.8 運送資訊 — "2–3 個工作日 · ● 現貨/缺貨".
          Stock indicator follows product.available (covers both
          inventory-tracked and continue-when-out-of-stock cases).
        {%- endcomment -%}
        {%- if section.settings.show_shipping -%}
          <div class="apgo-cc-pdp__shipping">
            <span class="apgo-cc-pdp__shipping-label">{{ section.settings.shipping_label | default: '2–3 個工作日' }}</span>
            <span class="apgo-cc-pdp__shipping-sep" aria-hidden="true">·</span>
            <span class="apgo-cc-pdp__shipping-stock{% unless product.available %} apgo-cc-pdp__shipping-stock--out{% endunless %}">
              {%- if product.available -%}● 現貨{%- else -%}● 缺貨{%- endif -%}
            </span>
          </div>
        {%- endif -%}

        {%- comment -%}
          CTA hierarchy (unified across in-panel + mobile buybar):
            加入購物車 = secondary (outlined orange)
            立即購買   = primary   (solid orange)
          Form submit stays on the 加入購物車 button regardless of style.
        {%- endcomment -%}
        <div class="apgo-cc-pdp__cta-row">
          <button
            type="submit"
            class="apgo-cc-pdp__cta apgo-cc-pdp__cta--secondary"
            {% if product.available == false %}disabled{% endif %}
          >
            {%- if product.available -%}加入購物車{%- else -%}已售完{%- endif -%}
          </button>
          {%- if section.settings.show_buy_now -%}
            <button type="button" class="apgo-cc-pdp__cta apgo-cc-pdp__cta--primary" data-apgo-cc-buy-now>
              立即購買
            </button>
          {%- endif -%}
        </div>
      </form>

      {%- comment -%} Promo pills row (deferred — these are part of the «全站滿千» work)
      {%- if section.settings.show_promos -%}
        <div class="apgo-cc-pdp__promos">…</div>
      {%- endif -%}
      {%- endcomment -%}
    </div>

  </div>

  {%- comment -%}
    ---------- Demo videos showcase ----------
    Driven by product.metafields.apgo.demo_videos (list of metaobjects with
    fields: video_file, poster, title, views, duration, sort_order).
    Renders a horizontal-scroll row of poster cards. Click → open modal
    with a <video> player. Only renders when admin has set the metafield.
  {%- endcomment -%}
  {%- assign demo_videos = product.metafields.apgo.demo_videos.value -%}
  {%- if demo_videos != blank and demo_videos.size > 0 -%}
    <section class="apgo-cc-pdp__videos" aria-labelledby="apgo-cc-videos-heading">
      <div class="apgo-cc-pdp__videos-head">
        <p class="apgo-cc-pdp__videos-kicker">PRODUCT VIDEOS</p>
        <h3 class="apgo-cc-pdp__videos-title" id="apgo-cc-videos-heading">
          {{ section.settings.videos_heading | default: '商品實測影片' }}
        </h3>
      </div>
      <div class="apgo-cc-pdp__videos-scroll">
        {%- assign sorted_videos = demo_videos | sort: 'sort_order' -%}
        {%- for v in sorted_videos -%}
          {%- assign vid_url = v.video_file | file_url -%}
          {%- assign poster_url = '' -%}
          {%- if v.poster -%}
            {%- assign poster_url = v.poster | image_url: width: 600 -%}
          {%- endif -%}
          <button type="button"
                  class="apgo-cc-pdp__video-card"
                  data-apgo-cc-video="{{ vid_url | escape }}"
                  data-apgo-cc-video-title="{{ v.title | default: product.title | escape }}"
                  aria-label="播放：{{ v.title | default: product.title }}">
            {%- if poster_url != blank -%}
              <img class="apgo-cc-pdp__video-thumb"
                   src="{{ poster_url }}"
                   alt="{{ v.title | default: product.title }}"
                   loading="lazy">
            {%- else -%}
              <div class="apgo-cc-pdp__video-thumb apgo-cc-pdp__video-thumb--blank" aria-hidden="true"></div>
            {%- endif -%}
            <span class="apgo-cc-pdp__video-play" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="22" height="22" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            </span>
            {%- if v.duration != blank -%}
              <span class="apgo-cc-pdp__video-duration">{{ v.duration }}</span>
            {%- endif -%}
            <div class="apgo-cc-pdp__video-info">
              <span class="apgo-cc-pdp__video-title">{{ v.title | default: '商品實測' }}</span>
              {%- if v.views != blank -%}
                <span class="apgo-cc-pdp__video-views">{{ v.views }} 觀看</span>
              {%- endif -%}
            </div>
          </button>
        {%- endfor -%}
      </div>
    </section>

    {%- comment -%} Single reusable video modal — JS sets the src on open {%- endcomment -%}
    <div class="apgo-cc-pdp__video-modal" data-apgo-cc-video-modal aria-hidden="true">
      <div class="apgo-cc-pdp__video-modal-backdrop" data-apgo-cc-video-close></div>
      <div class="apgo-cc-pdp__video-modal-dialog" role="dialog" aria-modal="true" aria-label="商品實測影片">
        <button type="button" class="apgo-cc-pdp__video-modal-close" data-apgo-cc-video-close aria-label="關閉">×</button>
        <video class="apgo-cc-pdp__video-modal-video"
               data-apgo-cc-video-player
               controls
               playsinline
               preload="metadata"></video>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} ---------- Tabs section ---------- {%- endcomment -%}
  <div class="apgo-cc-pdp__tabs" data-apgo-cc-tabs>
    <div class="apgo-cc-pdp__tab-bar" role="tablist">
      <button type="button" class="apgo-cc-pdp__tab is-active" role="tab" data-apgo-cc-tab="desc">商品描述</button>
      <button type="button" class="apgo-cc-pdp__tab" role="tab" data-apgo-cc-tab="usage">使用方式</button>
      <button type="button" class="apgo-cc-pdp__tab" role="tab" data-apgo-cc-tab="spec">規格和注意事項</button>
      <button type="button" class="apgo-cc-pdp__tab" role="tab" data-apgo-cc-tab="review">客戶評價</button>
      <button type="button" class="apgo-cc-pdp__tab" role="tab" data-apgo-cc-tab="faq">常見FAQ</button>
    </div>

    {%- comment -%} Tab: 商品描述 — wired to product.description {%- endcomment -%}
    <div class="apgo-cc-pdp__tab-panel is-active" data-apgo-cc-panel="desc">
      {%- if section.settings.desc_kicker != blank -%}
        <div class="apgo-cc-pdp__panel-kicker">{{ section.settings.desc_kicker }}</div>
      {%- endif -%}
      {%- if section.settings.desc_heading != blank -%}
        <h2 class="apgo-cc-pdp__panel-heading">{{ section.settings.desc_heading }}</h2>
      {%- endif -%}
      {%- if product.description != blank -%}
        <div class="apgo-cc-pdp__rte rte">{{ product.description }}</div>
      {%- else -%}
        <p class="apgo-cc-pdp__placeholder">尚未填寫商品描述。請至 Shopify 後台 → 產品 → Description 編輯。</p>
      {%- endif -%}
    </div>

    {%- comment -%} Tabs: 使用方式 / 規格 / 評價 / FAQ — placeholders until Phase 5 metafields wired {%- endcomment -%}
    <div class="apgo-cc-pdp__tab-panel" data-apgo-cc-panel="usage">
      {%- assign construction_steps = product.metafields.apgo.construction_steps.value -%}
      {%- if construction_steps != blank and construction_steps.size > 0 -%}
        <ol class="apgo-cc-pdp__steps">
          {%- for step in construction_steps -%}
            <li class="apgo-cc-pdp__step">
              <span class="apgo-cc-pdp__step-num">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</span>
              <div class="apgo-cc-pdp__step-body">
                {%- if step.title != blank -%}
                  <div class="apgo-cc-pdp__step-title">{{ step.title }}</div>
                {%- endif -%}
                {%- if step.desc != blank -%}
                  <div class="apgo-cc-pdp__step-desc">{{ step.desc }}</div>
                {%- endif -%}
              </div>
            </li>
          {%- endfor -%}
        </ol>
      {%- else -%}
        <p class="apgo-cc-pdp__placeholder">使用方式內容尚未設定（請於 Shopify 後台 → 產品 → Metafields → apgo.construction_steps 編輯）。</p>
      {%- endif -%}
    </div>
    {%- comment -%}
      規格和注意事項 — JSON metafield apgo.product_tabs.
      Format: [ { "title": "...", "content": "<p>...HTML...</p>" }, ... ]
      Each entry rendered as a section heading + HTML content block.
      Skip entries whose title is "產品描述" — that content already
      lives in the 商品描述 tab via product.description.
    {%- endcomment -%}
    <div class="apgo-cc-pdp__tab-panel" data-apgo-cc-panel="spec">
      {%- assign mf_tabs = product.metafields.apgo.product_tabs.value -%}
      {%- if mf_tabs != blank and mf_tabs.size > 0 -%}
        <div class="apgo-cc-pdp__sections">
          {%- for entry in mf_tabs -%}
            {%- unless entry.title == '產品描述' -%}
              <section class="apgo-cc-pdp__section">
                {%- if entry.title != blank -%}
                  <h3 class="apgo-cc-pdp__section-title">{{ entry.title }}</h3>
                {%- endif -%}
                {%- if entry.content != blank -%}
                  <div class="apgo-cc-pdp__section-body rte">{{ entry.content }}</div>
                {%- endif -%}
              </section>
            {%- endunless -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <p class="apgo-cc-pdp__placeholder">尚未設定（請於 Shopify 後台 → 產品 → Metafields → apgo.product_tabs 編輯）。</p>
      {%- endif -%}
    </div>

    {%- comment -%}
      客戶評價 — summary card on top + list of reviews. Each review entry has:
      name + date + scent (which scent the customer bought) + body.
    {%- endcomment -%}
    <div class="apgo-cc-pdp__tab-panel" data-apgo-cc-panel="review">
      {%- assign mf_reviews = product.metafields.apgo.reviews.value -%}
      {%- if mf_reviews != blank and mf_reviews.size > 0 -%}
        <div class="apgo-cc-pdp__rev-summary">
          <div class="apgo-cc-pdp__rev-score">{{ section.settings.rating_score | default: '4.9' }}</div>
          <div class="apgo-cc-pdp__rev-summary-meta">
            <div class="apgo-cc-pdp__rev-stars" aria-hidden="true">★★★★★</div>
            <div class="apgo-cc-pdp__rev-count">基於 {{ section.settings.rating_count | default: mf_reviews.size }} 則真實評價</div>
          </div>
        </div>
        <ul class="apgo-cc-pdp__rev-list">
          {%- for r in mf_reviews -%}
            <li class="apgo-cc-pdp__rev-item">
              <div class="apgo-cc-pdp__rev-head">
                <strong class="apgo-cc-pdp__rev-name">{{ r.name }}</strong>
                <span class="apgo-cc-pdp__rev-stars" aria-hidden="true">★★★★★</span>
              </div>
              <div class="apgo-cc-pdp__rev-meta">
                {%- if r.date != blank -%}{{ r.date }}{%- endif -%}
                {%- if r.scent != blank -%}{%- if r.date != blank %} · {% endif -%}已購買：{{ r.scent }}{%- endif -%}
              </div>
              {%- if r.body != blank -%}
                <p class="apgo-cc-pdp__rev-body">{{ r.body }}</p>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- else -%}
        <p class="apgo-cc-pdp__placeholder">客戶評價尚未設定（請於 Shopify 後台 → 產品 → Metafields → apgo.reviews 編輯）。</p>
      {%- endif -%}
    </div>

    {%- comment -%}
      常見 FAQ — accordion list of question / answer pairs from apgo.faqs.
      Uses <details>/<summary> for built-in expand/collapse (no JS needed).
    {%- endcomment -%}
    <div class="apgo-cc-pdp__tab-panel" data-apgo-cc-panel="faq">
      {%- assign mf_faqs = product.metafields.apgo.faqs.value -%}
      {%- if mf_faqs != blank and mf_faqs.size > 0 -%}
        <ul class="apgo-cc-pdp__faq-list">
          {%- for f in mf_faqs -%}
            <li>
              <details class="apgo-cc-pdp__faq-item">
                <summary class="apgo-cc-pdp__faq-summary">
                  <span class="apgo-cc-pdp__faq-q">Q. {{ f.question }}</span>
                  <span class="apgo-cc-pdp__faq-toggle" aria-hidden="true">+</span>
                </summary>
                <div class="apgo-cc-pdp__faq-a">A. {{ f.answer }}</div>
              </details>
            </li>
          {%- endfor -%}
        </ul>
      {%- else -%}
        <p class="apgo-cc-pdp__placeholder">常見 FAQ 尚未設定（請於 Shopify 後台 → 產品 → Metafields → apgo.faqs 編輯）。</p>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} Variants JSON for client-side variant switching {%- endcomment -%}
  <script type="application/json" data-apgo-cc-variants>
    {{ product.variants | json }}
  </script>
</section>

{%- comment -%} Mobile sticky buy bar — fixed bottom, hidden on desktop {%- endcomment -%}
{% render 'apgo-cc-mobile-buybar', product: product %}

{% schema %}
{
  "name": "APGO · 商品詳情 (Car Care)",
  "tag": "section",
  "class": "apgo-cc-pdp-section",
  "settings": [
    { "type": "header", "content": "頁面開關" },
    { "type": "checkbox", "id": "show_breadcrumb", "label": "顯示麵包屑", "default": true },
    { "type": "checkbox", "id": "show_rating",     "label": "顯示星等評分", "default": true },
    { "type": "checkbox", "id": "show_buy_now",    "label": "顯示「立即購買」按鈕", "default": true },
    { "type": "checkbox", "id": "show_thumbs",     "label": "顯示次圖縮圖列（關閉時用主圖底部橘色點點切換）", "default": true },

    { "type": "header", "content": "標題與評分" },
    { "type": "text", "id": "kicker",       "label": "上方小字（kicker，留空則不顯示）" },
    { "type": "text", "id": "rating_score", "label": "評分", "default": "4.9" },
    { "type": "text", "id": "rating_count", "label": "評價數", "default": "312" },

    { "type": "header", "content": "商品描述 tab" },
    { "type": "text", "id": "desc_kicker",  "label": "上方小字", "default": "ABOUT THE PRODUCT" },
    { "type": "text", "id": "desc_heading", "label": "大標（留空則不顯示）" },

    { "type": "header", "content": "影片區（apgo.demo_videos）" },
    { "type": "text", "id": "videos_heading", "label": "影片區標題", "default": "商品實測影片" },

    { "type": "header", "content": "促銷膠囊（§1.5）" },
    { "type": "paragraph", "content": "在價格區下方顯示 1～3 個彩色膠囊（滿千免運 / 會員 9 折 / ...）。空白欄會自動跳過。" },
    { "type": "checkbox", "id": "show_promo_pills", "label": "顯示促銷膠囊", "default": false },
    { "type": "text", "id": "promo_pill_1_text", "label": "膠囊 1 · 文字" },
    { "type": "select", "id": "promo_pill_1_color", "label": "膠囊 1 · 顏色",
      "options": [
        { "value": "orange",  "label": "橘" },
        { "value": "green",   "label": "綠" },
        { "value": "blue",    "label": "藍" },
        { "value": "red",     "label": "紅" },
        { "value": "neutral", "label": "灰（中性）" }
      ],
      "default": "orange"
    },
    { "type": "text", "id": "promo_pill_2_text", "label": "膠囊 2 · 文字" },
    { "type": "select", "id": "promo_pill_2_color", "label": "膠囊 2 · 顏色",
      "options": [
        { "value": "orange",  "label": "橘" },
        { "value": "green",   "label": "綠" },
        { "value": "blue",    "label": "藍" },
        { "value": "red",     "label": "紅" },
        { "value": "neutral", "label": "灰（中性）" }
      ],
      "default": "green"
    },
    { "type": "text", "id": "promo_pill_3_text", "label": "膠囊 3 · 文字" },
    { "type": "select", "id": "promo_pill_3_color", "label": "膠囊 3 · 顏色",
      "options": [
        { "value": "orange",  "label": "橘" },
        { "value": "green",   "label": "綠" },
        { "value": "blue",    "label": "藍" },
        { "value": "red",     "label": "紅" },
        { "value": "neutral", "label": "灰（中性）" }
      ],
      "default": "blue"
    },

    { "type": "header", "content": "運送資訊（§1.8）" },
    { "type": "checkbox", "id": "show_shipping", "label": "顯示運送資訊", "default": true },
    { "type": "text", "id": "shipping_label", "label": "運送說明（例：2–3 個工作日）", "default": "2–3 個工作日" }
  ],
  "presets": [
    { "name": "APGO · 商品詳情 (Car Care)" }
  ],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
