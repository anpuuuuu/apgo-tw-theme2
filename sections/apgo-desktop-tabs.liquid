{% comment %}
  APGO · Desktop Tabs (desktop-only self-contained mega section)
  4-tab switcher: 商品說明 / 規格 / 評價 / 常見問題
  Ported from variants/v1-classic-plus.jsx lower half
  Hidden on mobile via CSS (.apgo-desktop-only)
{% endcomment %}

<section class="apgo-dtabs apgo-desktop-only" data-section-id="{{ section.id }}">
  <div class="apgo-container">

    {%- comment -%} Tab nav {%- endcomment -%}
    <div class="apgo-dtabs-nav" role="tablist" data-apgo-mtabs>
      <button type="button" class="apgo-dtabs-tab active" data-apgo-mtab="desc" role="tab">商品說明</button>
      <button type="button" class="apgo-dtabs-tab" data-apgo-mtab="spec" role="tab">規格</button>
      <button type="button" class="apgo-dtabs-tab" data-apgo-mtab="review" role="tab">
        評價 {%- if section.settings.rating_count != blank -%}<span class="apgo-muted">({{ section.settings.rating_count }})</span>{%- endif -%}
      </button>
      <button type="button" class="apgo-dtabs-tab" data-apgo-mtab="faq" role="tab">常見問題</button>
    </div>

    {%- comment -%} Panel: 商品說明 {%- endcomment -%}
    <div class="apgo-dtabs-panel active" data-apgo-mpanel="desc">

      {%- comment -%} Ritual (editorial) — 2-col image + text {%- endcomment -%}
      <div class="apgo-dtabs-ritual">
        {%- if section.settings.ritual_image != blank -%}
          <div class="apgo-dtabs-ritual-media">
            <img src="{{ section.settings.ritual_image | image_url: width: 900 }}" alt="{{ section.settings.ritual_heading | default: product.title }}" loading="lazy">
            {%- if section.settings.ritual_video_url != blank -%}
              <a class="apgo-dtabs-ritual-play" href="{{ section.settings.ritual_video_url }}" target="_blank" rel="noopener" aria-label="播放影片"><span></span></a>
            {%- endif -%}
          </div>
        {%- endif -%}
        <div class="apgo-dtabs-ritual-text">
          <div class="apgo-kicker-small">— THE RITUAL —</div>
          <h2 class="apgo-serif">{{ section.settings.ritual_heading | default: '重新定義<br>洗衣的日常' }}</h2>
          <p class="apgo-muted">{{ section.settings.ritual_body | default: '追求的不只是乾淨，更是洗滌過程中的「儀式感」。以溫和純淨的配方，打理屬於您的每一件衣物。' }}</p>
        </div>
      </div>

      {%- comment -%} Pain × Solutions (4-col) {%- endcomment -%}
      <div class="apgo-dtabs-pain-wrap">
        <div class="apgo-kicker-small">— WHY APGO —</div>
        <h3 class="apgo-serif">日常痛點 · 專屬科學解方</h3>
        <div class="apgo-dtabs-pain-grid">
          {%- for block in section.blocks -%}
            {%- if block.type == 'pain' -%}
              <div class="apgo-dtabs-pain-card" {{ block.shopify_attributes }}>
                <div class="apgo-muted apgo-dtabs-pain-label">痛點</div>
                <div class="apgo-serif apgo-dtabs-pain-title">{{ block.settings.pain }}</div>
                <div class="apgo-dtabs-pain-arrow">↓</div>
                <div class="apgo-muted apgo-dtabs-pain-label">APGO 解方</div>
                <div class="apgo-serif apgo-dtabs-pain-sol">{{ block.settings.solution }}</div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      {%- comment -%} 24H Timeline (horizontal with absolute-positioned track) {%- endcomment -%}
      <div class="apgo-dtabs-timeline-wrap">
        <div class="apgo-kicker-small">— 24H LASTING —</div>
        <h3 class="apgo-serif">持續一整天的香氛</h3>
        <div class="apgo-dtabs-timeline">
          <div class="apgo-dtabs-timeline-axis"></div>
          {%- for block in section.blocks -%}
            {%- if block.type == 'timeline' -%}
              {%- assign pos = forloop.index0 | times: 100 | divided_by: 4 -%}
              <div class="apgo-dtabs-timeline-node" style="left:{{ pos }}%;" {{ block.shopify_attributes }}>
                <div class="apgo-dtabs-timeline-bar-v" style="height:{{ block.settings.strength }}%"></div>
                <div class="apgo-dtabs-timeline-dot"></div>
                <div class="apgo-dtabs-timeline-hour apgo-serif">{{ block.settings.hour }}</div>
                <div class="apgo-dtabs-timeline-label">{{ block.settings.label }}</div>
                <div class="apgo-dtabs-timeline-desc apgo-muted">{{ block.settings.description }}</div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      {%- comment -%} Comparison table (3-col header) {%- endcomment -%}
      <div class="apgo-dtabs-cmp-wrap">
        <div class="apgo-kicker-small">— THE DIFFERENCE —</div>
        <h3 class="apgo-serif">為什麼選 APGO？</h3>
        <div class="apgo-dtabs-cmp">
          <div class="apgo-dtabs-cmp-head">
            <div>項目</div>
            <div class="apgo-serif apgo-dtabs-cmp-apgo">APGO</div>
            <div class="apgo-muted">一般品牌</div>
          </div>
          {%- for block in section.blocks -%}
            {%- if block.type == 'compare' -%}
              <div class="apgo-dtabs-cmp-row" {{ block.shopify_attributes }}>
                <div class="apgo-muted">{{ block.settings.feature }}</div>
                <div class="apgo-serif"><span class="apgo-dtabs-cmp-win">✓</span> {{ block.settings.apgo_value }}</div>
                <div class="apgo-muted">{{ block.settings.competitor_value }}</div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>

      {%- comment -%} UGC (3-col) — optional {%- endcomment -%}
      {%- if section.settings.ugc_enabled -%}
        <div class="apgo-dtabs-ugc-wrap">
          <div class="apgo-kicker-small">— #APGOLAUNDRY —</div>
          <h3 class="apgo-serif">用戶實拍 · Instagram</h3>
          <p class="apgo-muted">2,100+ 位顧客分享使用心得</p>
          <div class="apgo-dtabs-ugc-grid">
            {%- for block in section.blocks -%}
              {%- if block.type == 'ugc' -%}
                <a href="{{ block.settings.url }}" class="apgo-dtabs-ugc-cell" {{ block.shopify_attributes }} target="_blank" rel="noopener">
                  {%- if block.settings.image != blank -%}
                    <img src="{{ block.settings.image | image_url: width: 600 }}" alt="@{{ block.settings.handle }}" loading="lazy">
                  {%- endif -%}
                  <div class="apgo-dtabs-ugc-overlay">
                    <div>@{{ block.settings.handle }}</div>
                    <div>♡ {{ block.settings.likes }}</div>
                  </div>
                </a>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Panel: 規格 {%- endcomment -%}
    <div class="apgo-dtabs-panel" data-apgo-mpanel="spec">
      <div class="apgo-dtabs-spec">
        {%- for block in section.blocks -%}
          {%- if block.type == 'spec' -%}
            <div class="apgo-dtabs-spec-row" {{ block.shopify_attributes }}>
              <div class="apgo-muted">{{ block.settings.key }}</div>
              <div class="apgo-serif">{{ block.settings.value }}</div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} Panel: 評價 {%- endcomment -%}
    <div class="apgo-dtabs-panel" data-apgo-mpanel="review">
      <div class="apgo-dtabs-rev-summary">
        <div class="apgo-dtabs-rev-score apgo-serif">{{ section.settings.rating_score }}</div>
        <div>
          <div class="apgo-stars">★★★★★</div>
          <div class="apgo-muted">基於 {{ section.settings.rating_count }} 則真實評價</div>
        </div>
      </div>
      <div class="apgo-dtabs-rev-grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'review' -%}
            <div class="apgo-dtabs-rev-item" {{ block.shopify_attributes }}>
              <div class="apgo-dtabs-rev-head">
                <strong>{{ block.settings.name }}</strong>
                <span class="apgo-stars">★★★★★</span>
              </div>
              <div class="apgo-dtabs-rev-meta apgo-muted">{{ block.settings.date }} · 已購買：{{ block.settings.scent }}</div>
              <p>{{ block.settings.body }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} Panel: 常見問題 {%- endcomment -%}
    <div class="apgo-dtabs-panel" data-apgo-mpanel="faq">
      <div class="apgo-dtabs-faq-list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'faq' -%}
            <details class="apgo-dtabs-faq" {{ block.shopify_attributes }}>
              <summary>
                <span class="apgo-serif">Q. {{ block.settings.q }}</span>
                <span class="apgo-dtabs-faq-toggle">+</span>
              </summary>
              <p class="apgo-muted">A. {{ block.settings.a }}</p>
            </details>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "APGO · Desktop Tabs",
  "tag": "section",
  "class": "apgo-section apgo-section-dtabs",
  "settings": [
    { "type": "header", "content": "評分摘要" },
    { "type": "text", "id": "rating_score", "label": "評分", "default": "4.9" },
    { "type": "text", "id": "rating_count", "label": "評價數", "default": "2,847" },

    { "type": "header", "content": "商品說明 - Ritual 區" },
    { "type": "image_picker", "id": "ritual_image", "label": "Ritual 視覺圖" },
    { "type": "url", "id": "ritual_video_url", "label": "影片連結（選填）" },
    { "type": "textarea", "id": "ritual_heading", "label": "標題（支援 HTML <br>）", "default": "重新定義<br>洗衣的日常" },
    { "type": "textarea", "id": "ritual_body", "label": "內文", "default": "追求的不只是乾淨，更是洗滌過程中的「儀式感」。以溫和純淨的配方，打理屬於您的每一件衣物。" },

    { "type": "header", "content": "UGC" },
    { "type": "checkbox", "id": "ugc_enabled", "label": "顯示 UGC 牆", "default": false }
  ],
  "blocks": [
    {
      "type": "pain",
      "name": "痛點 × 解方",
      "limit": 4,
      "settings": [
        { "type": "text", "id": "pain", "label": "痛點", "default": "洗不掉的頑垢" },
        { "type": "text", "id": "solution", "label": "解方", "default": "超濃縮酵素活性" }
      ]
    },
    {
      "type": "timeline",
      "name": "留香時間點",
      "limit": 5,
      "settings": [
        { "type": "text", "id": "hour", "label": "時間", "default": "0H" },
        { "type": "text", "id": "label", "label": "標籤", "default": "洗滌完成" },
        { "type": "text", "id": "description", "label": "描述", "default": "前段花香綻放" },
        { "type": "range", "id": "strength", "label": "強度 %", "min": 0, "max": 100, "step": 5, "default": 100 }
      ]
    },
    {
      "type": "compare",
      "name": "比較表 - 一列",
      "limit": 8,
      "settings": [
        { "type": "text", "id": "feature", "label": "項目", "default": "濃縮倍數" },
        { "type": "text", "id": "apgo_value", "label": "APGO", "default": "8 倍" },
        { "type": "text", "id": "competitor_value", "label": "一般", "default": "1-2 倍" }
      ]
    },
    {
      "type": "ugc",
      "name": "UGC 貼文",
      "limit": 9,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "圖片" },
        { "type": "text", "id": "handle", "label": "IG handle" },
        { "type": "number", "id": "likes", "label": "讚數", "default": 100 },
        { "type": "url", "id": "url", "label": "IG 貼文連結" }
      ]
    },
    {
      "type": "spec",
      "name": "規格列",
      "limit": 12,
      "settings": [
        { "type": "text", "id": "key", "label": "欄位", "default": "商品名稱" },
        { "type": "text", "id": "value", "label": "內容", "default": "APGO 超級濃縮洗衣精" }
      ]
    },
    {
      "type": "review",
      "name": "評價",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "name", "label": "姓名", "default": "黃小姐" },
        { "type": "text", "id": "date", "label": "日期", "default": "2026.03.12" },
        { "type": "text", "id": "scent", "label": "購買香氛", "default": "淨心棉花" },
        { "type": "textarea", "id": "body", "label": "評價內容", "default": "香味非常柔和不刺鼻，寶寶衣服洗起來也很放心。" }
      ]
    },
    {
      "type": "faq",
      "name": "常見問題",
      "limit": 8,
      "settings": [
        { "type": "text", "id": "q", "label": "問題", "default": "可以洗嬰幼兒衣服嗎？" },
        { "type": "textarea", "id": "a", "label": "回答", "default": "可以。通過 SGS 檢驗、8 大零添加、pH 中性，專為敏感肌與嬰幼兒設計。" }
      ]
    }
  ],
  "presets": [
    {
      "name": "APGO · Desktop Tabs",
