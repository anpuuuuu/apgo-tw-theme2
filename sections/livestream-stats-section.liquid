{% comment %}
  Livestream Stats Section - APGO 直播實力數據
  放置位置：/sections/livestream-stats-section.liquid
{% endcomment %}

<section class="livestream-section">
  <div class="livestream-container">
    <!-- 標題 -->
    <div class="livestream-header">
      <h2 class="livestream-title">{{ section.settings.title | default: '跨國直播，品質全民見證' }}</h2>
      <p class="livestream-subtitle">{{ section.settings.subtitle | default: '真實的呈現，是對顧客最直接保障' }}</p>
    </div>

    <!-- 團隊圖片展示 -->
    <div class="team-showcase">
      <div class="team-images">
        <div class="team-image-wrapper active" id="taiwan-team">
          <div class="team-image taiwan-team">
            <video
              class="team-video"
              src="{{ section.settings.video_taiwan | default: 'https://cdn.shopify.com/videos/c/o/v/9a0fa6d2993b468b9f3b3ecc48056039.mp4' }}"
              autoplay
              muted
              playsinline
            ></video>
            <div class="hearts-container" id="taiwan-hearts"></div>
          </div>
        </div>
        <div class="team-image-wrapper" id="sg-my-team">
          <div class="team-image sg-my-team">
            <video
              class="team-video"
              src="{{ section.settings.video_sgmy | default: 'https://cdn.shopify.com/videos/c/o/v/4ddb944f1ef94ed4bf6a6f3fe93a0a6c.mp4' }}"
              autoplay
              muted
              playsinline
            ></video>
            <div class="hearts-container" id="sg-my-hearts"></div>
          </div>
        </div>
      </div>

      <!-- Tabs -->
      <div class="team-tabs">
        <button class="tab-button active" data-team="taiwan">
          <span class="tab-icon">🇹🇼</span><span>{{ 'apgo_livestream.tab_taiwan' | t }}</span>
        </button>
        <button class="tab-button" data-team="sg-my">
          <span class="tab-icon">🇸🇬🇲🇾</span><span>{{ 'apgo_livestream.tab_sgmy' | t }}</span>
        </button>
      </div>
    </div>

    <!-- 數據區 -->
    <div class="stats-showcase">
      <div class="stat-item">
        <div class="stat-value">
          <span class="stat-number" data-target="{{ section.settings.stat_sales | default: '5000000' }}">0</span>
        </div>
        <div class="stat-label"><span class="stat-unit">{{ 'apgo_livestream.unit_sets' | t }}</span>{{ 'apgo_livestream.sales_label' | t }}</div>
      </div>
      <div class="stat-item">
        <div class="stat-value">
          <div class="country-carousel">
            <div class="country-track">
              <span class="country-flag">🇹🇼</span>
              <span class="country-flag">🇸🇬</span>
              <span class="country-flag">🇲🇾</span>
              <span class="country-flag">🇹🇼</span>
              <span class="country-flag">🇸🇬</span>
              <span class="country-flag">🇲🇾</span>
            </div>
          </div>
        </div>
        <div class="stat-label">{{ 'apgo_livestream.stable_countries' | t }}</div>
      </div>
      <div class="stat-item">
        <div class="stat-value">
          <span class="stat-number" data-target="{{ section.settings.stat_years | default: '10' }}">0</span>
          <span class="stat-unit">{{ 'apgo_livestream.unit_year' | t }}</span>
        </div>
        <div class="stat-label">{{ 'apgo_livestream.years_label' | t }}</div>
      </div>
      <div class="stat-item">
        <div class="stat-value">
          <span class="stat-number" data-target="{{ section.settings.stat_hosts | default: '30' }}">0</span>
          <span class="stat-unit">{{ 'apgo_livestream.unit_hosts' | t }}</span>
        </div>
        <div class="stat-label">{{ 'apgo_livestream.hosts_label' | t }}</div>
      </div>
    </div>

    <!-- CTA -->
    <div class="trust-cta-section">
      <div class="cta-container">
        <a href="{{ section.settings.cta_link | default: '/pages/buy_atomic_coating' }}" class="cta-button">
          {{ section.settings.cta_text | default: '了解更多' }}
        </a>
      </div>
    </div>
  </div>
</section>

{% style %}
  /* 基礎重置和變數 */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --primary-orange: #f08418;
            --secondary-dark: #374151;
            --dark-bg: #1a1a1a;
            --darker-bg: #0f0f0f;
            --text-white: #ffffff;
            --text-gray: #cccccc;
            --text-light-gray: #b0b0b0;
            --gradient-bg: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            --orange-gradient: linear-gradient(45deg, #f08418, #ff9a3c);
        }

        body {
            font-family: 'Arial', 'Microsoft JhengHei', sans-serif;
            background: #000000;
            color: var(--text-white);
        }

        /* 第二區塊：直播實力數據 */
        .livestream-section {
            background: #000000;
            padding: 100px 0;
            position: relative;
            overflow: hidden;
        }

        /* 背景動態光暈效果 */
        .livestream-section::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(240, 132, 24, 0.05) 0%, transparent 70%);
            animation: rotate 30s linear infinite;
            pointer-events: none;
        }

        @keyframes rotate {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        .livestream-container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 20px;
            position: relative;
            z-index: 1;
        }

        /* 標題區域 */
        .livestream-header {
            text-align: center;
            margin-bottom: 60px;
            opacity: 0;
            transform: translateY(30px);
            animation: fadeInUp 0.8s ease forwards;
        }

        @keyframes fadeInUp {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .livestream-title {
            font-size: 2.5rem;
            font-weight: bold;
            background: var(--orange-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 15px;
        }

        .livestream-subtitle {
            font-size: 1.2rem;
            color: var(--text-gray);
        }

        /* 團隊圖片區域 */
        .team-showcase {
            margin-bottom: 60px;
            opacity: 0;
            transform: translateY(30px);
            animation: fadeInUp 0.8s ease 0.2s forwards;
            width: 100%;
            max-width: 100%;
        }

        /* 分頁按鈕 */
        .team-tabs {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 30px;
        }

        .tab-button {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 30px;
            background: rgba(255, 255, 255, 0.05);
            border: 2px solid rgba(240, 132, 24, 0.3);
            border-radius: 50px;
            color: var(--text-gray);
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
        }

        .tab-button:hover {
            background: rgba(240, 132, 24, 0.1);
            border-color: var(--primary-orange);
            color: var(--text-white);
            transform: translateY(-2px);
        }

        .tab-button.active {
            background: var(--orange-gradient);
            border-color: transparent;
            color: var(--text-white);
        }

        .tab-icon {
            font-size: 1.5rem;
        }

        /* 圖片容器 - 修改為直式 */
        .team-images {
            position: relative;
            width: 100%;
            max-width: 400px;
            margin: 0 auto;
            height: 600px;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
        }

        .team-image-wrapper {
            position: absolute;
            width: 100%;
            height: 100%;
            opacity: 0;
            transform: translateX(100px);
            transition: all 0.5s ease;
        }

        .team-image-wrapper.active {
            opacity: 1;
            transform: translateX(0);
        }

        /* 使用顏色替代圖片 */
        .team-image {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 2rem;
            font-weight: bold;
            color: rgba(255, 255, 255, 0.8);
            position: relative;
            overflow: hidden;
        }

        /* 影片樣式 */
        .team-video {
            width: 100%;
            height: 100%;
            object-fit: cover;
            position: absolute;
            top: 0;
            left: 0;
            z-index: 1;
        }

        .taiwan-team {
            background: linear-gradient(135deg, #e74c3c, #c0392b);
        }

        .sg-my-team {
            background: linear-gradient(135deg, #3498db, #2980b9);
        }

        /* 愛心容器 */
        .hearts-container {
            position: absolute;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            overflow: hidden;
            z-index: 2;
        }

        /* 愛心樣式 */
        .heart {
            position: absolute;
            bottom: -50px;
            right: 30px;
            width: 20px;
            height: 20px;
            background-color: var(--heart-color, #ff6b6b);
            transform: rotate(-45deg);
            animation-timing-function: ease-in-out;
            opacity: 0.9;
        }

        .heart::before,
        .heart::after {
            content: "";
            position: absolute;
            width: 20px;
            height: 20px;
            background-color: var(--heart-color, #ff6b6b);
            border-radius: 50%;
        }

        .heart::before {
            top: -10px;
            left: 0;
        }

        .heart::after {
            top: 0;
            left: 10px;
        }

        /* 不同顏色的愛心 */
        .heart-red { --heart-color: #ff6b6b; }
        .heart-pink { --heart-color: #ff69b4; }
        .heart-orange { --heart-color: #ffa726; }
        .heart-yellow { --heart-color: #ffeb3b; }
        .heart-purple { --heart-color: #ba68c8; }

        /* 不同的飄動路徑 */
        @keyframes floatPath1 {
            0% {
                bottom: -50px;
                transform: rotate(-45deg) scale(0) translateX(0);
                opacity: 0;
            }
            10% {
                opacity: 0.9;
                transform: rotate(-45deg) scale(1) translateX(0);
            }
            30% {
                transform: rotate(-45deg) scale(1) translateX(-20px);
            }
            50% {
                transform: rotate(-45deg) scale(1) translateX(10px);
            }
            70% {
                transform: rotate(-45deg) scale(1) translateX(-30px);
            }
            90% {
                opacity: 0.9;
                transform: rotate(-45deg) scale(1) translateX(0);
            }
            100% {
                bottom: 40%;
                opacity: 0;
                transform: rotate(-45deg) scale(0.8) translateX(-15px);
            }
        }

        @keyframes floatPath2 {
            0% {
                bottom: -50px;
                transform: rotate(-45deg) scale(0) translateX(0);
                opacity: 0;
            }
            10% {
                opacity: 0.9;
                transform: rotate(-45deg) scale(1) translateX(0);
            }
            25% {
                transform: rotate(-45deg) scale(1) translateX(15px);
            }
            45% {
                transform: rotate(-45deg) scale(1) translateX(-25px);
            }
            65% {
                transform: rotate(-45deg) scale(1) translateX(20px);
            }
            85% {
                opacity: 0.9;
                transform: rotate(-45deg) scale(1) translateX(-10px);
            }
            100% {
                bottom: 40%;
                opacity: 0;
                transform: rotate(-45deg) scale(0.8) translateX(25px);
            }
        }

        @keyframes floatPath3 {
            0% {
                bottom: -50px;
                transform: rotate(-45deg) scale(0) translateX(0);
                opacity: 0;
            }
            10% {
                opacity: 0.9;
                transform: rotate(-45deg) scale(1) translateX(0);
            }
            20% {
                transform: rotate(-45deg) scale(1) translateX(-15px);
            }
            40% {
                transform: rotate(-45deg) scale(1) translateX(-5px);
            }
            60% {
                transform: rotate(-45deg) scale(1) translateX(-25px);
            }
            80% {
                opacity: 0.9;
                transform: rotate(-45deg) scale(1) translateX(-10px);
            }
            100% {
                bottom: 40%;
                opacity: 0;
                transform: rotate(-45deg) scale(0.8) translateX(-20px);
            }
        }

        @keyframes floatPath4 {
            0% {
                bottom: -50px;
                transform: rotate(-45deg) scale(0) translateX(0);
                opacity: 0;
            }
            10% {
                opacity: 0.9;
                transform: rotate(-45deg) scale(1) translateX(0);
            }
            35% {
                transform: rotate(-45deg) scale(1) translateX(25px);
            }
            55% {
                transform: rotate(-45deg) scale(1) translateX(5px);
            }
            75% {
                transform: rotate(-45deg) scale(1) translateX(30px);
            }
            90% {
                opacity: 0.9;
                transform: rotate(-45deg) scale(1) translateX(15px);
            }
            100% {
                bottom: 40%;
                opacity: 0;
                transform: rotate(-45deg) scale(0.8) translateX(10px);
            }
        }

        /* 應用不同路徑 */
        .heart-path-1 { animation: floatPath1 4.5s ease-in-out forwards; }
        .heart-path-2 { animation: floatPath2 4.8s ease-in-out forwards; }
        .heart-path-3 { animation: floatPath3 4.2s ease-in-out forwards; }
        .heart-path-4 { animation: floatPath4 5s ease-in-out forwards; }

        /* 發光邊框效果 */
        .team-images::before {
            content: '';
            position: absolute;
            top: -2px;
            left: -2px;
            right: -2px;
            bottom: -2px;
            background: linear-gradient(45deg, #f08418, #ff9a3c, #f08418);
            background-size: 300% 300%;
            border-radius: 20px;
            z-index: -1;
            animation: borderGlow 3s ease-in-out infinite;
            opacity: 0.6;
        }

        @keyframes borderGlow {
            0%, 100% { background-position: 0% 50%; }
            50% { background-position: 100% 50%; }
        }

        /* 數據展示區 - 單行排列 */
        .stats-showcase {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 60px;
            margin-bottom: 60px;
            flex-wrap: wrap;
            opacity: 0;
            transform: translateY(30px);
            animation: fadeInUp 0.8s ease 0.4s forwards;
        }

        .stat-item {
            text-align: center;
            position: relative;
            padding: 20px;
        }

        .stat-value {
            font-size: 3.5rem;
            font-weight: bold;
            color: var(--primary-orange);
            line-height: 1;
            margin-bottom: 10px;
            display: flex;
            align-items: baseline;
            justify-content: center;
            gap: 10px;
            font-family: 'Arial', monospace;
        }

        .stat-unit {
            font-size: 1.8rem;
            color: var(--text-white);
            font-weight: normal;
        }

        .stat-label {
            font-size: 1rem;
            color: var(--text-gray);
            font-weight: 600;
        }

        /* 特殊處理第一個項目的單位 */
        .stat-label .stat-unit {
            color: var(--text-gray);
            font-size: 1rem;
            font-weight: 600;
        }

        /* 國旗跑馬燈效果 */
        .country-carousel {
            width: 60px;
            height: 60px;
            overflow: hidden;
            position: relative;
            margin: 0 auto;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .country-track {
            display: flex;
            animation: scrollFlags 12s linear infinite;
            width: 360px; /* 6個國旗 x 60px */
        }

        .country-flag {
            font-size: 3rem;
            line-height: 60px;
            width: 60px;
            text-align: center;
            flex-shrink: 0;
            display: inline-block;
        }

        @keyframes scrollFlags {
            0% {
                transform: translateX(0);
            }
            100% {
                transform: translateX(-180px); /* 移動3個國旗的距離 */
            }
        }

        /* 動態光效 */
        .stat-item::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 120%;
            height: 120%;
            background: radial-gradient(circle, rgba(240, 132, 24, 0.2) 0%, transparent 70%);
            opacity: 0;
            transition: opacity 0.3s ease;
            pointer-events: none;
            border-radius: 50%;
        }

        .stat-item:hover::before {
            opacity: 1;
        }

        /* CTA區域 */
        .trust-cta-section {
            text-align: center;
            opacity: 0;
            transform: translateY(30px);
            animation: fadeInUp 0.8s ease 0.6s forwards;
        }

        /* CTA按鈕 */
        .cta-container {
            margin-top: 30px;
        }

        .cta-button {
            display: inline-block;
            padding: 18px 50px;
            background: linear-gradient(45deg, var(--primary-orange), #ff9a3c);
            color: var(--text-white);
            text-decoration: none;
            font-size: 1.2rem;
            font-weight: bold;
            border-radius: 50px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(240, 132, 24, 0.3);
        }

        .cta-button::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            background: rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            transform: translate(-50%, -50%);
            transition: width 0.6s ease, height 0.6s ease;
        }

        .cta-button:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 30px rgba(240, 132, 24, 0.4);
        }

        .cta-button:hover::before {
            width: 300px;
            height: 300px;
        }

        /* 數字跳動動畫 */
        .counting {
            animation: countPulse 0.3s ease;
        }

        @keyframes countPulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.05); }
            100% { transform: scale(1); }
        }

        /* 響應式設計 */
        @media (max-width: 1024px) {
            .stats-showcase {
                gap: 40px;
            }

            .stat-value {
                font-size: 3rem;
            }
        }

        @media (max-width: 768px) {
            .livestream-section {
                padding: 60px 0;
            }

            .livestream-title {
                font-size: 1.8rem;
                margin-bottom: 10px;
            }

            .livestream-subtitle {
                font-size: 0.95rem;
            }

            .livestream-header {
                margin-bottom: 40px;
            }

            .team-showcase {
                margin-bottom: 30px;
                padding: 0;
            }

            .team-tabs {
                gap: 10px;
            }

            .tab-button {
                padding: 10px 20px;
                font-size: 0.9rem;
            }

            .tab-icon {
                font-size: 1.2rem;
            }

            .team-images {
                height: 600px;
                max-width: 95%;
            }

            /* 手機版愛心調整 */
            .heart {
                width: 18px;
                height: 18px;
                right: 20px;
            }

            .heart::before,
            .heart::after {
                width: 18px;
                height: 18px;
            }

            .heart::before {
                top: -9px;
            }

            .heart::after {
                left: 9px;
            }

            /* 手機版數據展示區 - 保持一行 */
            .stats-showcase {
                display: flex;
                justify-content: center;
                align-items: center;
                gap: 15px;
                flex-wrap: nowrap;
                padding: 20px 10px;
            }

            .stat-item {
                flex: 0 1 auto;
                padding: 10px 8px;
                text-align: center;
            }

            .stat-value {
                font-size: 2.5rem;
                gap: 5px;
            }

            .stat-unit {
                font-size: 1.3rem;
            }

            .stat-label {
                font-size: 1rem;
                white-space: nowrap;
            }

            /* 特殊處理第一個項目的單位 */
            .stat-label .stat-unit {
                font-size: 1rem;
            }

            .cta-button {
                padding: 12px 30px;
                font-size: 1rem;
            }
        }

        @media (max-width: 480px) {
            .team-images {
                height: 650px;
                max-width: 95%;
            }

            .stats-showcase {
                gap: 10px;
                padding: 15px 10px;
            }

            .stat-item {
                padding: 5px 5px;
            }

            .stat-value {
                font-size: 2rem;
                gap: 3px;
            }

            .stat-unit {
                font-size: 1.1rem;
            }

            .stat-label {
                font-size: 0.85rem;
                white-space: nowrap;
                line-height: 1.2;
            }

            /* 特殊處理第一個項目的單位 */
            .stat-label .stat-unit {
                font-size: 0.85rem;
            }

            /* 針對特定數據調整 */
            .stat-number[data-target="5000000"] {
                font-size: 1.8rem;
            }

            .country-carousel {
                width: 50px;
                height: 50px;
            }

            .country-track {
                width: 300px; /* 6個國旗 x 50px */
            }

            .country-flag {
                font-size: 2.5rem;
                line-height: 50px;
                width: 50px;
            }

            @keyframes scrollFlags {
                0% {
                    transform: translateX(0);
                }
                100% {
                    transform: translateX(-150px); /* 移動3個國旗的距離 */
                }
            }

            .tab-button {
                padding: 8px 15px;
                font-size: 0.85rem;
            }

            .tab-icon {
                display: none;
            }

            .heart {
                width: 16px;
                height: 16px;
                right: 15px;
            }

            .heart::before,
            .heart::after {
                width: 16px;
                height: 16px;
            }

            .heart::before {
                top: -8px;
            }

            .heart::after {
                left: 8px;
            }
        }

        /* 超小螢幕優化 */
        @media (max-width: 360px) {
            .stat-value {
                font-size: 1.8rem;
            }

            .stat-unit {
                font-size: 1rem;
            }

            .stat-label {
                font-size: 0.8rem;
            }

            /* 特殊處理第一個項目的單位 */
            .stat-label .stat-unit {
                font-size: 0.8rem;
            }

            .stat-number[data-target="5000000"] {
                font-size: 1.6rem;
