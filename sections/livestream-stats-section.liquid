{% javascript %}
  // 創建愛心的函數
  function createHeart(container) {
    const heart = document.createElement('div');
    const colors = ['heart-red', 'heart-pink', 'heart-orange', 'heart-yellow', 'heart-purple'];
    const paths = ['heart-path-1', 'heart-path-2', 'heart-path-3', 'heart-path-4'];
    const randomColor = colors[Math.floor(Math.random() * colors.length)];
    const randomPath = paths[Math.floor(Math.random() * paths.length)];

    heart.className = `heart ${randomColor} ${randomPath}`;

    // 固定在右側，稍微有一點隨機偏移
    const randomOffset = Math.random() * 10 - 5; // -5 到 +5 的偏移
    heart.style.right = 30 + randomOffset + 'px';

    // 隨機大小
    const randomScale = 0.85 + Math.random() * 0.3;
    heart.style.transform = `rotate(-45deg) scale(${randomScale})`;

    // 隨機動畫時長（增加變化）
    const randomDuration = 4 + Math.random() * 2;
    heart.style.animationDuration = randomDuration + 's';

    container.appendChild(heart);

    // 動畫結束後移除
    setTimeout(() => {
      heart.remove();
    }, randomDuration * 1000);
  }

  // 持續生成愛心
  function startHeartAnimation() {
    const activeWrapper = document.querySelector('.team-image-wrapper.active');
    if (activeWrapper) {
      const heartsContainer = activeWrapper.querySelector('.hearts-container');
      if (heartsContainer) {
        createHeart(heartsContainer);
      }
    }
  }

  // 每隔一段時間生成愛心
  let heartInterval = setInterval(startHeartAnimation, 800);

  // 分頁切換功能
  function initTabSwitching() {
    const tabButtons = document.querySelectorAll('.tab-button');
    const teamImages = document.querySelectorAll('.team-image-wrapper');
    const taiwanVideo = document.querySelector('#taiwan-team .team-video');
    const sgMyVideo = document.querySelector('#sg-my-team .team-video');

    // 手動切換功能
    tabButtons.forEach((button) => {
      button.addEventListener('click', function () {
        // 移除所有 active 類
        tabButtons.forEach((btn) => btn.classList.remove('active'));
        teamImages.forEach((img) => img.classList.remove('active'));

        // 添加 active 類到點擊的按鈕
        this.classList.add('active');

        // 顯示對應的圖片
        const teamType = this.dataset.team;
        const targetImage = document.getElementById(`${teamType}-team`);
        if (targetImage) {
          targetImage.classList.add('active');
        }

        // 暫停非活動影片，播放活動影片
        if (teamType === 'taiwan') {
          taiwanVideo.play();
          sgMyVideo.pause();
          sgMyVideo.currentTime = 0;
        } else {
          sgMyVideo.play();
          taiwanVideo.pause();
          taiwanVideo.currentTime = 0;
        }
      });
    });

    // 自動切換功能 - 當台灣影片播放結束時
    if (taiwanVideo) {
      taiwanVideo.addEventListener('ended', function () {
        // 切換到新馬團隊
        const sgMyButton = document.querySelector('[data-team="sg-my"]');
        const taiwanButton = document.querySelector('[data-team="taiwan"]');

        // 更新按鈕狀態
        taiwanButton.classList.remove('active');
        sgMyButton.classList.add('active');

        // 切換影片
        document.getElementById('taiwan-team').classList.remove('active');
        document.getElementById('sg-my-team').classList.add('active');

        // 播放新馬影片
        sgMyVideo.currentTime = 0;
        sgMyVideo.play();
      });
    }

    // 當新馬影片播放結束時，切回台灣影片
    if (sgMyVideo) {
      sgMyVideo.addEventListener('ended', function () {
        // 切換回台灣團隊
        const sgMyButton = document.querySelector('[data-team="sg-my"]');
        const taiwanButton = document.querySelector('[data-team="taiwan"]');

        // 更新按鈕狀態
        sgMyButton.classList.remove('active');
        taiwanButton.classList.add('active');

        // 切換影片
        document.getElementById('sg-my-team').classList.remove('active');
        document.getElementById('taiwan-team').classList.add('active');

        // 播放台灣影片
        taiwanVideo.currentTime = 0;
        taiwanVideo.play();
      });
    }
  }

  // 數字跳動動畫
  function animateNumbers() {
    const numbers = document.querySelectorAll('.stat-number');

    numbers.forEach((number, index) => {
      const target = parseInt(number.getAttribute('data-target'));
      const duration = 2000;
      const increment = target / (duration / 16);
      let current = 0;

      // 延遲啟動，創造依序動畫效果
      setTimeout(() => {
        const updateNumber = () => {
          current += increment;
          if (current < target) {
            number.textContent = formatNumber(Math.floor(current));
            number.classList.add('counting');
            setTimeout(() => number.classList.remove('counting'), 100);
            requestAnimationFrame(updateNumber);
          } else {
            number.textContent = formatNumber(target);
          }
        };
        updateNumber();
      }, index * 200);
    });
  }

  // 格式化數字（添加千分位）
  function formatNumber(num) {
    if (num >= 1000000) {
      return Math.floor(num / 10000) + '萬';
    } else if (num >= 10000) {
      return (num / 10000).toFixed(0) + '萬';
    }
    return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ',');
  }

  // Intersection Observer 監聽元素進入視窗
  const observerOptions = {
    threshold: 0.3,
    rootMargin: '0px',
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        animateNumbers();
        observer.disconnect();
      }
    });
  }, observerOptions);

  // 開始觀察
  document.addEventListener('DOMContentLoaded', () => {
    initTabSwitching();

    const section = document.querySelector('.stats-showcase');
    if (section) {
      observer.observe(section);
    }
  });

  // CTA按鈕波紋效果
  document.querySelector('.cta-button').addEventListener('click', function (e) {
    const ripple = document.createElement('span');
    const rect = this.getBoundingClientRect();
    const size = Math.max(rect.width, rect.height);
    const x = e.clientX - rect.left - size / 2;
    const y = e.clientY - rect.top - size / 2;

    ripple.style.cssText = `
                position: absolute;
                width: ${size}px;
                height: ${size}px;
                border-radius: 50%;
                background: rgba(255, 255, 255, 0.5);
                left: ${x}px;
                top: ${y}px;
                pointer-events: none;
                transform: scale(0);
                animation: rippleEffect 0.6s ease-out;
            `;

    this.appendChild(ripple);
    setTimeout(() => ripple.remove(), 600);
  });

  // 添加波紋動畫樣式
  const style = document.createElement('style');
  style.textContent = `
            @keyframes rippleEffect {
                to {
                    transform: scale(4);
                    opacity: 0;
                }
            }
        `;
  document.head.appendChild(style);

  // 清理定時器（當頁面關閉時）
  window.addEventListener('beforeunload', () => {
    clearInterval(heartInterval);
  });
{% endjavascript %}

