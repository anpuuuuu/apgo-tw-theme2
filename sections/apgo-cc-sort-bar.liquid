{%- comment -%}
  APGO · Car Care Colors — Sort Bar (dropdown)
  Left: 「共 N 項商品」(collection.products_count)
  Right: dropdown — 綜合排序 (default) → 熱銷 / 新品 / 價格 ↑ / 價格 ↓
  Layout: always one row, count left + dropdown right (mobile + desktop).
  Phase 2.5 polish of docs/CAR_CARE_REDESIGN_PLAN.md.
{%- endcomment -%}

{%- liquid
  assign current_sort = collection.sort_by

  assign options_str = '|綜合排序,best-selling|熱銷,created-descending|新品,price-ascending|價格 ↑,price-descending|價格 ↓'
  assign options = options_str | split: ','

  comment
    Find current label. Empty current_sort (or matching the collection's
    default-sort manual) → "綜合排序".
  endcomment
  assign active_label = '綜合排序'
  for opt in options
    assign parts = opt | split: '|'
    if parts[0] == current_sort and current_sort != blank
      assign active_label = parts[1]
    endif
  endfor
-%}

<section class="apgo-cc-sort" id="apgo-cc-sort-anchor" aria-label="排序與商品數">
  <span class="apgo-cc-sort__count">
    共 <strong>{{ collection.products_count }}</strong> 項商品
  </span>

  <details class="apgo-cc-sort__dropdown" data-apgo-cc-sort>
    <summary class="apgo-cc-sort__summary" aria-label="切換排序方式">
      <span class="apgo-cc-sort__current">{{ active_label }}</span>
      <svg class="apgo-cc-sort__chevron" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </summary>
    <ul class="apgo-cc-sort__menu" role="menu">
      {%- for opt in options -%}
        {%- assign parts = opt | split: '|' -%}
        {%- assign sort_token = parts[0] -%}
        {%- assign sort_label = parts[1] -%}
        {%- assign is_active = false -%}
        {%- if sort_token == current_sort -%}{%- assign is_active = true -%}{%- endif -%}
        {%- if sort_token == blank and current_sort == blank -%}{%- assign is_active = true -%}{%- endif -%}
        <li role="none">
          {%- if sort_token == blank -%}
            <a href="{{ collection.url }}#apgo-cc-sort-anchor" class="apgo-cc-sort__option{% if is_active %} is-active{% endif %}" role="menuitem">{{ sort_label }}</a>
          {%- else -%}
            <a href="{{ collection.url }}?sort_by={{ sort_token }}#apgo-cc-sort-anchor" class="apgo-cc-sort__option{% if is_active %} is-active{% endif %}" role="menuitem">{{ sort_label }}</a>
          {%- endif -%}
        </li>
      {%- endfor -%}
    </ul>
  </details>
</section>

<script>
(function () {
  // Close dropdown when clicking outside.
  document.addEventListener('click', function (e) {
    document.querySelectorAll('details.apgo-cc-sort__dropdown[open]').forEach(function (d) {
      if (!d.contains(e.target)) d.removeAttribute('open');
    });
  });
  // Close on Escape.
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape') {
      document.querySelectorAll('details.apgo-cc-sort__dropdown[open]').forEach(function (d) {
        d.removeAttribute('open');
      });
    }
  });
})();
</script>

{% schema %}
{
  "name": "APGO · 排序列 (Car Care)",
  "tag": "section",
  "class": "apgo-cc-sort-section",
  "settings": [
    { "type": "paragraph", "content": "顯示「共 N 項商品」+ 排序下拉選單 (綜合排序 / 熱銷 / 新品 / 價格 ↑↓)。預設綜合排序。" }
  ],
  "presets": [
    { "name": "APGO · 排序列 (Car Care)" }
  ],
  "enabled_on": {
    "templates": ["collection"]
  }
}
{% endschema %}
