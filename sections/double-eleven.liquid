{% comment %} sections/double-eleven.liquid {% endcomment %}
<div
  class="double-eleven-main"
  id="{{ section.settings.section_id }}"
  data-section-id="{{ section.settings.section_id }}"
>
  {% comment %} ===== 第一块：Hero 横幅 ===== {% endcomment %}
  <section class="double-eleven-hero">
    <div class="hero-banner-wrapper">
      {% if section.settings.hero_banner_image_desktop %}
        <img
          src="{{ section.settings.hero_banner_image_desktop | img_url}}"
          srcset="{{ section.settings.hero_banner_image_desktop | img_url: '1920x' }} 1x,
                  {{ section.settings.hero_banner_image_desktop | img_url: '3840x' }} 2x"
          alt="Hero Banner Desktop"
          class="hero-banner-image hero-banner-desktop"
          loading="lazy"
        >
      {% else %}
        <div class="hero-banner-placeholder hero-banner-desktop">
          <p>請上傳電腦端 Hero 橫幅圖片 (1920×800)</p>
        </div>
      {% endif %}

      {% if section.settings.hero_banner_image_mobile %}
        <img
          src="{{ section.settings.hero_banner_image_mobile | img_url}}"
          srcset="{{ section.settings.hero_banner_image_mobile | img_url: '750x' }} 1x,
                  {{ section.settings.hero_banner_image_mobile | img_url: '2000x' }} 2x"
          alt="Hero Banner Mobile"
          class="hero-banner-image hero-banner-mobile"
          loading="lazy"
        >
      {% else %}
        <div class="hero-banner-placeholder hero-banner-mobile">
          <p>請上傳手機端 Hero 橫幅圖片 (375×614)</p>
        </div>
      {% endif %}
    </div>
  </section>
</div>

<style>
  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scrollbar-width: none;
    overflow-y: scroll;
    overflow-x: hidden;
  }

  html::-webkit-scrollbar {
    display: none;
  }

  body {
    overflow-x: hidden;
  }

  .double-eleven-main {
    background-color: black;
    overflow-x: hidden;
  }

  /* ===== 第一块 Hero 样式 ===== */
  .double-eleven-hero {
    width: 100%;
    height: auto;
    background-color: #18181b;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .hero-banner-wrapper {
    width: 100%;
    height: auto;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #18181b;
  }

  .hero-banner-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .hero-banner-desktop {
    display: block;
  }

  .hero-banner-mobile {
    display: none;
  }

  .hero-banner-placeholder {
    width: 100%;
    height: 400px;
    background: linear-gradient(135deg, #27272a 0%, #18181b 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #888;
    font-size: 16px;
    text-align: center;
  }

  /* ===== 手机响应式 ===== */
  @media (max-width: 450px) {
    .hero-banner-desktop {
      display: none;
    }

    .hero-banner-mobile {
      display: block;
    }

    .hero-banner-placeholder {
      height: 400px;
    }
  }
</style>

{% schema %}
{
  "name": "双十一活动页面",
  "settings": [
    {
      "type": "header",
      "content": "✨ 第一块 - Hero 横幅圖片"
    },
    {
      "type": "image_picker",
      "id": "hero_banner_image_desktop",
      "label": "電腦端 Hero 橫幅圖片"
    },
    {
      "type": "image_picker",
      "id": "hero_banner_image_mobile",
      "label": "手機端 Hero 橫幅圖片"
    },
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "info": "用於導航欄，不能有空格或特殊字符",
      "default": "section-hero",
      "placeholder": "例如: section-hero"
    }
  ],
  "presets": [
    {
      "name": "活動模板 - 双十一活动橫幅"
    }
  ]
}
{% endschema %}
