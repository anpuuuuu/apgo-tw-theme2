{% comment %}
  購物車頁-綜合優惠區塊
  檔案位置: sections/cart-combined-offer.liquid
  主要功能: 條件式優惠 + 推薦加購商品
{% endcomment %}

<!-- 內聯關鍵樣式防止閃爍 -->
<style>
  /* 防止白色閃爍 */
  .shopify-section,
  .combined-offer-wrapper {
    position: relative;
    background: transparent !important;
  }

  .combined-offer-section {
    position: relative;
    background-color: {{ section.settings.loading_bg_color }} !important;
    min-height: 120px;
  }
</style>

<style>
            /* ========================================
               購物車綜合優惠區塊 - 精簡版
               ======================================== */

            :root {
              --co-accent: {% if section.settings.use_accent_gradient %}
                linear-gradient(135deg, {{ section.settings.accent_color_start }}, {{ section.settings.accent_color_end }})
              {% else %}
                {{ section.settings.accent_color_start }}
              {% endif %};
              --co-accent-color: {{ section.settings.accent_color_start }};
              --co-text: {{ section.settings.text_color }};
              --co-text-secondary: {{ section.settings.text_secondary_color }};
              --co-bg: linear-gradient(145deg, #2d2d2d, #1a1a1a);
              --co-border: #404040;
            }

            /* 通用樣式 */
            .section-title,
            .tiers-title,
            .progress-title,
            .upsell-title {
              font-weight: 600;
              color: var(--co-text) !important;
              margin: 0 0 12px 0;
              position: relative;
              padding-left: 12px;
            }

            .section-title::before,
            .upsell-title::before {
              content: '';
              position: absolute;
              left: 0;
              top: 50%;
              transform: translateY(-50%);
              width: 3px;
              height: 20px;
              background: var(--co-accent) !important;
              border-radius: 2px;
            }

            .section-title {
              font-size: 18px;
              margin: 24px 0 16px 0;
            }

            .combined-offer-wrapper {
              max-width: 1200px;
              width: 100%;
              margin: 20px auto 0;
              padding: 0;
            }

            .combined-offer-section {
              background: var(--co-bg) !important;
              border: 1px solid var(--co-border) !important;
              border-radius: 12px;
              padding: 20px;
              position: relative;
              overflow: hidden;
              transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            }

            .combined-offer-section:hover {
              border-color: var(--co-accent-color) !important;
              transform: translateY(-2px);
              box-shadow: 0 8px 25px rgba(255, 107, 53, 0.2);
            }

            .combined-offer-section::before {
              content: '';
              position: absolute;
              top: 0;
              left: 0;
              right: 0;
              height: 3px;
              background: var(--co-accent) !important;
            }

            /* 條件優惠區域 */
            .conditional-offer-area {
              margin-bottom: 24px;
              padding-bottom: 20px;
              border-bottom: 1px solid #333333;
            }

            .offer-tiers-container {
              margin-bottom: 20px;
            }

            .tiers-title {
              font-size: 14px;
              display: flex;
              align-items: center;
              gap: 8px;
            }

            .tiers-title::before {
              content: '🏆';
              font-size: 16px;
            }

            /* 滾動容器通用樣式 */
            .offer-tiers-scroll,
            .upsell-slider {
              overflow-x: auto;
              scroll-behavior: smooth;
              -webkit-overflow-scrolling: touch;
              scrollbar-width: thin;
              scrollbar-color: var(--co-accent-color) #333333;
            }

            .offer-tiers-scroll::-webkit-scrollbar,
            .upsell-slider::-webkit-scrollbar {
              height: 4px;
            }

            .offer-tiers-scroll::-webkit-scrollbar-track,
            .upsell-slider::-webkit-scrollbar-track {
              background: #333333 !important;
              border-radius: 2px;
            }

            .offer-tiers-scroll::-webkit-scrollbar-thumb,
            .upsell-slider::-webkit-scrollbar-thumb {
              background: var(--co-accent) !important;
              border-radius: 2px;
            }

            .offer-tiers {
              display: flex;
              gap: 12px;
              padding: 4px 0;
              min-width: max-content;
            }

            /* 優惠階層卡片 */
            .offer-tier {
              background: var(--co-bg) !important;
              border: 1px solid var(--co-border) !important;
              border-radius: 8px;
              padding: 12px;
              position: relative;
              transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
              overflow: hidden;
              flex: 0 0 200px;
            }

            .offer-tier::before {
              content: '';
              position: absolute;
              top: 0;
              left: 0;
              width: 4px;
              height: 100%;
              background: var(--co-accent) !important;
              transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            }

            /* 階層狀態樣式 */
            .offer-tier.current {
              border-color: var(--co-accent-color) !important;
              transform: translateX(4px);
            }

            .offer-tier.achieved {
              border-color: #4caf50 !important;
            }

            .offer-tier.achieved::before {
              background: linear-gradient(180deg, #4caf50, #45a049) !important;
              box-shadow: 0 0 10px rgba(76, 175, 80, 0.5);
            }

            .offer-tier.next {
              border-color: #ff9800 !important;
            }

            .offer-tier.next::before {
              background: linear-gradient(180deg, #ff9800, #f57c00) !important;
              box-shadow: 0 0 10px rgba(255, 152, 0, 0.5);
            }

            .tier-content {
              display: flex;
              justify-content: space-between;
              align-items: center;
              margin-left: 8px;
            }

            .tier-amount {
              font-size: 13px;
              font-weight: 600;
              color: var(--co-text) !important;
              margin: 0 0 4px 0;
            }

            .tier-benefit {
              font-size: 11px;
              color: var(--co-text-secondary) !important;
              margin: 0;
            }

            .tier-description {
              font-size: 10px;
              color: var(--co-text-secondary) !important;
              margin: 2px 0 0 0;
              opacity: 0.8;
              font-style: italic;
            }

            .tier-status {
              display: flex;
              align-items: center;
              gap: 6px;
              font-size: 12px;
              font-weight: 500;
            }

            .tier-status.achieved { color: #4caf50 !important; }
            .tier-status.current { color: var(--co-accent-color) !important; }
            .tier-status.next { color: #ff9800 !important; }

            .tier-status-icon {
              font-size: 14px;
            }

            /* 進度條通用樣式 */
            .tier-progress,
            .progress-bar-bg {
              background: #333333 !important;
              border-radius: 4px;
              overflow: hidden;
              position: relative;
            }

            .tier-progress {
              width: 60px;
              height: 4px;
            }

            .progress-bar-bg {
              width: 100%;
              height: 8px;
            }

            .tier-progress-fill,
            .progress-bar-fill {
              height: 100%;
              background: var(--co-accent) !important;
              border-radius: inherit;
              transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1);
            }

            .tier-progress-fill.achieved,
            .progress-bar-fill.achieved {
              background: linear-gradient(90deg, #4caf50, #45a049) !important;
            }

            .tier-progress-fill.current {
              background: linear-gradient(90deg, var(--co-accent-color), #f7931e) !important;
            }

            .tier-progress-fill.next {
              background: linear-gradient(90deg, #ff9800, #f57c00) !important;
            }

            /* 進度條動畫 */
            .progress-bar-fill {
              position: relative;
              overflow: hidden;
            }

            .progress-bar-fill::after {
              content: '';
              position: absolute;
              top: 0;
              left: -100%;
              width: 100%;
              height: 100%;
              background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent);
              animation: shimmer 2s infinite;
            }

            @keyframes shimmer {
              to { left: 100%; }
            }

            .progress-container {
              margin-bottom: 16px;
            }

            .progress-title {
              font-size: 14px;
              display: flex;
              align-items: center;
              gap: 8px;
            }

            .progress-title::before {
              content: '🎯';
              font-size: 16px;
            }

            .progress-text {
              display: flex;
              justify-content: space-between;
              align-items: center;
              margin-top: 8px;
              font-size: 12px;
              color: var(--co-text-secondary) !important;
            }

            .current-amount {
              font-weight: 600;
              color: var(--co-accent-color) !important;
            }

            .target-amount {
              font-weight: 500;
            }

            /* 優惠訊息 */
            .offer-message-container {
              margin-top: 16px;
            }

            .offer-message {
              font-size: 13px;
              line-height: 1.4;
              color: var(--co-text) !important;
              margin: 0;
              padding: 12px;
              border-radius: 8px;
              background: rgba(255, 107, 53, 0.1) !important;
              border: 1px solid rgba(255, 107, 53, 0.2) !important;
              position: relative;
              overflow: hidden;
            }

            .offer-message::before {
              content: '💡';
              position: absolute;
              left: 12px;
              top: 50%;
              transform: translateY(-50%);
              font-size: 16px;
            }

            .offer-message .message-text {
              margin-left: 32px;
            }

            .offer-message.achieved {
              background: rgba(76, 175, 80, 0.1) !important;
              border-color: rgba(76, 175, 80, 0.3) !important;
            }

            .offer-message.achieved::before {
              content: '🎉';
            }

            .offer-amount {
              font-weight: 700;
              color: var(--co-accent-color) !important;
              text-shadow: 0 0 8px rgba(255, 107, 53, 0.3);
            }

            /* 推薦商品區域 */
            .upsell-area {
              margin-top: 20px;
            }

            .upsell-title {
              font-size: 16px;
            }

            .upsell-title::before {
              height: 18px;
            }

            .upsell-slider-container {
              position: relative;
              overflow: hidden;
              margin: 0 -8px;
              padding: 0 8px;
            }

            .upsell-slider {
              display: flex;
              gap: 10px;
              padding: 8px 0;
            }

            /* 商品卡片 */
            .upsell-product-card {
              flex: 0 0 var(--card-width-desktop, 280px);
              background: var(--co-bg) !important;
              border: 1px solid var(--co-border) !important;
              border-radius: 8px;
              padding: 12px 8px;
              transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
              position: relative;
              overflow: hidden;
              text-decoration: none;
              display: flex;
              align-items: center;
              gap: 8px;
            }

            .upsell-product-card:hover {
              border-color: var(--co-accent-color) !important;
              transform: translateY(-2px);
              box-shadow: 0 8px 20px rgba(255, 107, 53, 0.2);
            }

            .upsell-product-image {
              width: 50px;
              height: 60px;
              border-radius: 6px;
              overflow: hidden;
              position: relative;
              flex-shrink: 0;
              display: flex;
              align-items: center;
              justify-content: center;
            }

            .upsell-product-image img,
            .upsell-product-image .placeholder-svg {
              position: absolute;
              top: 0;
              left: 0;
              width: 100%;
              height: 100%;
            }

            .upsell-product-image img {
              object-fit: contain;
              transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            }

            .upsell-product-image .placeholder-svg {
              opacity: 0.3;
              filter: invert(1);
            }

            .upsell-product-link {
              display: flex;
              align-items: center;
              gap: 10px;
              flex: 1;
              text-decoration: none;
              color: inherit;
            }

            .upsell-product-card:hover .upsell-product-title {
              color: var(--co-accent-color) !important;
            }

            .upsell-product-info {
              flex: 1;
              min-width: 0;
              display: flex;
              flex-direction: column;
              gap: 3px;
            }

            .upsell-product-title {
              font-size: 12px;
              font-weight: 500;
              color: var(--co-text) !important;
              margin: 0;
              overflow: hidden;
              text-overflow: ellipsis;
              display: -webkit-box;
              -webkit-line-clamp: 1;
              -webkit-box-orient: vertical;
              line-height: 1.3;
            }

            .upsell-product-price {
              font-size: 13px;
              font-weight: 700;
              color: var(--co-accent-color) !important;
              margin: 0;
              text-shadow: 0 0 8px rgba(255, 107, 53, 0.3);
            }

            /* 加入購物車按鈕 */
            .upsell-add-to-cart {
              width: 32px;
              height: 32px;
              background: transparent !important;
              border: 2px solid var(--co-accent-color) !important;
              border-radius: 6px;
              color: var(--co-accent-color) !important;
              font-size: 16px;
              font-weight: 600;
              cursor: pointer;
              transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
              display: flex;
              align-items: center;
              justify-content: center;
              position: relative;
              overflow: hidden;
              flex-shrink: 0;
              outline: none !important;
              -webkit-tap-highlight-color: transparent;
            }

            .upsell-add-to-cart:focus {
              outline: none !important;
              box-shadow: none !important;
            }

            .upsell-add-to-cart:active {
              transform: scale(0.95);
            }

            .upsell-add-to-cart * {
              pointer-events: none;
            }

            .upsell-add-to-cart::before {
              content: '';
              position: absolute;
              top: 0;
              left: -100%;
              width: 100%;
              height: 100%;
              background: var(--co-accent) !important;
              transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
              z-index: 0;
            }

            .upsell-add-to-cart:hover::before {
              left: 0;
            }

            .upsell-add-to-cart span {
              position: relative;
              z-index: 1;
              transition: color 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            }

            .upsell-add-to-cart:hover {
              border-color: var(--co-accent-color) !important;
              color: #ffffff !important;
            }

            .upsell-add-to-cart:hover span {
              color: #ffffff !important;
            }

            .upsell-add-to-cart.loading {
              pointer-events: none;
              opacity: 0.7;
            }

            .upsell-add-to-cart.added {
              border-color: var(--co-accent-color) !important;
              color: var(--co-accent-color) !important;
            }

            .upsell-add-to-cart.added span {
              color: var(--co-accent-color) !important;
            }

            /* 載入狀態 */
            .combined-offer-section.loading {
              min-height: 150px;
              position: relative;
            }

            .combined-offer-section.loading::after {
              content: '';
              position: absolute;
              top: 50%;
              left: 50%;
              transform: translate(-50%, -50%);
              width: 40px;
              height: 40px;
              border: 3px solid #333333 !important;
              border-top-color: var(--co-accent-color) !important;
              border-radius: 50%;
              animation: spin 0.8s linear infinite;
            }

            @keyframes spin {
              to { transform: translate(-50%, -50%) rotate(360deg); }
            }

            /* 響應式設計 */
            @media (max-width: 768px) {
              .section-title {
                font-size: 16px;
                margin: 20px 0 12px 0;
              }

              .combined-offer-wrapper {
                padding: 0 16px;
                margin: 16px auto 0;
              }

              .combined-offer-section {
                padding: 16px;
                border-radius: 10px;
              }

              .conditional-offer-area {
                margin-bottom: 20px;
                padding-bottom: 16px;
              }

              .offer-tier {
                flex: 0 0 220px;
              }

              .upsell-product-card {
                flex: 0 0 240px;
                padding: 10px 6px;
              }

              .upsell-product-image {
                width: 45px;
                height: 55px;
              }

              .upsell-add-to-cart {
                width: 28px;
                height: 28px;
                font-size: 14px;
              }
            }

            @media (max-width: 480px) {
              .section-title {
                font-size: 15px;
                margin: 16px 0 10px 0;
              }

              .offer-tier {
                flex: 0 0 280px;
                padding: 10px;
              }

              .tier-progress {
                width: 50px;
                height: 3px;
              }

              .upsell-product-card {
                flex: 0 0 200px;
              }

              .upsell-product-image {
                width: 40px;
                height: 50px;
              }

              .upsell-add-to-cart {
                width: 26px;
                height: 26px;
                font-size: 12px;
              }
            }

            /* 隱藏選項 */
            .combined-offer-wrapper[data-hide-progress="true"] .progress-container,
            .combined-offer-wrapper[data-hide-conditional="true"] .conditional-offer-area,
            .combined-offer-wrapper[data-hide-upsell="true"] .upsell-area {
              display: none;
            }

            /* ========================================
             推薦商品標題區域佈局
             ======================================== */
          .upsell-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
          }

          .upsell-title {
            margin: 0 !important; /* 移除原有的底部邊距 */
          }

          /* 查看全部按鈕 */
          .view-all-products-btn {
            background: linear-gradient(135deg, var(--co-accent-color), #f7931e);
            color: #fff;
            border: none;
            border-radius: 20px;
            padding: 6px 14px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            gap: 2px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            white-space: nowrap;
          }

          .view-all-products-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(255, 107, 53, 0.3);
          }

          .view-all-products-btn:active {
            transform: scale(0.98);
          }

          .btn-text {
            font-size: 12px;
          }

          .btn-count {
            padding: 1px 5px;
            border-radius: 10px;
            font-size: 12px;
          }

          .btn-arrow {
            font-size: 13px;
            transition: transform 0.3s ease;
          }

          .view-all-products-btn:hover .btn-arrow {
            transform: translateX(3px);
          }

          /* ========================================
             彈窗樣式
             ======================================== */
        /* 彈窗遮罩 - 使用 fixed 但確保 z-index 正確 */
        .recommend-popup-overlay {
          position: fixed !important;
          top: 0 !important;
          left: 0 !important;
          right: 0 !important;
          bottom: 0 !important;
          background: rgba(0, 0, 0, 0.8);
          display: none;
          z-index: 16 !important; /* 提高 z-index */
          animation: fadeIn 0.3s ease;
          pointer-events: none; /* 預設不接收事件 */
        }
          .recommend-popup-overlay.active {
            display: block;
            pointer-events: auto; /* 啟用時接收事件 */
          }

          .recommend-popup-container {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: var(--co-bg);
            border-radius: 20px 20px 0 0;
            max-height: 90vh;
            min-height: 90vh;
            display: none;
            flex-direction: column;
            z-index: 17;
            animation: slideUp 0.3s ease;
            transform: translateZ(0); /* 創建新的層疊上下文 */
            will-change: transform; /* 優化動畫性能 */
          }

          .recommend-popup-container.active {
            display: flex;
          }

          /* 彈窗頭部 */
          .popup-header {
            padding: 15px 15px 10px;
            border-bottom: 1px solid var(--co-border);
            position: relative;
            flex-shrink: 0;
          }

          .popup-handle {
            width: 40px;
            height: 4px;
            background: #666;
            border-radius: 2px;
            margin: 0 auto 10px;
            cursor: grab;
          }

          .popup-title {
            font-size: 18px;
            font-weight: 600;
            text-align: center;
            color: var(--co-text);
          }

          .popup-close-btn {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            width: 32px;
            height: 32px;
            background: rgba(255, 107, 53, 0.1);
            border: 1px solid var(--co-accent-color);
            border-radius: 50%;
            color: var(--co-accent-color);
            font-size: 20px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            transition: all 0.3s ease;
          }

          .popup-close-btn:hover {
            background: var(--co-accent-color);
            color: #fff;
            transform: translateY(-50%) rotate(90deg);
          }

          /* 免運提醒 */
          .shipping-reminder {
            background: linear-gradient(135deg, #2a2a2a 0%, #1f1f1f 100%);
            padding: 12px 20px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            border-bottom: 1px solid var(--co-border);
            flex-shrink: 0;
          }

          .shipping-reminder-text {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 14px;
            color: var(--co-text);
          }

          .shipping-icon {
            width: 24px;
            height: 24px;
            background: rgba(255, 107, 53, 0.2);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
          }

          .shipping-amount {
            color: var(--co-accent-color);
            font-weight: bold;
            font-size: 16px;
          }

          /* 分類標籤 */
            .category-tabs {
                display: flex;
                gap: 12px;
                padding: 10px 20px 10px;
                background: linear-gradient(135deg, rgba(26, 26, 26, 0.95) 0%, rgba(45, 45, 45, 0.95) 100%);
                overflow-x: auto;
                flex-shrink: 0;
                -webkit-overflow-scrolling: touch;
                scrollbar-width: thin;
                scrollbar-color: var(--co-accent-color) rgba(255, 255, 255, 0.1);
                border-bottom: 2px solid rgba(255, 107, 53, 0.2);
                position: relative;
                backdrop-filter: blur(10px);
            }

          .category-tabs::-webkit-scrollbar {
      height: 6px;
    }
    .category-tabs::-webkit-scrollbar-track {
      background: rgba(255, 255, 255, 0.05);
      border-radius: 3px;
    }
    .category-tabs::-webkit-scrollbar-thumb {
      background: var(--co-accent-color);
      border-radius: 3px;
    }
    .category-tabs::before,
            .category-tabs::after {
                content: '';
                position: absolute;
                top: 0;
                bottom: 0;
                width: 25px;
                pointer-events: none;
                z-index: 2;
            }
    .category-tabs::before {
      left: 0;
      background: linear-gradient(to right, var(--co-bg), transparent);
    }

    .category-tabs::after {
      right: 0;
      background: linear-gradient(to left, var(--co-bg), transparent);
    }

    /* 确保第一个标签默认激活 */
    .category-tab:first-child {
      margin-left: 0;
    }

          .category-tab {
                background: linear-gradient(135deg, rgba(45, 45, 45, 0.6) 0%, rgba(35, 35, 35, 0.7) 100%);
                color: #aaaaaa;
                border: 1px solid rgba(255, 255, 255, 0.08);
                border-radius: 18px;
                padding: 6px 12px;
                font-size: 12px;
                font-weight: 500;
                white-space: nowrap;
                cursor: pointer;
                transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                flex-shrink: 0;
                position: relative;
                overflow: hidden;
                backdrop-filter: blur(3px);
                box-shadow: 0 1px 4px rgba(0, 0, 0, 0.2);
            }

            .category-tab::before {
                content: '';
                position: absolute;
                top: 0;
                left: -100%;
                width: 100%;
                height: 100%;
                background: linear-gradient(135deg, rgba(255, 107, 53, 0.15) 0%, rgba(247, 147, 30, 0.15) 100%);
                transition: left 0.3s cubic-bezier(0.4, 0, 0.2, 1);
                z-index: 0;
            }

            .category-tab:hover::before {
                left: 0;
            }

            .category-tab:hover {
                color: #e0e0e0;
                border-color: rgba(255, 107, 53, 0.25);
                transform: translateY(-1px);
                box-shadow: 0 3px 12px rgba(255, 107, 53, 0.2);
            }

          .category-tab.active {
                background: linear-gradient(135deg, rgba(255, 107, 53, 0.8) 0%, rgba(247, 147, 30, 0.8) 100%);
                color: #ffffff;
                border-color: rgba(255, 107, 53, 0.6);
                transform: translateY(-0.5px);
                box-shadow: 0 4px 15px rgba(255, 107, 53, 0.25), 0 0 10px rgba(255, 107, 53, 0.1);
            }

            .category-tab.active::before {
                left: 0;
                background: linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.04) 100%);
            }

            .category-tab span {
                position: relative;
                z-index: 1;
            }

          .category-count {
            display: inline-block;
            background: rgba(255, 255, 255, 0.2);
            padding: 1px 6px;
            border-radius: 10px;
            font-size: 11px;
            margin-left: 4px;
          }

          /* 彈窗內容區 */
          .popup-content {
            flex: 1;
            -ms-overflow-style: none;  /* IE 和 Edge */
            scrollbar-width: none;     /* Firefox */
            overflow-y: auto;
            padding: 20px 15px;
            -webkit-overflow-scrolling: touch;
          }

          /* 推薦商品網格 */
          .recommend-products-grid {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 12px;
          }

          .recommend-product-card {
            display: flex;
            flex-direction: column;
            transition: opacity 0.3s ease;
          }
          .recommend-product-link {
            text-decoration: none;
            color: inherit;
            display: block;
          }
          .recommend-product-card:hover .recommend-product-name {
            color: var(--co-accent-color);
          }
          .hot-tag {
            background: linear-gradient(135deg, #ff4444, #cc0000) !important;
          }

          .new-tag {
            background: linear-gradient(135deg, #4CAF50, #45a049) !important;
          }

          .discount-tag {
            background: linear-gradient(135deg, #ff9800, #f57c00) !important;
          }
          .product-placeholder {
            font-size: 48px;
            color: #666;
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
          }

          /* 售罄按鈕樣式 */
          .recommend-add-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            background: #666 !important;
          }

          /* 無商品提示 */
          .no-products-message,
          .no-products-in-category {
            grid-column: 1 / -1;
            text-align: center;
            padding: 40px;
            color: #999;
          }

          .recommend-product-image {
            width: 100%;
            aspect-ratio: 1;
            background: #333;
            border-radius: 8px;
            margin-bottom: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 32px;
            position: relative;
            overflow: hidden;
          }

          .recommend-product-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
          }

          .recommend-product-tag {
            position: absolute;
            top: 6px;
            right: 6px;
            background: var(--co-accent);
            color: #fff;
            padding: 3px 8px;
            border-radius: 6px;
            font-size: 10px;
            font-weight: bold;
          }

          .recommend-product-name {
            font-size: 12px;
            color: var(--co-text);
            margin-bottom: 6px;
            line-height: 1.4;
            height: 32px;
            overflow: hidden;
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
          }

          .recommend-product-price {
            display: flex;
            align-items: center;
            gap: 6px;
            margin-bottom: 8px;
            flex-wrap: wrap;
          }

          .recommend-current-price {
            color: var(--co-accent-color);
            font-size: 14px;
            font-weight: bold;
          }

          .recommend-original-price {
            color: #666;
            font-size: 11px;
            text-decoration: line-through;
          }

          .recommend-add-btn {
            width: 100%;
            background: var(--co-accent);
            color: #fff;
            border: none;
            border-radius: 6px;
            padding: 8px;
            font-size: 12px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: auto;
          }

          .recommend-add-btn:hover {
            transform: scale(1.05);
          }

          .recommend-add-btn:active {
            transform: scale(0.95);
          }

          .recommend-add-btn.added {
            background: #4caf50;
          }

          /* 動畫 */
          @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
          }

          @keyframes slideUp {
            from { transform: translateY(100%); }
            to { transform: translateY(0); }
          }

          /* ========================================
             手機版響應式
             ======================================== */
          @media (max-width: 768px) {
            .upsell-header {
              gap: 10px;
            }

            .view-all-products-btn {
              padding: 5px 10px;
              font-size: 11px;
            }

            .btn-text {
              font-size: 10px; /* 手機版只顯示數量 */
            }

            .btn-count {
              display:none;
              font-size: 10px;
            }

            /* 彈窗商品網格 - 手機版兩列 */
            .recommend-products-grid {
              grid-template-columns: repeat(2, 1fr);
              gap: 10px;
            }
          }

          @media (max-width: 480px) {
            .view-all-products-btn {
              padding: 4px 8px;
            }
          }

          /* ========================================
             桌面版優化
             ======================================== */
          @media (min-width: 1024px) {
            /* 桌面版商品網格 - 四列 */
            .recommend-products-grid {
              grid-template-columns: repeat(4, 1fr);
              gap: 16px;
            }

            /* 桌面版彈窗最大寬度 */
            .recommend-popup-container {
              left: 50%;
              transform: translateX(-50%);
              max-width: 1200px;
              border-radius: 20px;
              bottom: 20px;
              max-height: 80vh;
              min-height: 80vh;;
            }

            .recommend-popup-container.active {
              animation: slideUpDesktop 0.3s ease;
            }

            @keyframes slideUpDesktop {
              from {
                transform: translateX(-50%) translateY(100%);
              }
              to {
                transform: translateX(-50%) translateY(0);
              }
            }
          }
          .shipping-progress-mini {
                  flex: 1;
                  max-width: 100px;
                  height: 4px;
                  background: #333;
                  border-radius: 2px;
                  overflow: hidden;
                  margin: 0 10px;
              }

              .shipping-progress-fill-mini {
                  height: 100%;
                  background: linear-gradient(90deg, #ff6b35 0%, #ff8c42 100%);
                  width: 60%;
                  transition: width 0.3s ease;
              }
              /* 弹窗中的条件优惠区域样式调整 */
      .popup-conditional-offer {
        padding: 15px 20px;
        border-bottom: 1px solid var(--co-border);
        background: rgba(0, 0, 0, 0.2);
        /* 确保不会超出弹窗宽度 */
        width: 100%;
        box-sizing: border-box;
        overflow: hidden;
      }

      .popup-conditional-offer .conditional-offer-area {
        margin-bottom: 0;
        padding-bottom: 0;
        border-bottom: none;
        /* 限制最大宽度 */
        max-width: 100%;
        overflow: hidden;
      }

      .popup-conditional-offer .progress-container {
        margin-bottom: 12px;
      }

      .popup-conditional-offer .offer-message-container {
        margin-top: 12px;
      }

      /* 弹窗内的优惠阶层滚动容器调整 */
      .popup-conditional-offer .offer-tiers-scroll {
        max-width: 100%;
        overflow-x: auto;
        /* 添加内边距，让滚动内容不贴边 */
        margin: 0 -10px;
        padding: 0 10px;
      }

      .popup-conditional-offer .offer-tiers {
        /* 确保不会撑开容器 */
        width: max-content;
        max-width: none;
      }

      /* 弹窗内的优惠阶层卡片尺寸调整 */
      .popup-conditional-offer .offer-tier {
        /* 稍微缩小卡片宽度 */
        flex: 0 0 200px;
        padding: 10px;
      }

      /* 弹窗内的进度条调整 */
      .popup-conditional-offer .progress-bar-bg {
        width: 100%;
        max-width: 100%;
      }

      /* 弹窗内的优惠消息调整 */
      .popup-conditional-offer .offer-message {
        padding: 10px;
        font-size: 12px;
        /* 确保文字换行 */
        word-wrap: break-word;
        word-break: break-word;
      }

      .popup-conditional-offer .offer-message .message-text {
        margin-left: 28px;
      }

      /* 弹窗内的标题字体调整 */
      .popup-conditional-offer .progress-title {
        font-size: 13px;
        margin-bottom: 8px;
      }

      /* 弹窗内的金额文字调整 */
      .popup-conditional-offer .progress-text {
        font-size: 11px;
      }

      /* 手机端弹窗内的条件优惠进一步调整 */
      @media (max-width: 768px) {
        .popup-conditional-offer {
          padding: 12px 15px;
        }

        .popup-conditional-offer .offer-tier {
          flex: 0 0 200px;
          padding: 8px;
        }

        .popup-conditional-offer .tier-amount {
          font-size: 12px;
        }

        .popup-conditional-offer .tier-benefit {
          font-size: 10px;
        }

        .popup-conditional-offer .offer-message {
          padding: 8px;
          font-size: 11px;
        }

        .popup-conditional-offer .offer-message::before {
          font-size: 14px;
        }
      }

      /* 确保弹窗容器本身不会被撑开 */
      .recommend-popup-container {
        /* 添加 overflow-x: hidden 防止横向溢出 */
        overflow-x: hidden;
      }

      /* 修正弹窗整体布局 */
      .recommend-popup-container.active {
        display: flex;
        flex-direction: column;
      }

      .popup-conditional-offer {
        /* 确保是弹性项目，不会超出父容器 */
        flex-shrink: 0;
        min-width: 0; /* 允许收缩到比内容更小 */
      }



