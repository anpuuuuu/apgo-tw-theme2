<div
  class="combined-offer-wrapper"
  data-hide-progress="{{ section.settings.hide_progress }}"
  data-hide-conditional="{{ section.settings.hide_conditional }}"
  data-hide-upsell="{{ section.settings.hide_upsell }}"
>
  <!-- 專屬優惠券標題 -->
  {% unless section.settings.hide_conditional %}
    <h4 class="section-title">{{ 'cart.exclusive_coupon' | t }}</h4>
  {% endunless %}

  <div class="combined-offer-section" id="combined-offer-{{ section.id }}">
    <!-- 條件優惠區域 -->
    {% unless section.settings.hide_conditional %}
      <div class="conditional-offer-area">
        <!-- 進度條區域 -->
        {% unless section.settings.hide_progress %}
          <div class="progress-container">
            <h4 class="progress-title" id="progress-title-{{ section.id }}">{{ 'cart.progress_title' | t }}</h4>
            <div class="progress-bar-bg">
              <div class="progress-bar-fill" id="progress-fill-{{ section.id }}" style="width: 0%"></div>
            </div>
            <div class="progress-text">
              <span class="current-amount" id="current-amount-{{ section.id }}">NT$ 0</span>
              <span class="target-amount" id="target-amount-{{ section.id }}">NT$ 0</span>
            </div>
          </div>
        {% endunless %}

        <!-- 優惠階層區域 -->
        <div class="offer-tiers-container">
          <div class="offer-tiers-scroll" id="offer-tiers-scroll-{{ section.id }}">
            <div class="offer-tiers" id="offer-tiers-{{ section.id }}">
              <!-- 優惠階層將由 JavaScript 動態生成 -->
            </div>
          </div>
        </div>

        <!-- 優惠訊息區域 -->
        <div class="offer-message-container">
          <div class="offer-message" id="offer-message-{{ section.id }}">
            <div class="message-text">
              <span id="offer-text-{{ section.id }}">{{ section.settings.initial_message }}</span>
            </div>
          </div>
        </div>
      </div>
    {% endunless %}

    <!-- 推薦商品區域 -->
    {% unless section.settings.hide_upsell %}
      <div class="upsell-area">
        <!-- 按鈕部分 -->
        <div class="upsell-header">
          <h4 class="upsell-title">{{ section.settings.upsell_title }}</h4>
          <button class="view-all-products-btn" onclick="openRecommendPopup()">
            <span class="btn-text">{{ 'cart.view_all_recommend' | t }}</span>
            {% for product in section.settings.product_list %}
              {% if forloop.first %}
                {% if forloop.length > 0 %}
                  {% if forloop.length <= 10 %}
                    <span class="btn-count">({{ forloop.length }})</span>
                  {% else %}
                    {% assign display_base = forloop.length | minus: 1 | divided_by: 10 | times: 10 %}
                    <span class="btn-count">({{ display_base }}+)</span>
                  {% endif %}
                {% endif %}
              {% endif %}
            {% endfor %}
            <span class="btn-arrow">→</span>
          </button>
        </div>
        <div class="upsell-slider-container">
          <div class="upsell-slider" id="upsell-slider-{{ section.id }}">
            {% assign slider_products = section.settings.slider_product_list %}
            {% if slider_products == blank %}
              {% assign slider_products = section.settings.product_list | slice: 0, section.settings.max_products %}
            {% endif %}
            {% if slider_products != blank %}
              {% for product in slider_products limit: section.settings.max_products %}
                <div class="upsell-product-card" data-product-handle="{{ product.handle }}">
                  <a href="{{ product.url }}" class="upsell-product-link">
                    <div class="upsell-product-image">
                      {% if product.featured_image %}
                        <img
                          src="{{ product.featured_image | image_url: width: 200 }}"
                          alt="{{ product.title | escape }}"
                          width="200"
                          height="240"
                          loading="lazy"
                        >
                      {% else %}
                        {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
                      {% endif %}
                    </div>
                    <div class="upsell-product-info">
                      <h5 class="upsell-product-title">{{ product.title }}</h5>
                      {% if section.settings.show_prices %}
                        {% if product.variants.size > 1 %}
                          {% assign min_price = product.variants | map: 'price' | sort | first %}
                          {% assign max_price = product.variants | map: 'price' | sort | last %}
                          {% if min_price == max_price %}
                            <p class="upsell-product-price">{{ min_price | money }}</p>
                          {% else %}
