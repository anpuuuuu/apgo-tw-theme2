<script>
  // 綜合優惠功能
  class CombinedOffer {
    constructor(sectionId, settings) {
      this.sectionId = sectionId;
      this.settings = settings;
      this.currentAmount = 0;
      this.amountForTierCalculation = 0;
      this.targetAmount = 0;
      this.tiers = this.parseTiers(settings.tiers);
      console.log(JSON.stringify(this.tiers) + '--------------');
      this.maxTierAmount = this.tiers.length > 0 ? this.tiers[this.tiers.length - 1].amount : 0;
      this.appliedDiscounts = new Set(); // 追踪已应用的折扣
      this.highestAchievedTiersByType = {}; // 追踪各类别的最高达成阶层
      this.init();
    }
    
parseTiers(blocks) {
  if (!blocks || !Array.isArray(blocks)) return [];
  
  return blocks.map(block => ({
    id: block.id,
    amount: parseFloat(block.amount) || 0,
    benefit: block.benefit || '',
    description: block.description || '',
    type: block.type || '',
    highlight_on_achieve: block.highlight_on_achieve  // ✅ 添加这一行
  })).sort((a, b) => a.amount - b.amount);
}
    
    init() {
      this.updateCartAmount();
      this.setupEventListeners();
      this.interceptRequests();

      setTimeout(() => {
        this.updateSmartCategory();
      }, 500);
    }
    
    interceptRequests() {
      if (window.__coFetchPatched) return;
      window.__coFetchPatched = true;

      const originalFetch = window.fetch;
      window.fetch = async (...args) => {
        const resp = await originalFetch(...args);
        try {
          const url = (args[0] && (args[0].url || args[0])) || '';
          if (typeof url === 'string' && (/\/cart\/(add|change|update|clear)/.test(url))) {
            setTimeout(() => this.updateCartAmount(), 200);
          }
        } catch(_) {}
        return resp;
      };

      if (!window.__coXhrPatched) {
        window.__coXhrPatched = true;
        const origOpen = XMLHttpRequest.prototype.open;
        XMLHttpRequest.prototype.open = function(method, url, ...rest) {
          this.addEventListener('loadend', () => {
            try {
              if (typeof url === 'string' && (/\/cart\/(add|change|update|clear)/.test(url))) {
                setTimeout(() => document.dispatchEvent(new Event('cart:update')), 200);
              }
            } catch(_) {}
          });
          return origOpen.call(this, method, url, ...rest);
        };
      }
    }

    async updateSmartCategory() {
      let allTiersAchieved = this.tiers.every(tier => this.currentAmount >= tier.amount);  
      if (this.highestAchievedTier && this.highestAchievedTier.amount == this.maxTierAmount){
        allTiersAchieved = this.tiers.every(tier => this.maxTierAmount >= tier.amount);
      }
      const smartTab = document.getElementById(`smart-tab-${this.sectionId}`);
      if (smartTab) {
        if (allTiersAchieved) {
          smartTab.style.display = 'none';
          const grid = document.getElementById(`recommendProductsGrid-${this.sectionId}`);
          if (grid) {
            const existingSmartCards = grid.querySelectorAll('.recommend-product-card[data-smart-generated="true"]');
            existingSmartCards.forEach(card => card.remove());
          }
          if (smartTab.classList.contains('active')) {
            const nextVisibleTab = smartTab.nextElementSibling;
            if (nextVisibleTab) {
              switchCategory(nextVisibleTab.dataset.category, nextVisibleTab);
            }
          }
          return;
        } else {
          smartTab.style.display = 'flex';
        }
      }
      
      const nextTier = this.getNextTier();
      if (!nextTier) return;
      
      const threshold = nextTier.amount;
      const remaining = threshold - this.currentAmount;
      
      
      try {
        let allProducts = [];
        let page = 1;
        let hasMore = true;
        let priceRange = null;
                const formatter = new Intl.NumberFormat('zh-TW', {
          style: 'currency',
          currency: 'TWD',
          minimumFractionDigits: 0,
          maximumFractionDigits: 0
        });
        
        while (hasMore && page <= 20) {
          const response = await fetch(`/products.json?page=${page}&limit=250`);
          const data = await response.json();
          
          if (data.products && data.products.length > 0) {
            allProducts = allProducts.concat(data.products);
            page++;
            hasMore = data.products.length === 250;
          } else {
            hasMore = false;
          }
        }
        
        
        const smartProducts = [];
        
        allProducts.forEach(product => {
          let productMatches = false;
          let lowestPrice = Infinity;
          let selectedVariant = null;
          
          let productImage = null;
          if (product.images && product.images.length > 0) {
            productImage = product.images[0];
          } else if (product.image && product.image.src) {
            productImage = product.image.src;
          } else if (product.featured_image) {
            productImage = product.featured_image;
          }
          
          if (product.variants && product.variants.length > 0) {
            // 计算价格范围
    const prices = product.variants.map(v => {
      if (typeof v.price === 'string') {
        return parseFloat(v.price);
      } else if (typeof v.price === 'number') {
        return v.price / 100;
      }
      return 0;
    });
    const minPrice = Math.min(...prices);
    const maxPrice = Math.max(...prices);
    
    if (minPrice === maxPrice) {
      priceRange = formatter.format(minPrice);
    } else {
      priceRange = `${formatter.format(minPrice)} ~ ${formatter.format(maxPrice)}`;
    };
            product.variants.forEach(variant => {
              let variantPrice = 0;
              if (typeof variant.price === 'string') {
                variantPrice = parseFloat(variant.price);
              } else if (typeof variant.price === 'number') {
                variantPrice = variant.price / 100;
              }
              
              if (variantPrice >= remaining && remaining > 0 && variantPrice < lowestPrice) {
                productMatches = true;
                lowestPrice = variantPrice;
                selectedVariant = variant;
              }
            });
          } else {
            let price = 0;
            if (typeof product.price === 'string') {
              price = parseFloat(product.price);
            } else if (typeof product.price === 'number') {
              price = product.price / 100;
            }
            
            if (price >= remaining && remaining > 0) {
              productMatches = true;
              lowestPrice = price;
            }
          }
          
          if (productMatches) {
            smartProducts.push({
              id: product.id,
              title: product.title,
              handle: product.handle,
              image: productImage,
              price: lowestPrice,
              priceRange: priceRange,
              variantId: selectedVariant ? selectedVariant.id : (product.variants?.[0]?.id || product.id),
              available: product.available !== false,
              compareAtPrice: product.compare_at_price || product.compare_at_price_max
              // 所有变体中的最高价格
            });
          }
        });
        
        
        const grid = document.getElementById(`recommendProductsGrid-${this.sectionId}`);
        if (!grid) return;
        
        const existingSmartCards = grid.querySelectorAll('.recommend-product-card[data-smart-generated="true"]');
        existingSmartCards.forEach(card => card.remove());
        
        const firstNonSmartCard = grid.querySelector('.recommend-product-card:not([data-smart-generated="true"])');
        
        const maxSmartProducts = 100;

        
        smartProducts.slice(0, maxSmartProducts).forEach(product => {
          const card = document.createElement('div');
          card.className = 'recommend-product-card';
          card.dataset.category = 'smart';
          card.dataset.productId = product.id;
          card.dataset.price = product.price.toFixed(2);
          card.dataset.smartGenerated = 'true';
          
          let imageHtml = '<div class="product-placeholder">🎯</div>';
          if (product.image) {
            let imageUrl = product.image;
            if (typeof imageUrl === 'object' && imageUrl.src) {
              imageUrl = imageUrl.src;
            }
            
            if (typeof imageUrl === 'string') {
              if (!imageUrl.startsWith('http')) {
                imageUrl = 'https:' + imageUrl;
              }
              if (!imageUrl.includes('width=') && !imageUrl.includes('_300x')) {
                if (imageUrl.includes('?')) {
                  imageUrl += '&width=300';
                } else {
                  imageUrl += '?width=300';
                }
              }
              imageHtml = `<img src="${imageUrl}" alt="${product.title}" loading="lazy">`;
            }
          }
          card.innerHTML = `
            <a href="/products/${product.handle}" class="recommend-product-link" target="_blank">
              <div class="recommend-product-image">
                ${imageHtml}
              </div>
            </a>
            <div class="recommend-product-name">${product.title}</div>
            <div class="recommend-product-price">
                ${product.priceRange ? 
            `<span class="recommend-current-price">${product.priceRange}</span>` :
            `<span class="recommend-current-price">${formatter.format(product.price)}</span>`
          }
          ${product.compareAtPrice && product.compareAtPrice > product.price ? 
            `<span class="recommend-original-price">${formatter.format(product.compareAtPrice / 100)}</span>` : 
            ''
          }
            </div>
            ${product.available ? 
              `<button class="recommend-add-btn" 
                       data-variant-id="${product.variantId}"
                       onclick="event.preventDefault(); showProductVariantsModal('${product.handle}', '${product.title.replace(/'/g, "\\'")}');">
                加購
              </button>` :
              `<button class="recommend-add-btn" disabled>售罄</button>`
            }
          `;
          
          if (firstNonSmartCard) {
            grid.insertBefore(card, firstNonSmartCard);
          } else {
            grid.appendChild(card);
          }
        });
        
        const smartCountEl = document.getElementById(`smart-count-${this.sectionId}`);
        if (smartCountEl) {
          smartCountEl.textContent = Math.min(smartProducts.length, maxSmartProducts);
        }
        
        const activeTab = document.querySelector('.category-tab.active');
        if (activeTab && activeTab.dataset.category === 'smart') {
          switchCategory('smart', activeTab);
        }
        
      } catch (error) {
        console.error('获取商品列表失败:', error);
        
        if (smartTab) {
          smartTab.style.display = 'none';
        }
      }
    }

    updateCartAmount() {
      fetch(`/cart.js?_=${Date.now()}`, { cache: 'no-store' })
        .then(response => response.json())
        .then(cart => {
          this.currentAmount = cart.total_price / 100;
          this.amountForTierCalculation = (cart.original_total_price && cart.original_total_price > cart.total_price)
            ? cart.original_total_price / 100
            : this.currentAmount;
          
          this.appliedDiscounts.clear();
          this.highestAchievedTiersByType = {};

          const achievedTiers = this.tiers.filter(tier => {
              const amountToUse = tier.type === 'free_shipping' ? this.currentAmount : this.amountForTierCalculation;
              return amountToUse >= tier.amount;
          });

          // Group tiers by type and find the highest achieved tier within each type.
          achievedTiers.forEach(tier => {
            const type = tier.type || 'general';
            if (!this.highestAchievedTiersByType[type] || tier.amount > this.highestAchievedTiersByType[type].amount) {
              this.highestAchievedTiersByType[type] = tier;
            }
          });

          // Keep track of which Shopify discounts are active.
          if (cart.cart_level_discount_applications && cart.cart_level_discount_applications.length > 0) {
            cart.cart_level_discount_applications.forEach(discount => {
              const discountKey = `${discount.title}_${discount.target_selection}`;
              this.appliedDiscounts.add(discountKey);
            });
          }
          
          this.updateDisplay();
          this.updateSmartCategory();
        })
        .catch(error => {
          console.error('無法取得購物車資料:', error);
        });
    }

    getTierByAmount(amount) {
      for (let i = this.tiers.length - 1; i >= 0; i--) {
        if (amount >= this.tiers[i].amount) {
          return this.tiers[i];
        }
      }
      return null;
    }
    
    updateDisplay() {
      const updateArea = (prefix = '') => {
        const progressFill = document.getElementById(`${prefix}progress-fill-${this.sectionId}`);
        const currentAmountEl = document.getElementById(`${prefix}current-amount-${this.sectionId}`);
        const progressTitleEl = document.getElementById(`${prefix}progress-title-${this.sectionId}`);
        const targetAmountEl = document.getElementById(`${prefix}target-amount-${this.sectionId}`);
        const offerMessage = document.getElementById(`${prefix}offer-message-${this.sectionId}`);
        const offerText = document.getElementById(`${prefix}offer-text-${this.sectionId}`);
        
        const fmt = new Intl.NumberFormat('zh-TW', { 
          style: 'currency', 
          currency: '{{ cart.currency.iso_code | default: "TWD" }}', 
          minimumFractionDigits: 0 
        });
        
        const currentTier = this.getCurrentTier();
        const nextTier = this.getNextTier();

        // Update progress bar and related display
        if (nextTier) {
          const amountForProgress = nextTier.type === 'free_shipping' ? this.currentAmount : this.amountForTierCalculation;

          this.targetAmount = nextTier.amount;

          if (progressTitleEl) {
            progressTitleEl.textContent = `{{ 'cart.progress_to_benefit' | t }}${nextTier.benefit}{{ 'cart.progress_left' | t }}`;
          }
          
          const progressBase = currentTier ? currentTier.amount : 0;
          const progressRange = nextTier.amount - progressBase;
          const currentProgress = amountForProgress - progressBase;
          const progressPercent = Math.max(0, Math.min((currentProgress / progressRange) * 100, 100));
          
          if (progressFill) {
            progressFill.style.width = `${progressPercent}%`;
            progressFill.className = 'progress-bar-fill current';
          }
          
          if (targetAmountEl) {
            targetAmountEl.textContent = fmt.format(nextTier.amount);
          }
        } else { // All tiers achieved
          if (progressTitleEl) {
            progressTitleEl.textContent = `{{ 'cart.all_goal_achieved' | t }}`;
          }
          if (progressFill) {
            progressFill.style.width = '0%'; // Reset to 0%
            progressFill.className = 'progress-bar-fill';
          }
          if (targetAmountEl) {
            targetAmountEl.textContent = fmt.format(0); // Reset to 0
          }
        }
        
        // Update current amount display
        if (currentAmountEl) {
          if (!nextTier) { // If all tiers are achieved, display 0
             currentAmountEl.textContent = fmt.format(0);
          } else { // Otherwise, display the final, post-discount price
             currentAmountEl.textContent = fmt.format(this.currentAmount);
          }
        }
        
        // Update offer message
        if (offerMessage && offerText) {
          const allBenefits = this.getAllAchievedBenefits();
          if (nextTier) {
            offerMessage.classList.remove('achieved');
            const amountForMessage = nextTier.type === 'free_shipping' ? this.currentAmount : this.amountForTierCalculation;
            const remainingAmount = nextTier.amount - amountForMessage;
            let message;
            if (allBenefits) {
              message = `{{ 'cart.congrats_have' | t }} ${allBenefits}，{{ 'cart.add_more' | t }} <span class="offer-amount">${fmt.format(remainingAmount)}</span> {{ 'cart.get_benefit' | t }} <span class="offer-amount">${nextTier.benefit}</span>！`;
            } else {
              const firstTier = this.tiers[0];
              message = `{{ 'cart.add_more' | t }} <span class="offer-amount">${fmt.format(remainingAmount)}</span> {{ 'cart.get_benefit' | t }} <span class="offer-amount">${firstTier.benefit}</span>！`;
            }
            offerText.innerHTML = message;
          } else { // All tiers achieved
            offerMessage.classList.add('achieved');
            offerText.innerHTML = `{{ 'cart.congrats_all' | t }}${allBenefits}！`;
          }
        }
      };
      
      updateArea();
      updateArea('popup-');
      
      this.updateTiers();
      this.updateTiers('popup-');
      
      this.scrollToNextTarget();
      this.scrollToNextTarget('popup-');
    }
    
    getHighlightedAchievedTiers() {
        const mainSwitchIsOn = this.settings.cumulative_tiers === 'true';

        return this.tiers.filter(tier => {
            const tierType = tier.type || 'general';
            const amountToUseForAchievement = tierType === 'free_shipping' ? this.currentAmount : this.amountForTierCalculation;
            const isAchieved = amountToUseForAchievement >= tier.amount;

            if (!isAchieved) {
                return false;
            }

            if (mainSwitchIsOn) {
                // Cumulative highlighting: highlight if its own switch is on.
                return tier.highlight_on_achieve === true;
            } else {
                // Non-cumulative: highlight only if it's the highest for its type.
                const highestTierForThisType = this.highestAchievedTiersByType[tierType];
                return highestTierForThisType && tier.id === highestTierForThisType.id;
            }
        });
    }
    
    getAllAchievedBenefits() {
      const highlightedTiers = this.getHighlightedAchievedTiers();
      if (highlightedTiers.length === 0) return '';
      
      const benefits = highlightedTiers.map(tier => `<span class="offer-amount">${tier.benefit}</span>`);
      
      if (benefits.length === 1) {
        return benefits[0];
      } else if (benefits.length === 2) {
        return `${benefits[0]} 和 ${benefits[1]}`;
      } else {
        const lastBenefit = benefits.pop();
        return `${benefits.join('、')} 和 ${lastBenefit}`;
      }
    }
    
    scrollToNextTarget(prefix = '') {
      const scrollContainer = document.getElementById(`${prefix}offer-tiers-scroll-${this.sectionId}`);
      const nextTier = this.getNextTier();
      
      if (scrollContainer && nextTier) {
        const nextTierElement = scrollContainer.querySelector(`[data-tier-id="${nextTier.id}"]`);
        if (nextTierElement) {
          const containerRect = scrollContainer.getBoundingClientRect();
          const elementRect = nextTierElement.getBoundingClientRect();
          const scrollLeft = scrollContainer.scrollLeft;
          
          const targetScrollLeft = scrollLeft + elementRect.left - containerRect.left - (containerRect.width / 2) + (elementRect.width / 2);
          
          scrollContainer.scrollTo({
            left: targetScrollLeft,
            behavior: 'smooth'
          });
        }
      }
    }
    
    getCurrentTier() {
      // This function now needs to respect the progress bar logic (Free shipping first)
      // It should find the highest *achieved* tier that the progress bar is based on.
      const nextTier = this.getNextTier(); // Find the next goal first.
      if (!nextTier) { // If no next goal, all goals are achieved. Return the max tier.
          return this.tiers.length > 0 ? this.tiers[this.tiers.length - 1] : null;
      }

      // The "current" tier is the one right before the "next" tier.
      const nextTierIndex = this.tiers.findIndex(t => t.id === nextTier.id);
      if (nextTierIndex > 0) {
          return this.tiers[nextTierIndex - 1];
      }
      
      return null; // No tier before the next one, so no "current" achieved tier for progress bar.
    }
    
    getNextTier() {
      // Priority 1: Find the next unachieved 'free_shipping' tier.
      const nextFreeShippingTier = this.tiers.find(tier => 
          tier.type === 'free_shipping' && this.currentAmount < tier.amount
      );
      if (nextFreeShippingTier) {
          return nextFreeShippingTier;
      }

      // Priority 2: If all free shipping tiers are met, find the next unachieved tier of any other type.
      const nextOtherTier = this.tiers.find(tier => 
          tier.type !== 'free_shipping' && this.amountForTierCalculation < tier.amount
      );
      if (nextOtherTier) {
          return nextOtherTier;
      }

      return null; // All tiers of all types are achieved.
    }
    
    updateTiers(prefix = '') {
      const tiersContainer = document.getElementById(`${prefix}offer-tiers-${this.sectionId}`);
      if (!tiersContainer || this.tiers.length === 0) return;
      
      tiersContainer.innerHTML = '';
      
      this.tiers.forEach((tier, index) => {
        const tierElement = this.createTierElement(tier, index);
        tiersContainer.appendChild(tierElement);
      });
    }
    
    createTierElement(tier, index) {
      const tierDiv = document.createElement('div');
      tierDiv.className = 'offer-tier';
      tierDiv.setAttribute('data-tier-id', tier.id);
      
            // --- New Logic Implementation ---
      
            const mainSwitchIsOn = this.settings.cumulative_tiers === 'true';
      
            const tierSwitchIsOn = tier.highlight_on_achieve === true;
      
            const tierType = tier.type || 'general';
      
      
      
            const amountToUseForAchievement = tierType === 'free_shipping' ? this.currentAmount : this.amountForTierCalculation;
      const isAchieved = amountToUseForAchievement >= tier.amount;
      
            let shouldHighlightAsAchieved = false;
      
      
      
            if (isAchieved) {
      
              if (mainSwitchIsOn) {
      
                // Cumulative highlighting: highlight if its own switch is on.
      
                if (tierSwitchIsOn) {
      
                  shouldHighlightAsAchieved = true;
      
                }
      
              } else {
      
                // Non-cumulative: highlight only if it's the highest for its type.
      
                const highestTierForThisType = this.highestAchievedTiersByType[tierType];
      
                if (highestTierForThisType && tier.id === highestTierForThisType.id) {
      
                  shouldHighlightAsAchieved = true;
      
                }
      
              }
      
            }
      
      
      
            // Determine the visual state of the tier (current, next, achieved)
      
            const nextTierOverall = this.getNextTier();
      
            const isCurrent = nextTierOverall ? tier.id === nextTierOverall.id : false;
      
            const isNext = nextTierOverall ? tier.amount > nextTierOverall.amount : false;
      
      
      
            // Determine status text
      
            let statusText;
      
            if (shouldHighlightAsAchieved) {
      
              statusText = `{{ 'cart.tier_achieved' | t }}`;
      
            } else if (isAchieved) {
      
              statusText = '已享更優'; // Achieved but not highlighted
      
            } else if (isCurrent) {
      
              statusText = `{{ 'cart.tier_in_progress' | t }}`;
      
            } else {
      
              statusText = `{{ 'cart.tier_pending' | t }}`;
      
            }
      
      
      
                  // Apply classes for styling
      
      
      
                  if (shouldHighlightAsAchieved) {
      
      
      
                    tierDiv.classList.add('achieved');
      
      
      
                  } else if (isCurrent) {
      
      
      
                    tierDiv.classList.add('current');
      
      
      
                  } else if (isNext) {
      
      
      
                    tierDiv.classList.add('next');
      
      
      
                  }
      
      
      
                  // --- End of New Logic ---

      const progress = Math.min((amountToUseForAchievement / tier.amount) * 100, 100);
      const fmt = new Intl.NumberFormat('zh-TW', { 
        style: 'currency', 
        currency: '{{ cart.currency.iso_code | default: "TWD" }}', 
        minimumFractionDigits: 0 
      });
      
      tierDiv.innerHTML = `
        <div class="tier-content">
          <div class="tier-info">
            <div class="tier-amount">${fmt.format(tier.amount)}</div>
            <div class="tier-benefit">${tier.benefit}</div>
            ${tier.description ? `<div class="tier-description">${tier.description}</div>` : ''}
          </div>
          <div class="tier-status ${shouldHighlightAsAchieved ? 'achieved' : isCurrent ? 'current' : 'next'}">
            <span class="tier-status-icon">
              ${isAchieved ? '✅' : isCurrent ? '🎯' : '⏳'}
            </span>
            <span>${statusText}</span>
            <div class="tier-progress">
              <div class="tier-progress-fill ${shouldHighlightAsAchieved ? 'achieved' : isCurrent ? 'current' : 'next'}" 
                   style="width: ${isAchieved ? 100 : progress}%"></div>
            </div>
          </div>
        </div>
      `;
      
      return tierDiv;
    }
    
    setupEventListeners() {
      const debounce = (fn, wait = 250) => { let t; return (...a) => { clearTimeout(t); t = setTimeout(() => fn.apply(this, a), wait); }; };
      const debouncedUpdate = debounce(() => this.updateCartAmount(), 250);

      const EVENT_NAMES = [
        'cart:refresh','cart:updated','cart:update','cart:change',
        'product:added','ajaxProduct:added','cart:request:complete',
        'theme:cart:update','CartUpdateEvent'
      ];
      const targets = [document, document.documentElement, window];

      window.__coCombListeners = window.__coCombListeners || {};
      const key = this.sectionId;
      if (window.__coCombListeners[key]) {
        const { targets: oldTargets, names, handler } = window.__coCombListeners[key];
        oldTargets.forEach(t => {
          names.forEach(n => t.removeEventListener(n, handler));
          t.removeEventListener('CartUpdateEvent', handler);
        });
      }

      targets.forEach(t => {
        EVENT_NAMES.forEach(n => t.addEventListener(n, debouncedUpdate, { passive: true }));
        t.addEventListener('CartUpdateEvent', debouncedUpdate, { passive: true });
      });
      window.__coCombListeners[key] = { targets, names: EVENT_NAMES, handler: debouncedUpdate };

      document.addEventListener('visibilitychange', () => {
        if (!document.hidden) this.updateCartAmount();
      });
    }

    getShippingInfo() {
      // 用 type 判斷
      const freeShippingTier = this.tiers.find(tier => tier.type === 'free_shipping');
      
      if (freeShippingTier) {
        const remaining = Math.max(0, freeShippingTier.amount - this.currentAmount);
        const progress = Math.min((this.currentAmount / freeShippingTier.amount) * 100, 100);
        return {
          remaining: remaining,
          progress: progress,
          achieved: this.currentAmount >= freeShippingTier.amount,
          target: freeShippingTier.amount
        };
      }
      
      if (this.tiers.length > 0) {
        const firstTier = this.tiers[0];
        const remaining = Math.max(0, firstTier.amount - this.currentAmount);
        const progress = Math.min((this.currentAmount / firstTier.amount) * 100, 100);
        return {
          remaining: remaining,
          progress: progress,
          achieved: this.currentAmount >= firstTier.amount,
          target: firstTier.amount,
          benefit: firstTier.benefit
        };
      }
      
      return {
        remaining: 0,
        progress: 0,
        achieved: false,
        target: 0
      };
    }
  }
  
  // 統一的加入購物車函數
  function addToCartUnified(variantId, button, isFromPopup = false) {
    if (!variantId) {
      variantId = button.dataset.variantId;
    }
    if (!variantId) return;
    
    button.classList.add('loading');
    
    if (isFromPopup) {
      button.textContent = '...';
    } else {
      button.innerHTML = '<span>...</span>';
    }
    
    const root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root : '/';
    fetch(root + 'cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify({
        items: [{
          id: parseInt(variantId),
          quantity: 1
        }]
      })
    })
    .then(response => response.json())
    .then(data => {
      button.classList.remove('loading');

      if (isFromPopup) {
        button.innerHTML = '✓ {{ "cart.added" | t }}';
      } else {
        button.innerHTML = '<span>✓</span>';
      }
      
      const sectionElement = button.closest('.combined-offer-section') || 
                            document.querySelector('.combined-offer-section');
      const sectionId = sectionElement ? sectionElement.id.replace('combined-offer-', '') : '{{ section.id }}';
            const combinedOffer = window.combinedOffers && window.combinedOffers[sectionId];
      
      if (combinedOffer) {
        setTimeout(() => {
          combinedOffer.updateCartAmount();
        }, 100);
      }
      
      
      import('@theme/events').then(({ CartUpdateEvent }) => {
        const cartDrawer = document.querySelector('cart-drawer-component');
        
        fetch(`/cart.js?_=${Date.now()}`, { cache: 'no-store' })
          .then(res => res.json())
          .then(cart => {
            
            document.dispatchEvent(new CustomEvent('cart:update', { detail: { cart } }));
            
            const event = new CartUpdateEvent(cart, 'manual-trigger', {
              itemCount: cart.item_count,
              source: 'combined-offer-block',
              sections: {}
            });
            document.dispatchEvent(event);
            
            setTimeout(() => {
              if (combinedOffer) {
                combinedOffer.updateCartAmount();
              }
            }, 300);
            
            if (!isFromPopup && cartDrawer) {
              if (cartDrawer.hasAttribute('auto-open')) {
                cartDrawer.open();
              } else {
                if (typeof cartDrawer.open === 'function') {
                  cartDrawer.open();
                } else if (typeof cartDrawer.toggle === 'function') {
                  cartDrawer.toggle(true);
                }
              }
            }
            
            const cartItemsComponent = document.querySelector('cart-items-component');
            if (cartItemsComponent && typeof cartItemsComponent.refresh === 'function') {
              cartItemsComponent.refresh();
            }
          });
      }).catch((error) => {
        console.error('❌ 無法載入 @theme/events:', error);
        
        const cartDrawer = document.querySelector('cart-drawer-component, cart-drawer, .cart-drawer');
        
        fetch(`/cart.js?_=${Date.now()}`, { cache: 'no-store' })
          .then(res => res.json())
          .then(cart => {
            document.dispatchEvent(new CustomEvent('cart:update', { detail: { cart } }));
            
            document.documentElement.dispatchEvent(new CustomEvent('cart:refresh', {
              bubbles: true,
              detail: { cart: cart }
            }));
            
            setTimeout(() => {
              if (combinedOffer) {
                combinedOffer.updateCartAmount();
              }
            }, 300);
            
            if (!isFromPopup) {
              if (cartDrawer && typeof cartDrawer.open === 'function') {
                cartDrawer.open();
              } else {
                const cartButton = document.querySelector('[data-cart-drawer-toggle], [data-cart-toggle], .cart-toggle');
                if (cartButton) cartButton.click();
              }
            }
            
            if (window.location.pathname.includes('/cart')) {
              const cartTable = document.querySelector('.cart-items__table');
              if (cartTable) {
                fetch(window.location.href)
                  .then(res => res.text())
                  .then(html => {
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(html, 'text/html');
                    const newCartTable = doc.querySelector('.cart-items__table');
                    if (newCartTable && cartTable.parentNode) {
                      cartTable.parentNode.replaceChild(newCartTable, cartTable);
                    }
                  });
              }
            }
          });
      });
      
      setTimeout(() => {
        button.classList.remove('added');
        if (isFromPopup) {
          button.textContent = '{{ "cart.add_on" | t }}';
        } else {
          button.innerHTML = '<span>+</span>';
        }
      }, 3000);
    })
    .catch(error => {
      console.error('加入購物車失敗:', error);
      button.classList.remove('loading');
      
      if (isFromPopup) {
        button.textContent = '{{ "cart.failed" | t }}';
      } else {
        button.innerHTML = '<span>✗</span>';
      }

      setTimeout(() => {
        if (isFromPopup) {
          button.textContent = '{{ "cart.add_on" | t }}';
        } else {
          button.innerHTML = '<span>+</span>';
        }
      }, 2000);
    });
  }

  // 初始化綜合優惠
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.getElementById('combined-offer-{{ section.id }}');
    if (section) {
      if (!window.combinedOffers) {
        window.combinedOffers = {};
      }
      
      window.combinedOffers['{{ section.id }}'] = new CombinedOffer('{{ section.id }}', {
        initial_message: `{{ section.settings.initial_message | escape }}`,
        cumulative_tiers: `{{ section.settings.cumulative_tiers }}`,
        tiers: [
          {% for block in section.blocks %}
            
            {% comment %} === 情況 1: 一般優惠 (所有人可見) === {% endcomment %}
            {% if block.type == 'tier' %}
              {
                id: '{{ block.id }}',
                amount: {{ block.settings.amount | default: 0 }},
                benefit: '{{ block.settings.benefit | escape }}',
                description: '{{ block.settings.description | escape }}',
                highlight_on_achieve: {{ block.settings.highlight_on_achieve | json }},
                type: '{{ block.settings.tier_type | escape }}'
              }
              {% unless forloop.last %},{% endunless %}

            {% comment %} === 情況 2: 新客註冊禮 (動態判斷) === {% endcomment %}
            {% elsif block.type == 'new_member_tier' %}
              
              {% comment %} 液態邏輯：只有 (已登入 + 0訂單 + 無標籤) 才會輸出這段 JSON {% endcomment %}
              {% if customer and customer.orders_count == 0 %}
                {% unless customer.tags contains 'Gift_Sent' %}
                  {
                    id: '{{ block.id }}',
                    amount: {{ block.settings.amount | default: 1000 }}, 
                    benefit: '{{ block.settings.benefit | escape }}',
                    description: '{{ block.settings.description | escape }}',
                    highlight_on_achieve: true, 
                    type: 'discount'
                  }
                  {% unless forloop.last %},{% endunless %}
                {% endunless %}
              {% endif %}

            {% endif %}
          {% endfor %}
        ]
      });
    }
    setTimeout(() => {
      const firstVisibleTab = document.querySelector('.category-tab:not([style*="display: none"])');
      if (firstVisibleTab) {
        switchCategory(firstVisibleTab.dataset.category, firstVisibleTab);
      }
    }, 100);
  });

  function openRecommendPopup() {
    const overlay = document.getElementById('popup-overlay-{{ section.id }}');
    const container = document.getElementById('popup-container-{{ section.id }}');
    
    if (overlay && container) {
      overlay.classList.add('active');
      container.classList.add('active');
      document.body.style.overflow = 'hidden';
      
      const combinedOffer = window.combinedOffers && window.combinedOffers['{{ section.id }}'];
      if (combinedOffer) {
        combinedOffer.updateSmartCategory();
      }
      
      const firstVisibleTab = document.querySelector('.category-tab:not([style*="display: none"])');
      if (firstVisibleTab) {
        switchCategory(firstVisibleTab.dataset.category, firstVisibleTab);
      }
    }
  }

  function closeRecommendPopup() {
    const overlay = document.getElementById('popup-overlay-{{ section.id }}');
    const container = document.getElementById('popup-container-{{ section.id }}');
    
    if (overlay && container) {
      overlay.classList.remove('active');
      container.classList.remove('active');
      document.body.style.overflow = 'auto';
    }
  }

  function switchCategory(category, element) {
    document.querySelectorAll('.category-tab').forEach(tab => {
      tab.classList.remove('active');
    });
    element.classList.add('active');
    
    const allCards = document.querySelectorAll('.recommend-product-card');
    let visibleCount = 0;
    
    allCards.forEach(card => {
      const categories = card.dataset.category.split(' ');
      if (categories.includes(category)) {
        card.style.display = 'flex';
        visibleCount++;
      } else {
        card.style.display = 'none';
      }
    });
    
    const grid = document.getElementById('recommendProductsGrid-{{ section.id }}');
    let noProductsMsg = grid.querySelector('.no-products-in-category');
    
    if (visibleCount === 0) {
      if (!noProductsMsg) {
        allCards.forEach(card => card.style.display = 'none');
        
        noProductsMsg = document.createElement('div');
        noProductsMsg.className = 'no-products-in-category';
        noProductsMsg.innerHTML = '<p style="text-align: center; color: #999; padding: 40px;">{{ "cart.no_products_in_category" | t }}</p>';
        grid.appendChild(noProductsMsg);
      } else {
        noProductsMsg.style.display = 'block';
      }
    } else if (noProductsMsg) {
      noProductsMsg.remove();
    }
  }

  function updateShippingProgress() {
    const combinedOffer = window.combinedOffers && window.combinedOffers['{{ section.id }}'];
    if (combinedOffer) {
      combinedOffer.updateCartAmount();
    }
  }

  document.addEventListener('DOMContentLoaded', function() {
    const popup = document.querySelector('.recommend-popup-container');
    const handle = document.querySelector('.popup-handle');
    
    if (handle && popup) {
      let startY = 0;
      
      handle.addEventListener('touchstart', (e) => {
        startY = e.touches[0].clientY;
      });
      
      handle.addEventListener('touchmove', (e) => {
        const currentY = e.touches[0].clientY;
        const translateY = Math.max(0, currentY - startY);
        if (translateY > 0) {
          popup.style.transform = `translateY(${translateY}px)`;
        }
      });
      
      handle.addEventListener('touchend', (e) => {
        const currentY = e.changedTouches[0].clientY;
        const translateY = currentY - startY;
        if (translateY > 100) {
          closeRecommendPopup();
        }
        popup.style.transform = '';
      });
    }
  });
  // 产品变体弹窗相关函数
function showProductVariantsModal(productHandle, productTitle) {
  const modal = document.getElementById('product-variants-modal-{{ section.id }}');
  const titleElement = document.getElementById('product-variants-title-{{ section.id }}');
  const optionsContainer = document.getElementById('product-variants-options-{{ section.id }}');
  
  // 设置弹窗标题
  titleElement.textContent = productTitle;
  
  // 显示加载状态
  optionsContainer.innerHTML = '<div class="loading-placeholder">{{ "cart.loading" | t }}</div>';
  
  // 显示弹窗
  modal.classList.add('show');
  document.body.style.overflow = 'hidden';
  
  // 获取产品变体信息
  fetch(`/products/${productHandle}.js`)
    .then(response => response.json())
    .then(productData => {
      // 渲染变体选项
      renderProductVariants(productData);
    })
    .catch(error => {
      console.error('获取产品变体信息失败:', error);
      optionsContainer.innerHTML = '<div class="error-message">{{ "cart.load_failed" | t }}</div>';
    });
}
function closeProductVariantsModal() {
  const modal = document.getElementById('product-variants-modal-{{ section.id }}');
  modal.classList.remove('show');
  document.body.style.overflow = 'auto';
}

function renderProductVariants(productData) {
  const optionsContainer = document.getElementById('product-variants-options-{{ section.id }}');
  
  if (!productData.variants || productData.variants.length === 0) {
    optionsContainer.innerHTML = '<div class="no-variants-message">{{ "cart.no_variants" | t }}</div>';
    return;
  }
  
  let variantsHTML = '';
  
  productData.variants.forEach(variant => {
    if (variant.available) {
      // 获取变体图片，如果没有则使用产品主图
      let variantImage = '';
      if (variant.featured_image) {
        variantImage = `<img src="${variant.featured_image.src}" alt="${variant.title}" style="width: 65px; height: 60px; object-fit: cover; border-radius: 4px; margin-right: 10px;">`;
      } else if (productData.images && productData.images.length > 0) {
        variantImage = `<img src="${productData.images[0]}" alt="${variant.title}" style="width: 65px; height: 60px; object-fit: cover; border-radius: 4px; margin-right: 10px;">`;
      }
      
      variantsHTML += `
        <div class="apgo-variant-choice" onclick="addToCartFromVariantModal(${variant.id}, 1, '${(productData.title || '').replace(/'/g, "\\'")}')">
          <div class="apgo-choice-info" style="display: flex; align-items: center;">
            ${variantImage}
            <div>
              <h4>${productData.title}</h4>
              ${variant.public_title ? `<h4 style="font-size: 16px;">${variant.public_title}</h4>` : ''}
            </div>
          </div>
          <div class="apgo-choice-price">${(window.Shopify && window.Shopify.formatMoney) ? Shopify.formatMoney(variant.price) : 'NT$' + (variant.price/100).toFixed(0)}</div>
        </div>
      `;
    }
  });
  
  if (variantsHTML === '') {
    optionsContainer.innerHTML = '<div class="no-variants-message">{{ "cart.no_variants" | t }}</div>';
  } else {
    optionsContainer.innerHTML = variantsHTML;
  }
}

async function addToCartFromVariantModal(variantId, quantity, productName) {
  const clickedChoice = event.currentTarget;
  const originalContent = clickedChoice.innerHTML;
  
  if (clickedChoice.classList.contains('loading')) {
    return;
  }
  
  // 创建一个临时按钮元素以兼容 addToCartUnified
  const tempButton = document.createElement('button');
  tempButton.style.display = 'none';
  tempButton.dataset.variantId = variantId;
  document.body.appendChild(tempButton);
  
  clickedChoice.classList.add('loading');
  clickedChoice.style.opacity = '0.7';
  clickedChoice.style.cursor = 'not-allowed';
  clickedChoice.innerHTML = '<div>{{ "cart.adding_to_cart" | t }}</div>';
  
  try {
    // 使用 addToCartUnified 方法确保购物车界面和标签正确更新
    await new Promise(resolve => {
      addToCartUnified(variantId, tempButton, false);
      // 监听按钮状态变化来判断何时完成
      const checkComplete = setInterval(() => {
        if (!tempButton.classList.contains('loading')) {
          clearInterval(checkComplete);
          resolve();
        }
      }, 100);
    });
    
    // 关闭弹窗
    closeProductVariantsModal();
    
    // 更新综合优惠区域
    const sectionElement = document.querySelector('.combined-offer-section') || 
                          document.querySelector('.combined-offer-section');
    const sectionId = sectionElement ? sectionElement.id.replace('combined-offer-', '') : '{{ section.id }}';
    const combinedOffer = window.combinedOffers && window.combinedOffers[sectionId];
    
    if (combinedOffer) {
      setTimeout(() => {
        combinedOffer.updateCartAmount();
      }, 100);
    }
    
    return { success: true };
  } catch (error) {
    console.error('Add to cart error:', error);
    return { success: false, error: error.message };
  } finally {
    // 清理临时按钮
    if (tempButton.parentNode) {
      tempButton.parentNode.removeChild(tempButton);
    }
    
    clickedChoice.classList.remove('loading');
    clickedChoice.style.opacity = '1';
    clickedChoice.style.cursor = 'pointer';
    clickedChoice.innerHTML = originalContent;
  }
}


// 关闭弹窗的键盘事件
document.addEventListener('keydown', function(e) {
  const modal = document.getElementById('product-variants-modal-{{ section.id }}');
  if (e.key === 'Escape' && modal && modal.classList.contains('show')) {
    closeProductVariantsModal();
  }
});

// 点击弹窗外部关闭弹窗
document.addEventListener('click', function(e) {
  const modal = document.getElementById('product-variants-modal-{{ section.id }}');
  if (modal && modal.classList.contains('show') && e.target.classList.contains('apgo-modal-overlay')) {
    closeProductVariantsModal();
  }
});
</script>

