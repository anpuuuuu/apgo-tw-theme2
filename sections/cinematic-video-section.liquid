{% comment %}
  Cinematic Video Section - APGO 品牌形象影片
  放置位置：/sections/cinematic-video-section.liquid
{% endcomment %}

<section class="cinematic-video-section">
  <!-- 動態粒子背景 -->
  <div class="particle-canvas" id="particleCanvas"></div>

  <!-- 環境光效 -->
  <div class="ambient-glow"></div>

  <!-- 影片舞台 -->
  <div class="video-stage">
    <video 
      class="brand-video" 
      id="brandVideo"
      playsinline
      preload="metadata"
    >
      {% if section.settings.video_url != blank %}
        <source src="{{ section.settings.video_url }}" type="video/mp4">
      {% else %}
        <source src="https://cdn.shopify.com/videos/c/o/v/d8e8828223b342a3b6167dbdb1bda547.mp4" type="video/mp4">
      {% endif %}
    </video>

    <!-- 載入動畫 -->
    <div class="loading-ring" id="loadingRing"></div>

    <!-- 播放控制 -->
    <div class="play-control" id="playControl">
      <div class="play-icon"></div>
    </div>

    <!-- 狀態指示燈 -->
    <div class="status-indicator" id="statusIndicator"></div>

    <!-- 進度條 -->
    <div class="progress-track">
      <div class="progress-bar" id="progressBar"></div>
    </div>
  </div>
</section>

{% style %}
  /* 👉 這裡直接放你提供的 CSS 全套 —— 我已經精簡掉 <style> 包裝 */

  :root {
      --primary-orange: #f08418;
      --secondary-orange: #ff9a3c;
  }

  body {
      font-family: 'Arial','Microsoft JhengHei',sans-serif;
      background:#000;
      color:#fff;
      overflow-x:hidden;
  }

  .cinematic-video-section{position:relative;width:100%;height:120vh;min-height:800px;background:#000;overflow:hidden;display:flex;align-items:center;justify-content:center;padding:10vh 0;}
  .cinematic-video-section .particle-canvas{position:absolute;top:0;left:0;width:100%;height:100%;z-index:1;pointer-events:none;}
  .cinematic-video-section .floating-particle{position:absolute;width:2px;height:2px;background:var(--primary-orange);border-radius:50%;opacity:0;animation:cinematic-particleFloat 20s infinite linear;}
  .cinematic-video-section .floating-particle:nth-child(odd){box-shadow:0 0 6px var(--primary-orange);}
  .cinematic-video-section .floating-particle:nth-child(even){background:var(--secondary-orange);box-shadow:0 0 4px var(--secondary-orange);}
  @keyframes cinematic-particleFloat{0%{transform:translateY(100vh) translateX(-50px) scale(0);opacity:0;}10%{opacity:.8;transform:scale(1);}90%{opacity:.3;transform:scale(1);}100%{transform:translateY(-100px) translateX(50px) scale(0);opacity:0;}}
  
  /* 主影片區塊 */
  .cinematic-video-section .video-stage{position:relative;width:85%;max-width:1400px;aspect-ratio:16/9;z-index:5;opacity:0;transform:scale(.95);animation:cinematic-videoEntrance 2s ease .5s forwards;}
  @keyframes cinematic-videoEntrance{to{opacity:1;transform:scale(1);}}
  .cinematic-video-section .video-stage::before{content:'';position:absolute;top:-8px;left:-8px;right:-8px;bottom:-8px;background:linear-gradient(45deg,var(--primary-orange),var(--secondary-orange),#ffb366,var(--secondary-orange),var(--primary-orange));background-size:400% 400%;border-radius:24px;z-index:-2;animation:cinematic-gradientShift 6s ease-in-out infinite;filter:blur(1px);}
  .cinematic-video-section .video-stage::after{content:'';position:absolute;top:-4px;left:-4px;right:-4px;bottom:-4px;background:linear-gradient(135deg,rgba(240,132,24,.8),rgba(255,154,60,.6),rgba(240,132,24,.8));background-size:200% 200%;border-radius:20px;z-index:-1;animation:cinematic-innerGlow 4s ease-in-out infinite;}
  @keyframes cinematic-gradientShift{0%,100%{background-position:0% 50%;}50%{background-position:100% 50%;}}
  @keyframes cinematic-innerGlow{0%,100%{background-position:0% 0%;opacity:.8;}50%{background-position:100% 100%;opacity:1;}}
  
  .cinematic-video-section .brand-video{width:100%;height:100%;object-fit:cover;border-radius:16px;background:#0a0a0a;box-shadow:0 20px 60px rgba(0,0,0,.8),inset 0 1px 0 rgba(255,255,255,.1);transition:all .6s ease;}
  .cinematic-video-section .brand-video:hover{transform:scale(1.02);box-shadow:0 30px 80px rgba(0,0,0,.9),0 0 40px rgba(240,132,24,.3),inset 0 1px 0 rgba(255,255,255,.1);}

  /* 播放控制按鈕 */
  .cinematic-video-section .play-control{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%) scale(.8);width:80px;height:80px;background:rgba(240,132,24,.15);border:2px solid rgba(240,132,24,.6);border-radius:50%;display:flex;align-items:center;justify-content:center;cursor:pointer;backdrop-filter:blur(20px);opacity:0;transition:all .4s cubic-bezier(.4,0,.2,1);}
  .cinematic-video-section .play-control.show{opacity:1;transform:translate(-50%,-50%) scale(1);}
  .cinematic-video-section .play-control:hover{background:rgba(240,132,24,.25);border-color:var(--primary-orange);transform:translate(-50%,-50%) scale(1.1);}
  .cinematic-video-section .play-icon{width:0;height:0;border-left:20px solid var(--primary-orange);border-top:12px solid transparent;border-bottom:12px solid transparent;margin-left:4px;filter:drop-shadow(0 2px 4px rgba(0,0,0,.3));}

  .cinematic-video-section .status-indicator{position:absolute;top:30px;right:30px;width:12px;height:12px;background:var(--primary-orange);border-radius:50%;opacity:0;box-shadow:0 0 10px var(--primary-orange),0 0 20px rgba(240,132,24,.5);animation:cinematic-pulse 2s ease-in-out infinite;}
  .cinematic-video-section .status-indicator.active{opacity:1;}
  @keyframes cinematic-pulse{0%,100%{transform:scale(1);box-shadow:0 0 10px var(--primary-orange),0 0 20px rgba(240,132,24,.5);}50%{transform:scale(1.2);box-shadow:0 0 20px var(--primary-orange),0 0 40px rgba(240,132,24,.7);}}

  .cinematic-video-section .progress-track{position:absolute;bottom:0;left:0;width:100%;height:3px;background:rgba(255,255,255,.1);border-radius:0 0 16px 16px;overflow:hidden;}
  .cinematic-video-section .progress-bar{height:100%;width:0%;background:linear-gradient(90deg,var(--primary-orange),var(--secondary-orange));border-radius:inherit;transition:width .1s ease;box-shadow:0 0 10px rgba(240,132,24,.6);}

  .cinematic-video-section .ambient-glow{position:absolute;top:50%;left:50%;width:120%;height:120%;transform:translate(-50%,-50%);background:radial-gradient(ellipse at center,rgba(240,132,24,.05) 0%,rgba(255,154,60,.03) 40%,transparent 70%);z-index:-3;animation:cinematic-ambientPulse 8s ease-in-out infinite;}
  @keyframes cinematic-ambientPulse{0%,100%{transform:translate(-50%,-50%) scale(1);opacity:.5;}50%{transform:translate(-50%,-50%) scale(1.1);opacity:.8;}}

  .loading-ring{position:absolute;top:50%;left:50%;width:60px;height:60px;transform:translate(-50%,-50%);opacity:1;transition:opacity .5s ease;}
  .loading-ring.hide{opacity:0;}
  .loading-ring::before{content:'';position:absolute;width:60px;height:60px;border:3px solid transparent;border-top:3px solid var(--primary-orange);border-radius:50%;animation:cinematic-loadingSpin 1.5s linear infinite;}
  .loading-ring::after{content:'';position:absolute;top:6px;left:6px;width:48px;height:48px;border:2px solid transparent;border-bottom:2px solid var(--secondary-orange);border-radius:50%;animation:cinematic-loadingSpin 1s linear infinite reverse;}
  @keyframes cinematic-loadingSpin{0%{transform:rotate(0deg);}100%{transform:rotate(360deg);}}

{% endstyle %}

{% javascript %}
  class CinematicVideoController {
    constructor(){
      this.video = document.getElementById('brandVideo');
      this.playControl = document.getElementById('playControl');
      this.statusIndicator = document.getElementById('statusIndicator');
      this.progressBar = document.getElementById('progressBar');
      this.loadingRing = document.getElementById('loadingRing');
      this.hasPlayed = false;
      this.init();
      this.createParticles();
    }

    init(){
      this.setupIntersectionObserver();
      this.setupVideoEvents();
      this.setupPlayControl();
    }

    createParticles(){
      const canvas=document.getElementById('particleCanvas');
      const count=window.innerWidth<768?8:15;
      for(let i=0;i<count;i++){
        const p=document.createElement('div');
        p.className='floating-particle';
        p.style.left=Math.random()*100+'%';
        p.style.animationDelay=Math.random()*20+'s';
        p.style.animationDuration=(15+Math.random()*10)+'s';
        canvas.appendChild(p);
      }
    }

    setupIntersectionObserver(){
      const observer=new IntersectionObserver((entries)=>{
        entries.forEach(entry=>{
          if(entry.isIntersecting && !this.hasPlayed){
            this.autoPlay();
          }
        });
      },{threshold:.1,rootMargin:'100px 0px -50px 0px'});
      observer.observe(this.video);
    }

    setupVideoEvents(){
      this.video.addEventListener('loadeddata',()=>{this.loadingRing.classList.add('hide');});
      this.video.addEventListener('play',()=>{this.statusIndicator.classList.add('active');this.playControl.classList.remove('show');});
      this.video.addEventListener('pause',()=>{this.statusIndicator.classList.remove('active');this.playControl.classList.add('show');});
      this.video.addEventListener('ended',()=>{this.statusIndicator.classList.remove('active');this.playControl.classList.add('show');this.progressBar.style.width='0%';});
      this.video.addEventListener('timeupdate',()=>{if(this.video.duration){this.progressBar.style.width=(this.video.currentTime/this.video.duration)*100+'%';}});
      this.video.addEventListener('error',()=>{this.loadingRing.classList.add('hide');this.playControl.classList.add('show');});
    }

    setupPlayControl(){
      this.playControl.addEventListener('click',()=>{this.playVideo();});
    }

    async autoPlay(){
      try{this.video.muted=false;await this.video.play();this.hasPlayed=true;}
      catch(err){
        try{this.video.muted=true;await this.video.play();this.hasPlayed=true;}catch(e){this.playControl.classList.add('show');}
      }
    }

    async playVideo(){
      try{
        if(this.video.ended){this.video.currentTime=0;}
        this.video.muted=false;
        await this.video.play();
        this.hasPlayed=true;
      }catch(err){console.error('播放失敗',err);}
    }
  }

  document.addEventListener('DOMContentLoaded',()=>{new CinematicVideoController();});
  document.addEventListener('visibilitychange',()=>{const v=document.getElementById('brandVideo');if(document.hidden && !v.paused){v.pause();}});
{% endjavascript %}

{% schema %}
{
  "name": "APGO 品牌影片",
  "settings": [
    {
      "type": "url",
      "id": "video_url",
      "label": "影片連結 (mp4)",
      "info": "留空則使用預設"
    }
  ],
  "presets": [
    {
      "name": "APGO 品牌影片"
    }
  ]
}
{% endschema %}