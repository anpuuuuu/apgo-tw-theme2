{% comment %} sections/shopping-guarantee.liquid {% endcomment %}
<section class="shopping-guarantee">
  <div class="guarantee-container">
    <div class="guarantee-header">
      <h2 class="guarantee-title">{{ section.settings.guarantee_main_title }}</h2>
      <p class="guarantee-subtitle">{{ section.settings.guarantee_subtitle }}</p>
    </div>

    <div class="guarantee-cards-wrapper">
      {% for block in section.blocks %}
        {% if block.type == 'guarantee_item' %}
          <div class="guarantee-card">
            <div class="guarantee-card-content">
              {% if block.settings.card_type == 'refund' %}
                <div class="refund-number">
                  <span class="refund-days">{{ block.settings.refund_days }}</span>
                  <span class="refund-unit">{{ block.settings.refund_unit }}</span>
                </div>
              {% else %}
                <div class="guarantee-icon" data-svg-type="{{ block.settings.card_type }}">
