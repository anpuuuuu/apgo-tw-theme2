      padding: 20px 24px 24px;
    }

    .cart-shell-v2 [data-block='popup'] .p-grid {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  /* =========================================
     全域字體與標題易讀性優化 (Mobile Legibility)
     ========================================= */

  .cart-shell-v2 .cv-label {
    font-size: 14px !important;
    font-weight: 900 !important;
    letter-spacing: 2px !important;
    margin-bottom: 16px !important;
    display: inline-block;
  }

  .cart-shell-v2 [data-block='equipment'] .e-title {
    font-size: 16px !important;
    font-weight: 700 !important;
    line-height: 1.4 !important;
    margin-bottom: 4px !important;
  }
  .cart-shell-v2 [data-block='equipment'] .e-variant {
    font-size: 13px !important;
  }

  .cart-shell-v2 [data-block='upsell'] .u-title {
    font-size: 14px !important;
    line-height: 1.4 !important;
  }
  .cart-shell-v2 [data-block='popup'] .p-title {
    font-size: 14px !important;
    line-height: 1.4 !important;
  }

  .cart-shell-v2 .m-reward-desc {
    font-size: 12px !important;
  }
  .cart-shell-v2 .m-reward-note {
    font-size: 13px !important;
  }
  .cart-shell-v2 .m-reward-note-gap {
    font-size: 14px !important;
    font-weight: 800;
  }

  .cart-shell-v2 [data-block='sticky'] .f-label {
    font-size: 12px !important;
    font-weight: 700 !important;
  }
  .cart-shell-v2 [data-block='sticky'] .f-price {
    font-size: 1.5rem !important;
  }
  .cart-shell-v2 [data-block='sticky'] .f-btn {
    font-size: 16px !important;
    letter-spacing: 2px !important;
  }

  /* =========================================
     1 & 4. 標題統一化 (統一橘色、調整大小)
     ========================================= */
  .cart-shell-v2 .cv-label {
    font-size: 15px !important;
    font-weight: 900 !important;
    letter-spacing: 1.5px !important;
    color: var(--dt-signal-orange) !important;
    text-transform: uppercase;
    margin-bottom: 16px !important;
    display: inline-block;
  }

  /* =========================================
     2. 按鈕輕量化 & 彈窗卡片樣式同步 (吸底)
     ========================================= */
  .cart-shell-v2 [data-block='upsell'] .u-card,
  .cart-shell-v2 [data-block='popup'] .p-grid .u-card {
    padding: 0 !important;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    background: rgba(255,255,255,0.02);
    border-radius: var(--dt-radius-card) !important;
  }

  .cart-shell-v2 [data-block='upsell'] .u-img,
  .cart-shell-v2 [data-block='popup'] .p-grid .u-img {
    width: calc(100% - 20px) !important;
    margin: 10px 10px 8px 10px !important;
    border-radius: var(--dt-radius-inner) !important;
    border-bottom: none !important;
    aspect-ratio: 1;
  }

  .cart-shell-v2 [data-block='upsell'] .u-content,
  .cart-shell-v2 [data-block='popup'] .p-grid .u-content {
    padding: 0 10px 12px 10px !important;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .cart-shell-v2 [data-block='upsell'] .u-add,
  .cart-shell-v2 [data-block='popup'] .p-grid .u-add {
    margin-top: auto !important;
    width: 100% !important;
    border: 0 !important;
    border-top: 1px solid rgba(255,255,255,0.08) !important;
    border-radius: 0 0 var(--dt-radius-card) var(--dt-radius-card) !important;
    background: transparent !important;
    color: var(--dt-signal-orange) !important;
    font-weight: 800 !important;
    letter-spacing: 1px !important;
    padding: 10px !important;
    min-height: 44px !important;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }

  .cart-shell-v2 [data-block='upsell'] .u-add:hover,
  .cart-shell-v2 [data-block='popup'] .p-grid .u-add:hover {
    background: var(--dt-signal-orange) !important;
    color: #000 !important;
  }

  /* =========================================
     3. 任務進度區塊瘦身 & 金額字體放大
     ========================================= */
  .cart-shell-v2 .m-reward {
    padding: 1rem !important;
  }

  .cart-shell-v2 .m-reward-thumb {
    width: 72px !important;
    height: 72px !important;
    margin-bottom: 12px !important;
    border-radius: 12px !important;
  }

  .cart-shell-v2 .m-progress-description {
    font-size: 14px !important;
    color: #fff !important;
  }
  .cart-shell-v2 .m-progress-gap {
    font-size: 20px !important;
    font-weight: 900 !important;
  }

  .cart-shell-v2 .m-reward-note-gap {
    font-size: 15px !important;
    font-weight: 900 !important;
  }

  /* =========================================
     徹底解決 Loading 狀態文字與轉圈重疊
     ========================================= */
  .cart-shell-v2 button.is-loading {
    color: transparent !important;
    text-shadow: none !important;
  }

  .cart-shell-v2 button.is-loading > * {
    opacity: 0 !important;
    visibility: hidden !important;
  }

  /* =========================================
     縮小標題下方的多餘空隙
     ========================================= */
  .cart-shell-v2 .cv-label {
    margin-bottom: 8px !important;
  }

  .cart-shell-v2 .m-mission-head {
    margin-bottom: 4px !important;
  }

  .cart-shell-v2 [data-block='equipment'] .e-head,
  .cart-shell-v2 [data-block='upsell'] .u-head,
  .cart-shell-v2 [data-block='subtotal'] .t-head {
    margin-bottom: 8px !important;
  }

  /* =========================================
     修復 HTML5 hidden 屬性失效的陷阱
     ========================================= */
  .cart-shell-v2 [hidden] {
    display: none !important;
  }

  /* =========================================
     🌟 極速打包版：u-card 樣式修正 🌟
     ========================================= */

  /* 🌟 手機版橫向滑動：鎖定 150px */
  @media (max-width: 1023px) {
    .cart-shell-v2 [data-block='upsell'] .u-list .u-card {
      flex: 0 0 auto !important;
      width: 150px !important;
      min-width: 150px !important;
    }
  }

  /* 🌟 電腦版 3 欄網格：解除鎖定，自動填滿 100% */
  @media (min-width: 1024px) {
    .cart-shell-v2 [data-block='upsell'] .u-list .u-card {
      flex: 1 1 auto !important;
      width: 100% !important;
      min-width: 0 !important;
    }
  }

  /* 🔥 關鍵新增：當 u-card 在彈窗網格中時，必須強制填滿網格單元格 🔥 */
  .cart-shell-v2 [data-block='popup'] .p-grid .u-card {
    flex: 1 1 auto !important;
    width: 100% !important;
    min-width: 0 !important;
    margin: 0 !important;
  }

  /* =========================================
     規格選擇卡片 (Variant Select)
     ========================================= */
  .v2-variant-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    width: 100%;
    max-height: 55vh;
    overflow-y: auto;
    padding-bottom: 12px;
    scrollbar-width: none; /* 隱藏滾動條 */
  }
  .v2-v-card {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: var(--dt-radius-inner);
    padding: 8px;
    cursor: pointer;
    position: relative;
    transition: border-color 0.2s;
  }
  .v2-v-card img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 4px;
    margin-bottom: 8px;
    background: transparent !important;
  }
  .v2-v-title {
    font-size: 12px;
    color: #fff;
    font-weight: 700;
    margin-bottom: 4px;
    line-height: 1.3;
  }
  .v2-v-price {
    font-size: 13px;
    color: var(--dt-signal-orange);
    font-family: ui-monospace, Menlo, monospace;
    font-weight: 800;
  }
  .v2-v-ring {
    position: absolute;
    inset: 0;
    border: 2px solid var(--dt-signal-orange);
    border-radius: var(--dt-radius-inner);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
  }
  .v2-v-ring.is-active {
    opacity: 1;
  }

  /* =========================================
     🔥 修復：隱藏醜陋原生捲軸，防止按鈕被切斷 🔥
     ========================================= */
  .cart-shell-v2 .i-tabs,
  .cart-shell-v2 .s-tabs,
  .cart-shell-v2 .m-rewards-grid,
  .cart-shell-v2 .u-filter-list,
  .cart-shell-v2 .u-list,
  .cart-shell-v2 .p-tabs {
    scrollbar-width: none !important; /* 隱藏 Firefox 捲軸 */
    -ms-overflow-style: none !important; /* 隱藏 IE/Edge 捲軸 */
    padding-bottom: 4px !important; /* 往下撐開 4px，讓橘色邊框能完整露出來 */
  }

  /* 隱藏 Chrome, Safari 的捲軸 */
  .cart-shell-v2 .i-tabs::-webkit-scrollbar,
  .cart-shell-v2 .s-tabs::-webkit-scrollbar,
  .cart-shell-v2 .m-rewards-grid::-webkit-scrollbar,
  .cart-shell-v2 .u-filter-list::-webkit-scrollbar,
  .cart-shell-v2 .u-list::-webkit-scrollbar,
  .cart-shell-v2 .p-tabs::-webkit-scrollbar {
    display: none !important;
  }

  /* =========================================
     🔥 防禦機制：避免被右下角聊天 `+` 按鈕擋住表單 🔥
     ========================================= */
  .cart-shell-v2 .cv-main {
    /* 讓整個購物車最底部多出 80px 的空隙，讓顧客可以把表單往上滑，避開懸浮按鈕 */
    padding-bottom: 80px !important;
  }

  /* =========================================
     🔥 終極修復：移除黑底 & 全域統一樣式 🔥
     ========================================= */

  /* 1. 移除圖片與卡片的死硬底色，還原輸出原貌 (去背圖不再有黑塊) */
  .cart-shell-v2 [data-block='upsell'] .u-card,
  .cart-shell-v2 [data-block='popup'] .p-grid .u-card {
    background: transparent !important;
  }
  .cart-shell-v2 [data-block='popup'] .p-grid .u-card {
    border: 1px solid var(--dt-border) !important;
  }
  .cart-shell-v2 [data-block='upsell'] .u-img,
  .cart-shell-v2 [data-block='popup'] .p-grid .u-img {
    background: transparent !important;
  }

  /* 2. 解除區域限制，讓全場的標題與價格 100% 長一模一樣 */
  .cart-shell-v2 .u-title {
    font-weight: 600 !important;
    font-size: 14px !important;
    min-height: 42px !important;
    line-height: 1.4 !important;
    display: -webkit-box !important;
    -webkit-line-clamp: 2 !important;
    -webkit-box-orient: vertical !important;
    overflow: hidden !important;
  }

  .cart-shell-v2 .m-val {
    color: var(--dt-signal-orange) !important;
    font-family: ui-monospace, Menlo, monospace !important;
    font-weight: 800 !important;
    font-size: 14px !important;
    min-height: 24px !important;
  }
{% endstylesheet %}

