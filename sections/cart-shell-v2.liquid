      </button>
      <div class="m-bottom-sheet-body" style="padding-top: 0.5rem; text-align: left; align-items: flex-start; width: 100%;">
        <h2 class="m-detail-modal-title" style="font-size: 1.1rem; margin-bottom: 1rem; width: 100%; text-align: left;" data-variant-modal-title>選擇規格</h2>

        <div class="v2-variant-grid" data-variant-grid>
          </div>

        <div style="width: 100%; margin-top: 16px;">
          <button type="button" class="m-bottom-sheet-btn" data-variant-confirm disabled style="opacity: 0.5;">確認加入</button>
        </div>
      </div>
    </div>
  </div>

  <div class="cart-shell-v2__notice" data-v2-notice hidden></div>
</section>

<script>
  (function () {
    if (window.__apgoCartV2Bound) return;
    window.__apgoCartV2Bound = true;
    const ROOT_SELECTOR = '[data-section-type="cart-shell-v2"]';

    // --- 基礎工具函數 ---
    function getRoot(element) {
      return element?.closest(ROOT_SELECTOR);
    }

    function getCartUrl(path) {
      const root = window.Shopify?.routes?.root || '/';
      return root + path.replace(/^\//, '');
    }

    function setLoading(button, loading) {
      if (!button) return;
      button.disabled = loading;
      button.classList.toggle('is-loading', loading);
    }

    function showNotice(root, text) {
      if (!root) return;
      const notice = root.querySelector('[data-v2-notice]');
      if (!notice) return;
      notice.textContent = text;
      notice.hidden = false;
    }

    function clearNotice(root) {
      if (!root) return;
      const notice = root.querySelector('[data-v2-notice]');
      if (notice) {
        notice.hidden = true;
        notice.textContent = '';
      }
    }

    async function parseResponseAsJsonSafe(response) {
      const text = await response.text();
      try {
        return JSON.parse(text);
      } catch (error) {
        throw new Error(`NON_JSON_RESPONSE:${response.status}:${text.slice(0, 60)}`);
      }
    }

    // --- 發票類型記錄（配合 AKO 同步用） ---
    function setInvoiceTypeInForm(root, type) {
      if (!root) return;
      root.dataset.invoiceType = type || 'personal';
    }

    function validateTaxIdChecksum(taxId) {
      if (!taxId || taxId.length !== 8) return false;
      var weights = [1, 2, 1, 2, 1, 2, 4, 1];
      var sum = 0;
      for (var i = 0; i < 8; i++) {
        var num = parseInt(taxId[i], 10);
        if (isNaN(num)) return false;
        var product = num * weights[i];
        sum += Math.floor(product / 10) + (product % 10);
      }
      if (sum % 5 === 0) return true;
      if (taxId.charAt(6) === '7' && (sum + 1) % 5 === 0) return true;
      return false;
    }

    function readInvoiceFieldInRoot(root, fieldName) {
      if (!root || !fieldName) return '';
      var block = root.querySelector('[data-block="invoice"]');
      var content = block && block.querySelector('[data-invoice-content]');
      var el = content && content.querySelector('[data-invoice-field="' + fieldName + '"]');
      return el ? String(el.value || '').trim() : '';
    }

    // 回傳 { attributes } 或 { error: 錯誤訊息字串 }
    function buildInvoiceCartAttributes(root) {
      var block = root && root.querySelector('[data-block="invoice"]');
      var activeChip = block && block.querySelector('.i-chip[data-invoice-type].is-active');
      var type = (activeChip && activeChip.dataset.invoiceType) || (root && root.dataset.invoiceType) || 'personal';

      // Cart / 訂單屬性鍵名與 App 一致：「發票種類(InvoiceType)」等，勿用「attributes[…]」當鍵名
      // （attributes[鍵] 僅用於結帳 URL query，見 proceedToCheckout 內 _set）
      var a = {};
      var setBase = function (invoiceType, carrierType, carrierNum, companyName, companyId, loveCode) {
        a['發票種類(InvoiceType)'] = invoiceType;
        a['載具類型(CarrierType)'] = carrierType;
        a['載具編號(CarrierNum)'] = carrierNum;
        a['公司名稱(CompanyName)'] = companyName;
        a['統一編號(CompanyId)'] = companyId;
        a['捐贈碼(LoveCode)'] = loveCode;
      };

      // 發票種類(InvoiceType) 與 App 選單一致：e-invoice / company / carrier / donate
      if (type === 'personal') {
        setBase('e-invoice', '', '', '', '', '');
      } else if (type === 'company') {
        var rawId = readInvoiceFieldInRoot(root, 'company_id');
        var taxId = rawId.replace(/\D+/g, '');
        if (taxId.length !== 8) {
          return { error: '請填寫 8 碼公司統一編號。' };
        }
        if (!validateTaxIdChecksum(taxId)) {
          return { error: '統一編號檢核未通過，請再確認。' };
        }
        var title = readInvoiceFieldInRoot(root, 'company_title');
        // 公司發票：僅寫入此四鍵（與 App 對接）。注意：cart/update 為合併，若曾選過載具／捐贈，舊鍵可能仍留在購物車屬性。
        return {
          attributes: {
            '發票種類(InvoiceType)': 'company',
            '代處理發票(DelegateInvoice)': 'Y',
            '公司名稱(CompanyName)': title,
            '統一編號(CompanyId)': taxId
          }
        };
      } else if (type === 'mobile') {
        var carrier = readInvoiceFieldInRoot(root, 'mobile');
        if (!carrier) {
          return { error: '請填寫手機載具條碼。' };
        }
        setBase('carrier', '3', carrier, '', '', '');
      } else if (type === 'donate') {
        var code = readInvoiceFieldInRoot(root, 'donate_code');
        if (!code) {
          return { error: '請填寫捐贈碼。' };
        }
        setBase('donate', '', '', '', '', code);
      } else {
        setBase('e-invoice', '', '', '', '', '');
      }

      a['代處理發票(DelegateInvoice)'] = 'Y';
      return { attributes: a };
    }

    // --- 畫面狀態獲取與渲染 ---
    function getRootState(root) {
      const popup = root?.querySelector('[data-block="popup"]');
      const activeTab = popup?.querySelector('.p-tab.is-active');
      return {
        popupOpen: popup?.classList.contains('is-open') || false,
        activeCollection: activeTab?.dataset.collection || ''
      };
    }

    function renderPopupProducts(root, collectionHandle) {
      if (!root) return;
      const popup = root.querySelector('[data-block="popup"]');
      const grid = popup?.querySelector('[data-popup-grid]');
      const note = popup?.querySelector('[data-popup-collection-note]');
      if (!popup || !grid) return;

      const template = popup.querySelector(`[data-popup-template="${collectionHandle}"]`);
      if (!template) return;

      popup.querySelectorAll('.p-tab').forEach((tab) => {
        tab.classList.toggle('is-active', tab.dataset.collection === collectionHandle);
      });

      // if (note) note.textContent = `COLLECTION: ${collectionHandle}`;
      grid.innerHTML = template.innerHTML;
    }

    // --- 推薦加購同步切換邏輯 ---
    function applyUpsellFilter(root, filterKey) {
      if (!root || !filterKey) return;

      // 切換按鈕亮燈
      root.querySelectorAll('.u-filter-chip').forEach((chip) => {
        if (chip.dataset.filterCollection === filterKey) {
          chip.classList.add('is-active');
        } else {
          chip.classList.remove('is-active');
        }
      });

      // 顯示/隱藏對應的產品群組
      let hasVisibleCards = false;
      root.querySelectorAll('[data-upsell-group]').forEach((group) => {
        if (group.dataset.upsellGroup === filterKey) {
          group.style.display = '';
          group.removeAttribute('hidden');
          group.scrollTo({ left: 0, behavior: 'smooth' });
          hasVisibleCards = true;
        } else {
          group.style.display = 'none';
          group.setAttribute('hidden', 'hidden');
        }
      });

      // 防呆：如果找不到該分類商品，退回顯示全部分類
      if (filterKey !== 'all' && !hasVisibleCards) {
        root.querySelectorAll('[data-upsell-group]').forEach(function (group) {
          group.style.display = '';
          group.removeAttribute('hidden');
        });
      }
    }

    // --- 任務進度條動畫 ---
    function scrollMissionToNextLocked(root) {
      if (!root) return;
      const track = root.querySelector('.m-rewards');
      const nextLocked = root.querySelector('.m-reward.is-next-locked') || root.querySelector('.m-reward.is-locked');
      if (!track || !nextLocked) return;

      function doScroll() {
        const containerWidth = track.clientWidth;
        const cardWidth = nextLocked.offsetWidth;
        let targetScrollLeft = nextLocked.offsetLeft - cardWidth + (containerWidth - cardWidth * 2) / 2;
        const maxScroll = track.scrollWidth - track.clientWidth;
        const clamped = Math.max(0, Math.min(targetScrollLeft, maxScroll));
        track.scrollTo({ left: clamped, behavior: 'smooth' });
      }
      setTimeout(function () { requestAnimationFrame(doScroll); }, 100);
    }

    function syncMissionRewards(root) {
      if (!root) return;
      const rewardCards = root.querySelectorAll('[data-reward-card]');
      if (!rewardCards.length) return;

      window.__apgoCartV2RewardState = window.__apgoCartV2RewardState || {};
      var targetChanged = false;

      rewardCards.forEach(function (card) {
        var rewardId = card.dataset.rewardId;
        var previousUnlocked = Boolean(window.__apgoCartV2RewardState[rewardId]);
        var currentUnlocked = card.classList.contains('is-unlocked');

        if (currentUnlocked && !previousUnlocked) {
          card.classList.remove('is-unlock-animate');
          window.requestAnimationFrame(function () {
            card.classList.add('is-unlock-animate');
          });
          targetChanged = true;
        }
        if (!currentUnlocked && previousUnlocked) {
          targetChanged = true;
        }
        window.__apgoCartV2RewardState[rewardId] = currentUnlocked;
      });

      rewardCards.forEach(function (card) { card.classList.remove('is-next-locked'); });
      var firstLocked = root.querySelector('.m-reward.is-locked');
      if (firstLocked) firstLocked.classList.add('is-next-locked');

      if (!window.__apgoMissionScrollDone || targetChanged) {
        scrollMissionToNextLocked(root);
        window.__apgoMissionScrollDone = true;
      }
    }

    function bindMissionUI(root) {
      if (!root || root.dataset.missionUIBound) return;
      root.dataset.missionUIBound = '1';
      const missionBlock = root.querySelector('[data-block="mission"]');
      if (!missionBlock) return;

      var allToggleBtn = missionBlock.querySelector('[data-mission-all-toggle]');
      var allModal = root.querySelector('[data-mission-all-modal]');
      if (allToggleBtn && allModal) {
        allToggleBtn.addEventListener('click', function () {
          allModal.setAttribute('aria-hidden', 'false');
          document.body.style.overflow = 'hidden';
        });
      }

      var modal = root.querySelector('[data-mission-modal]');
      var openMissionModal = function (card) {
        if (!modal) return;
        var title = card.dataset.rewardModalTitle || '';
        var desc = card.dataset.rewardModalDesc || '';
        var img = card.dataset.rewardModalImage || '';
        var iconEl = modal.querySelector('[data-mission-modal-icon]');
        var titleEl = modal.querySelector('[data-mission-modal-title]');
        var descEl = modal.querySelector('[data-mission-modal-desc]');
        var statusEl = modal.querySelector('[data-mission-modal-status]');
        var cardNote = card.querySelector('.m-reward-note');

        if (statusEl) statusEl.innerHTML = cardNote ? cardNote.innerHTML : '';

        if (iconEl) {
          iconEl.innerHTML = '';
          iconEl.className = 'm-detail-modal-icon';
          if (img) {
            iconEl.classList.add('m-detail-modal-icon--img');
            var im = document.createElement('img');
            im.src = img; im.alt = title;
            iconEl.appendChild(im);
          } else {
            iconEl.classList.add('m-detail-modal-icon--service');
          }
        }
        if (titleEl) titleEl.textContent = title;
        if (descEl) descEl.textContent = desc;
        modal.setAttribute('aria-hidden', 'false');
      };

      missionBlock.addEventListener('click', function (e) {
        var card = e.target.closest('[data-reward-card]');
        if (card && !e.target.closest('a, button')) {
          e.preventDefault();
          openMissionModal(card);
        }
      });

      // 統一綁定所有彈窗的關閉事件
      root.querySelectorAll('[data-mission-modal-close], [data-mission-all-modal-close]').forEach(function (el) {
        el.addEventListener('click', function(e) {
          e.preventDefault();
          if (modal) modal.setAttribute('aria-hidden', 'true');
          if (allModal) allModal.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
        });
      });
    }

    // 取得 /cart.js 並依門檻同步滿額贈（加／扣／校正數量）
    async function syncGiftRewardsFromCart(root) {
      const cartRes = await fetch(getCartUrl('/cart.js'));
      let cartData = await parseResponseAsJsonSafe(cartRes);

      const allGiftCards = root.querySelectorAll('[data-reward-type="gift"][data-gift-variant-id]');
      if (allGiftCards.length === 0 || !cartData) {
        return { cartData, mutated: false };
      }

      const cartTotalCents = cartData.total_price || 0;
      const targetGifts = new Set();

      allGiftCards.forEach(function (card) {
        const vid = card.getAttribute('data-gift-variant-id');
        const th = parseInt(card.getAttribute('data-threshold') || '0', 10);
        if (vid && cartTotalCents >= th) targetGifts.add(String(vid));
      });

      const currentGifts = {};
      const allPossibleGiftIds = new Set(Array.from(allGiftCards).map(function (c) {
        return String(c.getAttribute('data-gift-variant-id'));
      }));

      (cartData.items || []).forEach(function (item) {
        const vid = String(item.variant_id);
        if (allPossibleGiftIds.has(vid)) currentGifts[vid] = { key: item.key, qty: item.quantity };
      });

      let requiresUpdate = false;
      const bulkUpdates = {};
      const itemsToAdd = [];

      for (const vid of allPossibleGiftIds) {
        if (!targetGifts.has(vid) && currentGifts[vid]) {
          bulkUpdates[currentGifts[vid].key] = 0;
          requiresUpdate = true;
        } else if (targetGifts.has(vid) && currentGifts[vid] && currentGifts[vid].qty !== 1) {
          bulkUpdates[currentGifts[vid].key] = 1;
          requiresUpdate = true;
        }
      }

      for (const vid of targetGifts) {
        if (!currentGifts[vid]) {
          itemsToAdd.push({ id: parseInt(vid, 10), quantity: 1, properties: { _gift_auto: 'true' } });
          requiresUpdate = true;
        }
      }

      if (!requiresUpdate) {
        return { cartData, mutated: false };
      }

      if (Object.keys(bulkUpdates).length > 0) {
        await fetch(getCartUrl('/cart/update.js'), {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ updates: bulkUpdates })
        });
      }
      if (itemsToAdd.length > 0) {
        await fetch(getCartUrl('/cart/add.js'), {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: itemsToAdd })
        });
      }
      const finalCartRes = await fetch(getCartUrl('/cart.js'));
      cartData = await parseResponseAsJsonSafe(finalCartRes);
      return { cartData, mutated: true };
    }

    async function refreshCartSection(root, state, cartData) {
      const sectionId = root.dataset.sectionId;
      const currentUrl = new URL(window.location.href);
      currentUrl.searchParams.set('sections', sectionId);

      const htmlRes = await fetch(currentUrl.toString(), {
        headers: { 'X-Requested-With': 'XMLHttpRequest' }
      });
      const htmlJson = await parseResponseAsJsonSafe(htmlRes);
      const finalHtml = htmlJson && htmlJson[sectionId];

      if (finalHtml) {
        const oldFill = root.querySelector('[data-mission-fill]');
        const previousPercent = oldFill ? (oldFill.style.width || '0%') : '0%';

        const doc = new DOMParser().parseFromString(finalHtml, 'text/html');
        const nextRoot = doc.querySelector(ROOT_SELECTOR);

        if (nextRoot) {
          root.replaceWith(nextRoot);
          initRoot(nextRoot);
          if (typeof window.__apgoV2HydrateShippingSelects === 'function') {
            window.__apgoV2HydrateShippingSelects();
          }

          const fill = nextRoot.querySelector('[data-mission-fill]');
          if (fill) {
            const targetAttr = fill.getAttribute('data-mission-target');
            const target = (targetAttr !== null && targetAttr !== '') ? (targetAttr + '%') : (fill.style.width || '0%');
            fill.style.width = previousPercent;
            requestAnimationFrame(function () {
              requestAnimationFrame(function () { fill.style.width = target; });
            });
          }

          if (state.popupOpen) {
            const popup = nextRoot.querySelector('[data-block="popup"]');
            if (popup) {
              popup.classList.add('is-open');
              document.body.style.overflow = 'hidden';
            }
            if (state.activeCollection) {
              renderPopupProducts(nextRoot, state.activeCollection);
            }
          }
        }
      }

      document.dispatchEvent(new CustomEvent('cart:updated', { detail: { cart: cartData } }));
    }

    // 初次進入購物車／編輯器載入：達標即補贈品並重繪 section（與加購後路徑一致）
    function hydrateGiftRewardsOnEnter(root) {
      if (!root) return;
      (async function () {
        try {
          const { cartData, mutated } = await syncGiftRewardsFromCart(root);
          if (mutated) {
            await refreshCartSection(root, getRootState(root), cartData);
          } else {
            document.dispatchEvent(new CustomEvent('cart:updated', { detail: { cart: cartData } }));
          }
        } catch (e) {
          console.error('[cart-shell-v2] hydrateGiftRewardsOnEnter', e);
        }
      })();
    }

    // 🚀🚀🚀 極速打包核心 API (One-Shot Request) 🚀🚀🚀
    async function executeCartAction(action, payload, root) {
      const state = getRootState(root);
      let cartData = null;

      try {
        if (action === 'add') {
          await fetch(getCartUrl('/cart/add.js'), {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify(payload)
          });
        } else if (action === 'change') {
          await fetch(getCartUrl('/cart/change.js'), {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify(payload)
          });
        }

        const synced = await syncGiftRewardsFromCart(root);
        cartData = synced.cartData;
        await refreshCartSection(root, state, cartData);
      } catch (error) {
        throw error;
      }
    }


    // --- 根節點初始化 ---
    function initRoot(root) {
      if (!root || root.dataset.cartV2Ready === 'true') return;
      root.dataset.cartV2Ready = 'true';

      const firstTab = root.querySelector('[data-block="popup"] .p-tab');
      if (firstTab) {
        renderPopupProducts(root, firstTab.dataset.collection);
      }

      syncMissionRewards(root);
      bindMissionUI(root);

      // 初始化加購分類
      var firstFilter = root.querySelector('.u-filter-chip');
      if (firstFilter) {
        applyUpsellFilter(root, firstFilter.dataset.filterCollection);
      }
      clearNotice(root);
    }

    // --- 全域事件監聽 (事件代理) ---
    document.addEventListener('click', async function (event) {
      const root = getRoot(event.target);
      if (!root) return;

      // 開啟規格選擇彈窗
      const openVarBtn = event.target.closest('[data-open-variant-modal]');
      if (openVarBtn && root) {
        event.preventDefault();
        const pid = openVarBtn.dataset.openVariantModal;
        const pTitle = openVarBtn.dataset.productTitle;
        const jsonEl = root.querySelector(`#v2-json-${pid}`);
        if (!jsonEl) return;

        const variants = JSON.parse(jsonEl.textContent);
        const modal = root.querySelector('[data-variant-modal]');
        if (!modal) return;

        modal.querySelector('[data-variant-modal-title]').textContent = pTitle;
        const grid = modal.querySelector('[data-variant-grid]');
        grid.innerHTML = '';

        const confirmBtn = modal.querySelector('[data-variant-confirm]');
        confirmBtn.disabled = true;
        confirmBtn.style.opacity = '0.5';
        confirmBtn.dataset.selectedVariant = '';
        confirmBtn.textContent = '確認加入';

        variants.forEach(v => {
          const el = document.createElement('div');
          el.className = 'v2-v-card';
          el.innerHTML = `
            <img src="${v.img}" alt="${v.title}">
            <div class="v2-v-title">${v.title}</div>
            <div class="v2-v-price">${v.display_price}</div>
            <div class="v2-v-ring"></div>
          `;
          el.onclick = () => {
            grid.querySelectorAll('.v2-v-ring').forEach(r => r.classList.remove('is-active'));
            el.querySelector('.v2-v-ring').classList.add('is-active');
            confirmBtn.dataset.selectedVariant = v.id;
            confirmBtn.disabled = false;
            confirmBtn.style.opacity = '1';
          };
          grid.appendChild(el);
        });

        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        return;
      }

      // 關閉規格彈窗
      if (event.target.closest('[data-variant-modal-close]') && root) {
        event.preventDefault();
        const modal = root.querySelector('[data-variant-modal]');
        if (modal) {
          modal.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
        }
        return;
      }

      // 確認加入所選規格 (串接極速大腦)
      const confirmVarBtn = event.target.closest('[data-variant-confirm]');
      if (confirmVarBtn && root) {
        event.preventDefault();
        const vid = confirmVarBtn.dataset.selectedVariant;
        if (!vid) return;

        setLoading(confirmVarBtn, true);
        try {
          await executeCartAction('add', { items: [{ id: Number(vid), quantity: 1 }] }, root);
          const modal = root.querySelector('[data-variant-modal]');
          if (modal) {
            modal.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
          }
        } catch (error) {
          showNotice(root, '加入失敗，請稍後再試。');
        } finally {
          setLoading(confirmVarBtn, false);
        }
        return;
      }

      // 🔥 修復：發票與物流切換 (遺失的事件處理) 🔥
      const invoiceChip = event.target.closest('.i-chip[data-invoice-type]');
      if (invoiceChip) {
        const block = root.querySelector('[data-block="invoice"]');
        const content = block && block.querySelector('[data-invoice-content]');
        if (!content) return;

        root.querySelectorAll('.i-chip[data-invoice-type]').forEach((c) => c.classList.remove('is-active'));
        invoiceChip.classList.add('is-active');

        const type = invoiceChip.dataset.invoiceType;
        const renderMap = {
          personal: '已選擇個人雲端發票，將寄送至 Email。',
          company: '<div class="i-row"><label class="s-label">公司統編</label><input class="cv-input" data-invoice-field="company_id" placeholder="8碼統編"></div><div class="i-row"><label class="s-label">公司抬頭</label><input class="cv-input" data-invoice-field="company_title" placeholder="公司名稱 (選填)"></div>',
          mobile: '<div class="i-row"><label class="s-label">手機載具條碼</label><input class="cv-input" data-invoice-field="mobile" placeholder="/AB12345"></div>',
          donate: '<div class="i-row"><label class="s-label">捐贈碼</label><input class="cv-input" data-invoice-field="donate_code" placeholder="例如：5280"></div>'
        };
        content.innerHTML = renderMap[type] || '';

        var hidden = root.querySelector('[data-invoice-ako-hidden]');
        var akoRoot = hidden && (hidden.querySelector('#akocommerce_cvs_section') || hidden.querySelector('.akoCvsScNS'));
        if (akoRoot) {
          var items = akoRoot.querySelectorAll('li[data-invoice]');
          var idx = { personal: 0, company: 1, mobile: 2, donate: 3 }[type];
          if (items[idx]) items[idx].click();
        }
        setInvoiceTypeInForm(root, type);
        return;
      }

      const shippingTab = event.target.closest('[data-shipping-tab]');
      if (shippingTab) {
        root.querySelectorAll('[data-shipping-tab]').forEach((tab) => tab.classList.remove('is-active'));
        shippingTab.classList.add('is-active');
        const target = shippingTab.dataset.shippingTab;
        root.querySelectorAll('[data-shipping-pane]').forEach((pane) => {
          pane.classList.toggle('is-active', pane.dataset.shippingPane === target);
        });
        return;
      }

      // 1. 彈窗與分類切換
      if (event.target.closest('[data-open-popup]')) {
        const popup = root.querySelector('[data-block="popup"]');
        if (popup) {
          popup.classList.add('is-open');
          document.body.style.overflow = 'hidden';
          const active = popup.querySelector('.p-tab.is-active');
          if (active) renderPopupProducts(root, active.dataset.collection);
        }
        return;
      }

      if (event.target.closest('[data-close-popup]')) {
        const popup = root.querySelector('[data-block="popup"]');
        if (popup) {
          popup.classList.remove('is-open');
          document.body.style.overflow = '';
        }
        return;
      }

      const tab = event.target.closest('.p-tab');
      if (tab) {
        renderPopupProducts(root, tab.dataset.collection);
        return;
      }

      const upsellFilter = event.target.closest('[data-filter-collection]');
      if (upsellFilter && upsellFilter.closest('[data-block="upsell"]')) {
        event.preventDefault();
        applyUpsellFilter(root, upsellFilter.dataset.filterCollection);
        return;
      }

      // 2. 加購、改數、刪除
      const addButton = event.target.closest('[data-variant-id]');
      if (addButton) {
        event.preventDefault();
        setLoading(addButton, true);
        try {
          await executeCartAction('add', { items: [{ id: Number(addButton.dataset.variantId), quantity: 1 }] }, root);
        } catch (error) {
          showNotice(root, '加入購物車過於頻繁，請稍後再試。');
        } finally {
          setLoading(addButton, false);
        }
        return;
      }

      const qtyButton = event.target.closest('[data-quantity-delta]');
      if (qtyButton) {
        event.preventDefault();
        const line = qtyButton.dataset.line;
        const delta = Number(qtyButton.dataset.quantityDelta || 0);
        const qtyVal = qtyButton.parentElement?.querySelector('.qty-val');
        const current = Number(qtyVal?.textContent || 1);
        const eItem = qtyButton.closest('.e-item');
        const isGift = eItem && eItem.getAttribute('data-is-gift') === 'true';
        var next = Math.max(0, current + delta);
        if (isGift && delta > 0 && current >= 1) next = 1;

        setLoading(qtyButton, true);
        try {
          await executeCartAction('change', { line: Number(line), quantity: Number(next) }, root);
        } catch (error) {
          showNotice(root, '購物車更新失敗，請稍後再試。');
        } finally {
          setLoading(qtyButton, false);
        }
        return;
      }

      const removeButton = event.target.closest('[data-remove-line]');
      if (removeButton) {
        event.preventDefault();
        const line = removeButton.dataset.removeLine;
        setLoading(removeButton, true);
        try {
          await executeCartAction('change', { line: Number(line), quantity: 0 }, root);
        } catch (_error) {
          showNotice(root, '移除失敗，請稍後再試。');
        } finally {
          setLoading(removeButton, false);
        }
        return;
      }

      // 3. 結帳與會員攔截邏輯
      const proceedToCheckout = async function (root) {
        // --- 工具函式 ---
        function _digitsOnly(v) { return (v || '').toString().replace(/\D+/g, ''); }
        function _normPhone(v) {
          var local = (v || '').trim();
          if (!local) return '';
          if (/^\+/.test(local)) return '+' + _digitsOnly(local);
          var d = _digitsOnly(local).replace(/^0+/, '');
          return d ? '+886' + d : '';
        }
        /** 國際碼數字（886…）無 +，給 checkout[phone]／query／部分瀏覽器較不易把 + 誤解成空白 */
        function _phoneDigitsIntl(e164) {
          if (!e164) return '';
          return _digitsOnly(e164);
        }
        function _splitName(full) {
          if (!full) return { first: '', last: '' };
          var raw = full.trim();
          if (/[A-Za-z]/.test(raw)) {
            var parts = raw.split(/\s+/);
            if (parts.length === 1) return { first: parts[0], last: '' };
            return { first: parts.slice(0, -1).join(' '), last: parts.slice(-1)[0] };
          }
          var name = raw.replace(/\s+/g, '');
          if (name.length <= 1) return { first: name, last: '' };
          return { first: name.slice(1), last: name[0] };
        }
        /** id 全站唯一：先 getElementById，避免 root 範圍或區段重繪後抓不到輸入 */
        function _val(id) {
          var e = document.getElementById(id);
          if (!e && root && root.querySelector) e = root.querySelector('#' + id);
          return e ? (e.value || '').trim() : '';
        }
        function _txt(id) {
          var e = document.getElementById(id);
          if (!e && root && root.querySelector) e = root.querySelector('#' + id);
          return e ? (e.textContent || '').trim() : '';
        }

        // --- 判斷目前選擇的運送方式（優先同一 section） ---
        var activePaneEl = root.querySelector ? root.querySelector('[data-shipping-pane].is-active') : null;
        if (!activePaneEl) activePaneEl = document.querySelector('[data-shipping-pane].is-active');
        var method = activePaneEl ? activePaneEl.dataset.shippingPane : 'home';

        var qp = new URLSearchParams(window.location.search);
        function _set(key, val) {
          var v = (val == null ? '' : String(val).trim());
          if (v) qp.set(key, v);
        }

        // 共用欄位（姓名、電話）— 跨宅配/超商共享，與舊版 cp-name/cp-phone 行為一致
        var sharedName  = _val('v2-shared-name');
        var sharedPhone = _normPhone(_val('v2-shared-phone'));
        var sp = _splitName(sharedName);
        // cart／note 屬性：886… 純數字 | 結帳 URL 的 checkout[phone]：與運送相同 E.164（+886…），Shopify 聯絡欄較常接受；用 URL 物件組 query 避免 + 在字串拼接時被瀏覽器誤解
        var phoneForContact = _phoneDigitsIntl(sharedPhone);

        // 有電話時勿帶 checkout[email]，避免結帳只套用 email、忽略電話（舊版 checkout-prefill 同樣處理）
        if (sharedPhone) qp.delete('checkout[email]');

        _set('checkout[shipping_address][first_name]', sp.first);
        _set('checkout[shipping_address][last_name]',  sp.last);
        _set('checkout[shipping_address][phone]',      sharedPhone);
        _set('checkout[phone]', sharedPhone);
        _set('checkout[shipping_address][country]',    'Taiwan');
        _set('checkout[billing_address][phone]', sharedPhone);
        _set('checkout[billing_address][country]', 'Taiwan');

        if (method === 'home') {
          var city     = _val('v2-receiver-city');
          var district = _val('v2-receiver-district');
          var addr     = _val('v2-receiver-address1');
          var zip      = _txt('v2-receiver-zip-value');
          var address1 = (district ? district + ' ' : '') + addr;

          _set('checkout[shipping_address][city]',     city);
          _set('checkout[shipping_address][province]', city);
          _set('checkout[shipping_address][address1]', address1);
          if (zip && zip !== '—') _set('checkout[shipping_address][zip]', zip);

        } else if (method === 'cvs') {
          var city     = _val('v2-cvs-city');
          var district = _val('v2-cvs-district');
          var store    = _val('v2-cvs-store');
          var zip      = _txt('v2-cvs-zip-value');
          var address1 = (district ? district + ' ' : '') + store;

          _set('checkout[shipping_address][city]',     city);
          _set('checkout[shipping_address][province]', city);
          _set('checkout[shipping_address][address1]', address1);
          if (zip && zip !== '—') _set('checkout[shipping_address][zip]', zip);
        }

        var invResult = buildInvoiceCartAttributes(root);
        if (invResult.error) {
          showNotice(root, invResult.error);
          return;
        }

        var cartAttrPayload = Object.assign({}, invResult.attributes);
        if (phoneForContact) {
          cartAttrPayload['電話'] = phoneForContact;
          cartAttrPayload['聯絡電話'] = phoneForContact;
          _set('attributes[電話]', phoneForContact);
        }

        Object.keys(invResult.attributes).forEach(function (ik) {
          _set('attributes[' + ik + ']', invResult.attributes[ik]);
        });

        try {
          await fetch(getCartUrl('/cart/update.js'), {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
            body: JSON.stringify({ attributes: cartAttrPayload })
          });
        } catch (e) {
          console.warn('[cart-shell-v2] cart attributes before checkout', e);
        }

        var path = getCartUrl('/checkout');
        if (path.indexOf('http') === 0) {
          var checkoutUrl = new URL(path);
          qp.forEach(function (value, key) {
            checkoutUrl.searchParams.set(key, value);
          });
          window.location.assign(checkoutUrl.toString());
        } else {
          if (path.charAt(0) !== '/') path = '/' + path;
          var u = new URL(path, window.location.origin);
          qp.forEach(function (value, key) {
            u.searchParams.set(key, value);
          });
          window.location.assign(u.toString());
        }
      };

      const checkoutTrigger = event.target.closest('[data-checkout-trigger]');
      if (checkoutTrigger) {
        event.preventDefault();
        const isLoggedIn = root.dataset.customerLoggedIn === 'true';
        if (!isLoggedIn) {
          const memberModal = root.querySelector('[data-member-warning-modal]');
          if (memberModal) {
            memberModal.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
          } else {
            await proceedToCheckout(root);
          }
        } else {
          await proceedToCheckout(root);
        }
        return;
      }

      const guestCheckoutTrigger = event.target.closest('[data-guest-checkout-trigger]');
      if (guestCheckoutTrigger) {
        event.preventDefault();
        const memberModal = root.querySelector('[data-member-warning-modal]');
        if (memberModal) {
          memberModal.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
        }
        await proceedToCheckout(root);
        return;
      }

      const closeMemberModal = event.target.closest('[data-member-warning-modal-close]');
      if (closeMemberModal) {
        event.preventDefault();
        const memberModal = root.querySelector('[data-member-warning-modal]');
        if (memberModal) {
          memberModal.setAttribute('aria-hidden', 'true');
          document.body.style.overflow = '';
        }
        return;
      }
    });

    // --- 快捷鍵與外部更新監聽 ---
    document.addEventListener('keydown', function (event) {
      if (event.key !== 'Escape') return;
      document.querySelectorAll(`${ROOT_SELECTOR} [data-block="popup"].is-open`).forEach((popup) => {
        popup.classList.remove('is-open');
      });
      document.querySelectorAll(`${ROOT_SELECTOR} [data-member-warning-modal]`).forEach(function (m) {
        m.setAttribute('aria-hidden', 'true');
      });
      document.body.style.overflow = '';
    });

    document.addEventListener('DOMContentLoaded', function() {
      document.querySelectorAll(ROOT_SELECTOR).forEach(initRoot);
      document.querySelectorAll(ROOT_SELECTOR).forEach(hydrateGiftRewardsOnEnter);
    });

    // 🔥 bfcache 恢復（從結帳/登入按返回）：DOMContentLoaded 不會再觸發，
    //    必須用 pageshow + event.persisted 偵測，並強制重繪整個 section。
    window.addEventListener('pageshow', function(event) {
      // event.persisted === true 代表從 bfcache 恢復，頁面是凍結快照
      var isBackNav = event.persisted ||
        (window.performance && window.performance.navigation &&
         window.performance.navigation.type === window.performance.navigation.TYPE_BACK_FORWARD) ||
        (document.referrer && document.referrer.includes('login'));

      if (!isBackNav) return;

      var roots = document.querySelectorAll(ROOT_SELECTOR);
      if (!roots.length) return;

      // 先送一次空 update 讓 Shopify 重新計算折扣，再用 Section Rendering API 重繪 DOM
      fetch(getCartUrl('/cart/update.js'), {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ updates: {} })
      })
      .then(function(res) { return res.json(); })
      .then(function(cartData) {
        roots.forEach(function(root) {
          refreshCartSection(root, getRootState(root), cartData);
        });
      })
      .catch(function() {});
    });

    // Shopify Theme Editor 重新載入時初始化
    document.addEventListener('shopify:section:load', function() {
      document.querySelectorAll(ROOT_SELECTOR).forEach(initRoot);
      document.querySelectorAll(ROOT_SELECTOR).forEach(hydrateGiftRewardsOnEnter);
    });

  })();
</script>

<script>
/* 吸底列：行動版 Chrome/Safari 網址列收合時，layout / visual viewport 不同步時補齊 bottom 間隙 */
(function () {
  function initStickyViewportBottom() {
    if (!document.querySelector('.cart-shell-v2')) return;
    if (window.__apgoV2StickyViewportBound) return;
    window.__apgoV2StickyViewportBound = true;

    var vv = window.visualViewport;
    function update() {
      if (!vv) {
        document.documentElement.style.setProperty('--vv-bottom-gap', '0px');
        return;
      }
      var gap = Math.max(0, window.innerHeight - vv.height - vv.offsetTop);
      document.documentElement.style.setProperty('--vv-bottom-gap', gap + 'px');
    }

    if (vv) {
      vv.addEventListener('resize', update);
      vv.addEventListener('scroll', update);
    }
    window.addEventListener('resize', update);
    window.addEventListener('orientationchange', function () {
      setTimeout(update, 250);
    });
    update();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initStickyViewportBottom);
  } else {
    initStickyViewportBottom();
  }
  document.addEventListener('shopify:section:load', initStickyViewportBottom);
})();
</script>

<script>
/* =========================================================
  V2 Subtotal Floating Card (Desktop)
  以 fixed 方式確保訂單明細在捲動時持續可見
  ========================================================= */
(function () {
  if (window.__apgoV2SubtotalFloatBound) return;
  window.__apgoV2SubtotalFloatBound = true;

  var mqDesktop = window.matchMedia('(min-width: 1024px)');
  var TOP_OFFSET = 24;
  var MAIN_GAP = 24;
  var FOOTER_GAP = 16;
  var FOOTER_SELECTORS = [
    '#shopify-section-footer',
    '.shopify-section-group-footer-group',
    '.site-footer',
    'footer'
  ];
  var states = [];
  var rafId = 0;

  function getFooterTopInDocument() {
    for (var i = 0; i < FOOTER_SELECTORS.length; i += 1) {
      var el = document.querySelector(FOOTER_SELECTORS[i]);
      if (el) {
        var rect = el.getBoundingClientRect();
        return rect.top + window.scrollY;
      }
    }
    return null;
  }

  function clearCardStyles(card) {
    card.style.position = '';
    card.style.top = '';
    card.style.left = '';
    card.style.width = '';
    card.style.zIndex = '';
    card.style.bottom = '';
  }

  function resetState(state) {
    if (!state || !state.card) return;
    clearCardStyles(state.card);
    if (state.anchor) state.anchor.style.position = '';
    if (state.placeholder) {
      state.placeholder.style.display = 'none';
      state.placeholder.style.height = '';
    }
    state.isFixed = false;
  }

  function cleanupStates() {
    states.forEach(function (state) {
      resetState(state);
      if (state.placeholder && state.placeholder.parentNode) {
        state.placeholder.parentNode.removeChild(state.placeholder);
      }
    });
    states = [];
  }

  function buildStates() {
    cleanupStates();
    document.querySelectorAll('.cart-shell-v2').forEach(function (root) {
      var anchor = root.querySelector('.cv-col--right');
      var card = root.querySelector('.cv-col--right [data-block="subtotal"]');
      if (!anchor || !card) return;

      var ph = document.createElement('div');
      ph.setAttribute('data-subtotal-float-placeholder', 'true');
      ph.style.display = 'none';
      ph.style.width = '100%';
      card.parentNode.insertBefore(ph, card);

      states.push({
        root: root,
        boundaryBlock: root.querySelector('[data-block="upsell"]'),
        main: root.querySelector('.cv-main'),
        anchor: anchor,
        card: card,
        placeholder: ph,
        startY: 0,
        isFixed: false
      });
    });
  }

  function updateState(state) {
    if (!state.card.isConnected || !state.anchor.isConnected) return;

    if (!mqDesktop.matches) {
      resetState(state);
      return;
    }

    if (!state.isFixed) {
      state.startY = state.card.getBoundingClientRect().top + window.scrollY;
    }

    var shouldFix = window.scrollY + TOP_OFFSET >= state.startY;
    if (!shouldFix) {
      resetState(state);
      return;
    }

    var anchorRect = state.anchor.getBoundingClientRect();
    var cardHeight = state.card.offsetHeight;
    var anchorTopDoc = anchorRect.top + window.scrollY;
    var sectionBottomDoc = null;
    if (state.boundaryBlock && state.boundaryBlock.isConnected) {
      sectionBottomDoc = state.boundaryBlock.getBoundingClientRect().bottom + window.scrollY;
    } else if (state.main && state.main.isConnected) {
      sectionBottomDoc = state.main.getBoundingClientRect().bottom + window.scrollY;
    } else {
      sectionBottomDoc = state.root.getBoundingClientRect().bottom + window.scrollY;
    }
    var fixedTopDoc = window.scrollY + TOP_OFFSET;
    var maxTopDoc = sectionBottomDoc - cardHeight - MAIN_GAP;
    state.placeholder.style.display = 'block';
    state.placeholder.style.height = cardHeight + 'px';
    state.anchor.style.position = 'relative';
    if (fixedTopDoc < maxTopDoc) {
      state.card.style.position = 'fixed';
      state.card.style.top = TOP_OFFSET + 'px';
      state.card.style.left = anchorRect.left + 'px';
      state.card.style.width = anchorRect.width + 'px';
      state.card.style.zIndex = '20';
      state.card.style.bottom = '';
    } else {
      var absoluteTop = Math.max(0, maxTopDoc - anchorTopDoc);
      state.card.style.position = 'absolute';
      state.card.style.top = absoluteTop + 'px';
      state.card.style.left = '0';
      state.card.style.width = '100%';
      state.card.style.zIndex = '5';
      state.card.style.bottom = '';
    }
    state.isFixed = true;
  }

  function updateAll() {
    rafId = 0;
    states.forEach(updateState);
  }

  function requestUpdate() {
    if (rafId) return;
    rafId = window.requestAnimationFrame(updateAll);
  }

  function init() {
    buildStates();
    requestUpdate();
  }

  window.addEventListener('scroll', requestUpdate, { passive: true });
  window.addEventListener('resize', function () {
    buildStates();
    requestUpdate();
  });
  if (mqDesktop.addEventListener) {
    mqDesktop.addEventListener('change', function () {
      buildStates();
      requestUpdate();
    });
  }

  document.addEventListener('shopify:section:load', function () {
    setTimeout(init, 80);
  });
  document.addEventListener('shopify:section:unload', function () {
    setTimeout(init, 80);
  });

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>

<script>
/* =========================================================
   V2 收件資訊預填 — OpenSheet 縣市/區域/郵遞區號聯動
   ========================================================= */
(function () {
  if (window.__apgoV2ShippingBound) return;
  window.__apgoV2ShippingBound = true;

  const OPENSHEET_URL = 'https://opensheet.elk.sh/1S81a-nrJR1yzmEnWVjuGJuiiW1S2UWP2VpGaxmBuoJ4/taiwan_road';
  let _cache = null;

  function normTW(s) {
    return s ? String(s).replace(/台/g, '臺').replace(/\s+/g, '') : '';
  }

  function fillSelect(sel, list, placeholder) {
    sel.innerHTML = '';
    const ph = document.createElement('option');
    ph.value = '';
    ph.textContent = placeholder;
    sel.appendChild(ph);
    list.forEach(function(v) {
      const o = document.createElement('option');
      o.value = v;
      o.textContent = v;
      sel.appendChild(o);
    });
    sel.disabled = list.length === 0;
  }

  function getDistricts(data, city) {
    const c = normTW(city);
    return [...new Set(
      data.filter(function(r) { return normTW(r.city) === c; })
          .map(function(r) { return normTW(r.district); })
    )].filter(Boolean).sort();
  }

  function getZip(data, city, district) {
    const c = normTW(city), d = normTW(district);
    const rows = data.filter(function(r) {
      return normTW(r.city) === c && normTW(r.district) === d;
    });
    const zips = [...new Set(
      rows.map(function(r) {
        return (r.zip || r.ZIP || r['郵遞區號'] || '').toString().trim();
      }).filter(Boolean)
    )];
    return zips[0] || '';
  }

  function setZip(id, zip) {
    const el = document.getElementById(id);
    if (el) el.textContent = zip || '—';
  }

  async function loadData() {
    if (_cache) return _cache;
    try {
      const res = await fetch(OPENSHEET_URL, { mode: 'cors', cache: 'no-store' });
      if (!res.ok) throw new Error('HTTP ' + res.status);
      const data = await res.json();
      if (!Array.isArray(data)) throw new Error('非陣列格式');
      _cache = data;
      return data;
    } catch (e) {
      console.error('[v2-shipping] OpenSheet 載入失敗:', e.message);
      return [];
    }
  }

  /** Section 重繪（贈品／改數量）後 DOM 會換新，需重灌縣市選項 */
  async function hydrateCountySelects() {
    const homeCity = document.getElementById('v2-receiver-city');
    const cvsCity = document.getElementById('v2-cvs-city');
    if (!homeCity && !cvsCity) return;
    const data = await loadData();
    if (!data || !data.length) return;
    const counties = [...new Set(data.map(function(r) { return normTW(r.city); }))].filter(Boolean).sort();
    if (homeCity) {
      fillSelect(homeCity, counties, '請選擇');
      const homeDist = document.getElementById('v2-receiver-district');
      if (homeDist) fillSelect(homeDist, [], '請先選縣市');
    }
    if (cvsCity) {
      fillSelect(cvsCity, counties, '請選擇');
      const cvsDist = document.getElementById('v2-cvs-district');
      if (cvsDist) fillSelect(cvsDist, [], '請先選縣市');
    }
    setZip('v2-receiver-zip-value', '');
    setZip('v2-cvs-zip-value', '');
  }

  window.__apgoV2HydrateShippingSelects = function () {
    hydrateCountySelects();
  };

  // 事件委派：換掉整塊 section 後仍能收到 change（不可綁在舊 select 上）
  document.addEventListener('change', async function (ev) {
    const t = ev.target;
    const id = t && t.id;
    if (!id) return;

    if (id === 'v2-receiver-city') {
      const homeDist = document.getElementById('v2-receiver-district');
      if (!homeDist) return;
      const city = t.value;
      setZip('v2-receiver-zip-value', '');
      if (!city) {
        fillSelect(homeDist, [], '請先選縣市');
        return;
      }
      const data = await loadData();
      fillSelect(homeDist, getDistricts(data, city), '請選擇區域');
      return;
    }

    if (id === 'v2-receiver-district') {
      const homeCity = document.getElementById('v2-receiver-city');
      const city = homeCity && homeCity.value;
      const dist = t.value;
      if (!city || !dist) {
        setZip('v2-receiver-zip-value', '');
        return;
      }
      const data = await loadData();
      setZip('v2-receiver-zip-value', getZip(data, city, dist));
      return;
    }

    if (id === 'v2-cvs-city') {
      const cvsDist = document.getElementById('v2-cvs-district');
      if (!cvsDist) return;
      const city = t.value;
      setZip('v2-cvs-zip-value', '');
      if (!city) {
        fillSelect(cvsDist, [], '請先選縣市');
        return;
      }
      const data = await loadData();
      fillSelect(cvsDist, getDistricts(data, city), '請選擇區域');
      return;
    }

    if (id === 'v2-cvs-district') {
      const cvsCity = document.getElementById('v2-cvs-city');
      const city = cvsCity && cvsCity.value;
      const dist = t.value;
      if (!city || !dist) {
        setZip('v2-cvs-zip-value', '');
        return;
      }
      const data = await loadData();
      setZip('v2-cvs-zip-value', getZip(data, city, dist));
    }
  });

  function initShipping() {
    hydrateCountySelects();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initShipping);
  } else {
    initShipping();
  }

  document.addEventListener('shopify:section:load', function() {
    _cache = null;
    initShipping();
  });
})();
</script>

{% stylesheet %}
  .cart-shell-v2 {
    --dt-bg-screen: #050505;
    --dt-bg-surface: #121212;
    --dt-bg-input: #1a1a1a;
    --dt-border: #333333;
    --dt-signal-orange: #f08418;
    --dt-text-primary: #ffffff;
    --dt-text-secondary: #999999;
    --dt-space: 16px;
    --dt-radius: 12px;
    --dt-radius-card: 12px;
    --dt-radius-inner: 8px;
