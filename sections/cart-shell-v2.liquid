  /* 參考 UI：標題區、金額右側、進度條漸層（空隙由 .cv-label margin-bottom 統一控制，避免疊加） */
  .cart-shell-v2 .m-mission-head {
    margin-bottom: 0;
  }
  .cart-shell-v2 .m-mission-label {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 10px;
    letter-spacing: 0.4em;
    font-weight: 900;
    text-transform: uppercase;
    color: rgba(249, 115, 22, 0.95);
    font-family: ui-monospace, "JetBrains Mono", Menlo, monospace;
  }
  .cart-shell-v2 .m-mission-label-line {
    display: none; /* 標題改為單純文字，不再顯示裝飾線 */
  }
  .cart-shell-v2 .m-progress-copy {
    margin-top: 10px;
    margin-bottom: 10px;
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: flex-end;
    flex-wrap: wrap;
  }
  .cart-shell-v2 .m-progress-value {
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    flex-wrap: wrap;
  }
  .cart-shell-v2 .m-progress-current {
    color: #fff;
    font-family: ui-monospace, Menlo, monospace;
    font-weight: 700;
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    letter-spacing: -0.02em;
  }
  .cart-shell-v2 .m-progress-target {
    color: #71717a;
    font-size: 1rem;
    font-weight: 300;
    font-family: ui-monospace, Menlo, monospace;
  }
  .cart-shell-v2 .m-progress-right {
    text-align: right;
    padding-bottom: 2px;
  }
  .cart-shell-v2 .m-progress-description {
    color: #cfcfcf;
    font-size: 12px;
    font-weight: 700;
    margin-bottom: 2px;
  }
  .cart-shell-v2 .m-progress-gap {
    color: rgba(251, 146, 60, 1);
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
    font-family: ui-monospace, Menlo, monospace;
  }
  .cart-shell-v2 .m-progress-next-label {
    font-size: 10px;
    color: #71717a;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    font-weight: 700;
  }

  .cart-shell-v2 .m-track {
    height: 16px;
    background: rgba(24, 24, 27, 0.8);
    border-radius: 9999px;
    overflow: hidden;
    margin-top: 12px;
    margin-bottom: 2.5rem;
    padding: 3.5px;
    border: 1px solid rgba(255,255,255,0.05);
    box-shadow: inset 0 1px 2px rgba(0,0,0,0.3);
  }

  .cart-shell-v2 .m-fill {
    height: 100%;
    border-radius: 9999px;
    transition: width 1s ease-out;
    background: linear-gradient(to right, #ea580c, #fb923c, #facc15);
    box-shadow: 0 0 25px rgba(249, 115, 22, 0.4);
  }

  /* 手機與電腦版皆橫向滑動，不切換 grid */
  .cart-shell-v2 .m-rewards-grid {
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    overflow-y: hidden;
    gap: 1rem;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 6px;
    scrollbar-width: thin;
    width: 100%;
  }
  .cart-shell-v2 .m-rewards::-webkit-scrollbar {
    height: 6px;
  }
  .cart-shell-v2 .m-rewards::-webkit-scrollbar-track {
    background: rgba(255,255,255,0.06);
    border-radius: 3px;
  }
  .cart-shell-v2 .m-rewards::-webkit-scrollbar-thumb {
    background: rgba(240,132,24,0.4);
    border-radius: 3px;
  }

  .cart-shell-v2 .m-reward {
    position: relative;
    z-index: 1;
    flex: 0 0 auto;
    width: calc((100% - 1rem) / 2);
    padding: 1.25rem;
    border-radius: 1rem;
    scroll-snap-align: start;
    scroll-snap-stop: always;
    border: 2px solid rgba(255,255,255,0.08);
    background: rgba(22, 22, 22, 1);
    display: flex;
    flex-direction: column;
    align-content: start;
    cursor: pointer;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .cart-shell-v2 .m-reward:hover {
    transform: scale(1.02);
    z-index: 2;
  }
  @media (min-width: 768px) {
    .cart-shell-v2 .m-reward {
      width: calc((100% - 2rem) / 3);
    }
  }

  .cart-shell-v2 .m-reward-icon-wrap {
    position: absolute;
    top: 12px;
    right: 12px;
    z-index: 2;
  }
  .cart-shell-v2 .m-reward-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
  }
  /* 已達成：白底、橘勾、陰影、略放大（與參考代碼一致） */
  .cart-shell-v2 .m-reward-icon--check {
    background: #fff;
    color: #ea580c;
    padding: 4px;
    box-shadow: 0 4px 14px rgba(0,0,0,0.25);
    transform: scale(1.1);
  }
  .cart-shell-v2 .m-reward-icon--check .m-reward-icon-svg {
    width: 12px;
    height: 12px;
  }
  /* 未解鎖：深色圓、毛玻璃、細邊框（與參考代碼一致） */
  .cart-shell-v2 .m-reward-icon--lock {
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    padding: 6px;
    border: 1px solid rgba(255,255,255,0.1);
    color: #71717a;
  }
  .cart-shell-v2 .m-reward-icon--lock .m-reward-icon-svg {
    width: 12px;
    height: 12px;
  }

  .cart-shell-v2 .m-reward.is-unlocked {
    border-color: rgba(249, 115, 22, 0.2);
    background: rgba(22, 22, 22, 1);
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
  }

  .cart-shell-v2 .m-reward.is-unlock-animate {
    animation: cart-shell-v2-unlock-burst 900ms ease;
  }

  .cart-shell-v2 .m-reward.is-locked {
    opacity: 0.5;
    filter: grayscale(1);
    border-color: rgba(255,255,255,0.05);
    background: rgba(24, 24, 27, 0.2);
  }
  /* 下一個目標的狀態：解除灰階、加上定時左右晃動 */
  .cart-shell-v2 .m-reward.is-next-locked {
    opacity: 1;
    filter: grayscale(0);
    animation: cart-shell-v2-shake-attention 3s ease-in-out infinite;
  }

  /* 震動動畫：平時靜止，每 3 秒快速左右晃動一下 */
  @keyframes cart-shell-v2-shake-attention {
    0%, 80%, 100% {
      transform: translateX(0);
      box-shadow: none;
      border-color: rgba(255, 255, 255, 0.08);
    }
    84% {
      transform: translateX(-3px);
      border-color: rgba(249, 115, 22, 0.4);
    }
    88% { transform: translateX(3px); }
    92% { transform: translateX(-3px); }
    96% {
      transform: translateX(3px);
      border-color: rgba(249, 115, 22, 0.4);
    }
  }
  @keyframes cart-shell-v2-locked-nudge {
    0%, 90%, 100% { transform: translateX(0); }
    93% { transform: translateX(-1px); }
    96% { transform: translateX(1px); }
    99% { transform: translateX(0); }
  }

  .cart-shell-v2 .m-reward.is-locked .m-reward-note {
    color: #666;
  }

  /* 免運費、訂單折扣：已解鎖時橘色漸層（與參考一致），未解鎖時深色 */
  .cart-shell-v2 .m-reward-thumb--service {
    background: linear-gradient(145deg, #202020, #111111);
    border: 1px solid rgba(255,255,255,0.06);
    color: #fff;
  }
  .cart-shell-v2 .m-reward.is-unlocked .m-reward-thumb--service {
    background: linear-gradient(to bottom right, #fb923c, #ea580c);
    border-top: 1px solid rgba(253, 186, 116, 0.5);
    box-shadow: 0 15px 30px rgba(249, 115, 22, 0.3);
    color: #fff;
  }
  /* 滿額贈：產品圖背景深黑 */
  .cart-shell-v2 .m-reward-thumb--gift {
    background: #0a0a0a;
    border: 1px solid rgba(255,255,255,0.06);
    color: #fff;
  }
  .cart-shell-v2 .m-reward-thumb {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 1rem;
    display: grid;
    place-items: center;
    font-size: 22px;
    margin-bottom: 1.25rem;
    overflow: hidden;
  }
  .cart-shell-v2 .m-reward.is-locked .m-reward-thumb--service,
  .cart-shell-v2 .m-reward.is-locked .m-reward-thumb--gift {
    background: #1a1a1a;
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: none;
  }
  .cart-shell-v2 .m-reward-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cart-shell-v2 .m-reward.is-locked .m-reward-thumb img {
    filter: brightness(0.25) grayscale(1);
  }
  .cart-shell-v2 .m-reward-fallback {
    font-size: 2rem;
  }

  .cart-shell-v2 .m-reward-title {
    font-size: 1.25rem;
    font-weight: 900;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin-bottom: 4px;
  }
  .cart-shell-v2 .m-reward.is-locked .m-reward-title {
    color: #a1a1aa;
  }
  .cart-shell-v2 .m-reward-desc {
    font-size: 11px;
    font-weight: 700;
    line-height: 1.4;
    color: rgba(249, 115, 22, 1);
    margin-bottom: 8px;
  }
  .cart-shell-v2 .m-reward.is-locked .m-reward-desc {
    color: #71717a;
  }
  .cart-shell-v2 .m-reward-note {
    margin-top: auto;
    padding-top: 12px;
    border-top: 1px solid rgba(255,255,255,0.05);
    color: #999;
    font-size: 10px;
    line-height: 1.2;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 4px;
  }
  .cart-shell-v2 .m-reward-note-text {
    flex: 1;
    min-width: 0;
  }
  .cart-shell-v2 .m-reward-note-gap {
    font-family: ui-monospace, Menlo, monospace;
    color: rgba(251, 146, 60, 1);
    flex-shrink: 0;
  }
  .cart-shell-v2 .m-reward.is-unlocked .m-reward-note,
  .cart-shell-v2 .m-reward.is-unlocked .m-reward-note-text {
    color: rgba(249, 115, 22, 0.8);
  }
  .cart-shell-v2 .m-reward.is-locked .m-reward-note .m-reward-note-gap {
    color: rgba(251, 146, 60, 1);
  }

  .cart-shell-v2 .m-mission-toggle-wrap {
    margin-top: 2rem;
    display: flex;
    justify-content: center;
  }
  .cart-shell-v2 .m-mission-toggle {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 32px;
    border-radius: 9999px;
    background: rgba(24, 24, 27, 1);
    border: 1px solid rgba(255,255,255,0.05);
    color: #71717a;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: color 0.3s, border-color 0.3s;
  }
  .cart-shell-v2 .m-mission-toggle:hover {
    color: var(--dt-signal-orange);
    border-color: rgba(249, 115, 22, 0.3);
  }
  .cart-shell-v2 .m-mission-toggle-icon {
    flex-shrink: 0;
  }

  /* =========================================
     Bottom Sheet (底部抽屜彈窗) 基礎設定
     ========================================= */
  .cart-shell-v2 .m-bottom-sheet {
    position: fixed;
    inset: 0;
    z-index: 99999 !important; /* 脫離層疊上下文後壓過吸底結帳區 */
    display: flex;
    align-items: flex-end;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }
  .cart-shell-v2 .m-bottom-sheet[aria-hidden="false"] {
    pointer-events: auto;
    opacity: 1;
    visibility: visible;
  }
  .cart-shell-v2 .m-bottom-sheet-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    cursor: pointer;
  }

  .cart-shell-v2 .m-bottom-sheet-content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 600px;
    max-height: 85vh;
    background: var(--dt-bg-surface);
    border-top: 1px solid rgba(240, 132, 24, 0.4);
    border-radius: 24px 24px 0 0;
    padding: 2rem 1.5rem max(2rem, env(safe-area-inset-bottom));
    box-shadow: 0 -10px 40px rgba(0, 0, 0, 0.8);
    transform: translateY(100%);
    transition: transform 0.4s cubic-bezier(0.32, 0.72, 0, 1);
    display: flex;
    flex-direction: column;
  }
  .cart-shell-v2 .m-bottom-sheet[aria-hidden="false"] .m-bottom-sheet-content {
    transform: translateY(0);
  }

  .cart-shell-v2 .m-bottom-sheet-drag-handle {
    position: absolute;
    top: 10px;
    left: 50%;
    transform: translateX(-50%);
    width: 40px;
    height: 4px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 4px;
  }

  .cart-shell-v2 .m-bottom-sheet-close {
    position: absolute;
    top: 16px;
    right: 16px;
    padding: 8px;
    color: #71717a;
    background: rgba(255, 255, 255, 0.05);
    border-radius: 50%;
    border: none;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
  }
  .cart-shell-v2 .m-bottom-sheet-close:hover {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
  }

  /* =========================================
     單一任務詳情 (Detail Modal) 內部樣式
     ========================================= */
  .cart-shell-v2 .m-bottom-sheet-body {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    overflow-y: auto;
    scrollbar-width: none;
  }
  .cart-shell-v2 .m-bottom-sheet-body::-webkit-scrollbar { display: none; }

  .cart-shell-v2 .m-detail-modal-icon {
    width: 6.5rem;
    height: 6.5rem;
    border-radius: 1.5rem;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: linear-gradient(145deg, #202020, #111111);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #fff;
    font-size: 2.5rem;
    box-shadow: 0 10px 25px rgba(0,0,0,0.5);
  }
  .cart-shell-v2 .m-detail-modal-icon img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .cart-shell-v2 .m-detail-modal-title {
    font-size: 1.5rem;
    font-weight: 900;
    color: #fff;
    margin-bottom: 8px;
    font-family: ui-monospace, Menlo, monospace;
  }
  .cart-shell-v2 .m-detail-modal-desc {
    color: #a1a1aa;
    font-size: 14px;
    line-height: 1.6;
    margin-bottom: 2rem;
    max-width: 90%;
  }
  .cart-shell-v2 .m-detail-modal-status {
    margin-bottom: 12px;
    padding: 6px 16px;
    background: rgba(249, 115, 22, 0.15);
    border: 1px solid rgba(249, 115, 22, 0.3);
    border-radius: 8px;
    font-family: ui-monospace, Menlo, monospace;
    font-size: 14px;
    font-weight: 800;
    color: var(--dt-signal-orange, #f97316);
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .cart-shell-v2 .m-bottom-sheet-btn {
    width: 100%;
    padding: 16px;
    background: rgba(249, 115, 22, 0.1);
    border: 1px solid rgba(249, 115, 22, 0.3);
    color: var(--dt-signal-orange);
    font-weight: 800;
    letter-spacing: 2px;
    border-radius: 12px;
    cursor: pointer;
    text-transform: uppercase;
    transition: background 0.2s, color 0.2s;
  }
  .cart-shell-v2 .m-bottom-sheet-btn:hover {
    background: var(--dt-signal-orange);
    color: #000;
  }

  /* =========================================
     所有任務總覽 (Timeline) 內部樣式
     ========================================= */
  .cart-shell-v2 .m-all-sheet-content .m-bottom-sheet-body {
    align-items: flex-start;
    text-align: left;
  }

  .cart-shell-v2 .m-timeline-list {
    position: relative;
    width: 100%;
    padding-left: 14px;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .cart-shell-v2 .m-timeline-list::before {
    content: '';
    position: absolute;
    top: 10px;
    bottom: 20px;
    left: 19px;
    width: 2px;
    background: rgba(255, 255, 255, 0.1);
    z-index: 0;
  }

  .cart-shell-v2 .m-timeline-row {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1.25rem;
    z-index: 1;
    padding-left: 1.5rem;
  }

  .cart-shell-v2 .m-timeline-node {
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: #3f3f46;
    border: 3px solid var(--dt-bg-surface);
    z-index: 2;
    transition: all 0.3s ease;
  }
  .cart-shell-v2 .m-timeline-row.is-unlocked .m-timeline-node {
    background: var(--dt-signal-orange);
    box-shadow: 0 0 12px rgba(249, 115, 22, 0.6);
  }

  .cart-shell-v2 .m-timeline-thumb {
    width: 56px;
    height: 56px;
    flex-shrink: 0;
    border-radius: 12px;
    display: grid;
    place-items: center;
    font-size: 1.5rem;
    border: 1px solid rgba(255,255,255,0.08);
  }
  .cart-shell-v2 .m-timeline-row.is-unlocked .m-timeline-thumb {
    border-color: rgba(249, 115, 22, 0.4);
  }
  .cart-shell-v2 .m-timeline-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 11px;
  }
  .cart-shell-v2 .m-timeline-row.is-locked .m-timeline-thumb img {
    filter: grayscale(1) brightness(0.5);
  }

  .cart-shell-v2 .m-timeline-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .cart-shell-v2 .m-timeline-title {
    font-weight: 800;
    color: #fff;
    font-size: 1.1rem;
  }
  .cart-shell-v2 .m-timeline-status {
    font-size: 0.8rem;
    color: #71717a;
    font-family: ui-monospace, Menlo, monospace;
  }
  .cart-shell-v2 .m-timeline-row.is-locked .m-timeline-title {
    color: #a1a1aa;
  }

  @keyframes cart-shell-v2-unlock-burst {
    0% { transform: scale(0.96); box-shadow: 0 0 0 rgba(240,132,24,0); }
    40% { transform: scale(1.05) translateY(-2px); box-shadow: 0 0 0 10px rgba(240,132,24,0.2); }
    70% { transform: scale(1); box-shadow: 0 0 0 20px rgba(240,132,24,0); }
    100% { transform: scale(1); box-shadow: 0 0 0 rgba(240,132,24,0); }
  }

  .cart-shell-v2 [data-block='equipment'] .e-head,
  .cart-shell-v2 [data-block='upsell'] .u-head,
  .cart-shell-v2 [data-block='subtotal'] .t-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 12px;
  }
  .cart-shell-v2 [data-block='upsell'] .u-head > div:first-child {
    min-width: 0;
  }

  .cart-shell-v2 [data-block='equipment'] .e-item {
    display: flex;
    gap: 12px;
    padding: 14px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
  }

  .cart-shell-v2 [data-block='equipment'] .e-item:last-child {
    border-bottom: 0;
  }

  .cart-shell-v2 [data-block='equipment'] .e-thumb {
    width: 76px;
    height: 76px;
    border-radius: 8px;
    background: #222;
    display: grid;
    place-items: center;
    overflow: hidden;
