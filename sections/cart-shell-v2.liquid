{%- liquid
  assign reward_blocks = section.blocks | where: 'type', 'reward'
  assign popup_blocks = section.blocks | where: 'type', 'popup_tab'

  assign progress_target = 0
  for block in reward_blocks
    assign threshold_cents = block.settings.threshold_amount | times: 100
    if threshold_cents > progress_target
      assign progress_target = threshold_cents
    endif
  endfor
  if progress_target <= 0
    assign progress_target = 100
  endif

  assign progress_percentage = cart.total_price | times: 100.0 | divided_by: progress_target | round
  if progress_percentage > 100
    assign progress_percentage = 100
  endif

  assign next_locked_title = blank
  assign next_locked_amount = 0
  for block in reward_blocks
    assign threshold_cents = block.settings.threshold_amount | times: 100
    if cart.total_price < threshold_cents
      assign next_locked_title = block.settings.title
      assign next_locked_amount = threshold_cents | minus: cart.total_price
      break
    endif
  endfor

  assign upsell_products = blank
  if section.settings.upsell_source_mode == 'collection' and section.settings.upsell_source_collection != blank
    assign upsell_products = section.settings.upsell_source_collection.products
  elsif section.settings.upsell_source_products != blank
    assign upsell_products = section.settings.upsell_source_products
  endif

  comment
    訂單折扣多階：Shopify 只套用最高等級折扣。找出「目前符合且已套用折扣」的最高門檻 = 當前階級。
    低於此階級的 order_discount 卡片顯示「已享更優」。
  endcomment
  assign current_order_discount_tier_cents = 0
  if cart.total_discount > 0
    for block in reward_blocks
      assign bt = block.settings.reward_type | default: 'standard'
      if bt == 'order_discount'
        assign tc = block.settings.threshold_amount | times: 100
        if cart.total_price >= tc and tc > current_order_discount_tier_cents
          assign current_order_discount_tier_cents = tc
        endif
      endif
    endfor
  endif
-%}

<section
  id="CartShellV2-{{ section.id }}"
  class="cart-shell-v2"
  data-section-id="{{ section.id }}"
  data-section-type="cart-shell-v2"
  data-invoice-mode="{{ section.settings.invoice_ui_mode | default: 'custom' }}"
  data-customer-logged-in="{% if customer %}true{% else %}false{% endif %}"
>
  <main class="cv-main">
    <div class="cv-col cv-col--left">
      <section data-block="mission" class="cv-card m-mission">
        {% comment %} 參考: 小標 UNLOCK PROGRESS → section.settings.mission_title {% endcomment %}
        <div class="m-mission-head">
          <span class="cv-label cv-label--accent m-mission-label">{% if section.settings.mission_title == blank or section.settings.mission_title == 'UNLOCK PROGRESS' %}解鎖進度{% else %}{{ section.settings.mission_title | escape }}{% endif %}</span>
        </div>
        <div class="m-progress-copy">
          {% comment %} 參考: 當前金額/下一門檻 → cart.total_price 大字、progress_target 反灰小字 {% endcomment %}
          <div class="m-progress-value">
            <span class="m-progress-current">{{ cart.total_price | money }}</span>
            <span class="m-progress-target">/ {{ progress_target | money }}</span>
          </div>
          {% comment %} 參考: 再差 $XX、即將解鎖 → next_locked_amount, mission_next_label {% endcomment %}
          <div class="m-progress-right">
            <div class="m-progress-description" data-mission-description>
              {%- if next_locked_title != blank -%}
                再差 <span class="m-progress-gap">{{ next_locked_amount | money }}</span>
              {%- else -%}
                所有階段已解鎖完成
              {%- endif -%}
            </div>
            <div class="m-progress-next-label">{{ section.settings.mission_next_label | default: '即將解鎖下一個目標' | escape }}</div>
          </div>
        </div>
        {% comment %} 參考: progress-bar width % → progress_percentage, data-mission-target {% endcomment %}
        <div class="m-track"><div class="m-fill" style="width: {{ progress_percentage }}%;" data-mission-fill data-mission-target="{{ progress_percentage }}"></div></div>
        {% assign first_locked_found = false %}
        <div class="m-rewards m-rewards-grid">
        {% for block in reward_blocks %}
          {%- liquid
            assign threshold_cents = block.settings.threshold_amount | times: 100
            assign rtype = block.settings.reward_type | default: 'standard'
            assign is_unlocked = false
            assign reward_note = block.settings.locked_text
            if rtype == 'standard'
              if cart.total_price >= threshold_cents
                assign is_unlocked = true
                assign reward_note = block.settings.unlocked_text | default: '已達成'
              endif
            elsif rtype == 'free_shipping'
              assign has_shipping_discount = false
              for disc in cart.discount_applications
                if disc.target_type == 'shipping_line'
                  assign has_shipping_discount = true
                  break
                endif
              endfor
              if has_shipping_discount or cart.total_price >= threshold_cents
                assign is_unlocked = true
                assign reward_note = block.settings.unlocked_text | default: '已達成'
              endif
            elsif rtype == 'order_discount'
              if cart.total_discount > 0 and cart.total_price >= threshold_cents
                assign is_unlocked = true
                if threshold_cents < current_order_discount_tier_cents
                  assign reward_note = block.settings.better_tier_text | default: '已享更優'
                else
                  assign reward_note = block.settings.unlocked_text | default: '已達成'
                endif
              elsif cart.total_price >= threshold_cents
                assign is_unlocked = true
                assign reward_note = block.settings.unlocked_text | default: '已達成'
              else
                assign reward_note = block.settings.locked_text
              endif
            elsif rtype == 'gift'
              if cart.total_price >= threshold_cents
                assign is_unlocked = true
                assign reward_note = block.settings.unlocked_text | default: '已達成'
              endif
            endif
            assign gap_cents = threshold_cents | minus: cart.total_price
            if gap_cents < 0
              assign gap_cents = 0
            endif
            assign is_next_locked = false
            if is_unlocked == false and first_locked_found == false
              assign is_next_locked = true
              assign first_locked_found = true
            endif
            assign display_note = reward_note
            if is_unlocked and display_note == '已解鎖'
              assign display_note = '已達成'
            endif
            if is_unlocked == false and display_note == blank
              assign display_note = '尚未解鎖'
            endif
            if is_unlocked == false and display_note contains 'gift tiers'
              assign display_note = '待解鎖'
            endif
            if is_unlocked == false and display_note contains 'GIFT TIERS'
              assign display_note = '待解鎖'
            endif
          -%}
          {%- assign gift_variant_id = '' -%}
          {%- if rtype == 'gift' and block.settings.gift_product != blank -%}
            {%- assign gp = block.settings.gift_product -%}
            {%- assign gift_variant_id = gp.selected_or_first_available_variant.id -%}
          {%- endif -%}
          {%- assign modal_desc = block.settings.reward_description | default: reward_note -%}
          {%- assign modal_image = '' -%}
          {%- if rtype == 'gift' and block.settings.gift_product != blank and block.settings.gift_product.featured_image != blank -%}
            {%- assign modal_image = block.settings.gift_product.featured_image | image_url: width: 400 -%}
          {%- elsif block.settings.icon_image != blank -%}
            {%- assign modal_image = block.settings.icon_image | image_url: width: 400 -%}
          {%- endif -%}
          <div
            class="m-reward{% if is_unlocked %} is-unlocked{% else %} is-locked{% endif %}{% if is_next_locked %} is-next-locked{% endif %}"
            data-reward-card
            data-reward-id="{{ block.id }}"
            data-reward-title="{{ block.settings.title | escape }}"
            data-reward-type="{{ rtype }}"
            data-threshold="{{ threshold_cents }}"
            data-reward-modal-title="{{ block.settings.title | escape }}"
            data-reward-modal-desc="{{ modal_desc | escape }}"
            {% if modal_image != '' %}data-reward-modal-image="{{ modal_image }}"{% endif %}
            data-reward-modal-type="{{ rtype }}"
            {% if gift_variant_id != '' %}data-gift-variant-id="{{ gift_variant_id }}"{% endif %}
            {{ block.shopify_attributes }}
          >
            <div class="m-reward-icon-wrap">
              {%- if is_unlocked -%}
                <span class="m-reward-icon m-reward-icon--check" aria-hidden="true"><svg class="m-reward-icon-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="4"><path d="M5 13l4 4L19 7"></path></svg></span>
              {%- else -%}
                <span class="m-reward-icon m-reward-icon--lock" aria-hidden="true"><svg class="m-reward-icon-svg" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 10-8 0v4h8z" stroke-width="2"></path></svg></span>
              {%- endif -%}
            </div>
            <div class="m-reward-thumb m-reward-thumb--{% if rtype == 'gift' %}gift{% else %}service{% endif %}">
              {%- if block.settings.icon_image != blank -%}
                {{ block.settings.icon_image | image_url: width: 180 | image_tag: loading: 'lazy', alt: block.settings.title }}
              {%- elsif rtype == 'gift' and block.settings.gift_product != blank -%}
                {%- assign gift_product = block.settings.gift_product -%}
                {%- if gift_product.featured_image != blank -%}
                  {{ gift_product.featured_image | image_url: width: 180 | image_tag: loading: 'lazy', alt: gift_product.title }}
                {%- else -%}
                  <span class="m-reward-fallback">{{ block.settings.icon_fallback | escape }}</span>
                {%- endif -%}
              {%- else -%}
                <span class="m-reward-fallback">{{ block.settings.icon_fallback | escape }}</span>
              {%- endif -%}
            </div>
            <div class="m-reward-title">{{ block.settings.title | escape }}</div>
            {%- if block.settings.reward_subtitle != blank -%}
              <div class="m-reward-desc">{{ block.settings.reward_subtitle | escape }}</div>
            {%- endif -%}
            <div class="m-reward-note">
              <span class="m-reward-note-text">{{ display_note | escape }}</span>
              {%- if is_unlocked == false and gap_cents > 0 -%}
                <span class="m-reward-note-gap">差 {{ gap_cents | money }}</span>
              {%- endif -%}
            </div>
          </div>
        {% endfor %}
        </div>
        <div class="m-mission-toggle-wrap">
          <button type="button" class="m-mission-toggle" data-mission-all-toggle>
            {{ section.settings.mission_expand_label | default: '展開所有獎勵' | escape }} ({{ reward_blocks.size }})
            <svg class="m-mission-toggle-icon" width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M19 9l-7 7-7-7" stroke-width="2"></path></svg>
          </button>
        </div>
      </section>

      {% render 'cart-items-v2', section: section %}

      {% comment %} 推薦加購 (改為與彈窗 100% 共用同一套 Collection 資料) {% endcomment %}
      <section data-block="upsell" class="cv-card">
      <div class="u-head">
        <div>
          <span class="cv-label cv-label--accent">{{ section.settings.upsell_title | escape }}</span>
          <div class="u-filter-list" data-upsell-filters>
            {%- for block in popup_blocks -%}
              {%- if block.settings.collection != blank and block.settings.show_in_popup -%}
                <button type="button" class="u-filter-chip {% if forloop.first %}is-active{% endif %}" data-filter-collection="{{ block.settings.collection.handle }}">
                  {{ block.settings.label | escape }}
                </button>
              {%- endif -%}
            {%- endfor -%}
          </div>
        </div>
        <div>
          <button type="button" class="u-open" data-open-popup>{{ section.settings.popup_label | escape }}</button>
        </div>
      </div>

      <div class="u-list-container">
        {%- for block in popup_blocks -%}
          {%- if block.settings.collection != blank and block.settings.show_in_popup -%}
            <div class="u-list" data-upsell-group="{{ block.settings.collection.handle }}" {% unless forloop.first %}hidden style="display: none;"{% endunless %}>
              {% assign available_products = block.settings.collection.products | where: 'available', true %}
              {% assign sold_out_products = block.settings.collection.products | where: 'available', false %}
              {% assign sorted_products = available_products | concat: sold_out_products %}
              {%- for product in sorted_products limit: section.settings.upsell_max_products -%}
                {%- assign current_variant = product.selected_or_first_available_variant -%}
                {%- assign has_variants = false -%}
                {%- if product.variants.size > 1 -%}
                  {%- assign has_variants = true -%}
                {%- endif -%}
                <article
                  class="u-card"
                  data-upsell-card
                  data-collections="{% for collection in product.collections %}{{ collection.handle }}{% unless forloop.last %},{% endunless %}{% endfor %}"
                >
                  <a href="{{ product.url }}" class="u-img">
                    {%- if product.featured_image != blank -%}
                      {{ product.featured_image | image_url: width: 320 | image_tag: loading: 'lazy', alt: product.title }}
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'u-img-placeholder' }}
                    {%- endif -%}
                  </a>
                  <div class="u-content">
                    <div class="u-title">{{ product.title }}</div>
                    <div class="m-val">{{ current_variant.price | money }}</div>
                  </div>

                  {%- if product.available == false -%}
                    <button class="u-add" type="button" disabled style="color: #666; background: transparent; cursor: not-allowed; border-top: 1px solid rgba(255,255,255,0.08);">已售完</button>
                  {%- elsif has_variants -%}
                    <button class="u-add" type="button" data-open-variant-modal="{{ product.id }}" data-product-title="{{ product.title | escape }}">選擇規格</button>
                    <script type="application/json" id="v2-json-{{ product.id }}">
                      [
                        {%- for v in product.variants -%}
                          {
                            "id": {{ v.id }},
                            "title": {{ v.title | json }},
                            "price": {{ v.price | divided_by: 100.0 }},
                            "display_price": {{ v.price | money | json }},
                            "img": "{{ v.featured_image | image_url: width: 300 | default: product.featured_image | image_url: width: 300 }}"
                          }{%- unless forloop.last -%},{%- endunless -%}
                        {%- endfor -%}
                      ]
                    </script>
                  {%- else -%}
                    <button class="u-add" type="button" data-variant-id="{{ current_variant.id }}">加入購物車</button>
                  {%- endif -%}
                </article>
              {%- endfor -%}
              {%- if block.settings.collection.products.size == 0 -%}
                <p style="color: #666; font-size: 12px; padding: 10px;">此分類目前無商品。</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
      </section>
    </div>

    <div class="cv-col cv-col--right">
      <section data-block="invoice" class="cv-card">
      <div class="cv-label cv-label--accent">發票設定 (E-INVOICE)</div>
      <div class="i-tabs" data-invoice-custom-tabs>
        <button type="button" class="i-chip is-active" data-invoice-type="personal">個人發票</button>
        <button type="button" class="i-chip" data-invoice-type="company">公司統編</button>
        {% if section.settings.show_invoice_mobile %}
          <button type="button" class="i-chip" data-invoice-type="mobile">手機載具</button>
        {% endif %}
        {% if section.settings.show_invoice_donate %}
          <button type="button" class="i-chip" data-invoice-type="donate">捐贈碼</button>
        {% endif %}
      </div>
      <div class="i-content" data-invoice-content>已選擇個人雲端發票，將寄送至 Email。</div>
      </section>

      <section class="cv-card cart-shell-v2__ako-native-zone" data-ako-native-zone aria-label="AKO 本尊（測試用）">
        <div class="cv-label cv-label--accent">AKO 本尊（測試用）</div>
        <p class="cart-shell-v2__ako-native-hint">可關閉下方區塊，測試上方自訂發票 UI 是否正常。</p>
        <button type="button" class="cart-shell-v2__ako-native-toggle" data-ako-native-toggle aria-expanded="true">隱藏 AKO 本尊</button>
        <div class="cart-shell-v2__invoice-ako-host" data-invoice-ako-host data-invoice-ako-hidden aria-hidden="true"></div>
      </section>

      <section data-block="shipping" class="cv-card">
      <div class="cv-label">收件資訊預填</div>

      <!-- 共用欄位：姓名、電話（跨宅配/超商共用，與舊版行為一致） -->
      <div class="s-row">
        <label class="s-label">收件人姓名 <span style="color:var(--dt-signal-orange)">*</span></label>
        <input class="cv-input" id="v2-shared-name" autocomplete="name" placeholder="例：王小明">
      </div>
      <div class="s-row">
        <label class="s-label">聯絡電話 <span style="color:var(--dt-signal-orange)">*</span></label>
        <input class="cv-input" id="v2-shared-phone" type="tel" inputmode="tel" autocomplete="tel-national" placeholder="例：0912345678">
      </div>

      <div class="s-tabs">
        <button type="button" class="s-tab is-active" data-shipping-tab="home">宅配到府</button>
        <button type="button" class="s-tab" data-shipping-tab="cvs">超商取貨</button>
        {% if section.settings.show_pickup_tab %}
          <button type="button" class="s-tab" data-shipping-tab="pickup">自取</button>
        {% endif %}
      </div>
      <div class="s-pane is-active" data-shipping-pane="home">
        <div class="s-row s-grid">
          <div>
            <label class="s-label">縣市</label>
            <select class="cv-input cv-input--select" id="v2-receiver-city" data-v2-county>
              <option value="">請選擇</option>
              <option>臺北市</option>
              <option>新北市</option>
              <option>基隆市</option>
              <option>桃園市</option>
              <option>新竹市</option>
              <option>新竹縣</option>
              <option>苗栗縣</option>
              <option>臺中市</option>
              <option>彰化縣</option>
              <option>南投縣</option>
              <option>雲林縣</option>
              <option>嘉義市</option>
              <option>嘉義縣</option>
              <option>臺南市</option>
              <option>高雄市</option>
              <option>屏東縣</option>
              <option>宜蘭縣</option>
              <option>花蓮縣</option>
              <option>臺東縣</option>
              <option>澎湖縣</option>
              <option>金門縣</option>
              <option>連江縣</option>
            </select>
          </div>
          <div>
            <label class="s-label">區域</label>
            <select class="cv-input cv-input--select" id="v2-receiver-district" data-v2-district disabled>
              <option value="">請先選縣市</option>
            </select>
            <div class="cart-shell-v2__zip-hint" id="v2-receiver-zip-wrap">郵遞區號：<span id="v2-receiver-zip-value">—</span></div>
          </div>
        </div>
        <div class="s-row">
          <label class="s-label">詳細地址</label>
          <input class="cv-input" id="v2-receiver-address1">
        </div>
      </div>
      <div class="s-pane" data-shipping-pane="cvs">
        <p class="cart-shell-v2__cvs-hint">請先選擇縣市、區域，系統將依此顯示附近超商門市；下方可填寫路名或門市名稱。</p>
        <div class="s-row s-grid">
          <div>
            <label class="s-label">縣市</label>
            <select class="cv-input cv-input--select" id="v2-cvs-city" data-v2-cvs-county>
              <option value="">請選擇</option>
              <option>臺北市</option>
              <option>新北市</option>
              <option>基隆市</option>
              <option>桃園市</option>
              <option>新竹市</option>
              <option>新竹縣</option>
              <option>苗栗縣</option>
              <option>臺中市</option>
              <option>彰化縣</option>
              <option>南投縣</option>
              <option>雲林縣</option>
              <option>嘉義市</option>
              <option>嘉義縣</option>
              <option>臺南市</option>
              <option>高雄市</option>
              <option>屏東縣</option>
              <option>宜蘭縣</option>
              <option>花蓮縣</option>
              <option>臺東縣</option>
              <option>澎湖縣</option>
              <option>金門縣</option>
              <option>連江縣</option>
            </select>
          </div>
          <div>
            <label class="s-label">區域</label>
            <select class="cv-input cv-input--select" id="v2-cvs-district" data-v2-cvs-district disabled>
              <option value="">請先選縣市</option>
            </select>
            <div class="cart-shell-v2__zip-hint" id="v2-cvs-zip-wrap">郵遞區號：<span id="v2-cvs-zip-value">—</span></div>
          </div>
        </div>
        <div class="s-row">
          <label class="s-label">詳細地址</label>
          <input class="cv-input" id="v2-cvs-store" placeholder="路名或門市名稱（選填）">
        </div>
      </div>
      {% if section.settings.show_pickup_tab %}
      <div class="s-pane" data-shipping-pane="pickup">
        <p class="cart-shell-v2__pickup-notice">自取選項僅能透過<strong>信用卡</strong>付款，請於結帳時選擇信用卡支付。</p>
        {% assign pickup_addr = section.settings.pickup_address | strip %}
          {% assign pickup_hrs = section.settings.pickup_hours | strip %}
          {% assign pickup_nt = section.settings.pickup_note | strip %}
          {% assign pickup_placeholder = '（選填）' %}
          {% if section.settings.pickup_heading != blank or pickup_addr != blank and pickup_addr != pickup_placeholder or pickup_hrs != blank and pickup_hrs != pickup_placeholder or pickup_nt != blank and pickup_nt != pickup_placeholder %}
          <div class="cart-shell-v2__pickup-info">
            {% if section.settings.pickup_heading != blank %}
              <div class="cart-shell-v2__pickup-heading">{{ section.settings.pickup_heading | escape }}</div>
            {% endif %}
            {% if pickup_addr != blank and pickup_addr != pickup_placeholder %}
              <div class="cart-shell-v2__pickup-address">{{ pickup_addr | escape }}</div>
            {% endif %}
            {% if pickup_hrs != blank and pickup_hrs != pickup_placeholder %}
              <div class="cart-shell-v2__pickup-hours">營業時間：{{ pickup_hrs | escape }}</div>
            {% endif %}
            {% if pickup_nt != blank and pickup_nt != pickup_placeholder %}
              <div class="cart-shell-v2__pickup-note">{{ pickup_nt | escape }}</div>
            {% endif %}
          </div>
        {% endif %}
      </div>
      {% endif %}
      </section>

      {% render 'cart-subtotal-v2', section: section %}
    </div>
  </main>

  <section data-block="sticky">
    <footer class="f-wrap">
      <div class="f-total">
        <div class="f-label">{{ section.settings.sticky_total_label | escape }}</div>
        <div class="f-price" data-cart-total-price>{{ cart.total_price | money }}</div>
      </div>
      <div class="f-actions" data-sticky-cta-host>
        <button type="button" class="f-btn" data-checkout-trigger>
          {{ section.settings.checkout_label | escape }}
        </button>
      </div>
    </footer>
  </section>

  <section data-block="popup">
    <div class="p-overlay" data-close-popup></div>
    <div class="p-sheet">
      <div class="p-head">
        <div><strong>{{ section.settings.popup_title | escape }}</strong></div>
        <button type="button" class="p-close" data-close-popup>×</button>
      </div>
      <div class="p-tabs">
        {%- for block in popup_blocks -%}
          {%- if block.settings.collection != blank and block.settings.show_in_popup -%}
            <button
              type="button"
              class="p-tab{% if forloop.first %} is-active{% endif %}"
              data-collection="{{ block.settings.collection.handle }}"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.label | escape }}
            </button>
          {%- endif -%}
        {%- endfor -%}
      </div>
      <div class="p-body">
        <div class="p-grid" data-popup-grid>
          {%- if popup_blocks == blank -%}
            <div class="cart-shell-v2__host-placeholder">請先設定 popup collections。</div>
          {%- endif -%}
        </div>
        {%- for block in popup_blocks -%}
          {%- if block.settings.collection != blank and block.settings.show_in_popup -%}
            <template data-popup-template="{{ block.settings.collection.handle }}">
              {% assign available_products = block.settings.collection.products | where: 'available', true %}
              {% assign sold_out_products = block.settings.collection.products | where: 'available', false %}
              {% assign sorted_products = available_products | concat: sold_out_products %}
              {%- for product in sorted_products limit: section.settings.popup_products_limit -%}
                {%- assign current_variant = product.selected_or_first_available_variant -%}
                {%- assign has_variants = false -%}
                {%- if product.variants.size > 1 -%}
                  {%- assign has_variants = true -%}
                {%- endif -%}

                {% comment %} 🌟 樣式統一：全場使用 u-card 樣式 🌟 {% endcomment %}
                <article class="u-card">
                  <a href="{{ product.url }}" class="u-img">
                    {%- if product.featured_image != blank -%}
                      {{
                        product.featured_image
                        | image_url: width: 320
                        | image_tag: loading: 'lazy', alt: product.title
                      }}
                    {%- else -%}
                      {{ 'product-1' | placeholder_svg_tag: 'u-img-placeholder' }}
                    {%- endif -%}
                  </a>
                  <div class="u-content">
                    <div class="u-title">{{ product.title }}</div>
                    <div class="m-val">{{ current_variant.price | money }}</div>
                  </div> {% comment %} 👈 關鍵修復：u-content 在這裡提早結束，不包住按鈕 {% endcomment %}

                  {%- if product.available == false -%}
                    <button type="button" class="u-add" disabled style="color: #666; background: transparent; cursor: not-allowed; border-top: 1px solid rgba(255,255,255,0.08);">已售完</button>
                  {%- elsif has_variants -%}
                    <button type="button" class="u-add" data-open-variant-modal="{{ product.id }}" data-product-title="{{ product.title | escape }}">選擇規格</button>
                    <script type="application/json" id="v2-json-{{ product.id }}">
                      [
                        {%- for v in product.variants -%}
                          {
                            "id": {{ v.id }},
                            "title": {{ v.title | json }},
                            "price": {{ v.price | divided_by: 100.0 }},
                            "display_price": {{ v.price | money | json }},
                            "img": "{{ v.featured_image | image_url: width: 300 | default: product.featured_image | image_url: width: 300 }}"
                          }{%- unless forloop.last -%},{%- endunless -%}
                        {%- endfor -%}
                      ]
                    </script>
                  {%- else -%}
                    <button type="button" class="u-add" data-variant-id="{{ current_variant.id }}">加入購物車</button>
                  {%- endif -%}
                </article>
              {%- endfor -%}
            </template>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </section>

  {% comment %} Bottom Sheet 置於最外層，脫離父層疊上下文，避免被吸底結帳蓋住 {% endcomment %}
  <div id="mission-detail-modal-{{ section.id }}" class="m-bottom-sheet" data-mission-modal aria-hidden="true">
