        <div class="m-detail-modal-icon" data-mission-modal-icon></div>
        <h2 class="m-detail-modal-title" data-mission-modal-title></h2>
        {% comment %} 動態顯示「已達成」或「差 $XXX」 {% endcomment %}
        <div class="m-detail-modal-status" data-mission-modal-status></div>
        <p class="m-detail-modal-desc" data-mission-modal-desc></p>
        <button type="button" class="m-bottom-sheet-btn" data-mission-modal-close>確認目標</button>
      </div>
    </div>
  </div>

  <div id="mission-all-modal-{{ section.id }}" class="m-bottom-sheet" data-mission-all-modal aria-hidden="true">
    <div class="m-bottom-sheet-backdrop" data-mission-all-modal-close></div>
    <div class="m-bottom-sheet-content m-all-sheet-content">
      <div class="m-bottom-sheet-drag-handle"></div>
      <button type="button" class="m-bottom-sheet-close" data-mission-all-modal-close aria-label="關閉">
        <svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12" stroke-width="2"></path></svg>
      </button>
      <div class="m-bottom-sheet-body">
        <div class="cv-label cv-label--accent" style="margin-bottom: 1.5rem;">MISSION ROADMAP</div>
        <div class="m-timeline-list">
          {% for block in reward_blocks %}
            {%- liquid
              assign threshold_cents = block.settings.threshold_amount | times: 100
              assign rtype = block.settings.reward_type | default: 'standard'
              assign is_unlocked = false

              if rtype == 'standard' or rtype == 'gift'
                if cart.total_price >= threshold_cents
                  assign is_unlocked = true
                endif
              elsif rtype == 'free_shipping'
                assign has_shipping_discount = false
                for disc in cart.discount_applications
                  if disc.target_type == 'shipping_line'
                    assign has_shipping_discount = true
                    break
                  endif
                endfor
                if has_shipping_discount or cart.total_price >= threshold_cents
                  assign is_unlocked = true
                endif
              elsif rtype == 'order_discount'
                if cart.total_price >= threshold_cents
                  assign is_unlocked = true
                endif
              endif

              assign gap_cents = threshold_cents | minus: cart.total_price
              if gap_cents < 0
                assign gap_cents = 0
              endif
            -%}
            <div class="m-timeline-row {% if is_unlocked %}is-unlocked{% else %}is-locked{% endif %}">
              <div class="m-timeline-node"></div>
              <div class="m-timeline-thumb m-reward-thumb--{% if rtype == 'gift' %}gift{% else %}service{% endif %}">
                {%- if block.settings.icon_image != blank -%}
                  {{ block.settings.icon_image | image_url: width: 80 | image_tag: loading: 'lazy', alt: block.settings.title }}
                {%- elsif rtype == 'gift' and block.settings.gift_product != blank and block.settings.gift_product.featured_image != blank -%}
                  {{ block.settings.gift_product.featured_image | image_url: width: 80 | image_tag: loading: 'lazy', alt: block.settings.gift_product.title }}
                {%- else -%}
                  <span class="m-reward-fallback">{{ block.settings.icon_fallback | escape }}</span>
                {%- endif -%}
              </div>
              <div class="m-timeline-info">
                <div class="m-timeline-title">{{ block.settings.title | escape }}</div>
                <div class="m-timeline-status">
                  {% if is_unlocked %}
                    <span style="color: #ea580c;">[ 任務達成 ]</span>
                  {% else %}
                    <span>需滿 {{ threshold_cents | money }}</span>
                    <span style="color: #fb923c; margin-left: 6px;">(差 {{ gap_cents | money }})</span>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>

