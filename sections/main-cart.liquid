<!-- 重構後的購物車商品組件 -->
<cart-items-component
  class="cart-items-component"
  data-section-id="{{ section.id }}"
>
  <div class="section-background color-{{ section.settings.color_scheme }}"></div>
  <div class="section color-{{ section.settings.color_scheme }} section--{{ section.settings.section_width }}">
    <div
      class="cart-page spacing-style{% if cart.empty? %} cart-page--empty{% endif %}"
      style="{% render 'spacing-style', settings: section.settings %}"
    >
      <div class="cart-page__items">
        <div class="cart-products-header">
          <div class="cart-products-header__main">
            <h4 class="cart-products-title">{{ section.settings.title | escape }}</h4>
          </div>
          {% if section.settings.show_item_count %}
            <div class="cart-products-count">
              {{ cart.item_count }} ITEMS
            </div>
          {% endif %}
        </div>
        {%- content_for 'block', id: 'cart-page-items', type: '_cart-products' %}
      </div>
    </div>
  </div>
</cart-items-component>

{% stylesheet %}
        /* ========================================
           AKO 風格購物車 - 重構版 v5.1
           ======================================== */

        :root {
          /* 顏色變量 */
          --cart-bg-primary: linear-gradient(145deg, #1a1a1a, #2d2d2d);
          --cart-accent: linear-gradient(135deg, #ff6b35, #f7931e);
          --cart-accent-color: #ff6b35;
          --cart-text-primary: #ffffff;
          --cart-text-secondary: #888888;
          --cart-border: #333333;

          /* 間距變量 */
          --cart-padding: 16px 20px;
          --cart-radius: 20px;
          --cart-gap: 12px;

          /* 響應式斷點 */
          --mobile: 768px;
          --tablet: 1024px;
          --desktop: 1440px;
        }

        /* ========================================
           主容器樣式 - 修復版
           ======================================== */
        .cart-items.spacing-style.cart-items--dividers {
          background: var(--cart-bg-primary);
          border-radius: var(--cart-radius);
          box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5),
                      inset 0 1px 0 rgba(255, 255, 255, 0.1);
          border: 1px solid var(--cart-border);
          padding: 0; /* 移除內邊距讓表格可以延伸到邊緣 */
          margin: 20px auto;
          max-width: 1200px;
          width: 100%;
          position: relative;
          overflow: hidden;
        }

        /* 頂部橘色裝飾線 */
        .cart-items.spacing-style.cart-items--dividers::before {
          content: '';
          position: absolute;
          top: 0;
          left: 0;
          right: 0;
          height: 3px;
          background: var(--cart-accent);
        }


        /* ========================================
           標題區塊
           ======================================== */
           @media screen and (min-width: 769px) {
        .cart-products-header {
          max-width: 1200px !important;
          margin: 0 auto 20px auto !important;
          width: 100% !important;
          box-sizing: border-box !important;
        }
      }

        .cart-products-header {
          display: grid;
          grid-template-columns: 1fr auto;
          gap: var(--cart-gap);
          align-items: center;
        }

        .cart-products-title {
          font-size: 18px;
          font-weight: 600;
          color: var(--cart-text-primary);
          position: relative;
          padding-left: 12px;
          overflow: hidden;
          text-overflow: ellipsis;
          white-space: nowrap;
        }

        /* 標題左側裝飾條 */
        .cart-products-title::before {
          content: '';
          position: absolute;
          left: 0;
          top: 50%;
          transform: translateY(-50%);
          width: 3px;
          height: 20px;
          background: var(--cart-accent);
          border-radius: 2px;
        }

        /* ========================================
           表格結構 - 修復版
           ======================================== */
        .cart-items__table {
          width: 100%;
          background: transparent;
          border-collapse: collapse;
          table-layout: auto;
          margin: 0; /* 移除負邊距 */
        }

        /* 隱藏表格標題和表頭 */
        .cart-items__table caption,
        .cart-items__table thead {
          display: none;
        }

        /* 商品行樣式 - 修復懸停背景 */
        .cart-items__table-row {
          background: transparent;
          border-bottom: 1px solid var(--cart-border);
          transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
          position: relative;
          animation: fadeInUp 0.6s ease-out both;
        }

        /* 使用負 margin-top 將除第一個以外的所有行向上拉 1px，以抵消邊框造成的空缺 */
        .cart-items__table-row:not(:first-child) {
          margin-top: -1px;
        }

        .cart-items__table-row:last-child {
          border-bottom: none;
        }

        /* 使用偽元素實現全寬懸停背景 */
        .cart-items__table-row::after {
          content: '';
          position: absolute;
          top: 0; /* 移除-8px的偏移，使其与行顶部对齐 */
          left: 0; /* 向左延伸超出容器 */
          right: 0; /* 向右延伸超出容器 */
          bottom: 0;
          background: linear-gradient(90deg, rgba(255, 107, 53, 0.05), rgba(247, 147, 30, 0.05));
          opacity: 0;
          transition: opacity 0.3s ease;
          pointer-events: none;
          z-index: 0;
        }

        .cart-items__table-row:hover::after {
          opacity: 1;
        }

        /* 左側懸停指示條 - 調整位置 */
        .cart-items__table-row::before {
          content: '';
          position: absolute;
          left: 0; /* 貼著左邊緣 */
          top: 50%;
          transform: translateY(-50%);
          width: 3px;
          height: 0;
          background: var(--cart-accent);
          transition: height 0.3s ease;
          border-radius: 0 2px 2px 0; /* 只有右側圓角 */
          z-index: 2;
        }

        .cart-items__table-row:hover::before {
          height: 100%; /* 改為 100% 防止溢出 */
          top: 50%; /* 恢復垂直居中 */
        }

        /* 表格單元格 - 確保內容在背景之上 */
        .cart-items__table-row td {
          padding: 20px 12px;
          vertical-align: middle;
          background: transparent;
          border: none;
          position: relative;
          z-index: 1;
        }

        /* 第一個單元格額外左內邊距 */
        .cart-items__table-row td:first-child {
          padding-left: 20px;
        }

        /* 最後一個單元格額外右內邊距 */
        .cart-items__table-row td:last-child {
          padding-right: 20px;
        }

        /* ========================================
           商品圖片
           ======================================== */
        .cart-items__media {
          width: 120px;
          padding-right: 8px;
        }

        .cart-items__media-container {
          width: 90px;
          height: 90px;
          display: block;
          border-radius: 12px;
          overflow: hidden;
          position: relative;
          transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .cart-items__media-image {
          width: 100%;
          height: 100%;
          object-fit: cover;
          transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* 圖片懸停放大效果 */
        .cart-items__table-row:hover .cart-items__media-image {
          transform: scale(1.1);
        }

        /* ========================================
           商品詳情
           ======================================== */
        .cart-items__details {
          width: auto;
          padding: 20px 16px 20px 24px;
          min-width: 350px;
        }

        /* 商品標題 */
        .cart-items__title {
          font-size: 16px;
          font-weight: 600;
          color: var(--cart-text-primary);
          text-decoration: none;
          transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
          position: relative;
          display: inline-block;
          line-height: 1.4;
        }

        /* 標題底線動畫 */
        .cart-items__title::after {
          content: '';
          position: absolute;
          bottom: -2px;
          left: 0;
          width: 0;
          height: 2px;
          background: var(--cart-accent);
          transition: width 0.3s ease;
        }

        .cart-items__title:hover {
          color: var(--cart-accent-color);
          text-shadow: 0 0 20px rgba(255, 107, 53, 0.5);
        }

        .cart-items__title:hover::after {
          width: 100%;
        }

        /* 商品規格標籤 */
        .cart-items__variant {
          display: inline-block;
          background: linear-gradient(135deg, #2a1810, #1a1a1a);
          padding: 4px 12px;
          border-radius: 20px;
          border: 1px solid var(--cart-accent-color);
          font-size: 12px;
          margin: 4px 4px 4px 0;
        }

        .cart-items__variant dt {
          display: inline;
          color: var(--cart-text-secondary);
          margin-right: 4px;
        }

        .cart-items__variant dd {
          display: inline;
          color: #e0e0e0;
          margin: 0;
        }

        /* 單價樣式 - 橘色漸變 */
        .cart-items__details > div:last-child {
          color: #cccccc !important;
          font-size: 14px !important;
          margin-top: 8px !important;
        }

        .cart-items__details > div:last-child .visually-hidden + span {
          background: linear-gradient(135deg, #ff6b35, #f7931e) !important;
          -webkit-background-clip: text !important;
          -webkit-text-fill-color: transparent !important;
          background-clip: text !important;
          font-weight: 700 !important;
          font-size: 16px !important;
        }

        /* ========================================
           數量選擇器
           ======================================== */


        /* 數量選擇器容器 */
        quantity-selector-component.quantity-selector.cart-primary-typography,
        .quantity-selector.cart-primary-typography quantity-selector-component {
          display: flex;
          align-items: center;
          justify-content: space-between;
          background: linear-gradient(145deg, #2d2d2d, #1a1a1a);
          border: 2px solid #404040;
          border-radius: 12px;
          overflow: hidden;
          box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3),
                      inset 0 1px 0 rgba(255, 255, 255, 0.05);
          transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
          width: 160px;
          height: 44px;
        }

        /* 數量選擇器懸停效果 */
        quantity-selector-component.quantity-selector.cart-primary-typography:hover,
        .quantity-selector.cart-primary-typography quantity-selector-component:hover {
          border-color: var(--cart-accent-color);
          box-shadow: 0 8px 25px rgba(255, 107, 53, 0.3),
                      inset 0 1px 0 rgba(255, 255, 255, 0.1);
        }

        /* 增減按鈕 */
        .button.quantity-minus.button-unstyled,
        .button.quantity-plus.button-unstyled {
          background: transparent;
          border: none;
          color: var(--cart-text-secondary);
          width: 44px;
          height: 44px;
          display: flex;
          align-items: center;
          justify-content: center;
          cursor: pointer;
          transition: all 0.3s ease;
        }

        .button.quantity-minus.button-unstyled:hover,
        .button.quantity-plus.button-unstyled:hover {
          background: rgba(255, 107, 53, 0.1);
          color: var(--cart-accent-color);
        }

        /* 數量輸入框 */
        quantity-selector-component input[type="number"],
        .quantity-selector input[type="number"] {
          background: transparent;
          border: none;
          border-left: 1px solid #404040;
          border-right: 1px solid #404040;
          color: var(--cart-text-primary);
          text-align: center;
          width: 72px;
          height: 44px;
          font-size: 16px;
          font-weight: 600;
        }

        /* 移除數字輸入框的箭頭 */
        quantity-selector-component input[type="number"]::-webkit-outer-spin-button,
        quantity-selector-component input[type="number"]::-webkit-inner-spin-button {
          -webkit-appearance: none;
          margin: 0;
        }

        /* 總價樣式 - 橘色漸變 */
        .cart-items__price text-component,
        .cart-items__price.cart-secondary-typography,
        .cart-secondary-typography {
          width: 110px !important;
          font-size: 18px !important;
          font-weight: 700 !important;
          color: var(--cart-accent-color) !important;
          text-shadow: 0 0 20px rgba(255, 107, 53, 0.5) !important;
          background: var(--cart-accent) !important;
          -webkit-background-clip: text !important;
          -webkit-text-fill-color: transparent !important;
          background-clip: text !important;
        }



  /* ========================================
     響應式設計 - 手機版保持原樣
     ======================================== */
  @media (max-width: 768px) {
    /* 修復容器溢出 - 調整為與推薦加購商品區塊相同寬度 */
    .cart-items.spacing-style.cart-items--dividers {
      margin: 12px 0 !important;
      border-radius: 16px !important;
      overflow-x: hidden !important;
      width: 100% !important;
      box-sizing: border-box !important;
    }

    /* 頂部橘色線條在手機版也要正確顯示 */
    .cart-items.spacing-style.cart-items--dividers::before {
      border-radius: 16px 16px 0 0 !important;  /* 配合手機版圓角 */
    }

    /* 標題區塊手機版調整 */
    .cart-products-header {
      flex-direction: column !important;
      gap: 12px !important;
      align-items: flex-start !important;
    }

    .cart-products-title {
      font-size: 18px !important;
    }

    /* 手機版表格調整 */
    .cart-items__table {
      margin: 0 !important;  /* 負 margin 讓表格延伸 */
      /* width: calc(100% + 32px) !important; */
      padding-right: 12px !important;  /* 右側內距 */
    }

    /* 移除表格最小寬度限制 */
    .cart-items__table {
      min-width: unset !important;
      table-layout: fixed !important;
    }

    /* 應用新的 Grid 佈局來實現 左-中-右 三欄結構 */
    .cart-items__table-row {
      display: grid !important;
      /* 圖片列改為自動寬度，由圖片容器決定 */
      grid-template-columns: auto 1fr auto !important; /* 左(自動) | 中(自動) | 右(自動) */
      grid-template-areas:
        'media details quantity'
        'media details price' !important;
      align-items: center !important;
      gap: 0 8px !important; /* 列間距縮小為 8px */
      padding: 12px 0 12px 8px !important; /* 將左側內邊距應用於整行 */
    }

    .cart-items__table-row td {
      padding: 0 !important; /* 重置內邊距 */
      width: auto !important; /* 重置寬度 */
    }

    /* --- Grid 區域分配 --- */
    .cart-items__media {
      grid-area: media !important;
      /* padding-left 已移至父元素 .cart-items__table-row */
      width: auto !important;
    }
    .cart-items__media-container {
      width: 70px !important; /* 圖片容器固定為 70px */
      height: 70px !important;
      border-radius: 10px !important; /* 保持圓角 */
    }
    .cart-items__details {
      grid-area: details !important;
      min-width: 0; /* 允許收縮 */
    }
    .cart-items__quantity {
      grid-area: quantity !important;
      align-self: end; /* 垂直靠下 */
      padding-bottom: 4px !important;
    }
    .cart-items__price {
      grid-area: price !important;
      align-self: start; /* 垂直靠上 */
      padding-top: 4px !important;
    }

    /* --- 右側欄樣式 --- */
    .cart-items__quantity, .cart-items__price {
      text-align: right !important;
      padding-right: 10px !important; /* 右側內邊距改為 10px */
    }

    /* 保持原有樣式 */
    tr {
        position: relative;
        transition: all 0.3s ease;
        box-shadow:
            inset 3px 0 0 0 transparent,
            inset 0 0 0 0 transparent;
    }

    tr:hover {
        background-color: rgba(255, 107, 53, 0.03);
        box-shadow:
            inset 3px 0 0 0 #ff6b35,
            inset 0 0 0 0 transparent;
    }

    .cart-items__table-row::before {
      display: none !important;
    }

    .cart-items__title {
      font-size: 14px !important;
      line-height: 1.3 !important;
      display: block !important;
      margin-bottom: 6px !important;
      white-space: normal !important;
      word-wrap: break-word !important;
      max-width: 100% !important;
    }

    .cart-items__variant {
      font-size: 11px !important;
    }

    .cart-items__details > div:last-child {
      font-size: 13px !important;
    }

    quantity-selector-component.quantity-selector.cart-primary-typography,
    .quantity-selector.cart-primary-typography quantity-selector-component {
      width: 130px !important;
      height: 40px !important;
      margin-left: auto; /* 靠右對齊 */
    }

    .cart-items__remove {
      display: none !important;
    }

    .cart-items__price text-component,
    .cart-secondary-typography {
      font-size: 17px !important;
    }

    /* 價格文字 - 加大字體 */
    .cart-items__price text-component,
    .cart-secondary-typography {
      font-size: 17px !important;
      display: block !important;
      white-space: nowrap !important;
      overflow: hidden !important;
      text-overflow: ellipsis !important;
    }

    /* 手機版特別優化 - 價格區域延伸到最右邊 */
    .cart-items__price.cart-secondary-typography {
      padding-right: 12px !important;  /* 增加右內距 */
      width: auto !important;
      min-width: 100px !important;
    }
    .cart-items__table-row::after {
          content: '';
          position: absolute;
          top: 0px;
          left: 0; /* 向左延伸超出容器 */
          right: 0; /* 向右延伸超出容器 */
          bottom: 0;
          background: linear-gradient(90deg, rgba(255, 107, 53, 0.05), rgba(247, 147, 30, 0.05));
          opacity: 0;
          transition: opacity 0.3s ease;
          pointer-events: none;
          z-index: 0;
        }
  }

  /* 更小的手機 - 圖片放大版 */
  @media (max-width: 480px) {
    .cart-items.spacing-style.cart-items--dividers {
      margin: 8px 0 !important;
      border-radius: 12px !important;
      width: 100% !important;
    }

    .cart-products-header {
      margin-bottom: 8px !important;
    }

    .cart-products-title {
      font-size: 16px !important;
    }

    .cart-products-title::before {
      height: 16px !important;
    }

    .cart-items__table {
      /* margin: 0 -12px !important; */
      /* width: calc(100% + 24px) !important; */
      padding-right: 8px !important;
    }

    .cart-items__table-row td {
      padding: 10px 2px !important;
    }

    /* 更小的圖片 - 但仍比原版大 */
    .cart-items__media {
      width: 90px !important; /* 從55px增加到90px */
      padding-left: 6px !important;
    }

    .cart-items__media-container {
      width: 90px !important; /* 從48px增加到80px */
      height: 90px !important; /* 從48px增加到80px */
      border-radius: 8px !important;
    }

    /* 更緊湊的文字 - 自動調整 */
    .cart-items__details {
      padding: 10px 4px !important;
      width: auto !important;
    }

    .cart-items__title {
      font-size: 13px !important;
      line-height: 1.2 !important;
    }

    .cart-items__variant {
      font-size: 10px !important;
      padding: 2px 6px !important;
    }

    .cart-items__details > div:last-child {
      font-size: 12px !important;
    }

    /* 數量選擇器 - 保持原始尺寸 */
    .cart-items__quantity {
      width: 120px !important;
      padding: 6px 2px !important;
      text-align: center !important;
    }

    quantity-selector-component.quantity-selector.cart-primary-typography,
    .quantity-selector.cart-primary-typography quantity-selector-component {
      width: 110px !important;
      height: 36px !important;
    }

    quantity-selector-component.quantity-selector.cart-primary-typography .button.quantity-minus.button-unstyled,
    quantity-selector-component.quantity-selector.cart-primary-typography .button.quantity-plus.button-unstyled,
    .quantity-selector.cart-primary-typography quantity-selector-component .button.quantity-minus.button-unstyled,
    .quantity-selector.cart-primary-typography quantity-selector-component .button.quantity-plus.button-unstyled {
      width: 36px !important;
      height: 36px !important;
    }

    quantity-selector-component.quantity-selector.cart-primary-typography input[type="number"],
    .quantity-selector.cart-primary-typography quantity-selector-component input[type="number"] {
      width: 38px !important; /* 110px - 72px = 38px */
      height: 36px !important;
      font-size: 14px !important;
    }

    /* 隱藏垃圾桶按鈕 */
    .cart-items__remove {
      display: none !important;
    }

    /* 價格 - 延伸到最右邊 */
    .cart-items__price {
      width: auto !important;
      min-width: 80px !important;
      padding-right: 4px !important;
      flex-grow: 1 !important;
    }

    .cart-items__price text-component,
    .cart-secondary-typography {
      font-size: 15px !important;
    }
  }

  /* iPhone SE 等超小螢幕 - 圖片放大版 */
  @media (max-width: 375px) {
    .cart-items__table-row td {
      padding: 8px 1px !important;
    }

    /* 移除表格縮放，改用更好的空間分配 */
    .cart-items__table {
      zoom: 1;
      -moz-transform: scale(1);
      -moz-transform-origin: 0 0;
    }

    .cart-items__media {
      width: 80px !important; /* 從48px增加到80px */
      padding-left: 4px !important;
    }

    .cart-items__media-container {
      width: 70px !important; /* 從44px增加到70px */
      height: 70px !important; /* 從44px增加到70px */
    }

    .cart-items__details {
      padding: 8px 3px !important;
      width: auto !important;
    }

    .cart-items__title {
      font-size: 12px !important;
    }

    .cart-items__variant {
      font-size: 9px !important;
      padding: 2px 5px !important;
    }

    /* 數量選擇器 - 優化空間使用 */
    .cart-items__quantity {
      width: 100px !important;
      padding: 4px 1px !important;
      text-align: center !important;
    }

    quantity-selector-component.quantity-selector.cart-primary-typography,
    .quantity-selector.cart-primary-typography quantity-selector-component {
      width: 100px !important;
      height: 34px !important;
      transform: scale(0.9) !important;
      margin: 0 -5px !important;
    }

    quantity-selector-component.quantity-selector.cart-primary-typography .button.quantity-minus.button-unstyled,
    quantity-selector-component.quantity-selector.cart-primary-typography .button.quantity-plus.button-unstyled,
    .quantity-selector.cart-primary-typography quantity-selector-component .button.quantity-minus.button-unstyled,
    .quantity-selector.cart-primary-typography quantity-selector-component .button.quantity-plus.button-unstyled {
      width: 34px !important;
      height: 34px !important;
    }

    quantity-selector-component.quantity-selector.cart-primary-typography input[type="number"],
    .quantity-selector.cart-primary-typography quantity-selector-component input[type="number"] {
      width: 32px !important; /* 100px - 68px = 32px */
      height: 34px !important;
      font-size: 13px !important;
    }

    /* 隱藏垃圾桶按鈕 */
    .cart-items__remove {
      display: none !important;
    }

    /* 價格區域延伸到最右邊 */
    .cart-items__price {
      width: auto !important;
      min-width: 70px !important;
      padding-right: 2px !important;
      flex-grow: 1 !important;
    }

    .cart-items__price text-component,
    .cart-secondary-typography {
      font-size: 14px !important;
    }
  }

        /* ========================================
           淡入動畫
           ======================================== */
        @keyframes fadeInUp {
          from {
            opacity: 0;
            transform: translateY(20px);
          }
          to {
            opacity: 1;
            transform: translateY(0);
          }
        }

        /* 動畫延遲 */
        .cart-items__table-row:nth-child(1) { animation-delay: 0.1s; }
        .cart-items__table-row:nth-child(2) { animation-delay: 0.2s; }
        .cart-items__table-row:nth-child(3) { animation-delay: 0.3s; }
        .cart-items__table-row:nth-child(4) { animation-delay: 0.4s; }
        .cart-items__table-row:nth-child(5) { animation-delay: 0.5s; }

        /* ========================================
           購物車頁面佈局
           ======================================== */
        .cart-page {
          display: grid;
          grid-template-columns: 1fr;
          gap: 0 var(--padding-5xl);
        }

        .cart-page--empty {
          display: flex;
          flex-direction: column;
          align-items: center;
          justify-content: center;
        }

        /* 桌面版佈局 */
        @media screen and (min-width: 750px) {
          .cart-page__summary {
            display: grid;
            height: 100%;
            grid-column: 2;
            grid-row: 1 / -1;
            align-self: stretch;
            grid-template-rows: subgrid;
            padding-top: 0;
            position: relative;
          }

          .section--page-width .cart-page:has(.cart__container--extend) {
            grid-column: 2 / 4;
            grid-template-columns: 1fr minmax(
                var(--sidebar-width),
                calc((100vw - var(--page-width)) / 2 + var(--sidebar-width))
              );
          }

          .cart__container--extend {
            height: 100%;
          }
        }


        /* ========================================
           刪除按鈕樣式（桌面版顯示）
           ======================================== */
        @media (min-width: 769px) {
          .cart-items__remove {
            background: transparent !important;
            border: 1px solid transparent !important;
            color: #888888 !important;
            padding: 6px !important;
            border-radius: 8px !important;
            cursor: pointer !important;
            transition: all 0.3s ease !important;
            margin-left: 8px !important;
          }

          .cart-items__remove:hover {
            background: rgba(244, 67, 54, 0.1) !important;
            border-color: #f44336 !important;
            color: #f44336 !important;
          }
        }

        /* ========================================
           確保所有文字顏色正確
           ======================================== */
        .cart-items.spacing-style.cart-items--dividers,
        .cart-items.spacing-style.cart-items--dividers * {
          color: #ffffff !important;
        }

        .cart-items.spacing-style.cart-items--dividers a {
          color: inherit !important;
        }

        /* ========================================
           視覺隱藏文字
           ======================================== */
        .visually-hidden {
          position: absolute !important;
          width: 1px !important;
          height: 1px !important;
          padding: 0 !important;
          margin: -1px !important;
          overflow: hidden !important;
          clip: rect(0, 0, 0, 0) !important;
          white-space: nowrap !important;
          border: 0 !important;
        }

        /* ========================================
           SVG 圖標優化
           ======================================== */
        .svg-wrapper {
          display: flex;
          align-items: center;
          justify-content: center;
          width: 14px;
          height: 14px;
        }

        .svg-wrapper svg {
          width: 14px;
          height: 14px;
          stroke: currentColor;
        }

        /* 隱藏滾動條 */
        html, body, .cart-items__table, .cart-items__wrapper {
          scrollbar-width: none; /* Firefox */
          -ms-overflow-style: none;  /* IE and Edge */
        }

        html::-webkit-scrollbar, body::-webkit-scrollbar, .cart-items__table::-webkit-scrollbar, .cart-items__wrapper::-webkit-scrollbar {
          display: none; /* Chrome, Safari, Opera */
        }

        /* ========================================
           APGO Cart UI override
           ======================================== */
        .cart-products-header {
          display: flex !important;
          justify-content: space-between !important;
          align-items: center !important;
          gap: 12px !important;
          margin-bottom: 12px !important;
        }

        .cart-products-header__main {
          min-width: 0;
        }

        .cart-products-title {
          font-size: 12px !important;
          letter-spacing: 1px !important;
          text-transform: uppercase !important;
          color: #999 !important;
          font-family: ui-monospace, SFMono-Regular, Menlo, monospace !important;
          padding-left: 0 !important;
        }

        .cart-products-title::before {
          display: none !important;
        }

        .cart-products-count {
          font-size: 12px;
          letter-spacing: 1px;
          text-transform: uppercase;
          color: #999;
          font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
          white-space: nowrap;
        }

        @media screen and (min-width: 1024px) {
          .cart-products-header {
            margin-bottom: 16px !important;
          }
        }
{% endstylesheet %}

