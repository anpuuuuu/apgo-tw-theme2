{% comment %}
  APGO 動態標題組件 - 完全獨立版本
  檔案位置: sections/apgo-dynamic-title.liquid
  使用獨立命名空間避免衝突
{% endcomment %}

<!-- 使用唯一的 wrapper 避免衝突 -->
<div class="apgo-unique-wrapper-{{ section.id }}" data-apgo-section="{{ section.id }}">
    <style>
      /* 所有樣式都使用唯一的前綴和 ID 選擇器 */
      .apgo-unique-wrapper-{{ section.id }} {
        /* CSS 變數定義 - 使用唯一前綴 */
        --apgo-{{ section.id }}-orange: {{ section.settings.primary_color }};
        --apgo-{{ section.id }}-orange-light: {{ section.settings.primary_color_light }};
        --apgo-{{ section.id }}-white: {{ section.settings.text_white }};
        --apgo-{{ section.id }}-gray: {{ section.settings.text_gray }};
        --apgo-{{ section.id }}-bg: {{ section.settings.dark_bg }};
        --apgo-{{ section.id }}-speed: {{ section.settings.animation_speed }}s;
        
        /* 重置此區塊內的所有元素 */
        all: initial;
        display: block;
        width: 100%;
        box-sizing: border-box;
      }
      
      /* 獨立的區塊樣式 */
      .apgo-unique-wrapper-{{ section.id }} .apgo-section-{{ section.id }} {
        /* 基本重置 */
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        
        /* 區塊樣式 */
        font-family: {{ section.settings.font_family }};
        background: var(--apgo-{{ section.id }}-bg);
        color: var(--apgo-{{ section.id }}-white);
        position: relative;
        overflow: hidden;
        min-height: 200px;
        display: block !important;
        visibility: visible !important;
        opacity: 1 !important;
        width: 100%;
        isolation: isolate; /* 創建新的堆疊上下文 */
      }
      
      /* 重置所有子元素 */
      .apgo-unique-wrapper-{{ section.id }} * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: inherit;
      }
  
      /* 背景裝飾 - 使用唯一類名 */
      {% if section.settings.show_bg_decoration %}
      .apgo-unique-wrapper-{{ section.id }} .apgo-bg-deco-{{ section.id }} {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        z-index: 0;
        pointer-events: none;
        overflow: hidden;
      }
  
      .apgo-unique-wrapper-{{ section.id }} .apgo-bg-deco-{{ section.id }}::before {
        content: '';
        position: absolute;
        top: -50%;
        right: -20%;
        width: 800px;
        height: 800px;
        background: radial-gradient(circle, 
          rgba(240, 132, 24, {{ section.settings.bg_decoration_opacity | divided_by: 100.0 }}) 0%, 
          transparent 70%);
        animation: apgo-float-{{ section.id }} {{ section.settings.bg_animation_duration }}s ease-in-out infinite;
      }
  
      .apgo-unique-wrapper-{{ section.id }} .apgo-bg-deco-{{ section.id }}::after {
        content: '';
        position: absolute;
        bottom: -30%;
        left: -10%;
        width: 600px;
        height: 600px;
        background: radial-gradient(circle, 
          rgba(240, 132, 24, {{ section.settings.bg_decoration_opacity | divided_by: 100.0 | times: 0.67 }}) 0%, 
          transparent 70%);
        animation: apgo-float-{{ section.id }} {{ section.settings.bg_animation_duration | times: 0.83 }}s ease-in-out infinite reverse;
      }
  
      /* 獨立的動畫定義 */
      @keyframes apgo-float-{{ section.id }} {
        0%, 100% { transform: translate(0, 0) rotate(0deg); }
        50% { transform: translate(30px, -20px) rotate(180deg); }
      }
      
      /* 手機版背景裝飾優化 */
      @media only screen and (max-width: 768px) {
        .apgo-unique-wrapper-{{ section.id }} .apgo-bg-deco-{{ section.id }}::before {
          width: 520px;
          height: 520px;
          opacity: 0.5;
        }
        .apgo-unique-wrapper-{{ section.id }} .apgo-bg-deco-{{ section.id }}::after {
          width: 420px;
          height: 420px;
          opacity: 0.4;
        }
      }
      {% endif %}
  
      /* 主容器 - 使用唯一類名 */
      .apgo-unique-wrapper-{{ section.id }} .apgo-container-{{ section.id }} {
        max-width: {{ section.settings.container_width }}px;
        margin: 0 auto;
        padding: {{ section.settings.section_padding_top }}px {{ section.settings.section_padding_horizontal }}px {{ section.settings.section_padding_bottom }}px;
        position: relative;
        z-index: 1;
        min-height: 100px;
        width: 100%;
      }
  
      /* 標題區 - 使用唯一類名 */
      .apgo-unique-wrapper-{{ section.id }} .apgo-header-{{ section.id }} {
        text-align: {{ section.settings.header_alignment }};
        margin-bottom: {{ section.settings.header_margin_bottom }}px;
        position: relative;
      }
  
      /* 主標題 - 使用唯一類名 */
      .apgo-unique-wrapper-{{ section.id }} .apgo-title-{{ section.id }} {
        font-size: {{ section.settings.title_font_size_desktop }}rem !important;
        font-weight: {{ section.settings.title_font_weight }} !important;
        letter-spacing: {{ section.settings.title_letter_spacing }}px !important;
        margin: 0 !important;
        padding: 0 !important;
        line-height: 1.2 !important;
        position: relative;
        display: block;
        {% if section.settings.title_gradient %}
        background: linear-gradient(135deg, 
          var(--apgo-{{ section.id }}-white) 0%, 
          var(--apgo-{{ section.id }}-orange) 100%) !important;
        -webkit-background-clip: text !important;
        background-clip: text !important;
        -webkit-text-fill-color: transparent !important;
        {% else %}
        color: var(--apgo-{{ section.id }}-white) !important;
        {% endif %}
      }
  
      {% if section.settings.show_title_badge %}
      .apgo-unique-wrapper-{{ section.id }} .apgo-title-{{ section.id }}::after {
        content: '{{ section.settings.title_badge_text | default: "apgo_dynamic_title.badge" | t }}';
        position: absolute;
        top: -15px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 0.8rem !important;
        letter-spacing: 5px !important;
        color: var(--apgo-{{ section.id }}-orange) !important;
        opacity: 0.5;
        font-weight: 400 !important;
        -webkit-text-fill-color: initial !important;
      }
      {% endif %}
  
      /* 副標題 - 使用唯一類名 */
      .apgo-unique-wrapper-{{ section.id }} .apgo-subtitle-{{ section.id }} {
        font-size: {{ section.settings.subtitle_font_size }}rem !important;
        color: var(--apgo-{{ section.id }}-gray) !important;
        font-weight: 300 !important;
        letter-spacing: 1px !important;
        opacity: 0.8;
        line-height: 1.5 !important;
        margin: 0 !important;
        padding: 0 !important;
      }
  
      /* 響應式設計 - 使用唯一選擇器 */
      @media only screen and (max-width: 768px) {
        .apgo-unique-wrapper-{{ section.id }} .apgo-section-{{ section.id }} {
          min-height: 0;
        }
        
        .apgo-unique-wrapper-{{ section.id }} .apgo-container-{{ section.id }} {
          min-height: 0;
          padding-top: clamp(16px, 4vw, 28px);
          padding-bottom: clamp(16px, 4vw, 28px);
          padding-left: clamp(12px, 4vw, 20px);
          padding-right: clamp(12px, 4vw, 20px);
        }
  
        .apgo-unique-wrapper-{{ section.id }} .apgo-title-{{ section.id }} {
          font-size: {{ section.settings.title_font_size_mobile }}rem !important;
        }
        
        .apgo-unique-wrapper-{{ section.id }} .apgo-header-{{ section.id }} {
          margin-bottom: max(16px, {{ section.settings.header_margin_bottom | divided_by: 2 }}px);
        }
      }
  
      @media only screen and (max-width: 480px) {
        .apgo-unique-wrapper-{{ section.id }} .apgo-title-{{ section.id }} {
          font-size: {{ section.settings.title_font_size_mobile | times: 0.8 }}rem !important;
        }
      }
      
      /* 防止外部樣式影響 */
      .apgo-unique-wrapper-{{ section.id }} h1,
      .apgo-unique-wrapper-{{ section.id }} p {
        all: unset;
        display: block;
      }
    </style>
  
    <!-- 主區塊容器 -->
    <section class="apgo-section-{{ section.id }}">
      <!-- 背景裝飾 -->
      {% if section.settings.show_bg_decoration %}
      <div class="apgo-bg-deco-{{ section.id }}" aria-hidden="true"></div>
      {% endif %}
  
      <!-- 主容器 -->
      <div class="apgo-container-{{ section.id }}">
        <!-- 標題區 -->
        {% if section.settings.show_header %}
        <div class="apgo-header-{{ section.id }}">
          <h1 class="apgo-title-{{ section.id }}">
            {{ section.settings.main_title | default: 'APGO 直播時程' }}
          </h1>
          {% if section.settings.subtitle != blank %}
          <p class="apgo-subtitle-{{ section.id }}">
            {{ section.settings.subtitle | default: '與專業團隊即時互動 · 掌握第一手產品資訊' }}
          </p>
          {% endif %}
        </div>
        {% else %}
        <!-- 預設內容 -->
        <div style="padding: 20px; text-align: center; color: {{ section.settings.text_white }};">
          <p style="color: inherit;">{{ 'apgo_dynamic_title.loaded' | t }}</p>
        </div>
        {% endif %}
      </div>
    </section>
  </div>
  
  {% schema %}
  {
    "name": "APGO 獨立標題組件",
    "class": "apgo-dynamic-title-standalone",
    "settings": [
      {
        "type": "header",
        "content": "🎨 顏色設定"
      },
      {
        "type": "color",
        "id": "primary_color",
        "label": "主要顏色",
        "default": "#f08418"
      },
      {
        "type": "color",
        "id": "primary_color_light",
        "label": "主要顏色 (淺)",
        "default": "#ff9a3c"
      },
      {
        "type": "color",
        "id": "text_white",
        "label": "白色文字",
        "default": "#ffffff"
      },
      {
        "type": "color",
        "id": "text_gray",
        "label": "灰色文字",
        "default": "#cccccc"
      },
      {
        "type": "color",
        "id": "dark_bg",
        "label": "深色背景",
        "default": "#000000"
      },
      {
        "type": "header",
        "content": "📐 版面設定"
      },
      {
        "type": "range",
        "id": "container_width",
        "label": "容器最大寬度",
        "min": 1000,
        "max": 1600,
        "step": 100,
        "default": 1400,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "section_padding_top",
        "label": "區塊上間距",
        "min": 20,
        "max": 120,
        "step": 10,
        "default": 60,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "section_padding_bottom",
        "label": "區塊下間距",
        "min": 20,
        "max": 120,
        "step": 10,
        "default": 60,
        "unit": "px"
      },
      {
        "type": "range",
        "id": "section_padding_horizontal",
        "label": "區塊水平間距",
        "min": 10,
        "max": 60,
        "step": 5,
        "default": 20,
        "unit": "px"
      },
      {
        "type": "header",
        "content": "📝 標題設定"
      },
      {
        "type": "checkbox",
        "id": "show_header",
        "label": "顯示標題區",
        "default": true
      },
      {
        "type": "text",
        "id": "main_title",
        "label": "主標題",
        "default": "APGO 直播時程"
      },
      {
        "type": "text",
        "id": "subtitle",
        "label": "副標題",
        "default": "與專業團隊即時互動 · 掌握第一手產品資訊"
      },
      {
        "type": "select",
        "id": "header_alignment",
        "label": "標題對齊",
        "options": [
          { "value": "left", "label": "靠左" },
          { "value": "center", "label": "置中" },
          { "value": "right", "label": "靠右" }
        ],
        "default": "center"
      },
      {
        "type": "range",
        "id": "title_font_size_desktop",
        "label": "標題文字大小 (桌面)",
        "min": 2,
        "max": 5,
        "step": 0.5,
        "default": 3.5,
        "unit": "rem"
      },
      {
        "type": "range",
        "id": "title_font_size_mobile",
        "label": "標題文字大小 (手機)",
        "min": 1.5,
        "max": 3,
        "step": 0.5,
        "default": 2.5,
        "unit": "rem"
      },
      {
        "type": "range",
        "id": "subtitle_font_size",
        "label": "副標題文字大小",
        "min": 0.8,
        "max": 1.5,
        "step": 0.1,
        "default": 1.1,
        "unit": "rem"
      },
      {
        "type": "range",
        "id": "title_font_weight",
        "label": "標題文字粗細",
        "min": 100,
        "max": 900,
        "step": 100,
        "default": 300
      },
      {
        "type": "range",
        "id": "title_letter_spacing",
        "label": "標題字間距",
        "min": 0,
        "max": 10,
        "step": 1,
        "default": 3,
        "unit": "px"
      },
      {
        "type": "checkbox",
        "id": "title_gradient",
        "label": "標題漸層效果",
        "default": true
      },
      {
        "type": "checkbox",
        "id": "show_title_badge",
        "label": "顯示標題徽章",
        "default": true
      },
      {
        "type": "text",
        "id": "title_badge_text",
        "label": "標題徽章文字",
        "default": "LIVE SCHEDULE"
      },
      {
        "type": "range",
        "id": "header_margin_bottom",
        "label": "標題區下邊距",
        "min": 40,
        "max": 120,
        "step": 10,
        "default": 80,
        "unit": "px"
      },
      {
        "type": "header",
        "content": "✨ 動畫設定"
      },
      {
        "type": "range",
        "id": "animation_speed",
        "label": "動畫速度",
        "min": 0.2,
        "max": 1,
        "step": 0.1,
        "default": 0.4,
        "unit": "s"
      },
      {
        "type": "checkbox",
        "id": "show_bg_decoration",
        "label": "顯示背景裝飾",
        "default": true
      },
      {
        "type": "range",
        "id": "bg_decoration_opacity",
        "label": "背景裝飾透明度",
        "min": 1,
        "max": 10,
        "step": 1,
        "default": 3,
        "unit": "%"
      },
      {
        "type": "range",
        "id": "bg_animation_duration",
        "label": "背景動畫持續時間",
        "min": 10,
        "max": 60,
        "step": 5,
        "default": 30,
        "unit": "s"
      },
      {
        "type": "header",
        "content": "🔤 字體設定"
      },
      {
        "type": "text",
        "id": "font_family",
        "label": "字體系列",
        "default": "'Inter', 'Arial', 'Microsoft JhengHei', sans-serif",
        "info": "輸入 CSS 字體名稱，多個字體用逗號分隔"
      }
    ],
    "presets": [
      {
        "name": "APGO 獨立標題",
        "settings": {
          "show_header": true,
          "main_title": "APGO 直播時程",
          "subtitle": "與專業團隊即時互動 · 掌握第一手產品資訊",
          "title_gradient": true,
          "show_bg_decoration": true
        }
      }
    ]
  }
  {% endschema %}