<div class="apgo-aio-container">
  
  <section id="apgo-hero" style="position: relative; border-bottom: 1px solid #333; margin-bottom: 0 !important;">
    <div class="apgo-hero-pc">
      {% if section.settings.hero_image_pc %}
        {{ section.settings.hero_image_pc | image_url: width: 1920 | image_tag: class: 'apgo-obj-cover' }}
      {% else %}
        <img src="https://placehold.co/1920x800/121212/f08418?text=Hero+PC" width="1920" height="800" class="apgo-obj-cover">
      {% endif %}
    </div>
    <div class="apgo-hero-mb">
      {% if section.settings.hero_image_mb %}
        {{ section.settings.hero_image_mb | image_url: width: 750 | image_tag: class: 'apgo-obj-cover' }}
      {% else %}
        <img src="https://placehold.co/750x1100/121212/f08418?text=Hero+MB" width="750" height="1100" class="apgo-obj-cover">
      {% endif %}
    </div>
  </section>

  <div id="nav-placeholder" style="height: 50px; display: none;"></div>
  <nav id="apgo-sticky-nav">
    <div id="sticky-nav-container" class="scrollbar-hide">
      {% assign nav_mode = section.settings.nav_mode | default: 'auto' %}
      {% assign has_nav_blocks = false %}
      {% assign has_content_blocks = false %}
      {% assign auto_has_coupon = false %}
      {% assign auto_grid_index = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'nav_item' %}{% assign has_nav_blocks = true %}{% endif %}
        {% if block.type == 'feature_banner_slot' or block.type == 'quick_links_grid_slot' or block.type == 'flash_sale_slot' or block.type == 'combo_showcase' or block.type == 'product_grid' or block.type == 'coupon_item' %}{% assign has_content_blocks = true %}{% endif %}
      {% endfor %}

      {% assign use_manual_nav = false %}
      {% if nav_mode == 'manual' and has_nav_blocks %}
        {% assign use_manual_nav = true %}
      {% endif %}

      {% if use_manual_nav %}
        {% for block in section.blocks %}
          {% if block.type == 'nav_item' %}
            <div class="sticky-nav-link" onclick="scrollToSection('{{ block.settings.nav_target_id }}')">{{ block.settings.nav_label }}</div>
          {% endif %}
        {% endfor %}
      {% else %}
        <div class="sticky-nav-link" onclick="scrollToSection('apgo-hero')">首圖</div>
        {% for block in section.blocks %}
          {% if block.type == 'feature_banner_slot' %}
            {% assign anchor_id = block.settings.custom_anchor_id | default: 'apgo-feature-' | append: block.id %}
            {% if block.settings.custom_anchor_id != blank %}{% assign anchor_id = block.settings.custom_anchor_id %}{% endif %}
            {% assign nav_label = block.settings.nav_label_override | default: block.settings.section_title | default: '焦點橫幅版位' %}
            <div class="sticky-nav-link" onclick="scrollToSection('{{ anchor_id }}')">{{ nav_label }}</div>
          {% elsif block.type == 'quick_links_grid_slot' %}
            {% assign anchor_id = block.settings.custom_anchor_id | default: 'apgo-quick-grid-' | append: block.id %}
            {% if block.settings.custom_anchor_id != blank %}{% assign anchor_id = block.settings.custom_anchor_id %}{% endif %}
            {% assign nav_label = block.settings.nav_label_override | default: block.settings.section_title | default: '快速導流格版位' %}
            <div class="sticky-nav-link" onclick="scrollToSection('{{ anchor_id }}')">{{ nav_label }}</div>
          {% elsif block.type == 'simple_banner_slot' %}
            {% assign anchor_id = block.settings.custom_anchor_id | default: 'apgo-simple-banner-' | append: block.id %}
            {% if block.settings.custom_anchor_id != blank %}{% assign anchor_id = block.settings.custom_anchor_id %}{% endif %}
            {% assign nav_label = block.settings.nav_label_override | default: block.settings.section_title | default: 'Banner' %}
            <div class="sticky-nav-link" onclick="scrollToSection('{{ anchor_id }}')">{{ nav_label }}</div>
          {% elsif block.type == 'flash_sale_slot' %}
            {% assign anchor_id = block.settings.custom_anchor_id | default: 'apgo-flash-' | append: block.id %}
            {% if block.settings.custom_anchor_id != blank %}{% assign anchor_id = block.settings.custom_anchor_id %}{% endif %}
            {% assign nav_label = block.settings.nav_label_override | default: block.settings.section_title | default: '整點驚喜' %}
            <div class="sticky-nav-link" onclick="scrollToSection('{{ anchor_id }}')">{{ nav_label }}</div>
          {% elsif block.type == 'combo_showcase' %}
            {% assign anchor_id = block.settings.custom_anchor_id | default: 'apgo-combo-' | append: block.id %}
            {% if block.settings.custom_anchor_id != blank %}
              {% assign anchor_id = block.settings.custom_anchor_id %}
            {% endif %}
            {% assign nav_label = block.settings.nav_label_override | default: block.settings.section_title | default: '組合推薦' %}
            <div class="sticky-nav-link" onclick="scrollToSection('{{ anchor_id }}')">{{ nav_label }}</div>
          {% elsif block.type == 'product_grid' %}
            {% assign auto_grid_index = auto_grid_index | plus: 1 %}
            {% assign anchor_id = block.settings.custom_anchor_id | default: 'apgo-grid-' | append: auto_grid_index %}
            {% if block.settings.custom_anchor_id != blank %}
              {% assign anchor_id = block.settings.custom_anchor_id %}
            {% endif %}
            {% assign nav_label = block.settings.nav_label_override | default: block.settings.section_title | default: '商品區塊' %}
            <div class="sticky-nav-link" onclick="scrollToSection('{{ anchor_id }}')">{{ nav_label }}</div>
          {% elsif block.type == 'coupon_slot' and auto_has_coupon == false %}
            {% assign auto_has_coupon = true %}
            {% assign nav_label = block.settings.nav_label_override | default: block.settings.section_title | default: section.settings.coupon_nav_label | default: section.settings.coupon_sec_title | default: '優惠版位' %}
            <div class="sticky-nav-link" onclick="scrollToSection('apgo-coupons')">{{ nav_label }}</div>
          {% elsif block.type == 'coupon_item' and auto_has_coupon == false %}
            {% assign auto_has_coupon = true %}
            <div class="sticky-nav-link" onclick="scrollToSection('apgo-coupons')">{{ section.settings.coupon_nav_label | default: section.settings.coupon_sec_title | default: '優惠版位' }}</div>
          {% endif %}
        {% endfor %}
        {% if auto_has_coupon == false %}
          <div class="sticky-nav-link" onclick="scrollToSection('apgo-coupons')">{{ section.settings.coupon_nav_label | default: section.settings.coupon_sec_title | default: '優惠版位' }}</div>
        {% endif %}
      {% endif %}
    </div>
  </nav>

  <div class="apgo-aio-inner">
    
    {% assign grid_section_index = 0 %}
    {% assign has_coupon_blocks = false %}
    {% assign coupon_slot_block = blank %}
    {% for b in section.blocks %}
      {% if b.type == 'coupon_slot' and coupon_slot_block == blank %}
        {% assign coupon_slot_block = b %}
      {% endif %}
      {% if b.type == 'coupon_item' %}
        {% assign has_coupon_blocks = true %}
        {% break %}
      {% endif %}
    {% endfor %}
    {% assign coupon_title = section.settings.coupon_sec_title %}
    {% assign coupon_icon = section.settings.coupon_sec_icon %}
    {% if coupon_slot_block != blank %}
      {% assign coupon_title = coupon_slot_block.settings.section_title | default: section.settings.coupon_sec_title %}
      {% assign coupon_icon = coupon_slot_block.settings.section_icon | default: section.settings.coupon_sec_icon %}
    {% endif %}
    {% assign coupon_section_rendered = false %}
    {% for block in section.blocks %}
      {% if block.type == 'feature_banner_slot' %}
        {% assign anchor_id = block.settings.custom_anchor_id | default: 'apgo-feature-' | append: block.id %}
        {% if block.settings.custom_anchor_id != blank %}{% assign anchor_id = block.settings.custom_anchor_id %}{% endif %}
        <section class="apgo-feature-banner-section" {{ block.shopify_attributes }}>
          <div class="apgo-grid-title" id="{{ anchor_id }}" style="margin-top: 2.5rem;">
            <i class="fa-solid {{ block.settings.section_icon }}" style="color:#f08418;"></i>
            {{ block.settings.section_title }}
          </div>
          <div class="apgo-wave1-box">
            {% if block.settings.show_banner %}
