  .apgo-coupon-card { background: #121212 !important; border: 1px solid #333 !important; border-radius: 0.5rem !important; padding: 0.5rem !important; text-align: center !important; position: relative !important; overflow: hidden !important; }
  .apgo-coupon-card::before { content: ''; position: absolute !important; top:0; left:0; width:100%; height:4px; background: var(--theme-color, #f08418) !important; }
  .apgo-coupon-amt { font-size: 1.125rem !important; font-weight: 900 !important; color: white !important; font-style: italic !important; }

  /* --- Smart Footer --- */
  /* 吸底購物車 z-index 低於 APGO Tactical Hub (9999)，避免壓住小工具抽屜 */
  #apgo-smart-footer { position: fixed !important; bottom: 0 !important; left: 0 !important; width: 100% !important; z-index: 9990 !important; transition: transform 0.3s ease !important; transform: translateY(120%); }
