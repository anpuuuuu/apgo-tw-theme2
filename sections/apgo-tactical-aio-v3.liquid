    var displayTotal = (typeof lastCartTotalFromShopify === 'number' && lastCartTotalFromShopify >= 0) ? (lastCartTotalFromShopify / 100) : total;
    document.getElementById('apgo-total').innerText = displayTotal.toLocaleString();
    document.getElementById('apgo-count').innerText = count;
    
    const footer = document.getElementById('apgo-smart-footer');
    if(count > 0) {
       footer.style.transform = 'translateY(0)';
