<script>
  (function() {
  var APGO_TIERS_RAW = [
  {% assign has_tiers = false %}
  {% for block in section.blocks %}
    {% if block.type == 'reward_tier' %}
      {% if has_tiers %},{% endif %}
      {"amount":{{ block.settings.amount | default: 799 }},"reward_name":{{ block.settings.reward_name | default: '獎勵項目' | json }}}
      {% assign has_tiers = true %}
    {% endif %}
  {% endfor %}
  ];
  if (APGO_TIERS_RAW.length === 0) {
    APGO_TIERS_RAW = [{"amount":{{ section.settings.target_amount | default: 799 }},"reward_name":{{ section.settings.target_reward | default: '獎勵項目' | json }}}];
  }
  window.APGO_TIERS = APGO_TIERS_RAW.slice().sort(function(a,b){ return a.amount - b.amount; });
  })();
  let cart = {};
  {% for item in cart.items %}
    cart["{{ item.variant_id }}"] = {
      key: "{{ item.key }}",
      qty: {{ item.quantity }},
      price: {{ item.final_price | default: item.price | divided_by: 100.0 }},
      original_price: {{ item.original_price | default: item.price | divided_by: 100.0 }},
      discounts: [
        {% for d in item.discounts %}
          { title: {{ d.title | json }} }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ],
      title: {{ item.title | json }},
      img: "{{ item.image | image_url: width: 600 }}"
    };
  {% endfor %}
  let selVid = null; let tempVar = null; let isDrawerOpen = false;
  var lastCartTotalFromShopify = {{ cart.total_price | default: 'null' }};
  var cartLevelDiscounts = [
    {% for d in cart.cart_level_discount_applications %}
      {
        title: {{ d.title | json }},
        total_allocated_amount: {{ d.total_allocated_amount | default: 0 }}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ];

  /** 從 Shopify 取得最新購物車並同步到畫面上（含折扣後價格、line key、訂單總計） */
  async function apgoSyncCartFromShopify() {
    try {
      const root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root : '/';
      const res = await fetch(root + 'cart.js');
      if (!res.ok) return;
      const data = await res.json();
      lastCartTotalFromShopify = data.total_price != null ? data.total_price : null;
      cartLevelDiscounts = data.cart_level_discount_applications || [];
      cart = {};
      (data.items || []).forEach(function(item) {
        var img = (item.featured_image && item.featured_image.url) ? item.featured_image.url : (item.image || '');
        var rawPrice = item.final_price != null ? item.final_price : (item.discounted_price != null ? item.discounted_price : item.price);
        var priceInCents = typeof rawPrice === 'number' ? rawPrice : parseInt(rawPrice, 10) || 0;
        
        var rawOriginalPrice = item.original_price != null ? item.original_price : item.price;
        var originalPriceInCents = typeof rawOriginalPrice === 'number' ? rawOriginalPrice : parseInt(rawOriginalPrice, 10) || 0;

        cart[String(item.variant_id)] = {
          key: item.key,
          qty: item.quantity,
          price: priceInCents / 100,
          original_price: originalPriceInCents / 100,
          discounts: item.discounts || [],
          title: item.title || '',
          img: img
        };
      });
      updateUI();
      syncFlashBuyButtonsWithCart();
    } catch (e) {
      console.error('apgoSyncCartFromShopify:', e);
    }
  }

  function syncFlashBuyButtonsWithCart() {
    var cards = document.querySelectorAll('.flash-item-card');
    cards.forEach(function(card) {
      var buyBtn = card.querySelector('.apgo-flash-buy-btn');
      var labelId = card.getAttribute('data-stock-state-id');
      var statusLabel = labelId ? document.getElementById(labelId) : null;
      if (!buyBtn) return;
      var variantId = String(card.getAttribute('data-variant-id') || '');
      var inCart = !!(variantId && cart[variantId] && cart[variantId].qty > 0);
      var soldout = buyBtn.getAttribute('data-soldout') === 'true';
      var ended = buyBtn.getAttribute('data-ended') === 'true';
      var upcoming = buyBtn.getAttribute('data-upcoming') === 'true';
      buyBtn.setAttribute('data-in-cart', inCart ? 'true' : 'false');

      if (ended) {
        buyBtn.classList.remove('is-flash-success');
        buyBtn.disabled = true;
        buyBtn.textContent = '活動已結束';
        if (statusLabel) {
          statusLabel.textContent = '活動已結束';
          statusLabel.classList.remove('is-available');
          statusLabel.classList.add('is-soldout');
        }
      } else if (upcoming) {
        buyBtn.classList.remove('is-flash-success');
        buyBtn.disabled = true;
        buyBtn.textContent = '即將開始';
        if (statusLabel) {
          statusLabel.textContent = '即將開始';
          statusLabel.classList.remove('is-available');
          statusLabel.classList.add('is-soldout');
        }
      } else if (soldout) {
        buyBtn.classList.remove('is-flash-success');
        buyBtn.disabled = true;
        buyBtn.textContent = '完售';
        if (statusLabel) {
          statusLabel.textContent = '完售';
          statusLabel.classList.remove('is-available');
          statusLabel.classList.add('is-soldout');
        }
      } else if (inCart) {
        buyBtn.classList.add('is-flash-success');
        buyBtn.disabled = true;
        buyBtn.textContent = buyBtn.getAttribute('data-success-text') || '前往結帳，以保有優惠';
        if (statusLabel) {
          statusLabel.textContent = '可購買';
          statusLabel.classList.remove('is-soldout');
          statusLabel.classList.add('is-available');
        }
      } else {
        buyBtn.classList.remove('is-flash-success');
        buyBtn.disabled = false;
        buyBtn.textContent = buyBtn.getAttribute('data-default-text') || '馬上搶';
        if (statusLabel) {
          statusLabel.textContent = '可購買';
          statusLabel.classList.remove('is-soldout');
          statusLabel.classList.add('is-available');
        }
      }
    });
  }

  // --- [整合導航邏輯] ---
  const nav = document.getElementById('apgo-sticky-nav');
  const placeholder = document.getElementById('nav-placeholder');
  const hero = document.getElementById('apgo-hero');
  const navLinks = document.querySelectorAll('.sticky-nav-link');
  let navStickTop = 0;

  function updateNavStickTop() {
    if (!nav) return;
    const wasFixed = nav.classList.contains('nav-fixed');
    if (wasFixed) {
      nav.classList.remove('nav-fixed');
      placeholder.style.display = 'none';
    }
    navStickTop = nav.getBoundingClientRect().top + window.scrollY;
    if (wasFixed) {
      nav.classList.add('nav-fixed');
      placeholder.style.display = 'block';
    }
  }

  updateNavStickTop();
  window.addEventListener('load', updateNavStickTop);
  window.addEventListener('resize', updateNavStickTop);

  window.addEventListener('scroll', () => {
    // 吸頂邏輯
    if (window.scrollY >= navStickTop) {
      nav.classList.add('nav-fixed');
      placeholder.style.display = 'block';
    } else {
      nav.classList.remove('nav-fixed');
      placeholder.style.display = 'none';
    }

    // Scroll Spy (自動亮起導航標籤): 依 nav 目標 ID 判定，不限 section[id]
    let current = "";
    navLinks.forEach(link => {
      const onclickAttr = link.getAttribute('onclick');
      const match = onclickAttr && onclickAttr.match(/scrollToSection\s*\(\s*['"]([^'"]+)['"]\s*\)/);
      const linkTargetId = match ? match[1] : '';
      const targetEl = linkTargetId ? document.getElementById(linkTargetId) : null;
      if (targetEl && pageYOffset >= targetEl.offsetTop - 120) {
        current = linkTargetId;
      }
    });

    navLinks.forEach((link, index) => {
      link.classList.remove('active');
      const onclickAttr = link.getAttribute('onclick');
      const match = onclickAttr && onclickAttr.match(/scrollToSection\s*\(\s*['"]([^'"]+)['"]\s*\)/);
      const linkTargetId = match ? match[1] : '';
      if (linkTargetId && linkTargetId === current) {
        link.classList.add('active');
        const container = document.getElementById('sticky-nav-container');
        if (container && container.scrollWidth > container.clientWidth) {
          // 將 Active 的導航項目盡可能保持在容器正中央
          const scrollLeft = link.offsetLeft - (container.clientWidth / 2) + (link.clientWidth / 2);
          // 原生 scrollTo 已經會自動處理 < 0 或超出最大捲動範圍的安全限制
          container.scrollTo({ left: scrollLeft, behavior: 'smooth' });
        }
      }
    });
  });

  function scrollToSection(id) {
    const el = document.getElementById(id);
    if (el) {
      window.scrollTo({ top: el.offsetTop - 60, behavior: 'smooth' });
    }
  }

  // --- [原有購物車與彈窗邏輯] ---
  function apgoCartRoot() {
    return (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root : '/';
  }

  function apgoNormalizeCouponCode(code) {
    return String(code == null ? '' : code).trim();
  }

  function apgoFindLineKeyForVariant(cartJson, variantId) {
    var want = String(variantId);
    var items = cartJson && cartJson.items;
    if (!Array.isArray(items)) return null;
    for (var i = items.length - 1; i >= 0; i--) {
      if (String(items[i].variant_id) === want) return items[i].key || null;
    }
    return null;
  }

  function apgoIsDiscountAppliedToCart(cartJson, code) {
    var want = apgoNormalizeCouponCode(code).toLowerCase();
    if (!want || !cartJson) return false;
    var codes = cartJson.discount_codes;
    if (Array.isArray(codes)) {
      for (var i = 0; i < codes.length; i++) {
        var c = codes[i];
        if (!c || c.code == null) continue;
        if (String(c.code).toLowerCase() !== want) continue;
        return c.applicable !== false;
      }
    }
    return false;
  }

  /** 從購物車 JSON 取出已套用的折扣碼字串（去重、保留順序），供與新碼合併 */
  function apgoDiscountCodeStringsFromCart(cartJson) {
    var out = [];
    var seen = Object.create(null);
    var codes = cartJson && cartJson.discount_codes;
    if (!Array.isArray(codes)) return out;
    for (var i = 0; i < codes.length; i++) {
      var c = codes[i];
      if (!c || c.code == null) continue;
      var raw = apgoNormalizeCouponCode(c.code);
      if (!raw) continue;
      var low = raw.toLowerCase();
      if (seen[low]) continue;
      seen[low] = true;
      out.push(raw);
    }
    return out;
  }

  /** 合併購物車現有碼與本次新碼，組成 cart/update.js 的 discount 字串（逗號分隔） */
  function apgoBuildMergedDiscountString(cartJson, newCode) {
    var n = apgoNormalizeCouponCode(newCode);
    if (!n) return '';
    var list = apgoDiscountCodeStringsFromCart(cartJson);
    var seen = Object.create(null);
    list.forEach(function(x) { seen[String(x).toLowerCase()] = true; });
    if (!seen[n.toLowerCase()]) list.push(n);
    return list.join(',');
  }

  async function apgoRemoveLineByKey(lineKey) {
    if (!lineKey) return;
    try {
      await fetch(apgoCartRoot() + 'cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: lineKey, quantity: 0 })
      });
    } catch (e) {
      console.error('APGO rollback line:', e);
    }
  }

  /**
   * 將 newCode 與 cartHint 內既有 discount_codes 合併後，一次 POST cart/update.js（逗號分隔），
   * 避免搶第二個商品時蓋掉第一個商品的折扣碼。
   */
  async function apgoApplyCartDiscount(newCode, cartHint) {
    var hint = cartHint || {};
    var merged = apgoBuildMergedDiscountString(hint, newCode);
    if (!merged) return { ok: false, cart: null };
    var res = await fetch(apgoCartRoot() + 'cart/update.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ discount: merged })
    });
    if (!res.ok) return { ok: false, cart: null };
    var cartData = await res.json().catch(function() { return null; });
    return { ok: true, cart: cartData };
  }

  async function apgoFetchCartJson() {
    try {
      var r = await fetch(apgoCartRoot() + 'cart.js');
      if (!r.ok) return null;
      return await r.json();
    } catch (e) {
      return null;
    }
  }


  async function apgoAdd(vid, title, price, img) {
    if(navigator.vibrate) navigator.vibrate(15);
    const root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root : '/';
    try {
      const addRes = await fetch(root + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: [{ id: vid, quantity: 1 }] })
      });
      if (!addRes.ok) {
        var err = await addRes.json().catch(function(){ return {}; });
        console.error('Error adding to cart:', err);
        return false;
      }
      await apgoSyncCartFromShopify();
      return true;
    } catch (error) {
      console.error('Error adding to cart:', error);
      return false;
    }
  }

  async function apgoAddWithAnimation(btn, vid, title, price, img) {
    if (!btn || btn.dataset.loading === 'true' || btn.disabled) return;
    var originalHtml = btn.innerHTML;
    var originalDisabled = btn.disabled;
    btn.dataset.loading = 'true';
    btn.disabled = true;
    btn.textContent = '加入購物車中...';
    try {
      var added = await apgoAdd(vid, title, price, img);
      if (added) {
        btn.textContent = '已加入購物車';
        await new Promise(function(resolve){ setTimeout(resolve, 900); });
      }
    } finally {
      btn.innerHTML = originalHtml;
      btn.disabled = originalDisabled;
      btn.dataset.loading = 'false';
    }
  }

  async function apgoFlashBuy(btn, vid, title, price, img) {
    if (!btn || btn.disabled || btn.dataset.loading === 'true') return;
    if (btn.getAttribute('data-upcoming') === 'true') return;
    if (btn.getAttribute('data-ended') === 'true') return;
    if (btn.dataset.soldout === 'true') return;

    var card = btn.closest('.flash-item-card');
    var couponCode = apgoNormalizeCouponCode(card ? card.getAttribute('data-coupon-code') : '');
    if (!couponCode) {
      console.warn('APGO: 未設定折扣碼，已中止加購');
      return;
    }

    var successText = btn.getAttribute('data-success-text') || '前往結帳，以保有優惠';

    btn.dataset.loading = 'true';
    btn.disabled = true;
    btn.classList.remove('is-flash-success');
    btn.textContent = '加入購物車中';
    btn.classList.add('is-loading');

    var lineKey = null;
    var succeeded = false;
    try {
      var addRes = await fetch(apgoCartRoot() + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: [{ id: vid, quantity: 1 }] })
      });
      if (!addRes.ok) {
        var errAdd = await addRes.json().catch(function(){ return {}; });
        console.error('APGO cart/add failed:', errAdd);
        return;
      }
      var addData = await addRes.json();
      lineKey = apgoFindLineKeyForVariant(addData, vid);
      if (!lineKey) {
        console.error('APGO: 無法取得購物車 line key');
        await apgoSyncCartFromShopify();
        return;
      }

      var cartForMerge = await apgoFetchCartJson() || addData;
      var upd = await apgoApplyCartDiscount(couponCode, cartForMerge);
      var cartState = upd.cart;
      if (!upd.ok || !cartState || !apgoIsDiscountAppliedToCart(cartState, couponCode)) {
        cartState = await apgoFetchCartJson();
      }
      if (!cartState || !apgoIsDiscountAppliedToCart(cartState, couponCode)) {
        console.error('APGO: 折扣碼未能成功套用，已回滾加購');
        await apgoRemoveLineByKey(lineKey);
        lineKey = null;
        await apgoSyncCartFromShopify();
        return;
      }

      if (navigator.vibrate) navigator.vibrate(15);
      await apgoSyncCartFromShopify();
      btn.classList.add('is-flash-success');
      btn.textContent = successText;
      btn.disabled = true;
      succeeded = true;
    } catch (e) {
      console.error('APGO apgoFlashBuy:', e);
      if (lineKey) {
        await apgoRemoveLineByKey(lineKey);
        lineKey = null;
        await apgoSyncCartFromShopify();
      }
    } finally {
      btn.classList.remove('is-loading');
      btn.dataset.loading = 'false';
      if (!succeeded) {
        syncFlashBuyButtonsWithCart();
      }
    }
  }


  async function apgoRemove(vid) {
    if(navigator.vibrate) navigator.vibrate(15);
    const v = String(vid);
    var key = cart[v] && cart[v].key;
    if (!key) {
      await apgoSyncCartFromShopify();
      key = cart[v] && cart[v].key;
    }
    if (!key) return;
    const root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root : '/';
    try {
      const res = await fetch(root + 'cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: 0 })
      });
      if (!res.ok) { console.error('Error removing from cart'); return; }
      await apgoSyncCartFromShopify();
    } catch (error) {
      console.error('Error removing from cart:', error);
    }
  }

  async function apgoChangeQty(vid, delta) {
    if(navigator.vibrate) navigator.vibrate(15);
    const v = String(vid);
    if(!cart[v]) return;
    var key = cart[v].key;
    if (!key) {
      await apgoSyncCartFromShopify();
      if (!cart[v]) return;
      key = cart[v].key;
    }
    if (!key) return;
    var newQty = Math.max(0, (cart[v].qty || 0) + delta);
    const root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root : '/';
    try {
      const res = await fetch(root + 'cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: newQty })
      });
      if (!res.ok) { console.error('Error updating cart quantity'); return; }
      await apgoSyncCartFromShopify();
    } catch (error) {
      console.error('Error updating cart quantity:', error);
    }
  }

