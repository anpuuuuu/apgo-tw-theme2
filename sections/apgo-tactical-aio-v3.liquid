  .apgo-card-foot { display: flex !important; justify-content: space-between !important; align-items: center !important; margin-top: 0.5rem !important; gap: 0.5rem !important; }
  .apgo-card-price { font-size: 1.125rem !important; font-weight: bold !important; color: white !important; }
  .apgo-card-actions { display: flex !important; border: 1px solid #333 !important; border-radius: 0.25rem !important; overflow: hidden !important; flex-shrink: 0 !important; }
  .apgo-btn { border: none !important; outline: none !important; appearance: none !important; -webkit-appearance: none !important; text-decoration: none !important; padding: 0.375rem 0.75rem !important; font-size: 11px !important; font-weight: bold !important; cursor: pointer !important; transition: all 0.2s !important; letter-spacing: 0.02em !important; display: inline-flex !important; align-items: center !important; justify-content: center !important; }
  .apgo-btn-left { background: #121212 !important; color: #f08418 !important; border-right: 1px solid #333 !important; }
  .apgo-btn-left:hover { background: #1a1a1a !important; color: #f08418 !important; }
  .apgo-btn-right { background: #f08418 !important; color: #000 !important; }
  .apgo-btn-right:hover { background: #fff !important; color: #000 !important; }
  .apgo-btn-right[disabled] { background:#333 !important; color:#999 !important; cursor:not-allowed !important; }
  .apgo-card.apgo-card-vertical {
    padding: 0 !important;
    overflow: hidden !important;
    min-height: 100% !important;
    display: flex !important;
    flex-direction: column !important;
