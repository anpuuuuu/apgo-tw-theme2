                          <i class="fa-solid fa-box" style="color:#666; font-size:24px;"></i>
                        {% endif %}
                      </div>
                      <div class="apgo-card-info">
                        <div>
                          <div class="apgo-card-title">{{ product.title }}</div>
                          <div class="apgo-card-desc">{{ product.description | strip_html | truncate: 50 }}</div>
                        </div>
                        <div class="apgo-card-foot"{% if card_layout == 'vertical' %} style="display:block !important;"{% endif %}>
                          <div class="apgo-card-price apgo-font-mono">{% if product.price_min < product.price_max %}{{ product.price_min | money }} ~ {{ product.price_max | money }}{% else %}{{ product.price | money }}{% endif %}</div>
                          <div class="apgo-card-actions">
                            <a href="{{ product.url }}" class="apgo-btn apgo-btn-left">詳情</a>
                            {% if has_variants %}
                              <button class="apgo-btn apgo-btn-right" {% unless product_is_available %}disabled{% endunless %} onclick="apgoOpenModal({{ product.id }})">{% if product_is_available %}加入{% else %}完售{% endif %}</button>
                            <script type="application/json" id="json-{{ product.id }}">
                              [
                                {% for v in product.variants %}
                                  {
                                    "id": {{ v.id }},
                                    "title": {{ v.title | json }},
                                    "price": {{ v.price | divided_by: 100.0 }},
                                    "display_price": {{ v.price | money | json }},
                                    "img": "{{ v.featured_image | image_url: width: 800 | default: product.featured_image | image_url: width: 800 }}"
                                  }{% unless forloop.last %},{% endunless %}
                                {% endfor %}
                              ]
                            </script>
                            {% else %}
                              {% assign p_img = '' %}
                              {% if product.featured_image %}{% assign p_img = product.featured_image | image_url: width: 800 %}{% endif %}
                              <button class="apgo-btn apgo-btn-right" {% unless selected_variant and selected_variant.available %}disabled{% endunless %} onclick="apgoAddWithAnimation(this, {{ selected_variant.id | default: 0 }}, '{{ product.title | escape }}', {{ product.price | divided_by: 100.0 }}, '{{ p_img }}')">{% if selected_variant and selected_variant.available %}加入{% else %}完售{% endif %}</button>
                            {% endif %}
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                {% endfor %}
              {% else %}
                <div class="apgo-card{% if card_layout == 'vertical' %} apgo-card-vertical{% endif %}">
                  <div class="apgo-card-head">
                    <span class="apgo-card-tag apgo-font-mono">// {{ block.settings.card_tag | default: 'TAG' }}</span>
                  </div>
                  <div class="apgo-card-body">
                    <div class="apgo-card-img-box">
                      <div class="apgo-img-placeholder">商品圖片位置</div>
                    </div>
                    <div class="apgo-card-info">
                      <div>
                        <div class="apgo-card-title">商品標題位置</div>
                        <div class="apgo-card-desc">商品描述位置（編輯器示意）</div>
                      </div>
                      <div class="apgo-card-foot"{% if card_layout == 'vertical' %} style="display:block !important;"{% endif %}>
                        <div class="apgo-card-price apgo-font-mono">$0</div>
                        <div class="apgo-card-actions">
                          <span class="apgo-btn apgo-btn-left">詳情</span>
                          <span class="apgo-btn apgo-btn-right">加入</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              {% endif %}
            </div>
          {% endif %}
        </section>
      {% elsif block.type == 'coupon_item' %}
        {% unless coupon_section_rendered %}
          {% assign coupon_section_rendered = true %}
          <section class="apgo-coupon-sec" id="apgo-coupons">
            <div class="apgo-grid-title" style="margin-bottom: 1rem;">
              <i class="fa-solid {{ coupon_icon }}" style="color:#f08418;"></i>
              {{ coupon_title }}
            </div>
            <div class="apgo-grid-banner" style="--apgo-banner-space-top:{% if section.settings.coupon_banner_spacing_top %}1rem{% else %}0{% endif %}; --apgo-banner-space-bottom:{% if section.settings.coupon_banner_spacing_bottom %}1rem{% else %}0{% endif %};">
              {% if section.settings.coupon_banner_img %}
                {{ section.settings.coupon_banner_img | image_url: width: 1920 | image_tag: class: 'apgo-obj-cover' }}
              {% else %}
                <div class="apgo-img-placeholder">Banner 圖片位置</div>
              {% endif %}
            </div>
            <div class="apgo-coupon-grid">
              {% for coupon_block in section.blocks %}
                {% if coupon_block.type == 'coupon_item' %}
                  <div class="apgo-coupon-card" style="--theme-color: {{ coupon_block.settings.theme_color }};{% if coupon_block.settings.highlight_discount %} border-color: {{ coupon_block.settings.theme_color }};{% endif %}" {{ coupon_block.shopify_attributes }}>
                    <i class="fa-solid fa-ticket" style="color:{{ coupon_block.settings.theme_color }}; font-size:18px; margin:4px 0;"></i>
                    <div style="font-size:10px; color:#6b7280;">{{ coupon_block.settings.condition }}</div>
                    <div class="apgo-coupon-amt"{% if coupon_block.settings.highlight_discount %} style="color:{{ coupon_block.settings.theme_color }};"{% endif %}>{{ coupon_block.settings.discount }}</div>
                  </div>
                {% endif %}
              {% endfor %}
            </div>
            <div style="text-align:center; font-size:10px; color:#666; margin-top:10px;">※ 優惠達門檻結帳自動折抵，無需手動輸入</div>
          </section>
        {% endunless %}
      {% endif %}
    {% endfor %}

    {% unless coupon_section_rendered %}
      <section class="apgo-coupon-sec" id="apgo-coupons">
        <div class="apgo-grid-title" style="margin-bottom: 1rem;">
          <i class="fa-solid {{ coupon_icon }}" style="color:#f08418;"></i>
          {{ coupon_title }}
        </div>
        <div class="apgo-grid-banner" style="--apgo-banner-space-top:{% if section.settings.coupon_banner_spacing_top %}1rem{% else %}0{% endif %}; --apgo-banner-space-bottom:{% if section.settings.coupon_banner_spacing_bottom %}1rem{% else %}0{% endif %};">
          {% if section.settings.coupon_banner_img %}
            {{ section.settings.coupon_banner_img | image_url: width: 1920 | image_tag: class: 'apgo-obj-cover' }}
          {% else %}
            <div class="apgo-img-placeholder">Banner 圖片位置</div>
          {% endif %}
        </div>
        <div class="apgo-coupon-grid">
          <div class="apgo-coupon-card" style="--theme-color: #f08418;">
            <i class="fa-solid fa-ticket" style="color:#f08418; font-size:18px; margin:4px 0;"></i>
            <div style="font-size:10px; color:#6b7280;">{{ section.settings.c1_condition }}</div>
            <div class="apgo-coupon-amt">{{ section.settings.c1_discount }}</div>
          </div>
          <div class="apgo-coupon-card" style="--theme-color: #9ca3af;">
            <i class="fa-solid fa-ticket" style="color:#9ca3af; font-size:18px; margin:4px 0;"></i>
            <div style="font-size:10px; color:#6b7280;">{{ section.settings.c2_condition }}</div>
            <div class="apgo-coupon-amt">{{ section.settings.c2_discount }}</div>
          </div>
          <div class="apgo-coupon-card" style="--theme-color: #f08418; border-color: rgba(240,132,24,0.5);">
            <i class="fa-solid fa-ticket" style="color:#f08418; font-size:18px; margin:4px 0;"></i>
            <div style="font-size:10px; color:#6b7280;">{{ section.settings.c3_condition }}</div>
            <div class="apgo-coupon-amt" style="color:#f08418;">{{ section.settings.c3_discount }}</div>
          </div>
        </div>
        <div style="text-align:center; font-size:10px; color:#666; margin-top:10px;">※ 優惠達門檻結帳自動折抵，無需手動輸入</div>
      </section>
    {% endunless %}

  </div>
</div>

