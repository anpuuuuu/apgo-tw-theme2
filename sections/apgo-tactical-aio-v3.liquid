  function parseSlotToTimestamp(slot) {
    if (!slot) return null;
    var raw = String(slot).trim().replace(/-/g, '/').replace('：', ':').replace(/\s+/g, ' ');
    var match = raw.match(/^(\d{4})\/(\d{1,2})\/(\d{1,2})\s+(\d{1,2}):(\d{1,2})$/);
    if (!match) return null;
    var y = parseInt(match[1], 10);
    var mo = parseInt(match[2], 10);
    var d = parseInt(match[3], 10);
    var h = parseInt(match[4], 10);
    var mi = parseInt(match[5], 10);
    if ([y, mo, d, h, mi].some(function(v){ return isNaN(v); })) return null;
    var date = new Date(y, mo - 1, d, h, mi, 0, 0);
    if (
      date.getFullYear() !== y ||
      date.getMonth() !== (mo - 1) ||
      date.getDate() !== d ||
      date.getHours() !== h ||
      date.getMinutes() !== mi
    ) return null;
    return date.getTime();
  }

  function formatFlashTabLabel(ts) {
    var date = new Date(ts);
    var mm = String(date.getMonth() + 1).padStart(2, '0');
    var dd = String(date.getDate()).padStart(2, '0');
    var hh = String(date.getHours()).padStart(2, '0');
    var mi = String(date.getMinutes()).padStart(2, '0');
    return {
      date: mm + '/' + dd,
      time: hh + ':' + mi
    };
  }

  function initFlashSaleSections() {
    var sections = document.querySelectorAll('.apgo-flash-section');
    sections.forEach(function(section) {
      var cards = Array.from(section.querySelectorAll('.flash-item-card'));
      if (!cards.length) return;

      var slotMap = {};
      cards.forEach(function(card) {
        var rawSlot = card.getAttribute('data-slot') || '';
        var ts = parseSlotToTimestamp(rawSlot);
        var rawEnd = card.getAttribute('data-end') || '';
        var endTs = parseSlotToTimestamp(rawEnd);
        if (ts == null) {
          card.style.display = 'none';
          return;
        }
        card.setAttribute('data-slot-ts', String(ts));
        if (!slotMap[ts]) slotMap[ts] = { ts: ts, endTs: null };
        if (endTs != null && endTs > ts) {
          var prevEnd = slotMap[ts].endTs;
          slotMap[ts].endTs = prevEnd == null ? endTs : Math.max(prevEnd, endTs);
        }
      });

      var slots = Object.keys(slotMap).map(function(key){ return slotMap[key]; }).sort(function(a, b){ return a.ts - b.ts; });
      if (!slots.length) return;

      function getSlotEndTs(slot, idx) {
        if (slot.endTs && slot.endTs > slot.ts) return slot.endTs;
        return idx < slots.length - 1 ? slots[idx + 1].ts : (slot.ts + 24 * 60 * 60 * 1000);
      }

      function getSlotState(slot, idx, nowTs) {
        var start = slot.ts;
        var end = getSlotEndTs(slot, idx);
        if (nowTs < start) return 'tab-upcoming';
        if (nowTs >= start && nowTs < end) return 'tab-active';
        return 'tab-ended';
      }

      function getDefaultActiveIndex(nowTs) {
        for (var i = 0; i < slots.length; i++) {
          if (getSlotState(slots[i], i, nowTs) === 'tab-active') return i;
        }
        for (var j = 0; j < slots.length; j++) {
          if (getSlotState(slots[j], j, nowTs) === 'tab-upcoming') return j;
        }
        return slots.length - 1;
      }

      function formatFlashDuration(startTs, endTs) {
        var diffMs = Math.max(0, endTs - startTs);
        var totalHours = diffMs / (60 * 60 * 1000);
        if (totalHours >= 24) {
          var days = totalHours / 24;
          var dayText = Number.isInteger(days) ? String(days) : days.toFixed(1).replace(/\.0$/, '');
          return dayText + '天';
        }
        var hourText = Number.isInteger(totalHours) ? String(totalHours) : totalHours.toFixed(1).replace(/\.0$/, '');
        return hourText + '小時';
      }

      var selectedSlotTs = slots[getDefaultActiveIndex(Date.now())].ts;
      function renderCardsBySlotTs(targetTs) {
        var nowTs = Date.now();
        cards.forEach(function(c) {
          var shouldShow = c.getAttribute('data-slot-ts') === String(targetTs);
          c.style.setProperty('display', shouldShow ? 'flex' : 'none', 'important');
          var cardTs = Number(c.getAttribute('data-slot-ts') || 0);
          var cardIdx = slots.findIndex(function(s){ return s.ts === cardTs; });
          var ended = false;
          var upcoming = false;
          if (cardIdx >= 0) {
            var state = getSlotState(slots[cardIdx], cardIdx, nowTs);
            ended = state === 'tab-ended';
            upcoming = state === 'tab-upcoming';
          }
          c.classList.toggle('is-ended', ended);
          c.setAttribute('data-ended', ended ? 'true' : 'false');
          c.setAttribute('data-upcoming', upcoming ? 'true' : 'false');
          var btn = c.querySelector('.apgo-flash-buy-btn');
          if (btn) {
            btn.setAttribute('data-ended', ended ? 'true' : 'false');
            btn.setAttribute('data-upcoming', upcoming ? 'true' : 'false');
          }
        });
        syncFlashBuyButtonsWithCart();
      }

      var tabs = section.querySelector('.apgo-flash-time-tabs');
      if (!tabs) return;
      var TABS_PER_VIEW = 4;
      var lastAutoAnchoredActiveIdx = -1;

      function clamp(num, min, max) {
        return Math.max(min, Math.min(max, num));
      }

      function getLastEndedIndex(nowTs) {
        var idx = -1;
        for (var i = 0; i < slots.length; i++) {
          if (getSlotState(slots[i], i, nowTs) === 'tab-ended') idx = i;
        }
        return idx;
      }

      function getWindowStartIndex(anchorIdx, nowTs) {
        var maxStart = Math.max(0, slots.length - TABS_PER_VIEW);
        var start = clamp(anchorIdx - 1, 0, maxStart);
        var endedIdx = getLastEndedIndex(nowTs);
        if (endedIdx >= 0) {
          var hasEndedInView = false;
          for (var i = start; i < Math.min(slots.length, start + TABS_PER_VIEW); i++) {
            if (getSlotState(slots[i], i, nowTs) === 'tab-ended') {
              hasEndedInView = true;
              break;
            }
          }
          if (!hasEndedInView) start = clamp(endedIdx, 0, maxStart);
        }
        return start;
      }

      function scrollTabsToStart(startIdx, behavior) {
        var tabEls = tabs.querySelectorAll('.apgo-flash-time-tab');
        if (!tabEls.length || !tabEls[startIdx]) return;
        tabs.scrollTo({ left: tabEls[startIdx].offsetLeft - tabs.offsetLeft, behavior: behavior || 'smooth' });
      }

      function ensureTabVisible(idx) {
        var tabEls = tabs.querySelectorAll('.apgo-flash-time-tab');
        if (!tabEls.length || !tabEls[idx]) return;
        var target = tabEls[idx];
        var viewLeft = tabs.scrollLeft;
        var viewRight = viewLeft + tabs.clientWidth;
        var targetLeft = target.offsetLeft - tabs.offsetLeft;
        var targetRight = targetLeft + target.offsetWidth;
        if (targetLeft < viewLeft || targetRight > viewRight) {
          tabs.scrollTo({ left: Math.max(0, targetLeft - target.offsetWidth), behavior: 'smooth' });
        }
      }

      function renderTabs(nowTs) {
        tabs.innerHTML = '';
        slots.forEach(function(slot, idx) {
          var stateClass = getSlotState(slot, idx, nowTs);
          var statusText = stateClass === 'tab-active' ? '搶購中' : (stateClass === 'tab-ended' ? '已結束' : '即將開始');
          var label = formatFlashTabLabel(slot.ts);
          var tab = document.createElement('div');
          tab.className = 'apgo-flash-time-tab ' + stateClass + (slot.ts === selectedSlotTs ? ' tab-selected' : '');
          tab.innerHTML =
            '<div class="apgo-flash-time-tab-hour"><span class="apgo-flash-time-tab-date">' + label.date + '</span> <span class="apgo-flash-time-tab-clock">' + label.time + '</span></div>' +
            '<div class="apgo-flash-time-tab-status">' + statusText + '</div>';
          tab.onclick = function() {
            selectedSlotTs = slot.ts;
            renderCardsBySlotTs(selectedSlotTs);
            renderTabs(Date.now());
            ensureTabVisible(idx);
          };
          tabs.appendChild(tab);
        });
      }

      renderCardsBySlotTs(selectedSlotTs);
      renderTabs(Date.now());

      function tickCountdown() {
        var nowTs = Date.now();
        var liveIdx = getDefaultActiveIndex(nowTs);
        var liveStart = slots[liveIdx].ts;
        var liveEnd = getSlotEndTs(slots[liveIdx], liveIdx);
        var liveState = getSlotState(slots[liveIdx], liveIdx, nowTs);
        var activeIdx = -1;
        var nextUpcomingIdx = -1;
        for (var i = 0; i < slots.length; i++) {
          var state = getSlotState(slots[i], i, nowTs);
          if (state === 'tab-active' && activeIdx === -1) activeIdx = i;
          if (state === 'tab-upcoming' && nextUpcomingIdx === -1) nextUpcomingIdx = i;
        }

        var targetTs = liveState === 'tab-upcoming' ? liveStart : liveEnd;
        var durationText = formatFlashDuration(liveStart, liveEnd);
        var useNextSlotMode = activeIdx === -1 && nextUpcomingIdx !== -1;
        if (useNextSlotMode) {
          targetTs = slots[nextUpcomingIdx].ts;
        }
        var remainMs = Math.max(0, targetTs - nowTs);
        var totalSec = Math.floor(remainMs / 1000);
        var h = Math.floor(totalSec / 3600);
        var m = Math.floor((totalSec % 3600) / 60);
        var s = totalSec % 60;
        var d = Math.floor(totalSec / 86400);
        var nextH = Math.floor((totalSec % 86400) / 3600);
        var nextM = Math.floor((totalSec % 3600) / 60);
        var nextS = totalSec % 60;
        var box = section.querySelector('[data-flash-countdown]');
        if (!box) return;
        var dd = box.querySelector('.days');
        var hh = box.querySelector('.hours');
        var mm = box.querySelector('.mins');
        var ss = box.querySelector('.secs');
        var countdownLabel = box.querySelector('.apgo-flash-countdown-label');
        if (useNextSlotMode) {
          if (dd) dd.textContent = String(d).padStart(2, '0');
          if (hh) hh.textContent = String(nextH).padStart(2, '0');
          if (mm) mm.textContent = String(nextM).padStart(2, '0');
          if (ss) ss.textContent = String(nextS).padStart(2, '0');
        } else {
          if (dd) dd.textContent = '00';
          if (hh) hh.textContent = String(h).padStart(2, '0');
          if (mm) mm.textContent = String(m).padStart(2, '0');
          if (ss) ss.textContent = String(s).padStart(2, '0');
        }
        if (countdownLabel) {
          if (useNextSlotMode) {
            countdownLabel.textContent = '距離下次檔期開始時間倒數';
          } else if (activeIdx !== -1) {
            countdownLabel.textContent = '本檔活動限時' + durationText + '，距離本檔結束';
          } else {
            countdownLabel.textContent = '目前無進行中檔期';
          }
        }
        if (liveIdx !== lastAutoAnchoredActiveIdx) {
          var startIdx = getWindowStartIndex(liveIdx, nowTs);
          scrollTabsToStart(startIdx, 'smooth');
          lastAutoAnchoredActiveIdx = liveIdx;
        }
        renderTabs(nowTs);
      }
      tickCountdown();
      setInterval(tickCountdown, 1000);
    });
  }

  async function fetchRealTimeInventory() {
    var cards = Array.from(document.querySelectorAll('.flash-item-card'));
    var productRequestCache = {};

    async function fetchProduct(handle) {
      if (!handle) return null;
      if (!productRequestCache[handle]) {
        productRequestCache[handle] = fetch('/products/' + handle + '.js')
          .then(function(res){ return res.ok ? res.json() : null; })
          .catch(function(e) {
            console.error('fetchRealTimeInventory:', e);
            return null;
          });
      }
      return productRequestCache[handle];
    }

    var tasks = cards.map(async function(card) {
      var handle = card.getAttribute('data-product-handle');
      var variantId = parseInt(card.getAttribute('data-variant-id') || '0', 10);
      var isAvailable = false;
      var data = await fetchProduct(handle);
      if (data && data.variants) {
        var variants = data.variants || [];
        for (var j = 0; j < variants.length; j++) {
          if (variantId && variants[j].id === variantId) {
            isAvailable = !!variants[j].available;
            break;
          }
        }
        if (!variantId && variants.length > 0) isAvailable = !!variants[0].available;
      }
      return { card: card, isAvailable: isAvailable };
    });

    var results = await Promise.all(tasks);
    results.forEach(function(result) {
      var card = result.card;
      var isAvailable = result.isAvailable;
      var labelId = card.getAttribute('data-stock-state-id');
      var label = labelId ? document.getElementById(labelId) : null;
      var buyBtn = card.querySelector('.apgo-flash-buy-btn');
      var copyBtn = card.querySelector('.apgo-flash-copy-btn');
      if (label) {
        label.textContent = isAvailable ? '可購買' : '完售';
        label.classList.remove('is-available', 'is-soldout');
        label.classList.add(isAvailable ? 'is-available' : 'is-soldout');
      }
      if (buyBtn) {
        var variantId = String(card.getAttribute('data-variant-id') || '');
        var inCart = !!(variantId && cart[variantId] && cart[variantId].qty > 0);
        var ended = card.getAttribute('data-ended') === 'true';
        var upcoming = card.getAttribute('data-upcoming') === 'true';
        buyBtn.setAttribute('data-soldout', isAvailable ? 'false' : 'true');
        buyBtn.setAttribute('data-in-cart', inCart ? 'true' : 'false');
        buyBtn.setAttribute('data-ended', ended ? 'true' : 'false');
        buyBtn.setAttribute('data-upcoming', upcoming ? 'true' : 'false');

        if (ended) {
          buyBtn.classList.remove('is-flash-success');
          buyBtn.disabled = true;
          buyBtn.textContent = '活動已結束';
          if (label) {
            label.textContent = '活動已結束';
            label.classList.remove('is-available');
            label.classList.add('is-soldout');
          }
        } else if (upcoming) {
          buyBtn.classList.remove('is-flash-success');
          buyBtn.disabled = true;
          buyBtn.textContent = '即將開始';
          if (label) {
            label.textContent = '即將開始';
            label.classList.remove('is-available');
            label.classList.add('is-soldout');
          }
        } else if (!isAvailable) {
          buyBtn.classList.remove('is-flash-success');
          buyBtn.disabled = true;
          buyBtn.textContent = '完售';
          if (label) {
            label.textContent = '完售';
            label.classList.remove('is-available');
            label.classList.add('is-soldout');
          }
        } else if (inCart) {
          buyBtn.classList.add('is-flash-success');
          buyBtn.disabled = true;
          buyBtn.textContent = buyBtn.getAttribute('data-success-text') || '前往結帳，以保有優惠';
          if (label) {
            label.textContent = '可購買';
            label.classList.remove('is-soldout');
            label.classList.add('is-available');
          }
        } else {
          buyBtn.classList.remove('is-flash-success');
          buyBtn.disabled = false;
          buyBtn.textContent = buyBtn.getAttribute('data-default-text') || '馬上搶';
          if (label) {
            label.textContent = '可購買';
            label.classList.remove('is-soldout');
            label.classList.add('is-available');
          }
        }
      }
      if (copyBtn) {
        copyBtn.dataset.available = isAvailable ? 'true' : 'false';
        var copyHandler = copyBtn.getAttribute('onclick') || '';
        if (copyHandler) {
          copyBtn.setAttribute('onclick', copyHandler.replace(/,\s*(true|false)\)$/, ', ' + (isAvailable ? 'true' : 'false') + ')'));
        }
      }
    });
  }

  function apgoCloseModal() { document.body.classList.remove('apgo-modal-open'); }

  initFlashSaleSections();
  fetchRealTimeInventory();

  updateUI();
  apgoSyncCartFromShopify();
</script>