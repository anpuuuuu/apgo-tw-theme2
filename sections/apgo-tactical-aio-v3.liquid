  .apgo-modal-backdrop { position: fixed !important; inset: 0 !important; background: rgba(0,0,0,0.8) !important; z-index: 10000 !important; display: none !important; backdrop-filter: blur(2px) !important; }
  .apgo-modal-content { position: fixed !important; bottom: 0 !important; left: 0 !important; width: 100% !important; background: #121212 !important; border-top: 1px solid #f08418 !important; z-index: 10001 !important; border-radius: 12px 12px 0 0 !important; max-height: 80vh !important; display: flex !important; flex-direction: column !important; transform: translateY(100%); transition: transform 0.3s !important; }
  @media(min-width:768px){ .apgo-modal-content { width: 500px !important; left: 50% !important; top: 50% !important; bottom: auto !important; transform: translate(-50%, -50%) !important; border-radius: 12px !important; border: 1px solid #f08418 !important; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.5) !important; } }
  .apgo-modal-open .apgo-modal-backdrop { display: block !important; }
