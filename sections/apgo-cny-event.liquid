        </section>
        {% endif %}

    </div>

    <div id="footer-backdrop" class="tw-fixed tw-inset-0 tw-bg-black/50 tw-z-40 tw-hidden tw-transition-opacity tw-backdrop-blur-sm" onclick="toggleApgoDrawer()"></div>

    <div id="apgo-smart-footer" class="tw-fixed tw-bottom-0 tw-left-0 tw-w-full tw-z-50 tw-transform tw-translate-y-[120%] tw-transition-transform tw-duration-500 tw-ease-out tw-flex tw-flex-col tw-items-end">
        <div id="apgo-cart-drawer" class="tw-w-full tw-bg-[#121212] tw-border-t tw-border-dt-orange/20 tw-max-h-0 tw-overflow-y-auto tw-transition-[max-height] tw-duration-300 tw-ease-in-out">
            <div class="tw-p-4 tw-space-y-3" id="apgo-cart-items-container">
                </div>
            <div class="tw-h-[80px]"></div>
        </div>
        
        <div class="tw-w-full tw-relative tw-shadow-[0_-10px_40px_rgba(0,0,0,0.9)]">
            <div class="tw-bg-[#1a1a1a] tw-w-full tw-py-1 tw-px-4 tw-border-t tw-border-dt-orange/50 tw-relative" onclick="toggleApgoDrawer()">
                <div class="tw-flex tw-justify-between tw-items-center tw-text-[10px] tw-mb-1 tw-cursor-pointer">
                    <span id="apgo-progress-text" class="tw-text-gray-400 tw-font-mono">任務目標: 解鎖黃金刮刮卡 (尚差 <span class="tw-text-dt-orange tw-font-bold">$2,888</span>)</span>
                    <i id="apgo-drawer-arrow" class="fas fa-chevron-up tw-text-gray-500 tw-transition-transform tw-duration-300"></i>
                </div>
                <div class="tw-w-full tw-bg-black tw-h-1.5 tw-rounded-none tw-overflow-hidden tw-relative">
                    <div id="apgo-progress-bar" class="tw-bg-dt-orange tw-h-full tw-w-0 tw-transition-all tw-duration-700 tw-ease-out tw-relative">
                        <div class="tw-absolute tw-inset-0 tw-w-full tw-h-full tw-bg-scan-line tw-animate-scan"></div>
                    </div>
                </div>
            </div>
            
            <div class="tw-bg-dt-screen/95 tw-backdrop-blur tw-border-t tw-border-dt-border tw-p-3 tw-flex tw-items-center tw-justify-between pb-safe tw-cursor-pointer" onclick="handleApgoFooterClick(event)">
                <div class="tw-flex tw-flex-col tw-pl-2 tw-group">
                    <div class="tw-text-dt-textSec tw-text-[10px] tw-font-mono tw-uppercase tw-flex tw-items-center tw-gap-1">
                        目前裝備數 <span class="tw-text-[9px] tw-bg-dt-border tw-px-1 tw-rounded tw-text-white" id="apgo-cart-count">0</span>
                    </div>
                    <div class="tw-text-white tw-font-mono tw-font-bold tw-text-2xl tw-flex tw-items-baseline !tw-text-white">
                        <span class="tw-text-sm tw-mr-1 tw-text-dt-orange">$</span>
                        <span id="apgo-cart-total-display">0</span>
                    </div>
                    <div class="tw-text-[9px] tw-text-gray-500 tw-mt-0.5 group-hover:tw-text-dt-orange tw-transition-colors">點擊查看明細</div>
                </div>
                <a href="/cart" class="tw-bg-dt-orange tw-text-black tw-font-black tw-px-8 tw-py-3 tw-rounded tw-shadow-[0_0_20px_rgba(240,132,24,0.4)] tw-flex tw-items-center tw-gap-2 active:tw-scale-95 tw-transition-transform clip-path-slant tw-z-10 hover:tw-bg-[#ff9f43] !tw-text-black !tw-no-underline">
                    去結帳 <i class="fas fa-chevron-right tw-text-xs"></i>
                </a>
            </div>
        </div>
    </div>
    <div id="apgo-footer-spacer" class="tw-h-0 tw-transition-all tw-duration-300"></div>

    <div id="modal-lucky-content" class="tw-fixed tw-inset-0 tw-z-[100] tw-hidden">
        <div class="tw-absolute tw-inset-0 tw-bg-black/80 tw-backdrop-blur-sm" onclick="closeModal('modal-lucky-content')"></div>
        <div class="tw-absolute tw-bottom-0 md:tw-top-1/2 md:tw-left-1/2 md:tw--translate-x-1/2 md:tw--translate-y-1/2 tw-w-full md:tw-w-[600px] tw-bg-[#121212] tw-border-t md:tw-border tw-border-dt-orange tw-rounded-t-xl md:tw-rounded-xl tw-shadow-2xl tw-flex tw-flex-col tw-max-h-[90vh]">
            
            <div class="tw-w-full tw-flex tw-justify-center tw-pt-3 tw-pb-1 md:tw-hidden" onclick="closeModal('modal-lucky-content')">
                <div class="tw-w-12 tw-h-1.5 tw-bg-gray-700 tw-rounded-full"></div>
            </div>

            <div class="tw-p-4 tw-border-b tw-border-dt-border tw-bg-[#1a1a1a] tw-flex tw-flex-col tw-items-center">
                <h3 class="tw-text-lg tw-font-bold tw-text-white !tw-text-white">福箱裝備清單</h3>
                <div class="tw-mt-1 tw-text-xs tw-text-gray-400">
                    總價值 <span class="tw-line-through tw-mr-1">${{ total_lucky_value }}</span> 
                    <i class="fas fa-arrow-right tw-text-dt-orange tw-mx-1"></i> 
                    驚喜價 <span class="tw-text-dt-gold tw-font-bold tw-text-lg">{{ lucky_product.price | default: 288800 | money_without_trailing_zeros }}</span>
                </div>
            </div>
            <div class="tw-p-4 tw-overflow-y-auto tw-bg-[#0a0a0a] tw-grid tw-grid-cols-3 md:tw-grid-cols-4 tw-gap-3">
                 {% for block in section.blocks %}
                    {% if block.type == 'lucky_item' %}
                        <div class="tw-bg-dt-input tw-border tw-border-dt-border tw-rounded tw-p-2 tw-flex tw-flex-col tw-items-center tw-text-center tw-relative">
                             <div class="tw-w-full tw-aspect-square tw-mb-2 tw-flex tw-items-center tw-justify-center">
                                 {% if block.settings.custom_img %}
                                    {{ block.settings.custom_img | image_url: width: 100 | image_tag: class: 'tw-w-full tw-h-full tw-object-contain', loading: 'lazy' }}
                                 {% else %}
                                    <div class="tw-text-[9px] tw-text-gray-600">
                                        ICON
                                    </div>
                                 {% endif %}
                            </div>
                            <div class="tw-text-xs tw-text-gray-300 tw-font-bold tw-leading-tight">{{ block.settings.item_name }}</div>
                            <div class="tw-absolute tw-top-1 tw-right-1 tw-bg-dt-border tw-text-white tw-text-[9px] tw-px-1 tw-rounded tw-font-mono">x{{ block.settings.item_qty }}</div>
                        </div>
                    {% endif %}
                 {% endfor %}
            </div>
            <div class="tw-p-4 tw-bg-[#1a1a1a] tw-border-t tw-border-dt-border">
                <button onclick="addToCart({{ lucky_product.selected_or_first_available_variant.id }})" class="tw-w-full tw-bg-dt-orange tw-text-black tw-font-bold tw-py-3 tw-rounded tw-shadow-lg">
                    立即以 {{ lucky_product.price | default: 288800 | money_without_trailing_zeros }} 帶走
                </button>
            </div>
        </div>
    </div>

    <div id="modal-variant" class="tw-fixed tw-inset-0 tw-z-[100] tw-hidden">
        <div class="tw-absolute tw-inset-0 tw-bg-black/80 tw-backdrop-blur-sm" onclick="closeModal('modal-variant')"></div>
        <div class="tw-absolute tw-bottom-0 md:tw-top-1/2 md:tw-left-1/2 md:tw--translate-x-1/2 md:tw--translate-y-1/2 tw-w-full md:tw-w-[500px] tw-bg-[#121212] tw-border-t md:tw-border tw-border-dt-orange tw-rounded-t-xl md:tw-rounded-xl tw-shadow-2xl tw-flex tw-flex-col tw-max-h-[90vh]">
            
            <div class="tw-w-full tw-flex tw-justify-center tw-pt-3 tw-pb-1 md:tw-hidden" onclick="closeModal('modal-variant')">
                <div class="tw-w-12 tw-h-1.5 tw-bg-gray-700 tw-rounded-full"></div>
            </div>

            <div class="tw-p-4 tw-border-b tw-border-dt-border tw-bg-[#1a1a1a]">
                <h3 id="variant-title" class="tw-text-lg tw-font-bold tw-text-white !tw-text-white">選擇規格</h3>
            </div>
            <div class="tw-p-5 tw-overflow-y-auto">
                <div id="variant-options" class="tw-grid tw-grid-cols-2 tw-gap-3"></div>
            </div>
            <div class="tw-p-4 tw-bg-[#1a1a1a] tw-border-t tw-border-dt-border tw-flex tw-gap-3 pb-safe">
                <button onclick="closeModal('modal-variant')" class="tw-flex-1 tw-border tw-border-dt-border tw-text-gray-400 tw-py-3 tw-rounded tw-font-mono tw-text-sm">取消</button>
                <button id="variant-confirm-btn" class="tw-flex-[2] tw-bg-dt-orange tw-text-black tw-font-bold tw-py-3 tw-rounded">加入購物車</button>
            </div>
        </div>
    </div>

</div>

<script>
    const TARGET_AMOUNT = 2888;
    let isDrawerOpen = false;
    let selectedVariantId = null;

    document.addEventListener('DOMContentLoaded', function() {
        refreshCart();
        
        const heroSection = document.getElementById('section-hero');
        const stickyNav = document.getElementById('apgo-sticky-nav');
        const placeholder = document.getElementById('nav-placeholder');
        const sections = document.querySelectorAll('section');
        const navLinks = document.querySelectorAll('.sticky-nav-link');
        const navContainer = document.getElementById('sticky-nav-container');

        // Sticky & Scroll Spy
        window.addEventListener('scroll', () => {
            const heroHeight = heroSection.offsetHeight;
            if (window.scrollY > heroHeight) {
                stickyNav.classList.add('nav-fixed');
                placeholder.classList.remove('tw-hidden');
            } else {
                stickyNav.classList.remove('nav-fixed');
                placeholder.classList.add('tw-hidden');
            }
            
            let currentSectionId = '';
            const scrollY = window.scrollY;
            const viewportHeight = window.innerHeight;
            const checkPoint = scrollY + (viewportHeight * 0.4);

            sections.forEach(section => {
                const sectionTop = section.offsetTop;
                const sectionHeight = section.offsetHeight;
                if (checkPoint >= sectionTop && checkPoint < sectionTop + sectionHeight) {
                    currentSectionId = section.getAttribute('id');
                }
            });

            if (currentSectionId) {
                navLinks.forEach(link => {
                    link.classList.remove('active');
                    if(link.getAttribute('data-target') === currentSectionId) {
                        link.classList.add('active');
                        const containerWidth = navContainer.clientWidth;
                        const itemLeft = link.offsetLeft;
                        const itemWidth = link.clientWidth;
                        const scrollLeft = itemLeft - (containerWidth / 2) + (itemWidth / 2);
                        navContainer.scrollTo({ left: scrollLeft, behavior: 'smooth' });
                    }
                });
            }
        });
    });

    function scrollToSection(id) {
        const section = document.getElementById(id);
        if (section) {
            const offset = 60; 
            const top = section.offsetTop - offset;
            window.scrollTo({
                top: top,
                behavior: 'smooth'
            });
        }
    }

    function removeFromCart(variantId) {
        if(!variantId) return;
        let formData = { 'id': variantId.toString(), 'quantity': 0 };
        fetch(window.Shopify.routes.root + 'cart/change.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(formData)
        })
        .then(response => response.json())
        .then(data => { refreshCart(); })
        .catch((error) => { console.error('Error removing item:', error); });
    }

    function addToCart(variantId) {
        if(!variantId) return;
        let formData = { 'items': [{ 'id': variantId, 'quantity': 1 }] };
        fetch(window.Shopify.routes.root + 'cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(formData)
        })
        .then(response => response.json())
        .then(data => {
            if(navigator.vibrate) navigator.vibrate(15);
            closeModal('modal-variant');
            closeModal('modal-lucky-content');
            refreshCart(); 
        })
        .catch((error) => {
            console.error('Error:', error);
            alert('加入失敗，請稍後再試');
        });
    }

    function refreshCart() {
        fetch(window.Shopify.routes.root + 'cart.js')
        .then(response => response.json())
        .then(cart => { updateFooterUI(cart); });
    }

    function updateFooterUI(cart) {
        const footer = document.getElementById('apgo-smart-footer');
        const spacer = document.getElementById('apgo-footer-spacer');
        const totalDisplay = document.getElementById('apgo-cart-total-display');
        const countDisplay = document.getElementById('apgo-cart-count');
        const progressBar = document.getElementById('apgo-progress-bar');
        const progressText = document.getElementById('apgo-progress-text');
        const backdrop = document.getElementById('footer-backdrop');
        
        let totalPrice = cart.total_price / 100;
        
        totalDisplay.innerText = totalPrice.toLocaleString();
        countDisplay.innerText = cart.item_count;

        // Toggle Footer Visibility
        if (cart.item_count > 0) {
            footer.classList.remove('tw-translate-y-[120%]');
            spacer.classList.add('tw-h-[140px]');
        } else {
            footer.classList.add('tw-translate-y-[120%]');
            spacer.classList.remove('tw-h-[140px]');
            // 如果購物車清空，確保遮罩也關閉
            if(isDrawerOpen) {
                toggleApgoDrawer();
            }
        }

        let percent = Math.min((totalPrice / TARGET_AMOUNT) * 100, 100);
        progressBar.style.width = percent + '%';

        if (totalPrice >= TARGET_AMOUNT) {
            progressText.innerHTML = '<span class="tw-text-green-500 tw-font-bold tw-font-mono">[ 任務完成 ]</span> 黃金刮刮卡資格已獲取';
            progressBar.classList.remove('tw-bg-dt-orange');
            progressBar.classList.add('tw-bg-green-500');
        } else {
            let diff = TARGET_AMOUNT - totalPrice;
            progressText.innerHTML = `任務目標: 解鎖黃金刮刮卡 (尚差 <span class="tw-text-dt-orange tw-font-bold">$${diff.toLocaleString()}</span>)`;
            progressBar.classList.add('tw-bg-dt-orange');
            progressBar.classList.remove('tw-bg-green-500');
        }

        renderCartItems(cart.items);
    }

    function renderCartItems(items) {
        const container = document.getElementById('apgo-cart-items-container');
        container.innerHTML = '';
        items.forEach(item => {
            const itemEl = document.createElement('div');
            itemEl.className = 'tw-relative tw-flex tw-gap-3 tw-bg-[#1a1a1a] tw-p-2 tw-rounded tw-border tw-border-dt-border tw-group';
            itemEl.innerHTML = `
                <div class="tw-w-16 tw-h-16 tw-bg-[#111] tw-border tw-border-dt-border tw-rounded tw-flex tw-items-center tw-justify-center tw-overflow-hidden tw-flex-shrink-0">
                    <img src="${item.image}" class="tw-w-full tw-h-full tw-object-cover" width="64" height="64">
                </div>
                <div class="tw-flex-1 tw-min-w-0 tw-flex tw-flex-col tw-justify-between">
                    <div class="tw-flex tw-justify-between tw-items-start">
                        <div class="tw-truncate tw-pr-6">
                            <div class="tw-text-white tw-text-sm tw-font-bold tw-truncate !tw-text-white">${item.product_title}</div>
                            ${item.variant_title != 'Default Title' ? `<div class="tw-text-dt-orange tw-text-xs tw-font-mono tw-mt-0.5">${item.variant_title}</div>` : ''}
                        </div>
                        <button onclick="removeFromCart(${item.variant_id})" class="tw-text-gray-600 hover:tw-text-dt-danger tw-transition-colors tw-absolute tw-top-2 tw-right-2">
                            <i class="fas fa-trash-alt"></i>
                        </button>
                    </div>
                    
                    <div class="tw-flex tw-justify-between tw-items-end tw-mt-1">
                        <div class="tw-text-[10px] tw-font-mono tw-bg-dt-border tw-text-gray-300 tw-px-1.5 tw-py-0.5 tw-rounded">QTY: ${item.quantity}</div>
                        <div class="tw-text-white tw-font-mono tw-font-bold !tw-text-white">$${(item.price / 100).toLocaleString()}</div>
                    </div>
                </div>
            `;
            container.appendChild(itemEl);
        });
    }

    // [重要] 遮罩與抽屜切換邏輯
    function toggleApgoDrawer() {
        const drawer = document.getElementById('apgo-cart-drawer');
        const arrow = document.getElementById('apgo-drawer-arrow');
        const backdrop = document.getElementById('footer-backdrop');
        
        isDrawerOpen = !isDrawerOpen;
        
        if (!isDrawerOpen) {
            // 關閉狀態
            drawer.style.maxHeight = '0px';
            arrow.style.transform = 'rotate(0deg)';
            backdrop.classList.add('tw-hidden');
        } else {
            // 開啟狀態
            drawer.style.maxHeight = '50vh';
            arrow.style.transform = 'rotate(180deg)';
            backdrop.classList.remove('tw-hidden');
        }
    }

    function handleApgoFooterClick(e) {
        if (e.target.closest('a')) return; 
        toggleApgoDrawer();
    }

    function openLuckyContentModal() {
        document.getElementById('modal-lucky-content').classList.remove('tw-hidden');
    }

    function closeModal(id) {
        document.getElementById(id).classList.add('tw-hidden');
    }

    function openVariantModal(productTitle, productId) {
        const dataScript = document.getElementById(`variants-data-${productId}`);
        if(!dataScript) { console.error("Variant data not found"); return; }
        const variants = JSON.parse(dataScript.innerHTML);

        const container = document.getElementById('variant-options');
        const confirmBtn = document.getElementById('variant-confirm-btn');
        document.getElementById('variant-title').innerText = productTitle;
        
        container.innerHTML = '';
        selectedVariantId = null;
        confirmBtn.disabled = true;
        confirmBtn.classList.add('tw-opacity-50');

        variants.forEach((v, idx) => {
            const card = document.createElement('div');
            card.className = 'tw-cursor-pointer tw-relative tw-group';
            let displayPrice = v.price.replace('$', '').replace('.00', '');
            
            card.innerHTML = `
                <div class="tw-border tw-border-dt-border tw-bg-[#1a1a1a] tw-rounded-lg tw-p-2 tw-transition-all hover:tw-border-gray-500 tw-h-full tw-flex tw-flex-col" id="variant-card-${v.id}">
                    <div class="tw-w-full tw-aspect-square tw-rounded tw-mb-2 tw-bg-[#111] tw-overflow-hidden">
                        <img src="${v.img}" class="tw-w-full tw-h-full tw-object-cover" width="200" height="200">
                    </div>
                    <div class="tw-mt-auto">
                        <div class="tw-text-gray-300 tw-text-xs tw-font-bold tw-leading-tight tw-mb-1">${v.title}</div>
                        <div class="tw-text-dt-orange tw-font-mono tw-font-bold">$${displayPrice}</div>
                    </div>
                    <div class="tw-absolute tw-inset-0 tw-border-2 tw-border-dt-orange tw-rounded-lg tw-opacity-0" id="variant-ring-${v.id}"></div>
                    ${!v.available ? '<div class="tw-absolute tw-inset-0 tw-bg-black/60 tw-flex tw-items-center tw-justify-center tw-text-white tw-text-xs tw-font-bold">售完</div>' : ''}
                </div>`;
            
            if(v.available) {
                card.onclick = () => {
                    variants.forEach(vr => {
                        const ring = document.getElementById(`variant-ring-${vr.id}`);
                        if(ring) ring.classList.add('tw-opacity-0');
                    });
                    document.getElementById(`variant-ring-${v.id}`).classList.remove('tw-opacity-0');
                    selectedVariantId = v.id;
                    confirmBtn.disabled = false;
                    confirmBtn.classList.remove('tw-opacity-50');
                };
            }
            container.appendChild(card);
        });

        confirmBtn.onclick = () => addToCart(selectedVariantId);
        document.getElementById('modal-variant').classList.remove('tw-hidden');
    }
</script>

