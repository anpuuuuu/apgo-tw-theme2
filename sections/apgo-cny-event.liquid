{% comment %}
  APGO 2026 新春戰術活動頁 - All-in-One Section
  Version: 14.0 (Visibility Toggles & Smart Footer Backdrop)
{% endcomment %}

<link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"></noscript>
<link rel="preload" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Noto+Sans+TC:wght@400;500;700;900&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
<noscript><link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Noto+Sans+TC:wght@400;500;700;900&display=swap" rel="stylesheet"></noscript>

<script>
    window.tailwindConfig = {
        prefix: 'tw-', 
        theme: {
            extend: {
                fontFamily: {
                    sans: ['"Noto Sans TC"', 'sans-serif'],
                    mono: ['"JetBrains Mono"', 'monospace'],
                },
                colors: {
                    dt: {
                        screen: '#050505',
                        surface: '#121212',
                        input: '#1a1a1a',
                        border: '#333333',
                        orange: '#f08418',
                        gold: '#C5A572',
                        textSec: '#999999',
                        danger: '#ef4444' 
                    }
                },
                backgroundImage: {
                    'scan-line': 'linear-gradient(to right, transparent 0%, rgba(255,255,255,0.4) 50%, transparent 100%)',
                },
                animation: {
                    'scan': 'scan 2s linear infinite',
                },
                keyframes: {
                    scan: {
                        '0%': { transform: 'translateX(-100%) skewX(-15deg)' },
                        '100%': { transform: 'translateX(200%) skewX(-15deg)' }
                    }
                }
            }
        }
    }
</script>
<script src="https://cdn.tailwindcss.com" defer onload="tailwind.config = window.tailwindConfig"></script>

<style>
    /* 強制覆蓋主題樣式 */
    #apgo-tactical-section {
        background-color: #050505 !important;
        color: #e5e5e5 !important;
        font-family: "Noto Sans TC", sans-serif !important;
        line-height: 1.5;
        width: 100%;
        overflow-x: hidden;
    }

    #apgo-tactical-section h1, h2, h3, h4, p, span, div, button {
        color: inherit; 
    }

    #apgo-tactical-section .font-mono {
        font-family: "JetBrains Mono", monospace !important;
    }

    /* 隱藏滾動條 */
    .scrollbar-hide::-webkit-scrollbar { display: none; }
    .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

    /* 圖片佔位符 */
    .placeholder-box {
        background-color: #1a1a1a; border: 2px dashed #333;
        display: flex; flex-direction: column; align-items: center; justify-content: center;
        color: #666; font-family: 'JetBrains Mono', monospace; text-align: center;
    }

    /* 斜角與按鈕 */
    .clip-path-slant { clip-path: polygon(10% 0, 100% 0, 100% 100%, 0% 100%); padding-left: 2rem; }
    
    /* 雙排滑動佈局 ($88) */
    .grid-scroll-area {
        display: grid; grid-template-rows: repeat(2, 1fr);
        grid-auto-flow: column; grid-auto-columns: 140px;
        gap: 12px; overflow-x: auto; scroll-snap-type: x mandatory; padding-bottom: 10px;
    }
    @media (min-width: 768px) { .grid-scroll-area { grid-auto-columns: 200px; } }
    .snap-item { scroll-snap-align: start; }

    /* 導航列樣式 */
    .sticky-nav-link {
        color: #999; padding: 12px 16px; font-weight: bold; font-size: 14px; white-space: nowrap;
        border-bottom: 2px solid transparent; transition: all 0.3s; cursor: pointer;
    }
    .sticky-nav-link:hover, .sticky-nav-link.active {
        color: #f08418; border-bottom-color: #f08418;
    }
    
    /* 強制固定樣式 */
    .nav-fixed {
        position: fixed !important;
        top: 0; left: 0; width: 100%;
        background-color: rgba(5, 5, 5, 0.95);
        backdrop-filter: blur(8px);
        z-index: 999;
        box-shadow: 0 4px 20px rgba(0,0,0,0.5);
        animation: slideDown 0.3s ease-out;
    }
    @keyframes slideDown {
        from { transform: translateY(-100%); }
        to { transform: translateY(0); }
    }
    
    section { scroll-margin-top: 60px; }
    .pb-safe { padding-bottom: env(safe-area-inset-bottom); }
    html { scroll-behavior: smooth; }
</style>

<div id="apgo-tactical-section" class="tw-relative tw-pb-40">

    <section id="section-hero" class="tw-w-full tw-relative">
        <div class="tw-hidden md:tw-block tw-w-full tw-h-auto">
            {% if section.settings.hero_image_pc %}
                {{ section.settings.hero_image_pc | image_url: width: 1920 | image_tag: class: 'tw-w-full tw-object-cover tw-h-auto', loading: 'eager', sizes: '100vw' }}
            {% else %}
                <div class="placeholder-box tw-w-full tw-h-[600px] tw-border-b tw-border-dt-orange">PC Banner (1920x850)</div>
            {% endif %}
        </div>
        <div class="md:tw-hidden tw-w-full tw-h-auto">
            {% if section.settings.hero_image_mb %}
                 {{ section.settings.hero_image_mb | image_url: width: 750 | image_tag: class: 'tw-w-full tw-object-cover tw-h-auto', loading: 'eager', sizes: '100vw' }}
            {% else %}
                <div class="placeholder-box tw-w-full tw-h-[500px] tw-border-b tw-border-dt-orange">Mobile Banner (750x1100)</div>
            {% endif %}
        </div>
    </section>

    <div id="nav-placeholder" class="tw-w-full tw-h-[50px] tw-hidden"></div>
    
    <div id="apgo-sticky-nav" class="tw-w-full tw-bg-[#050505] tw-border-b tw-border-dt-border tw-z-40">
        <div id="sticky-nav-container" class="tw-max-w-[1200px] tw-mx-auto tw-flex tw-overflow-x-auto scrollbar-hide">
            <div data-target="section-hero" class="sticky-nav-link" onclick="scrollToSection('section-hero')">主會場</div>
            
            {% if section.settings.show_luckybox %}
                <div data-target="section-luckybox" class="sticky-nav-link" onclick="scrollToSection('section-luckybox')">{{ section.settings.lucky_title }}</div>
            {% endif %}
            
            {% if section.settings.show_bogo %}
                <div data-target="section-bundle" class="sticky-nav-link" onclick="scrollToSection('section-bundle')">{{ section.settings.bogo_title }}</div>
            {% endif %}
            
            {% if section.settings.show_zone88 %}
                <div data-target="section-88" class="sticky-nav-link" onclick="scrollToSection('section-88')">$88專區</div>
            {% endif %}
            
            {% if section.settings.show_selected %}
                <div data-target="section-selected" class="sticky-nav-link" onclick="scrollToSection('section-selected')">{{ section.settings.selected_title }}</div>
            {% endif %}
        </div>
    </div>

    <div class="tw-max-w-[1200px] tw-mx-auto tw-px-4 tw-space-y-16 tw-py-8">
        
        {% if section.settings.show_luckybox %}
        <section id="section-luckybox" class="tw-w-full">
            <div class="tw-flex tw-items-center tw-gap-2 tw-mb-4">
                <div class="tw-w-1 tw-h-6 tw-bg-dt-orange"></div>
                <h2 class="tw-text-xl tw-font-bold tw-text-white tw-tracking-widest !tw-text-white">{{ section.settings.lucky_title }}</h2>
            </div>
            
            {% assign lucky_product = all_products[section.settings.lucky_product] %}
            
            <div class="tw-bg-dt-surface tw-border tw-border-dt-border tw-rounded-xl tw-overflow-hidden tw-relative">
                <div class="tw-w-full tw-h-auto tw-bg-dt-input tw-relative">
                   {% if section.settings.lucky_image %}
                        {{ section.settings.lucky_image | image_url: width: 1200 | image_tag: class: 'tw-w-full tw-h-auto tw-object-contain tw-block', loading: 'lazy', sizes: '(min-width: 768px) 1200px, 100vw' }}
                   {% else %}
                        <div class="placeholder-box tw-w-full tw-h-[400px]">福箱圖片 (高度自適應)</div>
                   {% endif %}
                </div>

                <div class="tw-p-5 tw-relative">
                    <div class="tw-flex tw-justify-between tw-items-end tw-mb-6">
                        <div>
                            <h3 class="tw-text-2xl tw-font-bold tw-text-white !tw-text-white">{{ lucky_product.title | default: 'APGO 馬年發財福箱' }}</h3>
                            <div class="tw-text-sm tw-text-dt-textSec tw-mt-1">{{ section.settings.lucky_desc }}</div>
                        </div>
                        <div class="tw-text-right">
                             {% if lucky_product.compare_at_price > lucky_product.price %}
                                <div class="tw-text-xs tw-text-dt-textSec tw-line-through tw-decoration-dt-orange">{{ lucky_product.compare_at_price | money_without_trailing_zeros }}</div>
                             {% endif %}
                            <div class="tw-text-3xl tw-font-mono tw-font-bold tw-text-dt-gold">{{ lucky_product.price | default: 288800 | money_without_trailing_zeros }}</div>
                        </div>
                    </div>

                    <div class="tw-bg-[#151515] tw-border tw-border-dt-border tw-rounded-lg tw-p-4 tw-mb-6">
                        <div class="tw-flex tw-justify-between tw-items-center tw-mb-3 tw-border-b tw-border-dt-border/50 tw-pb-2">
                            <span class="tw-text-xs tw-font-mono tw-text-dt-orange">內容物預覽</span>
                            <button onclick="openLuckyContentModal()" class="tw-text-xs tw-text-white hover:tw-text-dt-orange tw-flex tw-items-center tw-gap-1 tw-transition-colors">
                                查看全部 <i class="fas fa-search-plus"></i>
                            </button>
                        </div>
                        <div class="tw-grid tw-grid-cols-4 tw-gap-2">
                            {% assign lucky_blocks_count = 0 %}
                            {% assign total_lucky_value = 0 %}
                            
                            {% for block in section.blocks %}
                                {% if block.type == 'lucky_item' %}
                                    {% assign lucky_blocks_count = lucky_blocks_count | plus: 1 %}
                                    {% assign item_total = block.settings.item_value | times: block.settings.item_qty %}
                                    {% assign total_lucky_value = total_lucky_value | plus: item_total %}
                                    {% if lucky_blocks_count <= 4 %}
                                        <div class="tw-aspect-square tw-bg-dt-input tw-rounded tw-border tw-border-dt-border tw-flex tw-items-center tw-justify-center tw-p-1 tw-overflow-hidden">
                                            {% if block.settings.custom_img %}
                                                {{ block.settings.custom_img | image_url: width: 100 | image_tag: class: 'tw-w-full tw-h-full tw-object-contain', loading: 'lazy' }}
                                            {% else %}
                                                <div class="tw-text-[9px] tw-text-center tw-text-gray-500">
                                                    {% if block.settings.item_icon == 'main' %}<i class="fas fa-bottle-droplet tw-text-lg tw-mb-1"></i>{% endif %}
                                                    {% if block.settings.item_icon == 'tool' %}<i class="fas fa-tools tw-text-lg tw-mb-1"></i>{% endif %}
                                                    {% if block.settings.item_icon == 'gift' %}<i class="fas fa-gift tw-text-lg tw-mb-1"></i>{% endif %}
                                                    <br>{{ block.settings.item_name | truncate: 4 }}
                                                </div>
                                            {% endif %}
                                        </div>
                                    {% endif %}
                                {% endif %}
                            {% endfor %}
                            
                            {% if lucky_blocks_count > 4 %}
                                <div class="tw-aspect-square tw-bg-dt-input tw-rounded tw-border tw-border-dt-border tw-flex tw-items-center tw-justify-center tw-p-1 tw-cursor-pointer hover:tw-border-dt-orange" onclick="openLuckyContentModal()">
                                    <div class="tw-text-xs tw-font-bold tw-text-dt-orange">+{{ lucky_blocks_count | minus: 4 }}</div>
                                </div>
                            {% endif %}
                        </div>
                    </div>

                    {% if lucky_product.available %}
                        <button onclick="addToCart({{ lucky_product.selected_or_first_available_variant.id }})" class="tw-w-full tw-bg-dt-orange tw-text-black tw-font-bold tw-py-4 tw-rounded tw-shadow-[0_0_15px_rgba(240,132,24,0.3)] hover:tw-bg-[#ff9f43] active:tw-scale-[0.98] tw-transition-all tw-relative tw-overflow-hidden">
                            <span class="tw-relative tw-z-10">立即搶購</span>
                            <div class="tw-absolute tw-top-0 tw-left-0 tw-w-full tw-h-full tw-bg-gradient-to-r tw-from-transparent tw-via-white/20 tw-to-transparent tw--translate-x-full tw-animate-[shimmer_2s_infinite]"></div>
                        </button>
                    {% else %}
                         <button class="tw-w-full tw-bg-gray-700 tw-text-gray-400 tw-font-bold tw-py-4 tw-rounded tw-cursor-not-allowed">已售完</button>
                    {% endif %}
                </div>
            </div>
        </section>
        {% endif %}

        {% if section.settings.show_bogo %}
        <section id="section-bundle" class="tw-w-full">
            <div class="tw-flex tw-items-center tw-gap-2 tw-mb-4">
                <div class="tw-w-1 tw-h-6 tw-bg-dt-orange"></div>
                <h2 class="tw-text-xl tw-font-bold tw-text-white tw-tracking-widest !tw-text-white">{{ section.settings.bogo_title }}</h2>
            </div>
            
            <div class="tw-mb-6 tw-rounded-xl tw-overflow-hidden tw-border tw-border-dt-orange/30">
                <div class="tw-hidden md:tw-block">
                    {% if section.settings.bogo_banner_pc %}
                        {{ section.settings.bogo_banner_pc | image_url: width: 1200 | image_tag: class: 'tw-w-full tw-h-auto', loading: 'lazy' }}
                    {% else %}
                         <div class="placeholder-box tw-w-full tw-h-[250px]">PC BOGO Banner</div>
                    {% endif %}
                </div>
                 <div class="md:tw-hidden">
                    {% if section.settings.bogo_banner_mb %}
                        {{ section.settings.bogo_banner_mb | image_url: width: 750 | image_tag: class: 'tw-w-full tw-h-auto', loading: 'lazy' }}
                    {% else %}
                         <div class="placeholder-box tw-w-full tw-h-[200px]">Mobile BOGO Banner</div>
                    {% endif %}
                </div>
            </div>

            <div class="tw-grid tw-grid-cols-1 md:tw-grid-cols-2 tw-gap-4">
                {% for block in section.blocks %}
                    {% if block.type == 'bogo_item' %}
                        {% assign p = all_products[block.settings.product] %}
                        {% if p != empty %}
                        <div class="tw-bg-dt-surface tw-border tw-border-dt-border tw-rounded-xl tw-p-4 tw-flex tw-flex-col">
                            <div class="tw-w-full tw-aspect-square tw-bg-dt-input tw-rounded-lg tw-mb-4 tw-overflow-hidden tw-flex tw-items-center tw-justify-center">
                                {{ p.featured_image | image_url: width: 600 | image_tag: class: 'tw-w-full tw-h-full tw-object-contain', loading: 'lazy' }}
                            </div>
                            
                            <h3 class="tw-text-lg tw-font-bold tw-text-white !tw-text-white tw-mb-2">{{ p.title }}</h3>
                            
                            <div class="tw-font-mono tw-text-2xl tw-font-bold tw-text-dt-orange tw-mb-4">
                                {% if block.settings.custom_price != blank %}
                                    {{ block.settings.custom_price }}
                                {% else %}
                                    {{ p.price | money_without_trailing_zeros }}
                                {% endif %}
                            </div>
                            
                            <div class="tw-mt-auto">
                                {% if p.variants.size > 1 %}
                                    <script type="application/json" id="variants-data-{{ p.id }}">
                                        [
                                            {% for variant in p.variants %}
                                                {
                                                    "id": {{ variant.id }},
                                                    "title": "{{ variant.title }}",
                                                    "price": "{{ variant.price | money_without_trailing_zeros }}",
                                                    "img": "{% if variant.image %}{{ variant.image | image_url: width: 300 }}{% else %}{{ p.featured_image | image_url: width: 300 }}{% endif %}",
                                                    "available": {{ variant.available }}
                                                }{% unless forloop.last %},{% endunless %}
                                            {% endfor %}
                                        ]
                                    </script>
                                    <button onclick="openVariantModal('{{ p.title | escape }}', {{ p.id }})" class="tw-w-full tw-bg-dt-orange tw-text-black tw-font-black tw-py-3 tw-rounded hover:tw-bg-[#ff9f43] tw-transition-colors tw-flex tw-items-center tw-justify-center tw-gap-2">
                                        <i class="fas fa-cart-plus"></i> 加入購物車
                                    </button>
                                {% else %}
                                    <button onclick="addToCart({{ p.first_available_variant.id }})" class="tw-w-full tw-bg-dt-orange tw-text-black tw-font-black tw-py-3 tw-rounded hover:tw-bg-[#ff9f43] tw-transition-colors tw-flex tw-items-center tw-justify-center tw-gap-2">
                                        <i class="fas fa-cart-plus"></i> 加入購物車
                                    </button>
                                {% endif %}
                            </div>
                        </div>
                        {% endif %}
                    {% endif %}
                {% endfor %}
            </div>
        </section>
        {% endif %}

        {% if section.settings.show_zone88 %}
        <section id="section-88" class="tw-w-full">
            <div class="tw-flex tw-items-center tw-gap-2 tw-mb-4">
                <div class="tw-w-1 tw-h-6 tw-bg-dt-orange"></div>
                <h2 class="tw-text-xl tw-font-bold tw-text-white tw-tracking-widest !tw-text-white">$88 戰術補給</h2>
            </div>
            
            <div class="tw-mb-6 tw-rounded-xl tw-overflow-hidden tw-border tw-border-dt-border">
                <div class="tw-hidden md:tw-block">
                    {% if section.settings.zone_88_banner_pc %}
                        {{ section.settings.zone_88_banner_pc | image_url: width: 1200 | image_tag: class: 'tw-w-full tw-h-auto', loading: 'lazy' }}
                    {% else %}
                         <div class="placeholder-box tw-w-full tw-h-[200px]">$88 Banner PC</div>
                    {% endif %}
                </div>
                 <div class="md:tw-hidden">
                    {% if section.settings.zone_88_banner_mb %}
                        {{ section.settings.zone_88_banner_mb | image_url: width: 750 | image_tag: class: 'tw-w-full tw-h-auto', loading: 'lazy' }}
                    {% else %}
                         <div class="placeholder-box tw-w-full tw-h-[150px]">$88 Banner MB</div>
                    {% endif %}
                </div>
            </div>

            <div class="grid-scroll-area scrollbar-hide">
                {% for block in section.blocks %}
                    {% if block.type == 'zone88_item' %}
                        {% assign p = all_products[block.settings.product] %}
                        {% if p != empty %}
                        <div class="snap-item tw-bg-dt-surface tw-border tw-border-dt-border tw-rounded-lg tw-p-3 tw-flex tw-flex-col tw-h-full tw-group tw-relative">
                            <div class="tw-w-full tw-h-[100px] tw-bg-[#111] tw-rounded tw-mb-2 tw-overflow-hidden tw-flex tw-items-center tw-justify-center">
                                 {% if block.settings.custom_img %}
                                    {{ block.settings.custom_img | image_url: width: 200 | image_tag: class: 'tw-w-full tw-h-full tw-object-contain', loading: 'lazy' }}
                                 {% else %}
                                    {{ p.featured_image | image_url: width: 200 | image_tag: class: 'tw-w-full tw-h-full tw-object-contain', loading: 'lazy' }}
                                 {% endif %}
                            </div>
                            
                            <h4 class="tw-text-xs tw-text-gray-300 tw-font-bold tw-mb-1 tw-truncate">
                                {% if block.settings.custom_title != blank %}
                                    {{ block.settings.custom_title }}
                                {% else %}
                                    {{ p.title }}
                                {% endif %}
                            </h4>
                            
                            <div class="tw-mt-auto tw-flex tw-justify-between tw-items-end">
                                <div class="tw-font-mono tw-text-lg tw-font-bold tw-text-dt-orange">${{ block.settings.display_price }}</div>
                                
                                {% if p.variants.size > 1 %}
                                     <script type="application/json" id="variants-data-{{ p.id }}">
                                        [
                                            {% for variant in p.variants %}
                                                {
                                                    "id": {{ variant.id }},
                                                    "title": "{{ variant.title }}",
                                                    "price": "{{ variant.price | money_without_trailing_zeros }}",
                                                    "img": "{% if variant.image %}{{ variant.image | image_url: width: 300 }}{% else %}{{ p.featured_image | image_url: width: 300 }}{% endif %}",
                                                    "available": {{ variant.available }}
                                                }{% unless forloop.last %},{% endunless %}
                                            {% endfor %}
                                        ]
                                    </script>
                                    <button onclick="openVariantModal('{{ p.title | escape }}', {{ p.id }})" class="tw-bg-dt-border tw-text-white tw-w-7 tw-h-7 tw-rounded tw-flex tw-items-center tw-justify-center hover:tw-bg-dt-orange hover:tw-text-black tw-transition-colors"><i class="fas fa-plus tw-text-xs"></i></button>
                                {% else %}
                                    <button onclick="addToCart({{ p.first_available_variant.id }})" class="tw-bg-dt-border tw-text-white tw-w-7 tw-h-7 tw-rounded tw-flex tw-items-center tw-justify-center hover:tw-bg-dt-orange hover:tw-text-black tw-transition-colors"><i class="fas fa-plus tw-text-xs"></i></button>
                                {% endif %}
                            </div>
                        </div>
                        {% endif %}
                    {% endif %}
                {% endfor %}
            </div>
        </section>
        {% endif %}

        {% if section.settings.show_selected %}
        <section id="section-selected" class="tw-w-full">
            <div class="tw-flex tw-items-center tw-gap-2 tw-mb-4">
                <div class="tw-w-1 tw-h-6 tw-bg-dt-orange"></div>
                <h2 class="tw-text-xl tw-font-bold tw-text-white tw-tracking-widest !tw-text-white">{{ section.settings.selected_title }}</h2>
            </div>
            
            <div class="tw-mb-6 tw-rounded-xl tw-overflow-hidden">
                <div class="tw-hidden md:tw-block">
                    {% if section.settings.selected_banner_pc %}
                        {{ section.settings.selected_banner_pc | image_url: width: 1200 | image_tag: class: 'tw-w-full tw-h-auto', loading: 'lazy' }}
                    {% else %}
                         <div class="placeholder-box tw-w-full tw-h-[200px]">Selected Banner PC</div>
                    {% endif %}
                </div>
                 <div class="md:tw-hidden">
                    {% if section.settings.selected_banner_mb %}
                        {{ section.settings.selected_banner_mb | image_url: width: 750 | image_tag: class: 'tw-w-full tw-h-auto', loading: 'lazy' }}
                    {% else %}
                         <div class="placeholder-box tw-w-full tw-h-[150px]">Selected Banner MB</div>
                    {% endif %}
                </div>
            </div>
            
            <div class="tw-grid tw-grid-cols-2 md:tw-grid-cols-4 tw-gap-3">
                {% for block in section.blocks %}
                    {% if block.type == 'selected_item' %}
                        {% assign p = all_products[block.settings.product] %}
                        {% if p != empty %}
                        <div class="tw-bg-dt-surface tw-border tw-border-dt-border tw-rounded-lg tw-p-3">
                            <div class="tw-w-full tw-h-[120px] tw-bg-dt-input tw-rounded tw-mb-2 tw-overflow-hidden tw-flex tw-items-center tw-justify-center">
                                {{ p.featured_image | image_url: width: 300 | image_tag: class: 'tw-w-full tw-h-full tw-object-contain', loading: 'lazy' }}
                            </div>
                            <h4 class="tw-text-sm tw-font-bold tw-text-gray-300 tw-truncate">{{ p.title }}</h4>
                            <div class="tw-flex tw-justify-between tw-items-center tw-mt-2">
                                <span class="tw-text-dt-gold tw-font-mono tw-font-bold">{{ p.price | money_without_trailing_zeros }}</span>
                                <button onclick="addToCart({{ p.first_available_variant.id }})" class="tw-w-6 tw-h-6 tw-bg-dt-border tw-rounded tw-flex tw-items-center tw-justify-center tw-text-xs hover:tw-bg-dt-orange hover:tw-text-black"><i class="fas fa-plus"></i></button>
                            </div>
