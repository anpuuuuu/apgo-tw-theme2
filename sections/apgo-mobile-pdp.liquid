{% comment %}
  APGO · PDP 內容 (shared mega section, mobile + desktop)
  Mobile: shows full layout — carousel + info + tabs/panels + sticky CTA
  Desktop: only tabs + panels show (apgo-hero handles top of page).
  The .apgo-mpdp-mobile-shell wrapper + .apgo-mpdp-sticky are hidden on desktop via CSS.
{% endcomment %}

{%- liquid
  assign v = product.selected_or_first_available_variant
  assign has_compare = false
  if product.compare_at_price > product.price
    assign has_compare = true
    assign discount_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price
  endif
-%}

<section class="apgo-mpdp" data-section-id="{{ section.id }}">
  {% form 'product', product, id: 'apgo-mobile-product-form', class: 'apgo-product-form apgo-mpdp-form' %}
    <input type="hidden" name="id" value="{{ v.id }}" data-apgo-variant-id>

    {%- comment -%} ====== MOBILE-ONLY SHELL: carousel + info block (hidden on desktop) ====== {%- endcomment -%}
    <div class="apgo-mpdp-mobile-shell">

    {%- comment -%} Carousel (video optional + images) {%- endcomment -%}
    <div class="apgo-mpdp-carousel" data-apgo-carousel>
      <div class="apgo-mpdp-track" data-apgo-carousel-track>
        {%- if section.settings.video_url != blank -%}
          <div class="apgo-mpdp-slide apgo-mpdp-slide-video">
            <div class="apgo-mpdp-video-poster" style="background-image:url('{{ section.settings.video_poster | image_url: width: 800 }}');">
              <div class="apgo-mpdp-play"><span></span></div>
              <div class="apgo-mpdp-video-label">▶ {{ section.settings.video_label | default: '產品實測影片 · 60s' }}</div>
            </div>
          </div>
        {%- endif -%}
        {%- if product.media.size > 0 -%}
          {%- for m in product.media limit: 6 -%}
            <div class="apgo-mpdp-slide">
              <img src="{{ m | image_url: width: 900 }}" alt="{{ m.alt | default: product.title }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}">
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
      {%- if has_compare -%}
        <div class="apgo-mpdp-discount">限時 {{ discount_pct }}% OFF</div>
      {%- endif -%}
      <div class="apgo-mpdp-counter"><span data-apgo-carousel-idx>1</span> / <span data-apgo-carousel-total></span></div>
    </div>

    {%- comment -%} Info block {%- endcomment -%}
    <div class="apgo-mpdp-info">
      {%- if section.settings.kicker != blank -%}
        <div class="apgo-mpdp-kicker">{{ section.settings.kicker }}</div>
      {%- endif -%}
      <h1 class="apgo-mpdp-title apgo-serif">{{ product.title }}</h1>
      {%- if product.metafields.apgo.subtitle != blank -%}
        <div class="apgo-mpdp-subtitle">{{ product.metafields.apgo.subtitle }}</div>
      {%- endif -%}

      {%- if section.settings.show_rating -%}
        <div class="apgo-mpdp-rating">
          <span class="apgo-stars">★★★★★</span>
          <strong>{{ section.settings.rating_score }}</strong>
          <span class="apgo-muted">· {{ section.settings.rating_count }} 則評價</span>
        </div>
      {%- endif -%}

      <div class="apgo-mpdp-price-row">
        <span class="apgo-serif apgo-mpdp-price" data-apgo-price>{{ v.price | money }}</span>
        {%- if has_compare -%}
          <span class="apgo-mpdp-compare" data-apgo-compare>{{ product.compare_at_price | money }}</span>
          <span class="apgo-mpdp-discount-pill">−{{ discount_pct }}%</span>
        {%- endif -%}
      </div>
      {%- if section.settings.show_installment -%}
        <div class="apgo-mpdp-installment" data-apgo-installment>分 3 期 0 利率 · 每期 {{ v.price | divided_by: 3 | money }}</div>
      {%- endif -%}

      {%- comment -%} Variant options {%- endcomment -%}
      {%- for option in product.options_with_values -%}
        {%- assign is_scent = false -%}
        {%- if option.name contains '香' or option.name contains 'Scent' -%}{%- assign is_scent = true -%}{%- endif -%}

        <div class="apgo-mpdp-opt" data-apgo-option-group data-option-position="{{ option.position }}">
          <div class="apgo-mpdp-opt-label">
            <span>{{ option.name }}</span>
            <span class="apgo-muted" data-apgo-current-value>{{ option.selected_value }}</span>
          </div>
          {%- if is_scent -%}
            <div class="apgo-mpdp-scent-grid">
              {%- for value in option.values -%}
                {%- assign sc = '#E8DFC9' -%}
                {%- case value -%}
                  {%- when '淨心棉花' -%}{%- assign sc = '#E8DFC9' -%}
                  {%- when '花漾蒼蘭' -%}{%- assign sc = '#D4DDE0' -%}
                  {%- when '浪漫玫瑰' -%}{%- assign sc = '#E8D4CF' -%}
                  {%- when '海洋晨曦' -%}{%- assign sc = '#C8D6DA' -%}
                  {%- when '清雅白茶' -%}{%- assign sc = '#DAE0CE' -%}
                  {%- when '薰衣紫戀' -%}{%- assign sc = '#D6CFDD' -%}
                {%- endcase -%}
                <label class="apgo-mpdp-scentbtn {% if option.selected_value == value %}active{% endif %}">
                  <input type="radio" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" data-apgo-option-input {% if option.selected_value == value %}checked{% endif %}>
                  <span class="apgo-mpdp-swatch" style="background:{{ sc }}"></span>
                  <span class="apgo-serif">{{ value }}</span>
                </label>
              {%- endfor -%}
            </div>
          {%- else -%}
            <div class="apgo-mpdp-chip-grid">
              {%- for value in option.values -%}
                <label class="apgo-mpdp-chip {% if option.selected_value == value %}active{% endif %}">
                  <input type="radio" name="options[{{ option.name | escape }}]" value="{{ value | escape }}" data-apgo-option-input {% if option.selected_value == value %}checked{% endif %}>
                  <span>{{ value }}</span>
                </label>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}

      {%- comment -%} Qty (inline) {%- endcomment -%}
      <div class="apgo-mpdp-qty-row">
        <span class="apgo-mpdp-qty-label">數量</span>
        <div class="apgo-mpdp-qty">
          <button type="button" data-apgo-qty="down" aria-label="減少">−</button>
          <input type="number" name="quantity" value="1" min="1" data-apgo-qty-input>
          <button type="button" data-apgo-qty="up" aria-label="增加">+</button>
        </div>
      </div>

      {%- comment -%} Ship card (editable via blocks of type "ship_row") {%- endcomment -%}
      {%- assign ship_blocks = section.blocks | where: 'type', 'ship_row' -%}
      {%- if ship_blocks.size > 0 -%}
        <div class="apgo-mpdp-ship">
          {%- for block in ship_blocks -%}
            <div class="apgo-mpdp-ship-row" {{ block.shopify_attributes }}>
              <span class="apgo-mpdp-ship-icon">{{ block.settings.numeral }}</span>
              <div>
                <strong>{{ block.settings.title }}</strong>
                <div class="apgo-muted">{{ block.settings.subtitle }}</div>
              </div>
            </div>
            {%- unless forloop.last -%}<div class="apgo-mpdp-ship-sep"></div>{%- endunless -%}
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    </div>
    {%- comment -%} ====== END MOBILE-ONLY SHELL ====== {%- endcomment -%}

    {%- comment -%} Tabs {%- endcomment -%}
    <div class="apgo-mpdp-tabs" role="tablist" data-apgo-mtabs>
      <button type="button" class="apgo-mpdp-tab active" data-apgo-mtab="desc" role="tab">商品說明</button>
      <button type="button" class="apgo-mpdp-tab" data-apgo-mtab="spec" role="tab">規格</button>
      <button type="button" class="apgo-mpdp-tab" data-apgo-mtab="review" role="tab">評價</button>
      <button type="button" class="apgo-mpdp-tab" data-apgo-mtab="faq" role="tab">問答</button>
    </div>

    {%- comment -%}
      Tab panel: 商品說明
      ----------------------------------------------------------------
      STRICT MODE: this entire panel is driven by Shopify admin →
      Product → Description (rich-text editor, HTML mode capable).

      To reproduce the original UI (Ritual hero / 痛點 × 解方 / 比較表 /
      UGC / 長圖) the user pastes structured HTML using the existing
      class hooks (.apgo-mpdp-ritual-wrap, .apgo-mpdp-pain-wrap,
      .apgo-mpdp-cmp-wrap, .apgo-mpdp-ugc-wrap, .apgo-mpdp-longimg-wrap).
      A reference snippet is kept in the team handbook.

      Direct-child <div> snippets in description are NOT constrained by
      .apgo-mpdp-description's reading-width rules — they keep their
      original full-bleed look (see apgo-pdp.css line ~735).
    {%- endcomment -%}
    <div class="apgo-mpdp-panel active" data-apgo-mpanel="desc">
      {%- if product.description != blank -%}
        <div class="apgo-mpdp-description rte">
          {{ product.description }}
        </div>
      {%- endif -%}

      {%- comment -%}
        UGC grid — kept editable in theme editor (blocks of type "ugc") so
        non-technical admin can add/remove IG cells without touching HTML.
        Renders right after description; expects the description to already
        contain the heading wrap (kicker + 用戶實拍 · Instagram).
      {%- endcomment -%}
      {%- assign ugc_blocks = section.blocks | where: 'type', 'ugc' -%}
      {%- if ugc_blocks.size > 0 -%}
        <div class="apgo-mpdp-ugc-wrap apgo-mpdp-ugc-wrap--grid-only">
          <div class="apgo-mpdp-ugc-grid">
            {%- for block in ugc_blocks -%}
              <a href="{{ block.settings.url }}" class="apgo-mpdp-ugc-cell" {{ block.shopify_attributes }} {% if block.settings.url != blank %}target="_blank" rel="noopener"{% endif %}>
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 400 }}" alt="@{{ block.settings.handle }}" loading="lazy">
                {%- endif -%}
                <span class="apgo-mpdp-ugc-like">♡ {{ block.settings.likes }}</span>
              </a>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    </div>

    {%- comment -%} Tab panel: 規格 — prefer metafield, fallback to blocks {%- endcomment -%}
    {%- assign mf_spec_rows = product.metafields.apgo.spec_rows.value -%}
    <div class="apgo-mpdp-panel" data-apgo-mpanel="spec">
      {%- if mf_spec_rows != blank and mf_spec_rows.size > 0 -%}
        {%- for entry in mf_spec_rows -%}
          <div class="apgo-mpdp-spec-row">
            <div class="apgo-muted">{{ entry.key }}</div>
            <div class="apgo-serif">{{ entry.value }}</div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'spec' -%}
            <div class="apgo-mpdp-spec-row" {{ block.shopify_attributes }}>
              <div class="apgo-muted">{{ block.settings.key }}</div>
              <div class="apgo-serif">{{ block.settings.value }}</div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- comment -%} Tab panel: 評價 — prefer metafield, fallback to blocks {%- endcomment -%}
    {%- assign mf_reviews = product.metafields.apgo.reviews.value -%}
    <div class="apgo-mpdp-panel" data-apgo-mpanel="review">
      <div class="apgo-mpdp-rev-summary">
        <div class="apgo-serif apgo-mpdp-rev-score">{{ section.settings.rating_score }}</div>
        <div class="apgo-stars">★★★★★</div>
        <div class="apgo-muted">基於 {{ section.settings.rating_count }} 則真實評價</div>
      </div>
      {%- if mf_reviews != blank and mf_reviews.size > 0 -%}
        {%- for entry in mf_reviews -%}
          <div class="apgo-mpdp-rev-item">
            <div class="apgo-mpdp-rev-head">
              <strong>{{ entry.name }}</strong>
              <span class="apgo-stars">★★★★★</span>
            </div>
            <div class="apgo-mpdp-rev-meta">{{ entry.date }} · 已購買：{{ entry.scent }}</div>
            <p>{{ entry.body }}</p>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'review' -%}
            <div class="apgo-mpdp-rev-item" {{ block.shopify_attributes }}>
              <div class="apgo-mpdp-rev-head">
                <strong>{{ block.settings.name }}</strong>
                <span class="apgo-stars">★★★★★</span>
              </div>
              <div class="apgo-mpdp-rev-meta">{{ block.settings.date }} · 已購買：{{ block.settings.scent }}</div>
              <p>{{ block.settings.body }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- comment -%} Tab panel: 問答 — prefer metafield, fallback to blocks {%- endcomment -%}
    {%- assign mf_faqs = product.metafields.apgo.faqs.value -%}
    <div class="apgo-mpdp-panel" data-apgo-mpanel="faq">
      {%- if mf_faqs != blank and mf_faqs.size > 0 -%}
        {%- for entry in mf_faqs -%}
          <details class="apgo-mpdp-faq">
            <summary>
              <span class="apgo-serif">Q. {{ entry.question }}</span>
              <span class="apgo-mpdp-faq-toggle">+</span>
            </summary>
            <p>A. {{ entry.answer }}</p>
          </details>
        {%- endfor -%}
      {%- else -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'faq' -%}
            <details class="apgo-mpdp-faq" {{ block.shopify_attributes }}>
              <summary>
                <span class="apgo-serif">Q. {{ block.settings.q }}</span>
                <span class="apgo-mpdp-faq-toggle">+</span>
              </summary>
              <p>A. {{ block.settings.a }}</p>
            </details>
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- comment -%} Related products (horizontal scroll) {%- endcomment -%}
    {%- if section.settings.related_collection != blank -%}
      {%- assign rcol = collections[section.settings.related_collection] -%}
      {%- if rcol and rcol.products.size > 0 -%}
        <div class="apgo-mpdp-related">
          <h3 class="apgo-serif">您可能也喜歡</h3>
          <div class="apgo-mpdp-related-scroll">
            {%- for p in rcol.products limit: 8 -%}
              {%- unless p.id == product.id -%}
                <a class="apgo-mpdp-related-item" href="{{ p.url }}">
                  <img src="{{ p.featured_image | image_url: width: 280 }}" alt="{{ p.title }}" loading="lazy">
                  <div class="apgo-serif">{{ p.title }}</div>
                  <div>{{ p.price | money }}</div>
                </a>
              {%- endunless -%}
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}
    {%- endif -%}

    {%- comment -%} Sticky bottom CTA bar {%- endcomment -%}
    <div class="apgo-mpdp-sticky">
      <button type="button" class="apgo-mpdp-wish" aria-label="加入收藏">♡</button>
      <button type="submit" name="add" class="apgo-mpdp-cta-secondary" data-apgo-add {% unless v.available %}disabled{% endunless %}>
        {% if v.available %}加入購物車{% else %}補貨中{% endif %}
      </button>
      <button type="button" class="apgo-mpdp-cta-primary" data-apgo-buy-now {% unless v.available %}disabled{% endunless %}>
        立即購買 <span data-apgo-total>{{ v.price | money }}</span>
      </button>
    </div>

    <script type="application/json" data-apgo-variants>{{ product.variants | json }}</script>
  {% endform %}
</section>

{% schema %}
{
  "name": "APGO · PDP 內容（共用）",
  "tag": "section",
  "class": "apgo-section apgo-section-pdp-content",
  "settings": [
    { "type": "header", "content": "顶部 Carousel" },
    { "type": "url",          "id": "video_url",      "label": "影片連結（選填）" },
    { "type": "image_picker", "id": "video_poster",   "label": "影片封面（選填）" },
    { "type": "text",         "id": "video_label",    "label": "影片標籤", "default": "產品實測影片 · 60s" },

    { "type": "header", "content": "基本資訊" },
    { "type": "text",     "id": "kicker",       "label": "英文副標", "default": "AROMA AESTHETICS" },
    { "type": "checkbox", "id": "show_rating",  "label": "顯示評分", "default": true },
    { "type": "text",     "id": "rating_score", "label": "評分", "default": "4.9" },
    { "type": "text",     "id": "rating_count", "label": "評價數", "default": "2,847" },
    { "type": "checkbox", "id": "show_installment", "label": "顯示 3 期 0 利率", "default": true },

    { "type": "header", "content": "商品說明 tab" },
    { "type": "paragraph", "content": "「商品說明」整段內容（Ritual 視覺、痛點 × 解方、比較表、UGC、長圖）一律由 Shopify 後台 → 商品 → Description 提供。可在 Description 編輯器的 </> HTML 模式貼入結構化片段（class：apgo-mpdp-ritual-wrap / apgo-mpdp-pain-wrap / apgo-mpdp-cmp-wrap / apgo-mpdp-ugc-wrap / apgo-mpdp-longimg-wrap）。" },

    { "type": "header", "content": "相關商品" },
    { "type": "collection", "id": "related_collection", "label": "相關商品集合" }
  ],
  "blocks": [
    {
      "type": "ship_row",
      "name": "運送/保障資訊列",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "numeral", "label": "編號標記", "default": "i", "info": "顯示在最左邊的小符號（如 i / ii / iii）" },
        { "type": "text", "id": "title", "label": "主標", "default": "滿 NT$ 799 免運" },
        { "type": "text", "id": "subtitle", "label": "副標", "default": "黑貓宅配 · 24 小時內出貨" }
      ]
    },
    {
      "type": "ugc",
      "name": "UGC IG 貼文",
      "limit": 9,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "圖片" },
        { "type": "text", "id": "handle", "label": "IG handle（顯示在 alt）" },
        { "type": "number", "id": "likes", "label": "讚數", "default": 100 },
        { "type": "url", "id": "url", "label": "IG 貼文連結（選填）" }
      ]
    },
    {
      "type": "spec",
      "name": "規格列",
      "limit": 12,
      "settings": [
        { "type": "text", "id": "key", "label": "欄位", "default": "商品名稱" },
        { "type": "text", "id": "value", "label": "內容", "default": "APGO 超級濃縮洗衣精" }
      ]
    },
    {
      "type": "review",
      "name": "評價",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "name", "label": "姓名", "default": "黃小姐" },
        { "type": "text", "id": "date", "label": "日期", "default": "2026.03.12" },
        { "type": "text", "id": "scent", "label": "購買香氛", "default": "淨心棉花" },
        { "type": "textarea", "id": "body", "label": "評價內容", "default": "香味非常柔和不刺鼻，寶寶衣服洗起來也很放心。" }
      ]
    },
    {
      "type": "faq",
      "name": "常見問題",
      "limit": 8,
      "settings": [
        { "type": "text", "id": "q", "label": "問題", "default": "可以洗嬰幼兒衣服嗎？" },
        { "type": "textarea", "id": "a", "label": "回答", "default": "可以。通過 SGS 檢驗、8 大零添加、pH 中性，專為敏感肌與嬰幼兒設計。" }
      ]
    }
  ],
  "presets": [
    {
      "name": "APGO · Mobile PDP",
      "blocks": [
        { "type": "ship_row", "settings": { "numeral": "i",   "title": "滿 NT$ 799 免運",   "subtitle": "黑貓宅配 · 24 小時內出貨" }},
        { "type": "ship_row", "settings": { "numeral": "ii",  "title": "30 天鑑賞期",       "subtitle": "未拆封可無條件退換貨" }},
        { "type": "ship_row", "settings": { "numeral": "iii", "title": "SGS 國家級檢驗",    "subtitle": "99.9% 抗菌 · 八大零添加" }},
        { "type": "ugc", "settings": { "handle": "", "likes": 100, "url": "" }},
        { "type": "ugc", "settings": { "handle": "", "likes": 100, "url": "" }},
        { "type": "ugc", "settings": { "handle": "", "likes": 100, "url": "" }},
        { "type": "spec", "settings": { "key": "商品名稱", "value": "APGO 超級濃縮洗衣精" }},
        { "type": "spec", "settings": { "key": "容量",     "value": "1L / 2L / 4L 補充包" }},
        { "type": "spec", "settings": { "key": "產地",     "value": "台灣製造" }},
        { "type": "spec", "settings": { "key": "主要成分", "value": "濃縮酵素、護色因子、植萃香氛" }},
        { "type": "spec", "settings": { "key": "香氛選擇", "value": "6 款香氛可選" }},
        { "type": "spec", "settings": { "key": "適用",     "value": "各式衣物、嬰幼兒、寵物用品" }},
        { "type": "spec", "settings": { "key": "pH 值",    "value": "中性（pH 7.0 ± 0.5）" }},
        { "type": "spec", "settings": { "key": "保存期限", "value": "未開封 3 年／開封後 18 個月" }},
        { "type": "spec", "settings": { "key": "認證",     "value": "SGS 99.9% 抗菌合格" }},
