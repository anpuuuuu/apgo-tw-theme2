{% comment %} Section: Scent Quiz Banner · 預設關閉（等 Quiz 頁面上線後開啟） {% endcomment %}

{% if section.settings.enabled %}
  <section class="apgo-section apgo-quiz" data-section-id="{{ section.id }}">
    {% if section.settings.quiz_url != blank %}
      <div class="apgo-quiz-banner">
        <div>
          <div class="apgo-kicker" style="margin-bottom:10px; opacity:0.75; color:var(--apgo-bg);">— {{ section.settings.kicker }} —</div>
          <h3 class="apgo-serif" style="font-size:26px; font-weight:400; margin:0 0 8px;">{{ section.settings.heading }}</h3>
          <p style="font-size:13px; opacity:0.85; line-height:1.8; max-width:560px; margin:0;">{{ section.settings.body }}</p>
        </div>
        {% render 'apgo-cta-button', label: section.settings.button_label, style: 'sage', url: section.settings.quiz_url %}
      </div>
    {% else %}
      {% render 'apgo-placeholder', name: '香氛 Quiz Banner', hint: '請填入 Quiz 頁面網址後自動顯示' %}
    {% endif %}
  </section>
{% endif %}

{% schema %}
{
  "name": "APGO · Scent Quiz",
  "tag": "section",
  "settings": [
    { "type": "checkbox", "id": "enabled", "label": "啟用此區塊", "default": false, "info": "Quiz 頁面還沒建立前請保持關閉" },
    { "type": "text", "id": "kicker", "label": "英文副標", "default": "FIND YOUR SCENT" },
    { "type": "text", "id": "heading", "label": "標題", "default": "不確定哪款香氛適合你？" },
    { "type": "textarea", "id": "body", "label": "內文", "default": "回答 3 個問題，讓香氛師推薦最符合你生活風格的 APGO 香氛。" },
    { "type": "text", "id": "button_label", "label": "按鈕文字", "default": "開始 30 秒測驗 →" },
    { "type": "url", "id": "quiz_url", "label": "Quiz 頁面網址", "info": "例：/pages/scent-quiz" }
  ],
  "presets": [{ "name": "APGO · Scent Quiz" }]
}
{% endschema %}
