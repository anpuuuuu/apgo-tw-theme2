{% comment %} sections/warmup-activity.liquid {% endcomment %}

<section
  class="double-eleven-warmup"
  id="{{ section.settings.section_id }}"
  data-section-id="{{ section.settings.section_id }}"
>
  <div class="warmup-container">
    <div class="warmup-header">
      <h2 class="warmup-title warmup-title-desktop">{{ section.settings.warmup_title }}</h2>
      <h2 class="warmup-title warmup-title-mobile" id="warmupTitleMobile">
        {{ section.settings.warmup_title_mobile }}
      </h2>
      <p class="warmup-subtitle">{{ section.settings.warmup_subtitle }}</p>
    </div>

    {% comment %} 第一部分：原子琺瑯晶鍍膜活動 {% endcomment %}
    <div class="warmup-section warmup-enamel">
      {% if section.settings.enamel_background_image_desktop %}
        <img
          src="{{ section.settings.enamel_background_image_desktop | img_url }}"
          srcset="{{ section.settings.enamel_background_image_desktop | img_url: '1536x' }} 1x,
                  {{ section.settings.enamel_background_image_desktop | img_url: '3072x' }} 2x"
          alt="Enamel Background"
          class="enamel-background-image enamel-background-desktop"
          loading="lazy"
        >
      {% endif %}

      {% if section.settings.enamel_background_image_mobile %}
        <img
          src="{{ section.settings.enamel_background_image_mobile | img_url }}"
          srcset="{{ section.settings.enamel_background_image_mobile | img_url: '686x' }} 1x,
                  {{ section.settings.enamel_background_image_mobile | img_url: '2000x' }} 2x"
          alt="Enamel Background"
          class="enamel-background-image enamel-background-mobile"
          loading="lazy"
        >
      {% endif %}

      <h3 class="enamel-section-title">{{ section.settings.enamel_section_title }}</h3>
      <a href="{{ section.settings.enamel_main_link }}" class="enamel-main-card-link">
        <div class="enamel-main-card">
          <div class="enamel-main-image-wrapper enamel-main-image-wrapper-mobile">
            {% if section.settings.enamel_main_image_mobile %}
              <img
                src="{{ section.settings.enamel_main_image_mobile | img_url }}"
                srcset="{{ section.settings.enamel_main_image_mobile | img_url: '686x' }} 1x,
                      {{ section.settings.enamel_main_image_mobile | img_url: '2000x' }} 2x"
                alt="{{ section.settings.enamel_main_name }}"
                class="enamel-main-image"
              >
            {% else %}
              <div class="enamel-main-image-placeholder"></div>
            {% endif %}
          </div>

          <div class="enamel-main-info enamel-main-info-desktop">
            <div class="enamel-main-name">{{ section.settings.enamel_main_name }}</div>
            <div class="enamel-main-price">{{ section.settings.enamel_main_price }}</div>
            <div class="enamel-main-desc">{{ section.settings.enamel_main_desc }}</div>
            <div class="enamel-main-tag">{{ section.settings.enamel_main_tag }}</div>
          </div>

          <div class="enamel-main-info enamel-main-info-mobile">
            <div class="enamel-main-name">{{ section.settings.enamel_main_name }}</div>
            <div class="enamel-main-desc">{{ section.settings.enamel_main_desc }}</div>
            <div class="enamel-main-price-tag-wrapper">
              <div class="enamel-main-price">{{ section.settings.enamel_main_price }}</div>
              <div class="enamel-main-tag">{{ section.settings.enamel_main_tag }}</div>
            </div>
          </div>

          <div class="enamel-main-image-wrapper enamel-main-image-wrapper-desktop">
            {% if section.settings.enamel_main_image %}
              <img
                src="{{ section.settings.enamel_main_image | img_url }}"
                srcset="{{ section.settings.enamel_main_image | img_url: '798x' }} 1x,
                      {{ section.settings.enamel_main_image | img_url: '2000x' }} 2x"
                alt="{{ section.settings.enamel_main_name }}"
                class="enamel-main-image"
              >
            {% else %}
              <div class="enamel-main-image-placeholder"></div>
            {% endif %}
          </div>
        </div>
      </a>
      <div class="enamel-sub-grid">
        {% for block in section.blocks %}
          {% if block.type == 'enamel_combo' %}
            <a href="{{ block.settings.combo_link }}" class="enamel-combo-card-link">
              <div class="enamel-combo-card">
                <div class="enamel-combo-image-wrapper">
                  {% if block.settings.combo_image %}
                    <img
                      src="{{ block.settings.combo_image | img_url }}"
                      srcset="{{ block.settings.combo_image | img_url: '320x' }} 1x,
                          {{ block.settings.combo_image | img_url: '2000x' }} 2x"
                      alt="{{ block.settings.combo_name }}"
                      class="enamel-combo-image"
                    >
                  {% else %}
                    <div class="enamel-combo-image-placeholder"></div>
                  {% endif %}
                </div>

                <div class="enamel-combo-info enamel-combo-info-desktop">
                  <h4 class="enamel-combo-name">{{ block.settings.combo_name }}</h4>
                  <div class="enamel-combo-price">
                    <span class="combo-price">{{ block.settings.combo_price }}</span>
                    <span class="combo-tag">{{ block.settings.combo_tag }}</span>
                  </div>
                </div>

                <div class="enamel-combo-info enamel-combo-info-mobile">
                  <div class="enamel-combo-name-price-wrapper">
                    <h4 class="enamel-combo-name">{{ block.settings.combo_name }}</h4>
                    <span class="combo-price">{{ block.settings.combo_price }}</span>
                  </div>
                  <span class="combo-tag">{{ block.settings.combo_tag }}</span>
                </div>
              </div>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

