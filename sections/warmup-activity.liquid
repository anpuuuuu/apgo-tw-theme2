<script>
  document.addEventListener('DOMContentLoaded', function () {
    // 更新手機端標題顯示（將 · 轉換為 <br>）
    function updateMobileTitleDisplay() {
      const isMobile = window.innerWidth <= 450;
      const titleMobileElement = document.getElementById('warmupTitleMobile');

      if (titleMobileElement) {
        const originalText =
          titleMobileElement.getAttribute('data-original-text') || '{{ section.settings.warmup_title_mobile }}';

        // 儲存原始文字（第一次執行時）
        if (!titleMobileElement.getAttribute('data-original-text')) {
          titleMobileElement.setAttribute('data-original-text', originalText);
        }

        if (isMobile) {
          // 手機端：轉換 · 為 <br>
          const parts = originalText.split('·');
          titleMobileElement.innerHTML = parts.join('<br>');
        } else {
          // 電腦端：不轉換，直接顯示
          titleMobileElement.textContent = originalText;
        }
      }
    }

    // 視窗大小改變時重新計算和更新文字
    window.addEventListener('resize', function () {
      updateMobileTitleDisplay();
    });

    // 初始化
    updateMobileTitleDisplay();
  });
</script>

