  <script>
  (function(){
    const s = {{ section.settings | json }};
    const el = (id) => document.getElementById(id);
    const q = (sel, root) => (root || document).querySelector(sel);
    const msg = el('cp-msg');
    const DEFAULT_PHONE_CODE = '+886';
  
    // 元素引用
    const nameEl = el('cp-name');
    const phoneEl = el('cp-phone');
  
    // === 即時同步到網址 query：checkout 預填 & attributes ===
    const qp = new URLSearchParams(location.search);
  
    // 將目前欄位值 → 轉成 Shopify checkout 預填參數 + attributes
    function buildCheckoutParams({previewOnly=false} = {}) {
      const method = document.querySelector('input[name="cp-method"]:checked')?.value || (s.enable_home ? 'home' : 'cvs');
      const fullName = (nameEl?.value || '').trim();
      const phone = normPhone(phoneEl?.value || '');
      const { first: first_name, last: last_name } = splitName(fullName);
  
      // 共用：姓名、電話
      setQP(`checkout[shipping_address][first_name]`, first_name);
      setQP(`checkout[shipping_address][last_name]`,  last_name);
      setQP(`checkout[shipping_address][phone]`,      phone);
      setQP(`checkout[shipping_address][country]`,    s.country || 'Taiwan');
      setQP(`checkout[phone]`,      phone);
      delQP(`checkout[email]`);
      // 依運送方式組地址
      if (method === 'home') {
        const c = homeCounty?.value || '';      // 縣市（例：臺北市）
        const d = homeDistrict?.value || '';    // 區（例：大安區）
        const a1 = el('cp-home-address1')?.value?.trim() || '';
        // ★ 取自動偵測 zip（若偵測不到就不帶）
        const zFinal = detectedZipHome || '';
  
        // ✅ city 只放縣市；address1 前面加上區
        const cityOnly = c;
        const address1 = (d ? (d + ' ') : '') + a1;
  
        setQP(`checkout[shipping_address][city]`,      cityOnly);
        setQP(`checkout[shipping_address][province]`,  cityOnly); // 兼容性加強（可保留）
        setQP(`checkout[shipping_address][address1]`,  address1);
        if (zFinal) setQP(`checkout[shipping_address][zip]`, zFinal);
        else delQP(`checkout[shipping_address][zip]`);
  
        if (s.enable_attr) {
          setQP(`attributes[運送方式]`, '宅配');
          setQP(`attributes[縣市]`, c);
          setQP(`attributes[鄉鎮市區]`, d);
          setQP(`attributes[地址_address1]`, a1);
          setQP(`attributes[姓名]`, fullName);
          setQP(`attributes[電話]`, phone);
          if (zFinal) setQP(`attributes[地址_zip]`, zFinal); else delQP(`attributes[地址_zip]`);
          // 移除舊的合併欄位（若曾存在）
          delQP(`attributes[地址_city]`);
        }
      } else {
        const c = cvsCounty?.value || '';
        const d = cvsDistrict?.value || '';
        const road = (el('cp-cvs-road') ? (el('cp-cvs-road').value || '') : (el('cp-cvs-road-input')?.value?.trim() || ''));
        const extra = el('cp-cvs-address1-extra')?.value?.trim() || '';
  
        // ✅ city=縣市；address1=「區 + 路名 +（門牌）」；不帶 zip
        const cityOnly = c;
        const address1 = (d ? (d + ' ') : '') + (road ? road : '') + (extra ? (' ' + extra) : '');
  
                setQP(`checkout[shipping_address][city]`,      cityOnly);
          setQP(`checkout[shipping_address][province]`,  cityOnly); // 兼容性加強（可保留）
          setQP(`checkout[shipping_address][address1]`,  address1);
          
          // ★ 超商也帶入郵遞區號（Shopify 規定）
          const cvsZip = getZipByCityDistrict(addressData || [], c, d);
          if (cvsZip) setQP(`checkout[shipping_address][zip]`, cvsZip);
          else delQP(`checkout[shipping_address][zip]`);
  
          if (s.enable_attr) {
            setQP(`attributes[運送方式]`, '超商');
            setQP(`attributes[縣市]`, c);
            setQP(`attributes[鄉鎮市區]`, d);
            setQP(`attributes[地址_路名]`, road);
            setQP(`attributes[地址_address1]`, (road + (extra ? (' ' + extra) : '')));
            setQP(`attributes[姓名]`, fullName);
            setQP(`attributes[電話]`, phone);
            if (cvsZip) setQP(`attributes[地址_zip]`, cvsZip); else delQP(`attributes[地址_zip]`);
            delQP(`attributes[地址_city]`);
          }
      }
  
      // 沒值的 key 就從網址剔除（避免髒參數）
      cleanEmptyParams();
  
      // 預覽模式僅回傳，不寫網址
      if (previewOnly) return new URLSearchParams(qp);
  
      // 寫回當前網址（不重整）
      history.replaceState(null, '', `${location.pathname}?${qp.toString()}`);
    }
  
    // 工具：設/刪 query 參數（支援陣列風格 key）
    function setQP(key, val) {
      if (val == null) return;
      const v = String(val).trim();
      if (v) { qp.set(key, v); }
      else { qp.delete(key); }
    }
    function delQP(key) { qp.delete(key); }
  
    function cleanEmptyParams() {
      // 移除空值、undefined、null
      [...qp.keys()].forEach(k => {
        const v = qp.get(k);
        if (v == null || v === 'null' || v === 'undefined' || v.trim() === '') qp.delete(k);
      });
    }
  
    // 將每個欄位變更 → 立即同步到網址
    function wireLiveSync() {
      const ids = [
        'cp-name','cp-phone','cp-home-address1',
        'cp-home-county','cp-home-district',
        'cp-cvs-county','cp-cvs-district','cp-cvs-road','cp-cvs-road-input','cp-cvs-address1-extra'
      ];
            ids.forEach(id => {
          const e = el(id);
          if (!e) return;
          const evt = (e.tagName === 'INPUT') ? 'input' : 'change';
          e.addEventListener(evt, () => {
            buildCheckoutParams();
            // ★ 宅配欄位變更時順便偵測 zip
            if (id === 'cp-home-county' || id === 'cp-home-district' || id === 'cp-home-address1') {
              updateZipHomeDisplay();
            }
            // 超商欄位變更時更新 zip 提示
            if (id === 'cp-cvs-county' || id === 'cp-cvs-district') {
              updateZipCvsDisplay();
            }
          });
        });
  
      // 運送方式切換也即時同步
      document.querySelectorAll('input[name="cp-method"]').forEach(r => {
        r.addEventListener('change', () => {
          buildCheckoutParams();
          const v = document.querySelector('input[name="cp-method"]:checked')?.value;
          if (v === 'home') updateZipHomeDisplay();
        });
      });
    }
  
    // 面板切換（宅配/超商）
    document.querySelectorAll('input[name="cp-method"]').forEach(r => {
      r.addEventListener('change', () => {
        const v = document.querySelector('input[name="cp-method"]:checked')?.value;
        togglePane(v);
      });
    });
  
    function togglePane(v) {
      const home = el('cp-home');
      const cvs = el('cp-cvs');
      const warningEl = el('cvs-weight-warning');
      if (home) home.style.display = (v === 'home') ? '' : 'none';
      if (cvs) cvs.style.display = (v === 'cvs') ? '' : 'none';
      if (warningEl) warningEl.style.display = (v === 'cvs') ? '' : 'none';
    }
  
    // 初始化預設值
    (function() {
      const checked = document.querySelector('input[name="cp-method"]:checked');
      if (checked) togglePane(checked.value);
    })();
  
    // OpenSheet API（可在主題編輯器「OpenSheet 網址」自訂你的試算表）
    const OPENSHEET_DEFAULT = 'https://opensheet.elk.sh/1S81a-nrJR1yzmEnWVjuGJuiiW1S2UWP2VpGaxmBuoJ4/taiwan_road';
    const OPENSHEET_URL = (function () {
      const u = (s.opensheet_url && String(s.opensheet_url).trim()) || '';
      return u || OPENSHEET_DEFAULT;
    })();
    let addressData = null; // 快取資料
    let detectedZipHome = ''; // ★ 新增：偵測到的宅配郵遞區號
    
    // 載入完整地址資料（只載入一次）
    async function loadAddressData() {
      if (addressData) {
        console.log('使用快取資料');
        return addressData;
      }
      
      try {
        console.log('開始載入 OpenSheet 資料...');
        showLoading('載入地址資料中...');
        
        const response = await fetch(OPENSHEET_URL, { mode: 'cors', cache: 'no-store' });
        console.log('API 回應狀態:', response.status, 'URL:', OPENSHEET_URL);
        
        if (!response.ok) {
          throw new Error(`HTTP error! status: ${response.status}`);
        }
        
        const data = await response.json();
        if (data && typeof data === 'object' && !Array.isArray(data) && data.error) {
          throw new Error(String(data.error));
        }
        if (!Array.isArray(data)) {
          throw new Error('OpenSheet 回傳格式不是陣列，請檢查網址與工作表名稱是否正確');
        }
        console.log('成功載入資料，共', data.length, '筆');
        
        // 檢查資料結構
        if (data.length > 0) {
          console.log('資料欄位:', Object.keys(data[0]));
          console.log('第一筆資料範例:', data[0]);
        }
        
        addressData = data;
        hideMessage();
        return data;
      } catch (error) {
        console.error('載入地址資料失敗:', error);
        showError(
          '地址資料載入失敗。請確認主題設定中的 OpenSheet 網址正確，且 Google 試算表已設為「知道連結的任何人可檢視」。錯誤：' +
            (error && error.message ? error.message : String(error))
        );
        return [];
      }
    }
    
    // 取得不重複的縣市列表
    function getUniqueCounties(data) {
      const counties = [...new Set(data.map(item => item['city']))];
      return counties.filter(c => c).sort();
    }
    
    // 取得指定縣市的區域列表
    function getDistricts(data, county) {
      const c = canonicalCounty(county);
      const filtered = data.filter(item => canonicalCounty(item['city']) === c);
      const districts = [...new Set(filtered.map(item => canonicalDistrict(item['district'])))];
      return districts.filter(Boolean).sort();
    }
    
    // 取得指定縣市+區域的路名列表
    function getRoads(data, county, district) {
      const c = canonicalCounty(county);
      const d = canonicalDistrict(district);
      const filtered = data.filter(item =>
        canonicalCounty(item['city']) === c && canonicalDistrict(item['district']) === d
      );
      const roads = [...new Set(filtered.map(item => item['road']))];
      return roads.filter(Boolean).sort();
    }
    
    function fillSelect(select, list, placeholder) {
      select.innerHTML = '';
      const ph = document.createElement('option');
      ph.value = '';
      ph.textContent = placeholder || '請選擇';
      select.appendChild(ph);
      list.forEach(v => {
        const o = document.createElement('option');
        o.value = v;
        o.textContent = v;
        select.appendChild(o);
      });
      select.disabled = list.length === 0;
    }
  
    // ★ 新增：從 taiwan_road 直接推算 zip（以「縣市+行政區」為主，若每列皆有同一 zip，取其一）
    function getZipByCityDistrict(data, county, district) {
      if (!data || !data.length) return '';
      const c = canonicalCounty(county);
      const d = canonicalDistrict(district);
      // 篩出該縣市+區的所有列
      const rows = data.filter(item =>
        canonicalCounty(item['city']) === c && canonicalDistrict(item['district']) === d
      );
      if (!rows.length) return '';
      // 優先取該集合中唯一的 zip；如果有多個不同 zip，就先取第一個（多半台灣同區同一 zip）
      const zset = [...new Set(rows.map(r => (r.zip || r.ZIP || r['郵遞區號'] || '').toString().trim()).filter(Boolean))];
      return zset[0] || '';
    }
  
    // 更新 UI 與內部狀態
    async function updateZipHomeDisplay() {
      const city = el('cp-home-county')?.value || '';
      const dist = el('cp-home-district')?.value || '';
      if (!city || !dist) {
        detectedZipHome = '';
        setZipHint('cp-home-zip-hint','cp-home-zip-text','');
        buildCheckoutParams(); // 清除 zip
        return;
      }
      const data = await loadAddressData();
      const z = getZipByCityDistrict(data, city, dist);
      detectedZipHome = z || '';
      setZipHint('cp-home-zip-hint','cp-home-zip-text', detectedZipHome);
      buildCheckoutParams(); // 宅配 zip 會帶到 checkout & attributes
    }
  
    // ★ 新增：超商 zip 顯示（只顯示，不帶參數）
    async function updateZipCvsDisplay() {
      const city = el('cp-cvs-county')?.value || '';
      const dist = el('cp-cvs-district')?.value || '';
      if (!city || !dist) {
        setZipHint('cp-cvs-zip-hint','cp-cvs-zip-text','');
        return;
      }
      const data = await loadAddressData();
      const z = getZipByCityDistrict(data, city, dist);
      setZipHint('cp-cvs-zip-hint','cp-cvs-zip-text', z || '');
    }
  
    // 頁面載入時立即載入資料並檢查縣市名稱
    window.addEventListener('DOMContentLoaded', async () => {
      console.log('頁面載入完成，開始載入地址資料...');
      const data = await loadAddressData();
      if (data && data.length > 0) {
        console.log('✅ 地址資料載入成功');
        
        // 顯示實際的縣市列表供對照
        const actualCounties = getUniqueCounties(data);
        console.log('📍 資料庫中的縣市列表:', actualCounties);
        console.log('💡 提示: 請確認選單中的縣市名稱與資料庫一致');
        
        // 檢查第一個縣市的資料範例
        if (actualCounties.length > 0) {
          const sampleCity = actualCounties[0];
          const sampleDistricts = getDistricts(data, sampleCity);
          console.log(`📋 ${sampleCity} 的區域範例:`, sampleDistricts.slice(0, 5));
        }
        
        // ★ 新增：把縣市選單用資料覆蓋，避免台/臺不一致
        try {
          const actualCounties = [...new Set(addressData.map(r => canonicalCounty(r.city)))].filter(Boolean).sort();
          if (homeCounty) fillSelect(homeCounty, actualCounties, '請選擇');
          if (cvsCounty)  fillSelect(cvsCounty,  actualCounties, '請選擇');
        } catch(e){ console.warn('覆蓋縣市選單失敗', e); }
      } else {
        console.log('⚠️ 地址資料為空或載入失敗');
      }
  
            // 初始：把現有（若有）值同步一次到網址
        wireLiveSync();
        buildCheckoutParams();
        updateZipHomeDisplay();
        updateZipCvsDisplay();
  
      // ★ 新增：修正所有「前往結帳」入口，確保帶上 query
      patchCheckoutEntrances();
  
      function patchCheckoutEntrances(){
        // 1) <a href="/checkout">：點擊前動態補上目前 query
        document.addEventListener('click', (ev) => {
          const a = ev.target.closest && ev.target.closest('a[href^="/checkout"]');
          if (!a) return;
          buildCheckoutParams(); // 先把當前欄位同步到網址
          a.setAttribute('href', '/checkout' + (location.search || ''));
        }, true);
  
        // 2) 表單提交類（多數主題的結帳按鈕）
        document.querySelectorAll('form').forEach(form => {
          const btn = form.querySelector('button[name="checkout"], input[name="checkout"]');
          if (!btn) return;
  
          // 方案 A（最穩）：阻止預設提交，改導向 GET /checkout?...
          btn.addEventListener('click', (e) => {
            buildCheckoutParams();
            e.preventDefault();
            location.href = '/checkout' + (location.search || '');
          }, true);
  
          // 方案 B（要保留 POST 時，改 action；註解掉上面 A）
          // btn.addEventListener('click', () => {
          //   buildCheckoutParams();
          //   form.action = '/checkout' + (location.search || '');
          // }, true);
        });
      }
    });
  
    // 載入區/路：宅配
    const homeCounty = el('cp-home-county');
    const homeDistrict = el('cp-home-district');
    
    homeCounty?.addEventListener('change', async () => {
      console.log('宅配縣市變更:', homeCounty.value);
      const c = homeCounty.value;
      
      if (!c) {
        fillSelect(homeDistrict, [], '請先選縣市');
        return;
      }
      
      // 確保資料已載入
      const data = await loadAddressData();
      console.log('資料載入狀態:', data ? `${data.length}筆` : '無資料');
      
      if (data && data.length > 0) {
        const districts = getDistricts(data, c);
        console.log(`${c} 的區域:`, districts);
        fillSelect(homeDistrict, districts, '請選擇區');
      } else {
        fillSelect(homeDistrict, [], '無法載入區');
        showError('無法載入區域資料');
      }
      // 監聽結尾加：
      updateZipHomeDisplay();
    });
  
    // 載入區/路：超商
    const cvsCounty = el('cp-cvs-county');
    const cvsDistrict = el('cp-cvs-district');
    const cvsRoadSel = el('cp-cvs-road');
    const cvsRoadInput = el('cp-cvs-road-input');
  
    cvsCounty?.addEventListener('change', async () => {
      console.log('超商縣市變更:', cvsCounty.value);
      const c = cvsCounty.value;
      
      if (!c) {
        fillSelect(cvsDistrict, [], '請先選縣市');
        if (cvsRoadSel) fillSelect(cvsRoadSel, [], '請先選區');
        return;
      }
      
      // 確保資料已載入
      const data = await loadAddressData();
      console.log('資料載入狀態:', data ? `${data.length}筆` : '無資料');
      
      if (data && data.length > 0) {
        const districts = getDistricts(data, c);
        console.log(`${c} 的區域:`, districts);
        fillSelect(cvsDistrict, districts, '請選擇區');
        if (cvsRoadSel) fillSelect(cvsRoadSel, [], '請先選區');
            } else {
          fillSelect(cvsDistrict, [], '無法載入區');
          showError('無法載入區域資料');
        }
        updateZipCvsDisplay();
      });
  
    cvsDistrict?.addEventListener('change', async () => {
      console.log('超商區域變更:', cvsDistrict.value);
      const c = cvsCounty.value;
      const d = cvsDistrict.value;
      
      if (!c || !d) return;
      
      if (cvsRoadSel) {
        const data = await loadAddressData();
        
        if (data && data.length > 0) {
          const roads = getRoads(data, c, d);
          console.log(`${c} ${d} 的路名:`, roads);
          fillSelect(cvsRoadSel, roads, '請選擇路名');
                } else {
            fillSelect(cvsRoadSel, [], '無法載入路名');
            showError('無法載入路名資料');
          }
        }
        updateZipCvsDisplay();
      });
  
    // ★ 新增：台/臺與空白正規化
    function normalizeTW(str) {
      if (!str) return '';
      return String(str).replace(/台/g, '臺').replace(/\s+/g, '');
    }
    function canonicalCounty(v){ return normalizeTW(v); }
    function canonicalDistrict(v){ return normalizeTW(v); }
  
    // ★ 新增：郵遞區號提示共用函式
    function setZipHint(idWrap, idText, zip){
      const wrap = document.getElementById(idWrap);
      const txt  = document.getElementById(idText);
      if (!wrap || !txt) return;
      txt.textContent = zip || '—';
      wrap.setAttribute('data-empty', zip ? 'false' : 'true');
    }
    function digitsOnly(value){
      return (value || '').toString().replace(/\D+/g, '');
    }
    function dropLeadingZero(value){
      if (!value) return '';
      return value.replace(/^0+/, '');
    }
    function buildFullPhone(rawLocal){
      const local = (rawLocal || '').trim();
      if (!local) return '';
      if (/^\s*\+/.test(local)) {
        const digits = digitsOnly(local);
        return digits ? `+${digits}` : '';
      }
      const digits = dropLeadingZero(digitsOnly(local));
      if (!digits) return '';
      const code = DEFAULT_PHONE_CODE;
      return `${code}${digits}`;
    }
    // 工具：姓名拆分（中文優先，但回傳 first=名, last=姓）
    function splitName(full) {
      if (!full) return { first: '', last: '' };
      const raw = full.trim();
      // 英文：最後一個 token 視為姓，其餘是名
      if (/[A-Za-z]/.test(raw)) {
        const parts = raw.split(/\s+/);
        if (parts.length === 1) return { first: parts[0], last: '' };
        return { first: parts.slice(0, -1).join(' '), last: parts.slice(-1)[0] };
      }
      // 中文：第一字為姓，其餘為名（王小明 => 姓=王, 名=小明）
      const name = raw.replace(/\s+/g, '');
      if (name.length <= 1) return { first: name, last: '' };
      return { first: name.slice(1), last: name[0] };
    }
  
    function normPhone(v) {
      return buildFullPhone(v);
    }
  
    async function saveCartAttributes(obj) {
      if (!s.enable_attr) return;
      try {
        await fetch('/cart/update.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ attributes: obj })
        });
      } catch (e) {
        console.warn('cart attributes failed', e);
      }
    }
  
    // 訊息顯示功能
    function showLoading(text) {
      if (msg) {
        msg.innerHTML = `<span class="apgo-loading"></span> ${text}`;
        msg.className = 'apgo-message';
      }
    }
  
    function showError(text) {
      if (msg) {
        msg.textContent = text;
        msg.className = 'apgo-message error';
      }
    }
  
    function showSuccess(text) {
      if (msg) {
        msg.textContent = text;
        msg.className = 'apgo-message success';
      }
    }
  
    function hideMessage() {
      if (msg) {
        msg.textContent = '';
        msg.className = 'apgo-message';
      }
    }
  
  
  })();
  </script>
  
