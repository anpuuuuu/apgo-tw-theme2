{% comment %} Section: APGO Gallery — 綁 product.media {% endcomment %}

<section class="apgo-section apgo-gallery" data-section-id="{{ section.id }}">
  <div class="apgo-container">
    {% if product.media.size > 0 %}
      <div class="apgo-gallery-main" style="margin-bottom:12px;">
        <img src="{{ product.featured_media | image_url: width: 1200 }}"
             alt="{{ product.featured_media.alt | default: product.title }}"
             loading="eager"
             style="width:100%; border-radius:{{ section.settings.image_radius }}px; aspect-ratio: 4/5; object-fit:cover;">
      </div>
      {% if product.media.size > 1 %}
        <div class="apgo-gallery-thumbs" style="display:grid; grid-template-columns:repeat({{ section.settings.thumb_cols }},1fr); gap:8px;">
          {% for media in product.media limit: 6 %}
            <img src="{{ media | image_url: width: 300 }}"
                 alt="{{ media.alt }}"
                 loading="lazy"
                 style="width:100%; aspect-ratio:1/1; object-fit:cover; border-radius:{{ section.settings.thumb_radius }}px; cursor:pointer;"
                 data-gallery-thumb="{{ forloop.index0 }}">
          {% endfor %}
        </div>
      {% endif %}
    {% else %}
      {% render 'apgo-placeholder', name: 'Gallery', hint: '請到「商品 → 媒體」上傳至少 1 張主圖' %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "APGO · Gallery",
  "tag": "section",
  "class": "apgo-section-gallery",
  "settings": [
    { "type": "range", "id": "image_radius", "label": "主圖圓角", "min": 0, "max": 24, "step": 2, "default": 14 },
    { "type": "range", "id": "thumb_radius", "label": "縮圖圓角", "min": 0, "max": 24, "step": 2, "default": 10 },
    { "type": "range", "id": "thumb_cols", "label": "縮圖欄數", "min": 3, "max": 6, "step": 1, "default": 6 }
  ],
  "presets": [{ "name": "APGO · Gallery" }]
}
{% endschema %}
