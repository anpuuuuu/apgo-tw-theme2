<script>
  document.addEventListener('DOMContentLoaded', function () {
    // === 設定 ===
    // true: 以 GET 直接導到 /checkout?…（最保險，百分百帶參數）
    // false: 保留主題原本的 POST，僅把 form.action 改為 /checkout?…
    var REDIRECT_MODE = true;

    var btn = document.getElementById('checkout-standalone');
    if (!btn) return;

    var formId = btn.getAttribute('form') || 'cart-form';
    var form = document.getElementById(formId);
    var ctaContainer = btn.closest('.cart-cta');

    function relocateInjectedNodes() {
      if (!ctaContainer) return;
      var bridgeSection = document.querySelector('[id*="cart_ako_bridge_auto"]');
      if (!bridgeSection) return;

      // 精準搬移 AKO root，避免把 checkout 一起搬走
      var ctaAkoRoots = Array.prototype.slice.call(ctaContainer.querySelectorAll('#akocommerce_cvs_section, .akoCvsScNS'));
      ctaAkoRoots.forEach(function (akoRoot) {
        if (!akoRoot) return;
        var akoParent = akoRoot.parentElement;
        var styleSiblings = akoParent ? Array.prototype.slice.call(akoParent.querySelectorAll(':scope > style')) : [];
        styleSiblings.forEach(function (styleEl) {
          bridgeSection.appendChild(styleEl);
        });
        bridgeSection.appendChild(akoRoot);
      });

      // fallback：避免誤搬含 checkout 的整包容器
      Array.prototype.slice.call(ctaContainer.children).forEach(function (child) {
        var isCheckoutStandalone = child.id === 'checkout-standalone';
        var isAdditionalButtons = child.classList && child.classList.contains('additional-checkout-buttons');
        if (isCheckoutStandalone || isAdditionalButtons) return;
        if (child.querySelector && child.querySelector('#checkout-standalone')) return;
        bridgeSection.appendChild(child);
      });

      // 若 checkout 被第三方 DOM 操作搬離 .cart-cta，強制錨回
      if (!ctaContainer.querySelector('#checkout-standalone')) {
        var detachedCheckout = document.getElementById('checkout-standalone');
        if (detachedCheckout) {
          ctaContainer.insertBefore(detachedCheckout, ctaContainer.firstChild || null);
        }
      }
    }

    relocateInjectedNodes();

    // 取目前 query（先嘗試把最新輸入寫進網址）
    function getCurrentQuery() {
      try {
        // 你的收件欄位 section 內若有此函式，就會把當前輸入同步到 location.search
        if (typeof window.buildCheckoutParams === 'function') {
          window.buildCheckoutParams();
        }
      } catch (e) {
        /* ignore */
      }
      return window.location.search || '';
    }

    // 讓 a/form 也能同步（POST 模式時用得到；或主題別處有 checkout 連結）
    function syncEntrancesNow() {
      var qs = getCurrentQuery();

      // 改本表單 action（POST 模式用）
      if (!REDIRECT_MODE && form) {
        form.action = '/checkout' + qs;
      }

      // 如果主題上還有其它 /checkout 連結，也幫它們接上 query
      document.querySelectorAll('a[href^="/checkout"]').forEach(function (a) {
        a.setAttribute('href', '/checkout' + qs);
      });
    }

    // 初始化同步一次（特別是 POST 模式要先設好 action）
    syncEntrancesNow();

    var stickyTotal = ctaContainer ? ctaContainer.querySelector('[data-cart-cta-total]') : null;
    function syncStickyTotal() {
      if (!stickyTotal) return;
      var source =
        document.querySelector('[data-cart-subtotal]') ||
        document.querySelector('.cart__total .cart__value');
      if (!source) return;
      var text = (source.textContent || '').trim();
      if (text) stickyTotal.textContent = text;
    }
    syncStickyTotal();

    var totalSource = document.querySelector('[data-cart-subtotal]');
    if (totalSource) {
      var totalObserver = new MutationObserver(syncStickyTotal);
      totalObserver.observe(totalSource, { characterData: true, childList: true, subtree: true });
    }

    // 主要行為：點擊 CTA
    btn.addEventListener(
      'click',
      function (ev) {
        // 若按鈕 disabled（空購物車），就不處理
        if (btn.disabled || btn.getAttribute('aria-disabled') === 'true') return;

        var qs = getCurrentQuery();

        if (REDIRECT_MODE) {
          // 攔截提交，保證帶著 query 直達 /checkout
          ev.preventDefault();
          window.location.assign('/checkout' + qs);
        } else {
          // 保留原本 POST：只把 action 改成 /checkout?…
          if (form) form.action = '/checkout' + qs;
          // 不 preventDefault，照常提交
        }
      },
      true
    );

    // 若你的收件欄位用 history.replaceState 即時改網址，這裡再保險補一次
    window.addEventListener('popstate', syncEntrancesNow);

    // 有些主題/抽屜會晚載入或改動 DOM；短期輪詢補強一下
    var tries = 0,
      iv = setInterval(function () {
        syncEntrancesNow();
        syncStickyTotal();
        relocateInjectedNodes();
        if (++tries > 10) clearInterval(iv);
      }, 500);

    if (ctaContainer) {
      var ctaObserver = new MutationObserver(function (mutations) {
        var shouldRelocate = mutations.some(function (m) {
          return m.type === 'childList' && m.addedNodes && m.addedNodes.length > 0;
        });
        if (shouldRelocate) {
          relocateInjectedNodes();
        }
      });
      ctaObserver.observe(ctaContainer, { childList: true });
    }
  });

  // 確保 DOM 完全載入後再執行
  document.addEventListener('DOMContentLoaded', function () {
    // 監聽整個 AKO 購物車區塊的點擊事件
    const akoSection = document.getElementById('akocommerce_cvs_section') || document.querySelector('.akoCvsScNS');

    if (akoSection) {
      akoSection.addEventListener('click', function (event) {
        let targetElement = event.target;

        // 向上遍歷父元素，直到找到具有 data-invoice 屬性的 li 元素
        while (targetElement && targetElement !== this) {
          if (targetElement.matches('li[data-invoice]')) {
            // 找到目標 li 元素，強制觸發點擊事件
            // 模擬原生點擊事件，確保插件的 JS 能夠捕獲到
            const clickEvent = new MouseEvent('click', {
              view: window,
              bubbles: true,
              cancelable: true,
            });
            targetElement.dispatchEvent(clickEvent);

            // 嘗試觸發觸控事件，以防插件只監聽觸控
            const touchStartEvent = new TouchEvent('touchstart', {
              touches: [
                {
                  identifier: Date.now(),
                  target: targetElement,
                  clientX: event.clientX,
                  clientY: event.clientY,
                  screenX: event.screenX,
                  screenY: event.screenY,
                  pageX: event.pageX,
                  pageY: event.pageY,
                },
              ],
              targetTouches: [
                {
                  identifier: Date.now(),
                  target: targetElement,
                  clientX: event.clientX,
                  clientY: event.clientY,
                  screenX: event.screenX,
                  screenY: event.screenY,
                  pageX: event.pageX,
                  pageY: event.pageY,
                },
              ],
              changedTouches: [
                {
                  identifier: Date.now(),
                  target: targetElement,
                  clientX: event.clientX,
                  clientY: event.clientY,
                  screenX: event.screenX,
                  screenY: event.screenY,
                  pageX: event.pageX,
                  pageY: event.pageY,
                },
              ],
              bubbles: true,
              cancelable: true,
            });
            targetElement.dispatchEvent(touchStartEvent);

            const touchEndEvent = new TouchEvent('touchend', {
              touches: [],
              targetTouches: [],
              changedTouches: [
                {
                  identifier: Date.now(),
                  target: targetElement,
                  clientX: event.clientX,
                  clientY: event.clientY,
                  screenX: event.screenX,
                  screenY: event.screenY,
                  pageX: event.pageX,
                  pageY: event.pageY,
                },
              ],
              bubbles: true,
              cancelable: true,
            });
            targetElement.dispatchEvent(touchEndEvent);

            // 阻止原始事件的默認行為和冒泡，避免重複觸發或衝突
            event.preventDefault();
            event.stopPropagation();
            break; // 找到並處理後就跳出循環
          }
          targetElement = targetElement.parentElement;
        }
      });

      // 針對手機版，確保下拉選單項目始終可點擊
      const menuListItems = akoSection.querySelectorAll('.ako-menu-list li[data-invoice]');
      menuListItems.forEach((item) => {
        item.style.setProperty('pointer-events', 'auto', 'important');
        item.style.setProperty('cursor', 'pointer', 'important');
        item.style.setProperty('touch-action', 'manipulation', 'important');
        item.style.setProperty('-webkit-tap-highlight-color', 'rgba(255, 107, 53, 0.4)', 'important');
        item.style.setProperty('user-select', 'none', 'important');
        item.style.setProperty('-webkit-user-select', 'none', 'important');
        item.style.setProperty('-moz-user-select', 'none', 'important');
        item.style.setProperty('-ms-user-select', 'none', 'important');
      });

      // 確保按鈕本身也始終可點擊
      const menuButton = akoSection.querySelector('.ako-menu-button');
      if (menuButton) {
        menuButton.style.setProperty('pointer-events', 'auto', 'important');
        menuButton.style.setProperty('cursor', 'pointer', 'important');
        menuButton.style.setProperty('touch-action', 'manipulation', 'important');
        menuButton.style.setProperty('-webkit-tap-highlight-color', 'rgba(255, 107, 53, 0.4)', 'important');
        menuButton.style.setProperty('user-select', 'none', 'important');
        menuButton.style.setProperty('-webkit-user-select', 'none', 'important');
        menuButton.style.setProperty('-moz-user-select', 'none', 'important');
        menuButton.style.setProperty('-ms-user-select', 'none', 'important');
      }

      // 觀察 DOM 變化，如果插件動態添加或修改元素，重新應用樣式
      const observer = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          if (mutation.type === 'childList' || mutation.type === 'attributes') {
            const newItems = akoSection.querySelectorAll('.ako-menu-list li[data-invoice]');
            newItems.forEach((item) => {
              item.style.setProperty('pointer-events', 'auto', 'important');
              item.style.setProperty('cursor', 'pointer', 'important');
              item.style.setProperty('touch-action', 'manipulation', 'important');
              item.style.setProperty('-webkit-tap-highlight-color', 'rgba(255, 107, 53, 0.4)', 'important');
              item.style.setProperty('user-select', 'none', 'important');
              item.style.setProperty('-webkit-user-select', 'none', 'important');
              item.style.setProperty('-moz-user-select', 'none', 'important');
              item.style.setProperty('-ms-user-select', 'none', 'important');
            });
          }
        });
      });

      // 配置觀察器選項：監聽子節點變化和屬性變化
      const config = { childList: true, subtree: true, attributes: true };
      observer.observe(akoSection, config);
    }

    // 輸入框增強功能
    const enhanceInputs = () => {
      const akoInputs = document.querySelectorAll('.ako-input, input.ako-input');

      akoInputs.forEach(function (input) {
        // 避免重複綁定
        if (input.hasAttribute('data-ako-enhanced')) return;
        input.setAttribute('data-ako-enhanced', 'true');

        // 焦點增強效果
        input.addEventListener('focus', function () {
          this.classList.add('ako-input--focused');
          // 輕微震動反饋（支援的設備）
          if (navigator.vibrate) {
            navigator.vibrate(10);
          }
        });

        input.addEventListener('blur', function () {
          this.classList.remove('ako-input--focused');
        });

        // 即時驗證反饋
        input.addEventListener('input', function () {
          // 移除錯誤狀態（如果有輸入內容）
          if (this.value.trim() !== '') {
            this.setAttribute('aria-invalid', 'false');
            this.classList.remove('ako-input--error');
          }

          // 特殊處理統一編號格式
          if (this.name === 'ako-company-code') {
            // 只允許數字，最多8位
            this.value = this.value.replace(/\D/g, '').slice(0, 8);

            // 即時驗證統一編號長度
            if (this.value.length === 8) {
              this.classList.add('ako-input--valid');
            } else {
              this.classList.remove('ako-input--valid');
            }
          }

          // 公司名稱長度提示
          if (this.name === 'ako-company-name') {
            if (this.value.length > 50) {
              this.value = this.value.slice(0, 50);
            }
          }
        });

        // 貼上事件處理
        input.addEventListener('paste', function (e) {
          setTimeout(() => {
            this.dispatchEvent(new Event('input', { bubbles: true }));
          }, 0);
        });
      });
    };

    // 初始化輸入框增強
    enhanceInputs();

    // 監聽 DOM 變化，為新增的輸入框加上增強功能
    const inputObserver = new MutationObserver(function (mutations) {
      mutations.forEach(function (mutation) {
        mutation.addedNodes.forEach(function (node) {
          if (node.nodeType === 1) {
            // 元素節點
            enhanceInputs(); // 重新掃描所有輸入框
          }
        });
      });
    });

    // 觀察整個文檔的變化
    if (akoSection) {
      inputObserver.observe(akoSection, {
        childList: true,
        subtree: true,
      });
    }
  });
</script>

{% schema %}
{
  "name": "Cart CTA (Standalone)",
  "settings": [
    {
