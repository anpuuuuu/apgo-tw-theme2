{%- comment -%} Cart Checkout CTA (standalone section) {%- endcomment -%}
<div class="cart-cta color-{{ section.settings.color_scheme }}">
  <div class="cart-cta__bar">
    <div class="cart-cta__summary">
      <span class="cart-cta__summary-label">{{ section.settings.total_label | escape }}</span>
      <span class="cart-cta__summary-value" data-cart-cta-total>{{ cart.total_price | money }}</span>
    </div>
    <button
      type="submit"
      id="checkout-standalone"
      class="cart__checkout-button button"
      name="checkout"
      {%- if cart == empty -%}
        disabled
      {%- endif -%}
      form="cart-form"
    >
      {{ section.settings.checkout_label | escape }}
    </button>
  </div>

  {%- if section.settings.show_accelerated
    and additional_checkout_buttons
    and settings.show_accelerated_checkout_buttons
  -%}
    <div class="additional-checkout-buttons additional-checkout-buttons--vertical cart-cta__accelerated">
      {{ content_for_additional_checkout_buttons }}
    </div>
  {%- endif -%}
</div>

{% stylesheet %}
    /* ========================================
       購物車結帳按鈕樣式設計
       ======================================== */

    /* 主容器樣式 */
    .cart-cta {
      display: flex;
      flex-direction: column;
      gap: var(--gap-md);
      margin: 32px 0 40px 0;
    }

    /* 結帳按鈕主體樣式 */
    .cart-cta .cart__checkout-button,
    .cart-cta .button,
    #checkout-standalone.cart__checkout-button {
      background: linear-gradient(135deg, #ff6b35, #f7931e) !important;
      border: none !important;
      border-radius: 16px !important;
      padding: 20px 40px !important;
      font-size: 18px !important;
      font-weight: 700 !important;
      color: #ffffff !important;
      width: 100% !important;
      max-width: 480px !important;
      margin: 0 auto !important;
      cursor: pointer !important;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
      box-shadow:
          0 12px 35px rgba(255, 107, 53, 0.4),
          inset 0 1px 0 rgba(255, 255, 255, 0.2) !important;
      text-transform: none !important;
      letter-spacing: 1px !important;
      position: relative !important;
      overflow: hidden !important;
      display: block !important;
      z-index: 100 !important;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans', sans-serif !important;

      /* 確保按鈕不會被覆蓋 */
      clear: both !important;
    }

    /* 結帳按鈕發光效果 */
    .cart-cta .cart__checkout-button::before,
    .cart-cta .button::before,
    #checkout-standalone.cart__checkout-button::before {
      content: '' !important;
      position: absolute !important;
      top: 0 !important;
      left: -100% !important;
      width: 100% !important;
      height: 100% !important;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.3), transparent) !important;
      transition: left 0.6s ease !important;
    }

    /* 懸停效果 */
    .cart-cta .cart__checkout-button:hover,
    .cart-cta .button:hover,
    #checkout-standalone.cart__checkout-button:hover {
      transform: translateY(-4px) !important;
      box-shadow:
          0 16px 45px rgba(255, 107, 53, 0.5),
          inset 0 1px 0 rgba(255, 255, 255, 0.3) !important;
    }

    .cart-cta .cart__checkout-button:hover::before,
    .cart-cta .button:hover::before,
    #checkout-standalone.cart__checkout-button:hover::before {
      left: 100% !important;
    }

    /* 按下效果 */
    .cart-cta .cart__checkout-button:active,
    .cart-cta .button:active,
    #checkout-standalone.cart__checkout-button:active {
      transform: translateY(-2px) !important;
      box-shadow:
          0 8px 25px rgba(255, 107, 53, 0.4),
          inset 0 1px 0 rgba(255, 255, 255, 0.2) !important;
    }

    /* 禁用狀態 */
    .cart-cta .cart__checkout-button:disabled,
    .cart-cta .button:disabled,
    #checkout-standalone.cart__checkout-button:disabled,
    .cart-cta .cart__checkout-button[style*="pointer-events: none"],
    .cart-cta .button[style*="pointer-events: none"],
    #checkout-standalone.cart__checkout-button[style*="pointer-events: none"] {
      background: linear-gradient(135deg, #666666, #555555) !important;
      cursor: not-allowed !important;
      transform: none !important;
      box-shadow:
          0 4px 15px rgba(0, 0, 0, 0.2),
          inset 0 1px 0 rgba(255, 255, 255, 0.1) !important;
      opacity: 0.6 !important;
    }

    /* 額外結帳按鈕樣式 */
    .additional-checkout-buttons {
      margin-top: 16px !important;
    }

    .additional-checkout-buttons .additional-checkout-button {
      background: linear-gradient(145deg, #2d2d2d, #1a1a1a) !important;
      border: 2px solid #404040 !important;
      border-radius: 12px !important;
      padding: 16px 20px !important;
      font-size: 15px !important;
      color: #ffffff !important;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
      box-shadow:
          0 4px 15px rgba(0, 0, 0, 0.3),
          inset 0 1px 0 rgba(255, 255, 255, 0.1) !important;
      margin: 8px 0 !important;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif !important;
    }

    .additional-checkout-buttons .additional-checkout-button:hover {
      border-color: #ff6b35 !important;
      box-shadow:
          0 8px 25px rgba(255, 107, 53, 0.3),
          inset 0 1px 0 rgba(255, 255, 255, 0.1) !important;
      transform: translateY(-2px) !important;
    }

    /* 響應式設計 */
    @media (max-width: 768px) {
      .cart-cta .cart__checkout-button,
      .cart-cta .button,
      #checkout-standalone.cart__checkout-button {
        padding: 18px 32px !important;
        font-size: 16px !important;
        margin: 24px auto 32px auto !important;
        border-radius: 14px !important;
      }

      .cart-cta {
        margin: 24px 0 32px 0;
      }
    }

    @media (max-width: 480px) {
      .cart-cta .cart__checkout-button,
      .cart-cta .button,
      #checkout-standalone.cart__checkout-button {
        padding: 16px 28px !important;
        font-size: 15px !important;
        margin: 20px auto 28px auto !important;
        border-radius: 12px !important;
      }

      .cart-cta {
        margin: 20px 0 28px 0;
      }
    }

    /* 動畫效果 */
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .cart-cta {
      animation: fadeInUp 0.6s ease-out !important;
    }

  .cart-cta {
      position: fixed !important;
      left: 16px !important;
      right: 16px !important;
      bottom: 16px !important;
      z-index: 90 !important;
      margin: 0 !important;
  }

  .cart-cta__bar {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 12px;
      border: 1px solid #333333;
      border-radius: 14px;
      background: rgba(18, 18, 18, 0.96);
      backdrop-filter: blur(12px);
  }

  .cart-cta__summary {
      min-width: 0;
      display: flex;
      flex-direction: column;
      gap: 4px;
  }

  .cart-cta__summary-label {
      font-size: 11px;
      letter-spacing: 1px;
      text-transform: uppercase;
      color: #999999;
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  .cart-cta__summary-value {
      color: #ffffff;
      font-size: 16px;
      font-weight: 800;
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }

  .cart-cta .cart__checkout-button,
  .cart-cta .button,
  #checkout-standalone.cart__checkout-button {
      max-width: none !important;
      margin: 0 !important;
      flex: 1 1 auto;
      min-height: 52px;
      border-radius: 10px !important;
      box-shadow: none !important;
  }

  .cart-cta__accelerated {
      display: none;
  }

  @supports selector(body:has(.cart-cta)) {
      body:has(.cart-cta) {
          padding-bottom: 120px !important;
      }
  }

  @media (min-width: 1024px) {
      .cart-cta {
          left: 50% !important;
          right: auto !important;
          width: min(1360px, calc(100vw - 48px)) !important;
          transform: translateX(-50%);
          bottom: 20px !important;
      }

      .cart-cta__bar {
          width: min(420px, 100%);
          margin-left: auto;
      }

      @supports selector(body:has(.cart-cta)) {
          body:has(.cart-cta) {
              padding-bottom: 140px !important;
          }
      }
  }

  #akocommerce_cvs_section,
  #akocommerce_cvs_section *,
  .akoCvsScNS,
  .akoCvsScNS * {
      color: #ffffff !important;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, 'Noto Sans', sans-serif !important;
      box-sizing: border-box !important;
  }

  /* 確保頁面背景 */
  body:has(#akocommerce_cvs_section),
  body:has(.akoCvsScNS) {
      background: #0a0a0a !important;
      color: #ffffff !important;
  }

  /* 主容器樣式 */
  #akocommerce_cvs_section,
  .akoCvsScNS {
      background: transparent !important;
      border: none !important;
      padding: 0 !important;
      margin: 0 auto !important;
  }

  .ako-container {
      position: relative;
      overflow: hidden; 
      background: linear-gradient(145deg, #1a1a1a, #2d2d2d) !important;
      border-radius: 20px !important;
      box-shadow:
          0 25px 50px rgba(0, 0, 0, 0.5),
          inset 0 1px 0 rgba(255, 255, 255, 0.1) !important;
      border: 1px solid #333333 !important;
      padding: 0 !important;
      margin: 20px auto !important;
      max-width: 480px !important;
      width: 100% !important;
      display: flex !important;
      flex-direction: column !important;
      gap: 0 !important;
      min-height: auto !important;
      position: relative !important;
      z-index: 1 !important;
  }

  /* 區段樣式 */
  .ako-invoice,
  .ako-cvs-section,
  section.ako-invoice,
  section.ako-cvs-section {
      padding: 32px !important;
      border-bottom: 1px solid #333333 !important;
      position: relative !important;
      background: transparent !important;
      margin: 0 !important;
      display: flex !important;
      flex-direction: column !important;
      row-gap: 16px !important;
      overflow: visible !important;
      z-index: 2 !important;
  }

  .ako-cvs-section:last-child,
  section.ako-cvs-section:last-child {
      border-bottom: none !important;
  }

  /* 橘色頂部線條 */
  .ako-invoice::before,
  .ako-cvs-section::before,
  section.ako-invoice::before,
  section.ako-cvs-section::before {
      content: '' !important;
      position: absolute !important;
      top: 0 !important;
      left: 0 !important;
      right: 0 !important;
      height: 3px !important;
      background: linear-gradient(90deg, #ff6b35, #f7931e) !important;
      border-radius: 0 0 2px 2px !important;
      width: 100%;
  }

  /* 標題樣式 */
  .ako-invoice-title,
  .ako-cvs-title,
  h2.ako-invoice-title,
  h2.ako-cvs-title {
      font-size: 24px !important;
      font-weight: 700 !important;
      color: #ffffff !important;
      margin: 0 0 8px 0 !important;
      background: linear-gradient(135deg, #ff6b35, #f7931e) !important;
      -webkit-background-clip: text !important;
      -webkit-text-fill-color: transparent !important;
      background-clip: text !important;
      text-shadow: 0 0 10px rgba(255, 107, 53, 0.5) !important;
      text-align: left !important;
      padding: 0 !important;
  }

  .ako-invoice-subtitle {
      font-size: 16px !important;
      font-weight: 600 !important;
      color: #cccccc !important;
      margin: 0 0 16px 0 !important;
      padding: 0 !important;
  }

  /* 資訊框樣式 */
  .ako-info-box,
  p.ako-info-box {
      background: linear-gradient(135deg, #2a1810, #1a1a1a) !important;
      border: 1px solid #ff6b35 !important;
      border-radius: 12px !important;
      padding: 20px !important;
      margin: 0 0 24px 0 !important;
      font-size: 14px !important;
      color: #e0e0e0 !important;
      position: relative !important;
      overflow: hidden !important;
      line-height: 1.5 !important;
  }

  .ako-info-box::before,
  p.ako-info-box::before {
      content: '' !important;
      position: absolute !important;
      top: 0 !important;
      left: 0 !important;
      right: 0 !important;
      height: 3px !important;
      background: linear-gradient(90deg, #ff6b35, #f7931e) !important;
  }

  .ako-info-box strong,
  p.ako-info-box strong {
      color: #ff6b35 !important;
      font-weight: 600 !important;
  }

  /* 發票設定區域 */
  .ako-invoice-setting,
  .ako-invoice-type {
      display: flex !important;
      flex-direction: column !important;
      gap: 16px !important;
      margin: 0 !important;
      padding: 0 !important;
  }

  /* ========================================
     關鍵修復：下拉選單系統
     ======================================== */

  /* 下拉選單容器 - 最高優先級 */
  .ako-menu {
      position: relative !important;
      z-index: 9999 !important;
      margin: 0 0 20px 0 !important;
      width: 100% !important;
  }

  /* 下拉按鈕 - 手機版優化 + 點擊修復 */
  .ako-menu-button {
      width: 100% !important;
      background: linear-gradient(145deg, #2d2d2d, #1a1a1a) !important;
      border: 2px solid #404040 !important;
      border-radius: 12px !important;
      padding: 16px 20px !important;
      font-size: 15px !important;
      color: #ffffff !important;
      cursor: pointer !important;
      display: flex !important;
      align-items: center !important;
      justify-content: space-between !important;
      transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
      box-shadow:
          0 4px 15px rgba(0, 0, 0, 0.3),
          inset 0 1px 0 rgba(255, 255, 255, 0.1) !important;
      margin: 0 !important;
      min-height: 56px !important;
      position: relative !important;

      /* 手機端觸控優化 */
      -webkit-tap-highlight-color: rgba(255, 107, 53, 0.3) !important;
      touch-action: manipulation !important;
      user-select: none !important;
      -webkit-user-select: none !important;
      -moz-user-select: none !important;
      -ms-user-select: none !important;

      /* 點擊事件修復 */
      pointer-events: auto !important;
  }

  /* 修復按鈕內部元素的點擊事件傳遞 */
  .ako-menu-button * {
      pointer-events: auto !important;
  }

  /* 確保按鈕內的 li 元素能正確處理點擊 */
  .ako-menu-button .ako-menu__item {
      pointer-events: auto !important;
      cursor: pointer !important;
      width: 100% !important;
      display: flex !important;
      align-items: center !important;
      gap: 8px !important;
      padding: 0 !important;
      margin: 0 !important;
      list-style: none !important;
      background: transparent !important;
      border: none !important;
  }

  /* 修復按鈕內部元素的樣式衝突 */
  .ako-menu-button .ako-menu__item span {
      pointer-events: none !important; /* 防止圖示攔截點擊 */
  }

  .ako-menu-button:hover,
  .ako-menu-button:focus,
  .ako-menu-button:active {
      border-color: #ff6b35 !important;
      box-shadow:
          0 8px 25px rgba(255, 107, 53, 0.3),
          inset 0 1px 0 rgba(255, 255, 255, 0.1) !important;
      transform: translateY(-2px) !important;
      outline: none !important;
  }

  /* 箭頭圖示 */
  .ako-menu-button__arrow {
      width: 20px !important;
      height: 20px !important;
      color: #888888 !important;
      transition: transform 0.3s ease, color 0.3s ease !important;
      position: static !important;
      transform: none !important;
      right: auto !important;
      top: auto !important;
      margin: 0 !important;
      flex-shrink: 0 !important;
      pointer-events: none !important; /* 確保箭頭不會攔截點擊事件 */
  }

  .ako-menu-button:hover .ako-menu-button__arrow {
      color: #ff6b35 !important;
  }

  /* 核心修復：下拉選單顯示邏輯 */
  .ako-menu-list {
      position: absolute !important;
      top: 100% !important;
      left: 0 !important;
      right: 0 !important;
      width: 100% !important;
      background: linear-gradient(145deg, #2d2d2d, #1a1a1a) !important;
      border: 2px solid #404040 !important;
      border-radius: 12px !important;
      margin: 8px 0 0 0 !important;
      padding: 0 !important;
      z-index: 10000 !important;
      box-shadow:
          0 20px 40px rgba(0, 0, 0, 0.5),
          inset 0 1px 0 rgba(255, 255, 255, 0.1) !important;

      /* 預設隱藏 - 重要：覆蓋所有可能的顯示狀態 */
      max-height: 0 !important;
      overflow: hidden !important;
      opacity: 0 !important;
      visibility: hidden !important;
      transform: translateY(-10px) scale(0.95) !important;
      pointer-events: none !important;

      /* 流暢動畫 */
      transition:
          max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1),
          opacity 0.3s ease,
          visibility 0.3s ease,
          transform 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
  }

  /* 關鍵修復：多種顯示狀態檢測 */
  /* 當 JavaScript 設定非零 max-height 時顯示 */
  .ako-menu-list[style*="max-height"][style*="px"]:not([style*="max-height: 0px"]),
  .ako-menu-list[style*="max-height: 1"],
  .ako-menu-list[style*="max-height: 2"],
  .ako-menu-list[style*="max-height: 3"],
  .ako-menu-list[style*="max-height: 4"],
  .ako-menu-list[style*="max-height: 5"],
  .ako-menu-list[style*="max-height: 100"],
  .ako-menu-list[style*="max-height: 150"],
  .ako-menu-list[style*="max-height: 200"],
  .ako-menu-list[style*="max-height: 250"],
  .ako-menu-list[style*="max-height: 300"],
  .ako-menu-list[style*="max-height: 400"],
  .ako-menu-list[style*="max-height: 500"] {
      max-height: 300px !important;
      overflow: visible !important;
      opacity: 1 !important;
      visibility: visible !important;
      transform: translateY(0) scale(1) !important;
      pointer-events: auto !important;
      border-color: #ff6b35 !important;
  }

  /* 備用顯示方案 - 基於 class 或 data 屬性 */
  .ako-menu.open .ako-menu-list,
  .ako-menu[data-open="true"] .ako-menu-list,
  .ako-menu-list.open,
  .ako-menu-list[data-open="true"],
  .ako-menu-list.show,
  .ako-menu-list[data-show="true"] {
      max-height: 300px !important;
      overflow: visible !important;
      opacity: 1 !important;
      visibility: visible !important;
      transform: translateY(0) scale(1) !important;
      pointer-events: auto !important;
      border-color: #ff6b35 !important;
  }

  /* 下拉選單項目 - 手機版優化 + 點擊修復 */
  .ako-menu-list .ako-menu__item,
  .ako-menu-list li.ako-menu__item {
      padding: 18px 20px !important;
      cursor: pointer !important;
      display: flex !important;
      align-items: center !important;
      gap: 12px !important;
      justify-content: space-between !important;
      border-bottom: 1px solid #404040 !important;
      color: #e0e0e0 !important;
      list-style: none !important;
      margin: 0 !important;
      position: relative !important;

      /* 手機端觸控優化 */
      -webkit-tap-highlight-color: rgba(255, 107, 53, 0.2) !important;
      touch-action: manipulation !important;
      min-height: 56px !important;
      user-select: none !important;
      -webkit-user-select: none !important;

      /* 點擊事件修復 */
      pointer-events: auto !important;

      /* 流暢過渡 */
      transition:
          background-color 0.2s ease,
          color 0.2s ease !important;
  }

  /* 確保選單項目內的所有元素都能傳遞點擊事件 */
  .ako-menu-list .ako-menu__item * {
      pointer-events: none !important; /* 讓點擊事件穿透到父元素 */
  }

  /* 但是保持項目本身可點擊 */
  .ako-menu-list .ako-menu__item {
      pointer-events: auto !important;
  }

  /* 修復：當選單顯示時確保可以互動 */
  .ako-menu-list[style*="max-height"][style*="px"]:not([style*="max-height: 0px"]) .ako-menu__item {
      pointer-events: auto !important;
  }

  /* 額外修復：確保在所有顯示狀態下都能點擊 */
  .ako-menu-list[style*="max-height: 1"] .ako-menu__item,
  .ako-menu-list[style*="max-height: 2"] .ako-menu__item,
  .ako-menu-list[style*="max-height: 3"] .ako-menu__item,
  .ako-menu-list[style*="max-height: 4"] .ako-menu__item,
  .ako-menu-list[style*="max-height: 5"] .ako-menu__item,
  .ako-menu-list[style*="max-height: 200"] .ako-menu__item,
  .ako-menu-list[style*="max-height: 250"] .ako-menu__item,
  .ako-menu-list[style*="max-height: 300"] .ako-menu__item,
  .ako-menu-list[style*="max-height: 400"] .ako-menu__item,
  .ako-menu-list[style*="max-height: 500"] .ako-menu__item {
      pointer-events: auto !important;
      cursor: pointer !important;
  }

  /* 特別處理：確保在任何情況下選單項目都能響應點擊 */
  .ako-menu-list li[data-invoice] {
      pointer-events: auto !important;
      cursor: pointer !important;
  }

  .ako-menu-list .ako-menu__item:last-child,
  .ako-menu-list li.ako-menu__item:last-child {
      border-bottom: none !important;
      border-radius: 0 0 10px 10px !important;
  }

  .ako-menu-list .ako-menu__item:first-child,
  .ako-menu-list li.ako-menu__item:first-child {
      border-radius: 10px 10px 0 0 !important;
