{% comment %} Section: Related Products · 立即可用（綁 collection） {% endcomment %}

<section class="apgo-section apgo-related" data-section-id="{{ section.id }}">
  <div class="apgo-container" style="padding:60px 32px; border-top:1px solid var(--apgo-line);">
    <h3 class="apgo-serif" style="font-size:24px; margin-bottom:28px; font-weight:400; text-align:center;">{{ section.settings.heading }}</h3>

    {%- assign col = collections[section.settings.collection] -%}
    {% if col and col.products.size > 0 %}
      <div style="display:grid; grid-template-columns:repeat({{ section.settings.columns }}, 1fr); gap:20px;">
        {% for p in col.products limit: section.settings.limit %}
          {% if p.handle != product.handle %}
            <a href="{{ p.url }}" style="text-decoration:none; color:inherit;">
              <img src="{{ p.featured_image | image_url: width: 400 }}"
                   alt="{{ p.title }}"
                   loading="lazy"
                   style="width:100%; aspect-ratio:1/1; object-fit:cover; margin-bottom:12px; border-radius:12px;">
              <div class="apgo-serif" style="font-size:14px; margin-bottom:4px;">{{ p.title }}</div>
              <div style="font-size:13px;">{{ p.price | money }}</div>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      {% render 'apgo-placeholder', name: '相關商品', hint: '請在此 Section 設定選擇一個 Collection' %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "APGO · Related Products",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "標題", "default": "您可能也喜歡" },
    { "type": "collection", "id": "collection", "label": "商品集合" },
    { "type": "range", "id": "columns", "label": "欄數", "min": 2, "max": 5, "step": 1, "default": 4 },
    { "type": "range", "id": "limit", "label": "最多顯示", "min": 2, "max": 12, "step": 1, "default": 4 }
  ],
  "presets": [{ "name": "APGO · Related Products" }]
}
{% endschema %}
