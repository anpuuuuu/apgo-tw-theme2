{% comment %}
  Coating Products Showcase - APGO 專業鍍膜產品展示（橫向滑動）
{% endcomment %}

<div class="header-section-coating">
  <h1 class="main-title">{{ section.settings.title | default: "專業鍍膜產品系列" }}</h1>
  <p class="description-text">{{ section.settings.subtitle | default: "APGO研發的鍍膜皆不分任何車色、不分任何材質，開始挑選專屬自己的鍍膜吧" }}</p>
</div>

<section class="coating-showcase">
  <div class="product-scroll-wrapper coating-products-scrollbar" id="productScroller">
    {% for block in section.blocks %}
    <div class="product-block">
      <div class="product-card {{ block.settings.effect }}">
        <div class="product-card-top-bar"></div>
        {% if block.settings.badge != blank %}
          <div class="product-badge">{{ block.settings.badge }}</div>
        {% endif %}
        <div class="product-image">
          {% if block.settings.image != blank %}
            <img src="{{ block.settings.image | image_url }}" alt="{{ block.settings.name }}">
          {% endif %}
        </div>
        <div class="product-content">
          <div>
            <h3 class="product-name">{{ block.settings.name }}</h3>
            <p class="product-description">{{ block.settings.description }}</p>
          </div>
          <div class="properties">
            {% if block.settings.duration != blank %}
              <div class="property">
                <div class="property-header">
                  <span class="property-name">持久度</span><span class="property-value">{{ block.settings.duration }}</span>
                </div>
                <div class="progress-bar"><div class="progress-fill" style="width: {{ block.settings.duration_fill }}"></div></div>
              </div>
            {% endif %}
            {% if block.settings.hydrophobic != blank %}
              <div class="property">
                <div class="property-header">
                  <span class="property-name">疏水度</span><span class="property-value">{{ block.settings.hydrophobic }}</span>
                </div>
                <div class="progress-bar"><div class="progress-fill" style="width: {{ block.settings.hydrophobic_fill }}"></div></div>
              </div>
            {% endif %}
            {% if block.settings.wash != blank %}
              <div class="property">
                <div class="property-header">
                  <span class="property-name">耐洗度</span><span class="property-value">{{ block.settings.wash }}</span>
                </div>
                <div class="progress-bar"><div class="progress-fill" style="width: {{ block.settings.wash_fill }}"></div></div>
              </div>
            {% endif %}
            {% if block.settings.gloss != blank %}
              <div class="property">
                <div class="property-header">
                  <span class="property-name">光澤度</span><span class="property-value">{{ block.settings.gloss }}</span>
                </div>
                <div class="progress-bar"><div class="progress-fill" style="width: {{ block.settings.gloss_fill }}"></div></div>
              </div>
            {% endif %}
          </div>
          <div class="cta-wrapper">
            <button class="cta-button" onclick="goToProduct('{{ block.settings.product_key }}')">立即試用</button>
          </div>
        </div>
      </div>
    </div>
    {% endfor %}
  </div>

  <!-- 滾動指示器 -->
  <div class="scroll-indicator">
    <div class="scroll-indicator-text">← 滑動查看更多產品 →</div>
    <div class="scroll-dots">
      {% for block in section.blocks %}
        <div class="scroll-dot {% if forloop.first %}active{% endif %}"></div>
      {% endfor %}
    </div>
  </div>
</section>
{% style %}
  * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: 'Arial', sans-serif;
      background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
      color: #ffffff;
      overflow-x: hidden;
    }
    
    /* 標題區域樣式 */
    .header-section-coating {
      text-align: center;
      padding: 40px 20px 20px 20px;
    }
    
    .main-title {
      font-size: 2.5rem;
      font-weight: bold;
      color: #f08418;
      margin-bottom: 16px;
      line-height: 1.2;
    }
    
    .description-text {
      font-size: 1.1rem;
      color: #b0b0b0;
      line-height: 1.6;
      max-width: 800px;
      margin: 0 auto;
    }
    
    .coating-showcase {
      padding: 20px 20px 60px 20px;
      position: relative;
      width: 100%;
      max-width: 100vw;
    }
    .product-scroll-wrapper {
      display: flex;
      gap: 30px;
      overflow-x: auto !important;
      overflow-y: hidden !important;
      padding: 20px 0 40px 0;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      /* 強制顯示滾動條 */
      scrollbar-width: thin !important;
      scrollbar-color: #f08418 rgba(255, 255, 255, 0.1) !important;
    }
    
    /* WebKit 瀏覽器滾動條 - 提高優先級 */
    .coating-showcase .product-scroll-wrapper.coating-products-scrollbar::-webkit-scrollbar {
      height: 8px !important;
      display: block !important;
    }
    .coating-showcase .product-scroll-wrapper.coating-products-scrollbar::-webkit-scrollbar-track {
      background: rgba(255, 255, 255, 0.1) !important;
      border-radius: 4px !important;
    }
    .coating-showcase .product-scroll-wrapper.coating-products-scrollbar::-webkit-scrollbar-thumb {
      background: #f08418 !important;
      border-radius: 4px !important;
    }
    .coating-showcase .product-scroll-wrapper.coating-products-scrollbar::-webkit-scrollbar-thumb:hover {
      background: #ff9a3c !important;
    }
    
    /* 右邊漸層提示 - 讓用戶知道還有更多內容 */
    .coating-showcase::after {
      content: '';
      position: absolute;
      top: 20px;
      right: 0;
      width: 30px;
      height: calc(100% - 120px);
      background: linear-gradient(90deg, transparent 0%, rgba(26, 26, 26, 0.8) 100%);
      pointer-events: none;
      z-index: 5;
    }
    
    /* 滾動指示器 - 強制樣式 */
    .scroll-indicator {
      position: absolute !important;
      bottom: 20px !important;
      left: 50% !important;
      transform: translateX(-50%) !important;
      color: #f08418 !important;
      font-size: 0.8rem !important;
      text-align: center !important;
      z-index: 10 !important;
      opacity: 0.8 !important;
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      justify-content: center !important;
      width: 200px !important;
    }
    
    .scroll-indicator-text {
      margin-bottom: 8px !important;
      color: #f08418 !important;
      font-size: 0.8rem !important;
      text-align: center !important;
      display: block !important;
      width: 100% !important;
      line-height: 1.2 !important;
    }
    
    .scroll-dots {
      display: flex !important;
      gap: 8px !important;
      justify-content: center !important;
      align-items: center !important;
      margin: 0 auto !important;
      width: 100% !important;
    }
    
    .scroll-dot {
      width: 8px !important;
      height: 8px !important;
      border-radius: 50% !important;
      background: rgba(240, 132, 24, 0.3) !important;
      transition: all 0.3s ease !important;
      display: block !important;
      flex-shrink: 0 !important;
    }
    
    .scroll-dot.active {
      background: #f08418 !important;
      transform: scale(1.2) !important;
    }
    
    .product-block {
      flex: 0 0 auto;
      width: 420px;
      height: 400px;
      position: relative;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .product-card {
      position: relative;
      width: 100%;
      height: 100%;
      background: #252525 !important;
      border-radius: 16px;
      padding: 24px;
      border: 1px solid #3a3a3a;
      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);
      transition: all 0.3s ease;
      display: flex;
      flex-direction: row;
      align-items: stretch;
    }
    
    .product-card:hover {
      box-shadow: 0 12px 32px rgba(240, 132, 24, 0.3);
      transform: translateY(-4px);
    }
    
    .product-card-top-bar {
      position: absolute;
      top: 0;
      left: 50%;
      transform: translateX(-50%);
      width: 85%;
      height: 4px;
      background: linear-gradient(90deg, #f08418, #ff9a3c);
      border-radius: 16px;
      z-index: 1;
    }
    
    .product-badge {
      position: absolute;
      top: 16px;
      right: 16px;
      background: #f08418;
      color: white;
      padding: 1px 12px;
      border-radius: 15px;
      font-size: 0.9rem;
      font-weight: bold;
      z-index: 10;
    }

    .product-image {
      width: 160px;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
      flex-shrink: 0;
    }

    .product-image img {
      width: auto;
      height: 90%;
      max-width: 100%;
      object-fit: contain;
      display: block;
      filter: drop-shadow(0 8px 16px rgba(0, 0, 0, 0.3));
    }

    .product-content {
      flex: 1;
      display: flex;
      flex-direction: column;
      padding-left: 20px;
      justify-content: center;
      height: 100%;
      position: relative;
    }

    .cta-wrapper {
      text-align: center;
      margin-top: 15px;
    }

    .cta-button {
      display: block;
      width: 100%;
      background: linear-gradient(45deg, #f08418, #ff9a3c);
      color: white;
      text-decoration: none;
      padding: 8px 12px !important;
      border-radius: 12px;
      font-size: 0.85rem !important;
      font-weight: bold;
      cursor: pointer;
      transition: all 0.3s ease;
      box-shadow: 0 2px 6px rgba(240, 132, 24, 0.3);
      border: none;
      text-align: center;
    }

    .cta-button:hover {
      background: linear-gradient(45deg, #ff9a3c, #f08418);
      transform: translateY(-1px);
      box-shadow: 0 3px 10px rgba(240, 132, 24, 0.4);
    }
    
    .product-name {
      font-size: 1.5rem !important;
      font-weight: bold;
      color: #f08418;
      margin-bottom: 8px;
    }
    
    /* 各產品專屬效果 */
    /* 鈦晶鍍膜 - 極光漸變效果 */
    .titanium-product .product-name {
      background: linear-gradient(45deg, #4FC3F7, #81E6F3, #4DD0E1);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      animation: titanium-aurora 3s ease-in-out infinite;
    }
    
    @keyframes titanium-aurora {
      0%, 100% { 
        background: linear-gradient(45deg, #4FC3F7, #81E6F3, #4DD0E1);
        -webkit-background-clip: text;
        background-clip: text;
      }
      50% { 
        background: linear-gradient(45deg, #81E6F3, #4DD0E1, #4FC3F7);
        -webkit-background-clip: text;
        background-clip: text;
      }
    }
    
    /* 原子極光鍍膜 - 星形閃爍效果 */
    .aurora-product .product-name {
      color: #4DD0E1 !important;
      position: relative;
    }
    
    .aurora-product .product-name::before {
      content: '✦';
      position: absolute;
      top: -5px;
      right: -8px;
      font-size: 0.8rem;
      color: #4DD0E1;
      animation: aurora-twinkle 2s ease-in-out infinite;
    }
    
    @keyframes aurora-twinkle {
      0%, 100% { 
        opacity: 0.3;
        transform: scale(0.8);
      }
      50% { 
        opacity: 1;
        transform: scale(1.2);
      }
    }
    
    /* 原子釉鍍膜 - 釉面光澤效果（維持不變） */
    .glaze-product .product-name {
      color: #66BB6A !important;
      position: relative;
      overflow: hidden;
    }
    
    .glaze-product .product-name::after {
      content: '';
      position: absolute;
      top: 0;
      left: -100%;
      width: 100%;
      height: 100%;
      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);
      animation: glaze-sweep 4s ease-in-out infinite;
    }
    
    @keyframes glaze-sweep {
      0% { left: -100%; }
      20% { left: 100%; }
      100% { left: 100%; }
    }
    
    /* 原子微晶鍍膜 - 蠟筆風格點綴 */
    .microcrystal-product .product-name {
      color: #81C784 !important;
      position: relative;
    }
    
    .microcrystal-product .product-name::before {
      content: '●';
      position: absolute;
      top: -3px;
      left: -18px;
      font-size: 0.6rem;
      color: #A5D6A7;
      animation: crayon-dot1 3s ease-in-out infinite;
    }
    
    .microcrystal-product .product-name::after {
      content: '●';
      position: absolute;
      bottom: -3px;
      right: -18px;
      font-size: 0.8rem;
      color: #66BB6A;
      animation: crayon-dot2 3s ease-in-out infinite 1.5s;
    }
    
    @keyframes crayon-dot1 {
      0%, 100% { 
        opacity: 0.4;
        transform: translateY(0) scale(0.8);
      }
      50% { 
        opacity: 0.8;
        transform: translateY(-2px) scale(1.1);
      }
    }
    
    @keyframes crayon-dot2 {
      0%, 100% { 
        opacity: 0.5;
        transform: translateY(0) scale(0.9);
      }
      50% { 
        opacity: 0.9;
        transform: translateY(2px) scale(1.2);
      }
    }
    
    /* 原子封體鍍膜 - 蠟筆風格線條 */
    .sealant-product .product-name {
      color: #D4AF37 !important;
      position: relative;
    }
    
    .sealant-product .product-name::before {
      content: '';
      position: absolute;
      bottom: -8px;
      left: 0;
      width: 100%;
      height: 3px;
      background: linear-gradient(90deg, transparent, #F7DC6F, #D4AF37, #F7DC6F, transparent);
      border-radius: 2px;
      animation: crayon-underline 4s ease-in-out infinite;
    }
    
    .sealant-product .product-name::after {
      content: '◆';
      position: absolute;
      top: -5px;
      right: -20px;
      font-size: 0.7rem;
      color: #F7DC6F;
      animation: crayon-diamond 2.5s ease-in-out infinite;
    }
    
    @keyframes crayon-underline {
      0%, 100% { 
        opacity: 0.6;
        transform: scaleX(0.8);
      }
      50% { 
        opacity: 1;
        transform: scaleX(1.1);
      }
    }
    
    @keyframes crayon-diamond {
      0%, 100% { 
        opacity: 0.5;
        transform: rotate(0deg) scale(0.9);
      }
      50% { 
        opacity: 0.9;
        transform: rotate(45deg) scale(1.1);
      }
    }
    
    /* 原子鍍膜 - 簡潔效果 */
    .basic-product .product-name {
      color: #f08418 !important;
      transition: all 0.3s ease;
    }
    
    .basic-product .product-name:hover {
      color: #ff9a3c !important;
      text-shadow: 0 2px 8px rgba(240, 132, 24, 0.3);
    }
    
    .product-description {
      font-size: 0.95rem !important;
      color: #b0b0b0;
      margin-bottom: 18px;
      line-height: 1.4;
    }
    .properties {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .property {
      margin-bottom: 0px;
    }
    .property-header {
      display: flex;
      justify-content: space-between;
      margin-bottom: 5px;
    }
    .property-name {
      font-size: 0.85rem !important;
    }
    .property-value {
      font-size: 0.85rem !important;
      font-weight: bold;
      color: #f08418;
    }
    .progress-bar {
      height: 8px;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      overflow: hidden;
    }
    .progress-fill {
      height: 100%;
      background: linear-gradient(90deg, #f08418, #ff9a3c);
      border-radius: 8px;
      transition: width 0.5s ease;
    }

    /* 響應式設計 */
    @media (max-width: 768px) {
      .header-section-coating {
        padding: 30px 20px 15px 20px;
      }
      
      .main-title {
        font-size: 2rem;
      }
      
      .description-text {
        font-size: 0.95rem;
        padding: 0 10px;
      }
      
      .coating-showcase {
        padding: 15px 20px 60px 20px;
      }
      
      /* 手機版強制顯示滾動條 */
      .product-scroll-wrapper {
        scrollbar-width: thin !important;
        scrollbar-color: #f08418 rgba(255, 255, 255, 0.2) !important;
        padding-bottom: 20px !important;
      }
      
      .product-scroll-wrapper::-webkit-scrollbar {
        height: 6px !important;
        display: block !important;
        -webkit-appearance: none !important;
      }
      
      .product-scroll-wrapper::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.2) !important;
        border-radius: 3px !important;
      }
      
      .product-scroll-wrapper::-webkit-scrollbar-thumb {
        background: #f08418 !important;
        border-radius: 3px !important;
        min-width: 30px !important;
      }
      
      /* 手機版右邊漸層更明顯 */
      .coating-showcase::after {
        width: 20px;
        background: linear-gradient(90deg, transparent 0%, rgba(26, 26, 26, 0.9) 100%);
      }
      
      /* 手機版滾動指示器強制樣式 */
      .scroll-indicator {
        display: flex !important;
        bottom: 10px !important;
        font-size: 0.7rem !important;
        width: 180px !important;
        color: #f08418 !important;
      }
      
      .scroll-indicator-text {
        font-size: 0.7rem !important;
        color: #f08418 !important;
        margin-bottom: 6px !important;
      }
      
      .product-block {
        width: 380px;
        height: 420px;
      }
      .product-card {
        padding: 16px;
        border-radius: 12px;
        background: #1a1a1a !important;
      }
      .product-image {
        width: 140px;
        height: 100%;
      }
      
      .product-content {
        padding-left: 12px;
        justify-content: center;
      }
      .product-name {
        font-size: 0.9rem;
      }
      .product-description {
        font-size: 0.7rem;
        margin-bottom: 8px;
      }
      .properties {
        gap: 5px;
      }
      .property-name, .property-value {
        font-size: 0.65rem;
      }
      .cta-wrapper {
        margin-top: 20px;
      }
      
      .cta-button {
        padding: 10px 8px !important;
        font-size: 15px !important;
        border-radius: 10px !important;
      }
    }
    
    /* 桌面版隱藏滾動指示器 */
    @media (min-width: 769px) {
      .scroll-indicator {
        display: flex !important;
      }
    }
{% endstyle %}

{% javascript %}
  // 產品 ID 配置 - 只需要替換為您的實際產品 ID
    const productIds = {
      'titanium-coating': '9034349379835',  // 請替換為您實際的產品 ID
      'atomic-aurora': 'YOUR_PRODUCT_ID_2', 
      'atomic-glaze': 'YOUR_PRODUCT_ID_3',
      'atomic-microcrystal': 'YOUR_PRODUCT_ID_4',
      'atomic-sealant': 'YOUR_PRODUCT_ID_5',
      'atomic-basic': 'YOUR_PRODUCT_ID_6'
    };

    // 使用產品 ID 直接跳轉到產品頁面
    function goToProduct(productKey) {
      console.log('產品 ID:' + productKey);
      const productId = productIds[productKey];
      if (productId) {
        // 先取得產品資料來獲取正確的 handle
        fetch(`/products/${productId}.js`)
          .then(response => response.json())
          .then(product => {
            // 直接跳轉到產品頁面
            window.location.href = `/products/${product.handle}`;
          })
          .catch(error => {
            console.error('跳轉失敗:', error);
            // 備用方案：使用產品 ID 進行搜尋
            window.location.href = `/search?q=id:${productId}`;
          });
      } else {
        console.error('找不到產品 ID:', productKey);
      }
    }

    // 滾動指示器邏輯
    document.addEventListener('DOMContentLoaded', function() {
      const scroller = document.getElementById('productScroller');
      const dots = document.querySelectorAll('.scroll-dot');
      
      if (scroller && dots.length > 0) {
        // 更新滾動指示器
        function updateScrollIndicator() {
          const scrollLeft = scroller.scrollLeft;
          const scrollWidth = scroller.scrollWidth - scroller.clientWidth;
          const scrollPercentage = scrollLeft / scrollWidth;
          
          // 根據滾動位置計算當前應該高亮的點
          const activeIndex = Math.round(scrollPercentage * (dots.length - 1));
          
          dots.forEach((dot, index) => {
            if (index === activeIndex) {
              dot.classList.add('active');
            } else {
              dot.classList.remove('active');
            }
          });
        }
        
        // 監聽滾動事件
        scroller.addEventListener('scroll', updateScrollIndicator);
        
        // 初始化
        updateScrollIndicator();
      }
    });
{% endjavascript %}

{% schema %}
{
  "name": "Coating Products Showcase",
  "settings": [
    { "type": "text", "id": "title", "label": "標題", "default": "專業鍍膜產品系列" },
    { "type": "text", "id": "subtitle", "label": "副標題", "default": "APGO研發的鍍膜皆不分任何車色、不分任何材質，開始挑選專屬自己的鍍膜吧" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "產品",
      "settings": [
        { "type": "text", "id": "name", "label": "產品名稱" },
        { "type": "textarea", "id": "description", "label": "產品描述" },
        { "type": "text", "id": "badge", "label": "右上角標籤" },
        { "type": "select", "id": "effect", "label": "專屬效果樣式", "options": [
          {"value":"titanium-product","label":"鈦晶特效"},
          {"value":"aurora-product","label":"極光特效"},
          {"value":"glaze-product","label":"釉鍍膜特效"},
          {"value":"microcrystal-product","label":"微晶特效"},
          {"value":"sealant-product","label":"封體特效"},
          {"value":"basic-product","label":"經典效果"}
