{% comment %}
  APGO Custom Reset Password Page - Dark Tech Style
{% endcomment %}

<style>
  .customer-reset-section {
    padding: 60px 20px;
    max-width: 500px;
    margin: 0 auto;
    color: #ffffff;
    background-color: #050505;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  .reset-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .reset-header h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 0 0 10px 0;
    color: #ffffff !important;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  
  .reset-header p {
    color: #888;
    font-size: 0.95rem;
  }

  .form-field {
    margin-bottom: 20px;
  }

  .form-field input {
    width: 100%;
    padding: 15px;
    background-color: #1a1a1a !important; 
    border: 1px solid #333 !important;
    border-radius: 8px !important;
    color: #ffffff !important;
    font-size: 1rem;
    transition: all 0.3s ease;
    box-sizing: border-box;
  }

  .form-field input::placeholder {
    color: #666 !important;
  }

  .form-field input:focus {
    outline: none;
    border-color: #f08418 !important;
    box-shadow: 0 0 0 1px #f08418 !important;
  }

  .submit-btn {
    width: 100%;
    padding: 15px;
    background-color: #f08418 !important;
    color: #ffffff !important;
    font-size: 1.1rem;
    font-weight: bold;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    text-transform: uppercase;
    transition: background-color 0.3s, transform 0.2s;
    margin-top: 10px;
  }

  .submit-btn:hover {
    background-color: #d66a00 !important;
    transform: translateY(-2px);
  }

  /* 錯誤訊息樣式 */
  .errors ul {
    list-style: none;
    padding: 0;
    margin: 0 0 20px 0;
    background: rgba(255, 68, 68, 0.1);
    border: 1px solid #ff4444;
    border-radius: 8px;
  }
  .errors li {
    padding: 12px;
    color: #ffcccc;
    font-size: 0.9rem;
    text-align: center;
  }
</style>

<div class="customer-reset-section">
  
  <div class="reset-header">
    <h1>重設密碼</h1>
    <p>請為您的 APGO 帳號設定新的密碼</p>
  </div>

  {% form 'reset_customer_password' %}
    
    {{ form.errors | default_errors }}

    <div class="form-field">
      <input 
        type="password" 
        name="customer[password]" 
        id="ResetPassword" 
        placeholder="新密碼"
        required
      >
    </div>

    <div class="form-field">
      <input 
        type="password" 
        name="customer[password_confirmation]" 
        id="PasswordConfirmation" 
        placeholder="再次確認新密碼"
        required
      >
    </div>

    <button type="submit" class="submit-btn">確認並重設密碼</button>

  {% endform %}
</div>

{% schema %}
{
  "name": "Reset Password",
  "settings": []
}
{% endschema %}