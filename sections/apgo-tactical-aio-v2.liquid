            {{ section.settings.coupon_banner_img | image_url: width: 1920 | image_tag: class: 'apgo-obj-cover' }}
          {% else %}
            <div class="apgo-img-placeholder">Banner 圖片位置</div>
          {% endif %}
        </div>
        <div class="apgo-coupon-grid">
          <div class="apgo-coupon-card" style="--theme-color: #f08418;">
            <i class="fa-solid fa-ticket" style="color:#f08418; font-size:18px; margin:4px 0;"></i>
            <div style="font-size:10px; color:#6b7280;">{{ section.settings.c1_condition }}</div>
            <div class="apgo-coupon-amt">{{ section.settings.c1_discount }}</div>
          </div>
          <div class="apgo-coupon-card" style="--theme-color: #9ca3af;">
            <i class="fa-solid fa-ticket" style="color:#9ca3af; font-size:18px; margin:4px 0;"></i>
            <div style="font-size:10px; color:#6b7280;">{{ section.settings.c2_condition }}</div>
            <div class="apgo-coupon-amt">{{ section.settings.c2_discount }}</div>
          </div>
          <div class="apgo-coupon-card" style="--theme-color: #f08418; border-color: rgba(240,132,24,0.5);">
            <i class="fa-solid fa-ticket" style="color:#f08418; font-size:18px; margin:4px 0;"></i>
            <div style="font-size:10px; color:#6b7280;">{{ section.settings.c3_condition }}</div>
            <div class="apgo-coupon-amt" style="color:#f08418;">{{ section.settings.c3_discount }}</div>
          </div>
        </div>
        <div style="text-align:center; font-size:10px; color:#666; margin-top:10px;">※ 優惠達門檻結帳自動折抵，無需手動輸入</div>
      </section>
    {% endunless %}

  </div>
</div>

<div id="footer-backdrop" onclick="toggleApgoDrawer()"></div>
<div id="apgo-smart-footer">
  <div id="apgo-cart-drawer">
    <div class="apgo-drawer-header">
      <div style="font-size:12px; font-weight:bold; color:#f08418;">裝備庫明細</div>
      <div onclick="toggleApgoDrawer()" style="cursor:pointer; color:#999; font-size:12px; display:flex; align-items:center; gap:4px;">
        收起 <i class="fa-solid fa-chevron-down"></i>
      </div>
    </div>
    <div style="padding:1rem; display:flex; flex-direction:column; gap:0.75rem;" id="apgo-cart-items-container"></div>
    <div style="height:20px;"></div>
  </div>

  <div class="apgo-progress-strip" onclick="toggleApgoDrawer()">
    <div style="display:flex; justify-content:space-between; color:#9ca3af; font-size:10px; margin-bottom:4px; font-family:monospace;">
      <span id="apgo-task-text">任務目標: {{ section.settings.target_reward }} (尚差 <span style="color:#f08418; font-weight:bold;">${{ section.settings.target_amount }}</span>)</span>
      <i id="apgo-drawer-arrow" class="fa-solid fa-chevron-up" style="transition:transform 0.3s;"></i>
    </div>
    <div class="apgo-progress-track">
      <div id="apgo-progress-bar" class="apgo-progress-fill">
        <div class="apgo-scan-line" style="animation-duration:1s;"></div>
      </div>
    </div>
  </div>
  <div class="apgo-footer-bar" onclick="handleApgoFooterClick(event)">
    <div>
      <div style="font-size:10px; color:#999; text-transform:uppercase; font-family:monospace;">裝備數量 <span id="apgo-count" style="background:#333; color:white; padding:0 4px; border-radius:2px;">0</span></div>
      <div style="color:white; font-family:monospace; font-weight:bold; font-size:24px;">$<span id="apgo-total">0</span></div>
    </div>
    <button class="apgo-checkout-btn" onclick="window.location.href='/cart'">
      結帳 <i class="fa-solid fa-chevron-right" style="font-size:10px;"></i>
    </button>
  </div>
</div>

<div id="apgo-modal" class="apgo-modal-backdrop">
  <div class="apgo-modal-content">
    <div style="padding:1rem; border-bottom:1px solid #333; background:#1a1a1a; display:flex; flex-direction:column; align-items:center;">
      <div style="font-weight:bold; color:white; font-size:1.125rem;" id="modal-title">選擇規格</div>
    </div>
    <div style="padding:1rem; overflow-y:auto; flex:1; background:#0a0a0a;">
      <div id="modal-grid" style="display:grid; grid-template-columns: 1fr 1fr; gap:0.75rem;"></div>
    </div>
    <div style="padding:1rem; border-top:1px solid #333; background:#1a1a1a; display:flex; gap:0.5rem;">
      <button style="flex:1; padding:0.75rem; background:transparent; border:1px solid #333; color:#999; border-radius:0.25rem; font-weight:bold;" onclick="apgoCloseModal()">取消</button>
      <button style="flex:2; padding:0.75rem; background:#f08418; border:none; color:black; border-radius:0.25rem; font-weight:bold;" id="modal-confirm-btn">加入裝備庫</button>
    </div>
  </div>
</div>

<script>
  (function() {
  var APGO_TIERS_RAW = [
  {% assign has_tiers = false %}
  {% for block in section.blocks %}
    {% if block.type == 'reward_tier' %}
      {% if has_tiers %},{% endif %}
      {"amount":{{ block.settings.amount | default: 799 }},"reward_name":{{ block.settings.reward_name | default: '獎勵項目' | json }}}
      {% assign has_tiers = true %}
    {% endif %}
  {% endfor %}
  ];
  if (APGO_TIERS_RAW.length === 0) {
    APGO_TIERS_RAW = [{"amount":{{ section.settings.target_amount | default: 799 }},"reward_name":{{ section.settings.target_reward | default: '獎勵項目' | json }}}];
  }
  window.APGO_TIERS = APGO_TIERS_RAW.slice().sort(function(a,b){ return a.amount - b.amount; });
  })();
  let cart = {};
  {% for item in cart.items %}
    cart["{{ item.variant_id }}"] = {
      key: "{{ item.key }}",
      qty: {{ item.quantity }},
      price: {{ item.final_price | default: item.price | divided_by: 100.0 }},
      original_price: {{ item.original_price | default: item.price | divided_by: 100.0 }},
      discounts: [
        {% for d in item.discounts %}
          { title: {{ d.title | json }} }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ],
      title: {{ item.title | json }},
      img: "{{ item.image | image_url: width: 200 }}"
    };
  {% endfor %}
  let selVid = null; let tempVar = null; let isDrawerOpen = false;
  var lastCartTotalFromShopify = {{ cart.total_price | default: 'null' }};
  var cartLevelDiscounts = [
    {% for d in cart.cart_level_discount_applications %}
      {
        title: {{ d.title | json }},
        total_allocated_amount: {{ d.total_allocated_amount | default: 0 }}
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ];

  /** 從 Shopify 取得最新購物車並同步到畫面上（含折扣後價格、line key、訂單總計） */
  async function apgoSyncCartFromShopify() {
    try {
      const root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root : '/';
      const res = await fetch(root + 'cart.js');
      if (!res.ok) return;
      const data = await res.json();
      lastCartTotalFromShopify = data.total_price != null ? data.total_price : null;
      cartLevelDiscounts = data.cart_level_discount_applications || [];
      cart = {};
      (data.items || []).forEach(function(item) {
        var img = (item.featured_image && item.featured_image.url) ? item.featured_image.url : (item.image || '');
        var rawPrice = item.final_price != null ? item.final_price : (item.discounted_price != null ? item.discounted_price : item.price);
        var priceInCents = typeof rawPrice === 'number' ? rawPrice : parseInt(rawPrice, 10) || 0;
        
        var rawOriginalPrice = item.original_price != null ? item.original_price : item.price;
        var originalPriceInCents = typeof rawOriginalPrice === 'number' ? rawOriginalPrice : parseInt(rawOriginalPrice, 10) || 0;

        cart[String(item.variant_id)] = {
          key: item.key,
          qty: item.quantity,
          price: priceInCents / 100,
          original_price: originalPriceInCents / 100,
          discounts: item.discounts || [],
          title: item.title || '',
          img: img
        };
      });
      updateUI();
    } catch (e) {
      console.error('apgoSyncCartFromShopify:', e);
    }
  }

  // --- [整合導航邏輯] ---
  const nav = document.getElementById('apgo-sticky-nav');
  const placeholder = document.getElementById('nav-placeholder');
  const hero = document.getElementById('apgo-hero');
  const navLinks = document.querySelectorAll('.sticky-nav-link');
  let navStickTop = 0;

  function updateNavStickTop() {
    if (!nav) return;
    const wasFixed = nav.classList.contains('nav-fixed');
    if (wasFixed) {
      nav.classList.remove('nav-fixed');
      placeholder.style.display = 'none';
    }
    navStickTop = nav.getBoundingClientRect().top + window.scrollY;
    if (wasFixed) {
      nav.classList.add('nav-fixed');
      placeholder.style.display = 'block';
    }
  }

  updateNavStickTop();
  window.addEventListener('load', updateNavStickTop);
  window.addEventListener('resize', updateNavStickTop);

  window.addEventListener('scroll', () => {
    // 吸頂邏輯
    if (window.scrollY >= navStickTop) {
      nav.classList.add('nav-fixed');
      placeholder.style.display = 'block';
    } else {
      nav.classList.remove('nav-fixed');
      placeholder.style.display = 'none';
    }

    // Scroll Spy (自動亮起導航標籤): 依 nav 目標 ID 判定，不限 section[id]
    let current = "";
    navLinks.forEach(link => {
      const onclickAttr = link.getAttribute('onclick');
      const match = onclickAttr && onclickAttr.match(/scrollToSection\s*\(\s*['"]([^'"]+)['"]\s*\)/);
      const linkTargetId = match ? match[1] : '';
      const targetEl = linkTargetId ? document.getElementById(linkTargetId) : null;
      if (targetEl && pageYOffset >= targetEl.offsetTop - 120) {
        current = linkTargetId;
      }
    });

    navLinks.forEach((link, index) => {
      link.classList.remove('active');
      const onclickAttr = link.getAttribute('onclick');
      const match = onclickAttr && onclickAttr.match(/scrollToSection\s*\(\s*['"]([^'"]+)['"]\s*\)/);
      const linkTargetId = match ? match[1] : '';
      if (linkTargetId && linkTargetId === current) {
        link.classList.add('active');
        const container = document.getElementById('sticky-nav-container');
        if (container && container.scrollWidth > container.clientWidth) {
          // 將 Active 的導航項目盡可能保持在容器正中央
          const scrollLeft = link.offsetLeft - (container.clientWidth / 2) + (link.clientWidth / 2);
          // 原生 scrollTo 已經會自動處理 < 0 或超出最大捲動範圍的安全限制
          container.scrollTo({ left: scrollLeft, behavior: 'smooth' });
        }
      }
    });
  });

  function scrollToSection(id) {
    const el = document.getElementById(id);
    if (el) {
      window.scrollTo({ top: el.offsetTop - 60, behavior: 'smooth' });
    }
  }

  // --- [原有購物車與彈窗邏輯] ---
  async function apgoAdd(vid, title, price, img) {
    if(navigator.vibrate) navigator.vibrate(15);
    const root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root : '/';
    try {
      const addRes = await fetch(root + 'cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ items: [{ id: vid, quantity: 1 }] })
      });
      if (!addRes.ok) {
        var err = await addRes.json().catch(function(){ return {}; });
        console.error('Error adding to cart:', err);
        return;
      }
      await apgoSyncCartFromShopify();
    } catch (error) {
      console.error('Error adding to cart:', error);
    }
  }

  async function apgoRemove(vid) {
    if(navigator.vibrate) navigator.vibrate(15);
    const v = String(vid);
    var key = cart[v] && cart[v].key;
    if (!key) {
      await apgoSyncCartFromShopify();
      key = cart[v] && cart[v].key;
    }
    if (!key) return;
    const root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root : '/';
    try {
      const res = await fetch(root + 'cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: 0 })
      });
      if (!res.ok) { console.error('Error removing from cart'); return; }
      await apgoSyncCartFromShopify();
    } catch (error) {
      console.error('Error removing from cart:', error);
    }
  }

  async function apgoChangeQty(vid, delta) {
    if(navigator.vibrate) navigator.vibrate(15);
    const v = String(vid);
    if(!cart[v]) return;
    var key = cart[v].key;
    if (!key) {
      await apgoSyncCartFromShopify();
      if (!cart[v]) return;
      key = cart[v].key;
    }
    if (!key) return;
    var newQty = Math.max(0, (cart[v].qty || 0) + delta);
    const root = (window.Shopify && window.Shopify.routes && window.Shopify.routes.root) ? window.Shopify.routes.root : '/';
    try {
      const res = await fetch(root + 'cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: newQty })
      });
      if (!res.ok) { console.error('Error updating cart quantity'); return; }
      await apgoSyncCartFromShopify();
    } catch (error) {
      console.error('Error updating cart quantity:', error);
    }
  }

  // 監聽 Shopify 購物車更新事件 (如果主題有發送事件)
  document.addEventListener('cart:updated', function(event) {
    if(event.detail && event.detail.cart) {
      apgoSyncCartFromShopify();
    }
  });

  function updateUI() {
    let total = 0; let count = 0;
    const list = document.getElementById('apgo-cart-items-container');
    list.innerHTML = '';
    const cartLevelDiscountTitleSet = new Set(
      (cartLevelDiscounts || [])
        .map(function(d) { return ((d && d.title) ? String(d.title) : '').trim(); })
        .filter(Boolean)
    );

    for(let k in cart) {
      const item = cart[k];
      total += item.price * item.qty;
      count += item.qty;
      
      let priceHtml = '';
      if (item.original_price && item.original_price > item.price) {
        priceHtml = `<span style="text-decoration:line-through; color:#999; margin-right:6px;">$${Number(item.original_price).toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 2 })}</span>` +
                    `<span style="color:#f08418; font-weight:bold;">$${Number(item.price).toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 2 })}</span>`;
      } else {
        priceHtml = `<span style="color:#f08418;">$${Number(item.price).toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 2 })}</span>`;
      }

      let discountsHtml = '';
      if (item.discounts && item.discounts.length > 0) {
        item.discounts.forEach(d => {
          var discountTitle = ((d && d.title) ? String(d.title) : '').trim();
          // 避免整單折扣在每個商品重複顯示，只保留真正的商品折扣
          if (!discountTitle || cartLevelDiscountTitleSet.has(discountTitle)) return;
          discountsHtml += `<div style="font-size:10px; color:#22c55e; margin-top:2px; display:flex; align-items:center; gap:4px;"><i class="fa-solid fa-tag"></i> ${d.title}</div>`;
        });
      }

      const row = document.createElement('div');
      row.style.cssText = 'display:flex; gap:10px; padding:8px; background:#1a1a1a; border:1px solid #333; border-radius:4px; align-items:center;';
      row.innerHTML = `
        <img src="${item.img}" width="40" height="40" style="width:40px; height:40px; object-fit:cover; border-radius:4px; background:#000;">
        <div style="flex:1;">
          <div style="font-size:12px; color:white; font-weight:bold;">${item.title}</div>
          <div style="font-size:10px; font-family:monospace; margin-top:2px;">${priceHtml}</div>
          ${discountsHtml}
        </div>
        <div class="apgo-drawer-qty">
          <div style="width:24px; height:24px; display:flex; align-items:center; justify-content:center; color:#999; cursor:pointer;" onclick="apgoChangeQty('${k}', -1)">-</div>
          <span style="width:20px; text-align:center; font-size:12px; font-weight:bold; color:white; font-family:monospace;">${item.qty}</span>
          <div style="width:24px; height:24px; display:flex; align-items:center; justify-content:center; color:#999; cursor:pointer;" onclick="apgoChangeQty('${k}', 1)">+</div>
        </div>
        <button onclick="apgoRemove('${k}')" style="background:transparent; border:none; color:#666; cursor:pointer; margin-left:8px;"><i class="fa-solid fa-trash"></i></button>
      `;
      list.appendChild(row);
    }

    if (cartLevelDiscounts && cartLevelDiscounts.length > 0) {
      const discountContainer = document.createElement('div');
      discountContainer.style.cssText = 'border-top: 1px dashed #333; padding-top: 8px; margin-top: 4px;';
      
      cartLevelDiscounts.forEach(d => {
        const dRow = document.createElement('div');
        dRow.style.cssText = 'display:flex; justify-content:space-between; align-items:center; font-size:12px; color:#22c55e; margin-bottom:4px;';
        
        let amountText = '';
        let amount = d.total_allocated_amount != null ? d.total_allocated_amount : d.amount;
        if (amount != null) {
          let displayAmount = (typeof amount === 'number' ? amount : parseInt(amount, 10)) / 100;
          amountText = `-$${Number(displayAmount).toLocaleString(undefined, { minimumFractionDigits: 0, maximumFractionDigits: 2 })}`;
        }
        
        dRow.innerHTML = `
          <div style="display:flex; align-items:center; gap:6px;">
            <i class="fa-solid fa-ticket"></i> ${d.title}
          </div>
          <div style="font-family:monospace; font-weight:bold;">${amountText}</div>
        `;
        discountContainer.appendChild(dRow);
      });
      list.appendChild(discountContainer);
    }
    
    var displayTotal = (typeof lastCartTotalFromShopify === 'number' && lastCartTotalFromShopify >= 0) ? (lastCartTotalFromShopify / 100) : total;
    document.getElementById('apgo-total').innerText = displayTotal.toLocaleString();
    document.getElementById('apgo-count').innerText = count;
    
    const footer = document.getElementById('apgo-smart-footer');
    if(count > 0) {
       footer.style.transform = 'translateY(0)';
    } else {
       footer.style.transform = 'translateY(120%)';
       if(isDrawerOpen) toggleApgoDrawer();
    }

    const bar = document.getElementById('apgo-progress-bar');
    const txt = document.getElementById('apgo-task-text');
    const tiers = (window.APGO_TIERS && window.APGO_TIERS.length) ? window.APGO_TIERS : [{ amount: 799, reward_name: '獎勵項目' }];

    var lastUnlockedIndex = -1;
    for (var i = 0; i < tiers.length; i++) {
      if (total >= tiers[i].amount) lastUnlockedIndex = i;
    }
    var nextTierIndex = lastUnlockedIndex + 1;
    var nextTier = tiers[nextTierIndex];
    var needForNext = nextTier ? Math.max(0, nextTier.amount - total) : 0;
    var pct = nextTier ? Math.min((total / nextTier.amount) * 100, 100) : 100;
    bar.style.width = pct + '%';

    if (nextTier) {
      bar.style.backgroundColor = '#f08418';
      if (lastUnlockedIndex >= 0) {
        txt.innerHTML = '<span style="color:#22c55e; font-weight:bold;">已獲取 ' + tiers[lastUnlockedIndex].reward_name + '</span>。再消費 <span style="color:#f08418; font-weight:bold;">$' + needForNext.toLocaleString() + '</span> 可獲得 ' + nextTier.reward_name;
      } else {
        txt.innerHTML = '任務目標: ' + nextTier.reward_name + ' (尚差 <span style="color:#f08418; font-weight:bold;">$' + needForNext.toLocaleString() + '</span>)';
      }
    } else {
      bar.style.backgroundColor = '#22c55e';
      txt.innerHTML = '<span style="color:#22c55e; font-weight:bold;">已獲取 ' + tiers[lastUnlockedIndex].reward_name + '</span>。全部目標已達成！';
    }
  }
  
  function toggleApgoDrawer() {
    const drawer = document.getElementById('apgo-cart-drawer');
    const arrow = document.getElementById('apgo-drawer-arrow');
    const backdrop = document.getElementById('footer-backdrop');
    isDrawerOpen = !isDrawerOpen;
    if(isDrawerOpen) {
      drawer.style.maxHeight = '50vh';
      arrow.style.transform = 'rotate(180deg)';
      backdrop.style.display = 'block';
    } else {
      drawer.style.maxHeight = '0';
      arrow.style.transform = 'rotate(0deg)';
      backdrop.style.display = 'none';
    }
  }
  
  function handleApgoFooterClick(e) {
    if(e.target.closest('button') || e.target.closest('a')) return;
    toggleApgoDrawer();
  }

  function apgoOpenModal(pid) {
    if(navigator.vibrate) navigator.vibrate(15);
    const data = document.getElementById('json-'+pid);
    if(!data) return;
    const vars = JSON.parse(data.innerText);
    const title = document.querySelector(`[data-pid="${pid}"] .apgo-card-title`).innerText;
    document.getElementById('modal-title').innerText = title;
    const grid = document.getElementById('modal-grid');
    grid.innerHTML = ''; selVid = null;
    const btn = document.getElementById('modal-confirm-btn');
    btn.style.opacity = '0.5'; btn.disabled = true;
    vars.forEach(v => {
      const el = document.createElement('div');
      el.style.cssText = 'border:1px solid #333; background:#1a1a1a; border-radius:8px; padding:8px; position:relative; cursor:pointer;';
      el.innerHTML = `<img src="${v.img}" width="300" height="300" style="width:100%; aspect-ratio:1; object-fit:cover; border-radius:4px; margin-bottom:8px;"><div style="font-size:12px; color:#ddd; font-weight:bold;">${v.title}</div><div style="font-size:14px; color:#f08418; font-family:monospace; font-weight:bold;">${v.display_price}</div><div class="ring" style="position:absolute; inset:0; border:2px solid #f08418; border-radius:8px; display:none;"></div>`;
      el.onclick = () => {
        document.querySelectorAll('.ring').forEach(r => r.style.display='none');
        el.querySelector('.ring').style.display='block';
        selVid = v.id; tempVar = { title: title + ' - ' + v.title, price: v.price, img: v.img };
        btn.style.opacity = '1'; btn.disabled = false;
      };
      grid.appendChild(el);
    });
    document.body.classList.add('apgo-modal-open');
    btn.onclick = async () => { await apgoAdd(selVid, tempVar.title, tempVar.price, tempVar.img); apgoCloseModal(); };
  }

  function apgoCloseModal() { document.body.classList.remove('apgo-modal-open'); }

  updateUI();
  apgoSyncCartFromShopify();
</script>