                  <button class="apgo-combo-btn apgo-combo-btn-right" onclick="apgoAdd({{ cp.selected_or_first_available_variant.id }}, '{{ cp.title | escape }}', {{ cp.price | divided_by: 100.0 }}, '{{ cp_img }}')">
                    <i class="fa-solid fa-cart-plus"></i> 加入組合
