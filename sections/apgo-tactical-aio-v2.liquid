        "default": "條件一"
      },
      {
        "type": "text",
        "id": "c1_discount",
        "label": "Coupon 1 折扣",
        "default": "內容一"
      },
      {
        "type": "text",
        "id": "c2_condition",
        "label": "Coupon 2 門檻",
        "default": "條件二"
      },
      {
        "type": "text",
        "id": "c2_discount",
        "label": "Coupon 2 折扣",
        "default": "內容二"
      },
      {
        "type": "text",
        "id": "c3_condition",
        "label": "Coupon 3 門檻",
        "default": "條件三"
      },
      {
        "type": "text",
        "id": "c3_discount",
        "label": "Coupon 3 折扣",
