                    <div class="apgo-card-head">
                      <span class="apgo-card-tag apgo-font-mono">// {{ block.settings.card_tag }}</span>
                    </div>
                    <div class="apgo-card-body">
                      <div class="apgo-card-img-box">
                        {% if product.featured_image %}
                          {{ product.featured_image | image_url: width: 200 | image_tag: class: 'apgo-obj-cover' }}
                        {% else %}
                          <i class="fa-solid fa-box" style="color:#666; font-size:24px;"></i>
                        {% endif %}
                      </div>
                      <div class="apgo-card-info">
                        <div>
                          <div class="apgo-card-title">{{ product.title }}</div>
                          <div class="apgo-card-desc">{{ product.description | strip_html | truncate: 50 }}</div>
                        </div>
                        <div class="apgo-card-foot"{% if card_layout == 'vertical' %} style="display:block !important;"{% endif %}>
                          <div class="apgo-card-price apgo-font-mono">{{ product.price | money }}</div>
                          <div class="apgo-card-actions">
                            <a href="{{ product.url }}" class="apgo-btn apgo-btn-left">詳情</a>
                            {% if has_variants %}
                              <button class="apgo-btn apgo-btn-right" onclick="apgoOpenModal({{ product.id }})">加入</button>
                            <script type="application/json" id="json-{{ product.id }}">
                              [
                                {% for v in product.variants %}
                                  {
                                    "id": {{ v.id }},
                                    "title": {{ v.title | json }},
                                    "price": {{ v.price | divided_by: 100.0 }},
                                    "display_price": {{ v.price | money | json }},
                                    "img": "{{ v.featured_image | image_url: width: 300 | default: product.featured_image | image_url: width: 300 }}"
                                  }{% unless forloop.last %},{% endunless %}
                                {% endfor %}
                              ]
                            </script>
                            {% else %}
                              {% assign p_img = '' %}
                              {% if product.featured_image %}{% assign p_img = product.featured_image | image_url: width: 300 %}{% endif %}
                              <button class="apgo-btn apgo-btn-right" onclick="apgoAdd({{ product.selected_or_first_available_variant.id }}, '{{ product.title | escape }}', {{ product.price | divided_by: 100.0 }}, '{{ p_img }}')">加入</button>
                            {% endif %}
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                {% endfor %}
              {% else %}
                <div class="apgo-card{% if card_layout == 'vertical' %} apgo-card-vertical{% endif %}">
                  <div class="apgo-card-head">
                    <span class="apgo-card-tag apgo-font-mono">// {{ block.settings.card_tag | default: 'TAG' }}</span>
