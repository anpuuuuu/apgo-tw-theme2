                        {{ product.featured_image | image_url: width: 200 | image_tag: class: 'apgo-obj-cover' }}
                      {% else %}
                        <i class="fa-solid fa-box" style="color:#666; font-size:24px;"></i>
                      {% endif %}
                    </div>
                    <div class="apgo-combo-sub-title">{{ product.title | truncate: 20 }}</div>
                  </div>
