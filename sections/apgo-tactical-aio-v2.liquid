{% comment %}
  APGO 2026 新春戰術活動頁 - All-in-One Integrated Version
  整合功能：吸頂導航、動態錨點、戰術購物車、完整 Schema
{% endcomment %}

{% schema %}
  {
    "name": "APGO - 戰術活動頁 (All-in-One)",
    "class": "apgo-tactical-aio",
    "settings": [
      {
        "type": "header",
        "content": "🛠️ 全域設定 (Global Settings)"
      },
      {
        "type": "paragraph",
        "content": "下方「獎勵門檻」區塊可新增多檔目標；若未新增任何門檻，則使用以下單一門檻。"
      },
      {
        "type": "number",
        "id": "target_amount",
        "label": "滿額贈門檻金額 (元) — 未設多檔時使用",
        "default": 799
      },
      {
        "type": "text",
        "id": "target_reward",
        "label": "滿額贈品名稱 — 未設多檔時使用",
        "default": "獎勵項目"
      },
      {
        "type": "header",
        "content": "1. 主視覺 (Hero)"
      },
      {
        "type": "image_picker",
        "id": "hero_image_pc",
        "label": "PC Banner (1920x800)"
      },
      {
        "type": "image_picker",
        "id": "hero_image_mb",
        "label": "Mobile Banner (750x1100)"
      },
      {
        "type": "header",
        "content": "3. 優惠資訊版位 (Coupons)"
      },
      {
        "type": "text",
        "id": "coupon_sec_icon",
        "label": "優惠版位 Icon (FontAwesome)",
        "default": "fa-ticket"
      },
      {
        "type": "text",
        "id": "coupon_sec_title",
        "label": "區塊分隔標題",
        "default": "優惠版位標題"
      },
      {
        "type": "text",
        "id": "coupon_nav_label",
        "label": "優惠版位導航名稱（auto 模式用）",
        "default": "優惠版位"
      },
      {
        "type": "select",
        "id": "nav_mode",
        "label": "導航模式",
        "default": "auto",
        "options": [
          { "value": "auto", "label": "自動生成（建議）" },
          { "value": "manual", "label": "手動（使用 nav_item blocks）" }
