{% # theme-check-disable RemoteAsset %}
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
{% # theme-check-enable RemoteAsset %}

<style>
  /* --- Reset & Global --- */
  html { scroll-behavior: smooth; }
  
  /* 修正跳轉偏移量，避免被吸頂導航列擋住標題 */
  section[id] { scroll-margin-top: 70px; }

  .apgo-aio-container {
    background-color: #050505 !important;
    color: #ffffff !important;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif !important;
    width: 100% !important;
    overflow-x: hidden !important;
    padding-bottom: 140px !important; 
  }
  
  .apgo-aio-inner {
    max-width: 1200px !important;
    margin: 0 auto !important;
    padding: 0 1rem !important;
  }

  .apgo-font-mono {
    font-family: "SF Mono", "Menlo", "Monaco", "Courier New", monospace !important;
  }

  /* --- Sticky Nav Styles --- */
  #apgo-sticky-nav {
    width: 100%; 
    background: #050505; 
    border-bottom: 1px solid #333; 
    z-index: 1000;
    margin: 0 !important; /* 確保無邊距 */
  }

  /* 吸頂後的樣式 */
  .nav-fixed {
    position: fixed !important; 
    top: 0; 
    left: 0;
    background: rgba(5, 5, 5, 0.9) !important; 
    backdrop-filter: blur(10px);
    animation: navSlideDown 0.3s ease-out;
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
  }

  @keyframes navSlideDown { 
    from {transform: translateY(-100%);} 
    to {transform: translateY(0);} 
  }
  
  #sticky-nav-container {
    max-width: 1200px; 
    margin: 0 auto; 
    display: flex; 
    overflow-x: auto;           /* 手機維持可橫向滑動 */
  }
  
  .scrollbar-hide::-webkit-scrollbar { display: none; }
  .scrollbar-hide { -ms-overflow-style: none; scrollbar-width: none; }

  .sticky-nav-link {
    color: #888; 
    padding: 14px 14px; 
    font-size: 12px; 
    font-weight: bold; 
    white-space: nowrap;
    cursor: pointer; 
    border-bottom: 2px solid transparent; 
    transition: all 0.2s;
    text-transform: uppercase; 
    font-family: "SF Mono", monospace;
    flex: 0 0 auto;            /* 手機：項目依內容寬度排，避免被壓縮 */
    text-align: center;
  }

  @media (min-width: 768px) {
    #sticky-nav-container {
      display: flex;
      overflow-x: visible;
      justify-content: space-evenly;  /* 桌機：平均分配寬度 */
      align-items: center;
    }
    .sticky-nav-link {
      font-size: 13px;
      padding: 14px 18px;
      flex: 1 1 0;             /* 桌機：每個 nav 等寬 */
      min-width: 0;
    }
  }

  .sticky-nav-link.active { 
    color: #f08418; 
    border-bottom-color: #f08418; 
  }

  /* --- Hero --- */
  .apgo-hero-pc { display: none !important; width: 100% !important; aspect-ratio: 1920/800 !important; }
  .apgo-hero-mb { display: block !important; width: 100% !important; aspect-ratio: 10.5/16 !important; }
  @media (min-width: 768px) {
    .apgo-hero-pc { display: block !important; }
    .apgo-hero-mb { display: none !important; }
  }
  .apgo-obj-cover { width: 100% !important; height: 100% !important; object-fit: cover !important; }
  .apgo-scan-line {
    position: absolute !important; inset: 0 !important;
    background: linear-gradient(to bottom, transparent, rgba(240,132,24,0.3), transparent) !important;
    animation: apgo-scan 3s linear infinite !important;
    pointer-events: none !important;
  }
  @keyframes apgo-scan { 0% {transform:translateY(-100%)} 50% {opacity:1} 100% {transform:translateY(100%);opacity:0} }

  /* --- Wave & Content --- */
  .apgo-wave1-box { width: 100% !important; background: transparent !important; border: 1px solid #333 !important; border-radius: 0.75rem !important; overflow: hidden !important; position: relative !important; display: flex !important; flex-direction: column !important; }
  .apgo-wave1-banner-wrap { width: 100% !important; aspect-ratio: 1920/1016 !important; position: relative !important; border-radius: 0.75rem 0.75rem 0 0 !important; overflow: hidden !important; z-index: 1 !important; margin-bottom: -1px !important; }
  
