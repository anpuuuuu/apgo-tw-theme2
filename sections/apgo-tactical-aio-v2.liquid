<div class="apgo-aio-container">
  
  <section id="apgo-hero" style="position: relative; border-bottom: 1px solid #333; margin-bottom: 0 !important;">
    <div class="apgo-hero-pc">
      {% if section.settings.hero_image_pc %}
        {{ section.settings.hero_image_pc | image_url: width: 1920 | image_tag: class: 'apgo-obj-cover' }}
      {% else %}
        <img src="https://placehold.co/1920x800/121212/f08418?text=Hero+PC" width="1920" height="800" class="apgo-obj-cover" style="opacity:0.8">
      {% endif %}
    </div>
    <div class="apgo-hero-mb">
      {% if section.settings.hero_image_mb %}
        {{ section.settings.hero_image_mb | image_url: width: 750 | image_tag: class: 'apgo-obj-cover' }}
      {% else %}
        <img src="https://placehold.co/750x1100/121212/f08418?text=Hero+MB" width="750" height="1100" class="apgo-obj-cover" style="opacity:0.8">
      {% endif %}
    </div>
  </section>

  <div id="nav-placeholder" style="height: 50px; display: none;"></div>
  <nav id="apgo-sticky-nav">
    <div id="sticky-nav-container" class="scrollbar-hide">
      {% assign nav_mode = section.settings.nav_mode | default: 'auto' %}
      {% assign has_nav_blocks = false %}
      {% assign has_content_blocks = false %}
      {% assign auto_has_coupon = false %}
      {% assign auto_grid_index = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'nav_item' %}{% assign has_nav_blocks = true %}{% endif %}
        {% if block.type == 'feature_banner_slot' or block.type == 'quick_links_grid_slot' or block.type == 'combo_showcase' or block.type == 'product_grid' or block.type == 'coupon_item' %}{% assign has_content_blocks = true %}{% endif %}
      {% endfor %}

      {% assign use_manual_nav = false %}
      {% if nav_mode == 'manual' and has_nav_blocks %}
        {% assign use_manual_nav = true %}
      {% endif %}

      {% if use_manual_nav %}
        {% for block in section.blocks %}
          {% if block.type == 'nav_item' %}
            <div class="sticky-nav-link" onclick="scrollToSection('{{ block.settings.nav_target_id }}')">{{ block.settings.nav_label }}</div>
          {% endif %}
        {% endfor %}
      {% else %}
        <div class="sticky-nav-link" onclick="scrollToSection('apgo-hero')">首圖</div>
        {% for block in section.blocks %}
          {% if block.type == 'feature_banner_slot' %}
            {% assign anchor_id = block.settings.custom_anchor_id | default: 'apgo-feature-' | append: block.id %}
            {% if block.settings.custom_anchor_id != blank %}{% assign anchor_id = block.settings.custom_anchor_id %}{% endif %}
            {% assign nav_label = block.settings.nav_label_override | default: block.settings.section_title | default: '焦點橫幅版位' %}
