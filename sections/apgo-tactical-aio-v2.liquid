          {% assign vertical_rows = block.settings.vertical_rows | default: '1' %}
          {% assign vertical_cards_per_view = block.settings.vertical_cards_per_view | default: '2.5' %}

          {% if has_products_in_grid or request.design_mode %}
            <div class="apgo-card-grid{% if card_layout == 'vertical' %} apgo-card-grid-vertical{% if vertical_rows == '2' %} apgo-card-grid-vertical-2rows{% endif %}{% endif %}"{% if card_layout == 'vertical' %} style="--apgo-cards-per-view: {{ vertical_cards_per_view }};"{% endif %}>
