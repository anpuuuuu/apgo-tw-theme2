{% comment %}
  APGO Custom Register Page - Dark Tech Style (Safe Version)
  Fix: Removed aggressive wildcard styling to protect HIKO/Social Login buttons.
{% endcomment %}

<style>
  /* --- 基礎佈局 --- */
  .customer-register-section {
    padding: 60px 20px;
    max-width: 500px;
    margin: 0 auto;
    color: #fff;
    /* 設定深色背景，但不強制覆蓋內部子元素 */
    background-color: #050505; 
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }

  .register-header {
    text-align: center;
    margin-bottom: 40px;
  }

  .register-header h1 {
    font-size: 2.2rem;
    font-weight: 700;
    margin: 0 0 10px 0;
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    background-color: transparent !important; /* 只對文字去背 */
  }
  
  .register-header p {
    color: #888;
    font-size: 0.95rem;
    background-color: transparent !important; /* 只對文字去背 */
  }

  /* --- 輸入框樣式 --- */
  .form-field {
    margin-bottom: 20px;
  }

  /* 針對輸入框設定深色樣式 */
  .form-field input {
    width: 100%;
    padding: 15px;
    background-color: #1a1a1a !important; /* 強制深灰底色 */
    border: 1px solid #333 !important;    /* 深色邊框 */
    border-radius: 8px !important;        /* 圓角 */
    color: #fff !important;               /* 輸入文字白色 */
    font-size: 1rem;
    transition: all 0.3s ease;
    box-sizing: border-box;
  }

  .form-field input::placeholder { color: #666 !important; }

  /* 輸入框 Focus 光暈 */
  .form-field input:focus {
    outline: none;
    border-color: #f08418 !important;
    box-shadow: 0 0 0 1px #f08418 !important;
  }

  /* --- 註冊按鈕 (APGO 橘) --- */
  .submit-btn {
    width: 100%;
    padding: 15px;
    background-color: #f08418 !important; /* 強制 APGO 橘 */
    color: #ffffff !important;
    font-size: 1.1rem;
    font-weight: bold;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    text-transform: uppercase;
    transition: background-color 0.3s, transform 0.2s;
    margin-top: 10px;
  }

  .submit-btn:hover {
    background-color: #d66a00 !important;
    transform: translateY(-2px);
  }

  /* 底部連結區塊 */
  .register-footer {
    /* 改成這樣：上下各留 30px 的距離，左右 0 */
    margin: 30px 0; 
    
    text-align: center;
    font-size: 0.9rem;
    color: #ccc;
    
    /* 確保它是區塊元素，會乖乖佔據一行 */
    display: block; 
  }

  .register-footer a {
    color: #f08418;
    text-decoration: none;
    font-weight: 500;
    background-color: transparent !important;
  }
  
  .register-footer a:hover { text-decoration: underline; }

  /* --- 錯誤訊息樣式 --- */
  .errors ul {
    list-style: none;
    padding: 0;
    margin: 0 0 20px 0;
    background: rgba(255, 68, 68, 0.1); /* 半透明紅底 */
    border: 1px solid #ff4444;
    border-radius: 8px;
  }
  .errors li {
    padding: 12px;
    color: #ffcccc;
    font-size: 0.9rem;
    text-align: center;
    background-color: transparent !important;
  }
  .errors li a { color: #fff; text-decoration: underline; background-color: transparent !important; }
  
</style>

<div class="customer-register-section">
  
  <div class="register-header">
    <h1>註冊新會員</h1>
    <p>加入 APGO，享受專屬優惠與服務</p>
  </div>

  {% form 'create_customer' %}
    
    {{ form.errors | default_errors }}

    <div class="form-field">
      <input 
        type="text" 
        name="customer[last_name]" 
        id="RegisterForm-LastName" 
        {% if form.last_name %}value="{{ form.last_name }}"{% endif %} 
        autocomplete="family-name" 
        placeholder="姓氏"
        required
      >
    </div>

    <div class="form-field">
      <input 
        type="text" 
        name="customer[first_name]" 
        id="RegisterForm-FirstName" 
        {% if form.first_name %}value="{{ form.first_name }}"{% endif %} 
        autocomplete="given-name" 
        placeholder="名字"
        required
      >
    </div>

    <div class="form-field">
      <input 
        type="email" 
        name="customer[email]" 
        id="RegisterForm-email" 
        {% if form.email %} value="{{ form.email }}"{% endif %} 
        spellcheck="false" 
        autocapitalize="off" 
        autocomplete="email" 
        aria-required="true" 
        placeholder="電子信箱 (Email)"
        required
      >
    </div>

    <div class="form-field">
      <input 
        type="password" 
        name="customer[password]" 
        id="RegisterForm-password" 
        aria-required="true" 
        placeholder="設定密碼"
        required
      >
    </div>

    <button type="submit" class="submit-btn">立即註冊</button>
    
    <div class="register-footer">
      已經有帳號了嗎？ <a href="{{ routes.account_login_url }}">返回登入</a>
    </div>

  {% endform %}
</div>

{% schema %}
{
  "name": "Register",
  "settings": []
}
{% endschema %}