{% comment %} Section: Spec Table · 商品規格 · 立即可用 {% endcomment %}

<section class="apgo-section apgo-spec" data-section-id="{{ section.id }}">
  <div class="apgo-container" style="padding:60px 32px;">
    <h3 class="apgo-serif" style="font-size:24px; margin-bottom:28px; font-weight:400;">{{ section.settings.heading }}</h3>

    {% if section.blocks.size > 0 %}
      <div style="display:grid; grid-template-columns:1fr 1fr; gap:0 40px;">
        {% for block in section.blocks %}
          <div style="display:grid; grid-template-columns:120px 1fr; gap:16px; padding:14px 0; border-bottom:1px solid var(--apgo-line);" {{ block.shopify_attributes }}>
            <div class="apgo-muted" style="font-size:12px; letter-spacing:0.1em;">{{ block.settings.key }}</div>
            <div class="apgo-serif" style="font-size:14px;">{{ block.settings.value }}</div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      {% render 'apgo-placeholder', name: '規格表', hint: '請新增規格 block' %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "APGO · Spec Table",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "標題", "default": "商品規格" }
  ],
  "blocks": [
    {
      "type": "row",
      "name": "規格列",
      "settings": [
        { "type": "text", "id": "key", "label": "項目" },
        { "type": "text", "id": "value", "label": "值" }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "APGO · Spec Table",
      "blocks": [
        { "type": "row", "settings": { "key": "容量",   "value": "2000mL" }},
        { "type": "row", "settings": { "key": "濃縮度", "value": "8 倍" }},
        { "type": "row", "settings": { "key": "pH 值", "value": "中性 7.0" }},
        { "type": "row", "settings": { "key": "適用",   "value": "嬰幼兒 / 敏感肌" }},
        { "type": "row", "settings": { "key": "認證",   "value": "SGS / 八大零添加" }},
        { "type": "row", "settings": { "key": "產地",   "value": "台灣製造" }}
      ]
    }
  ]
}
{% endschema %}
