        <a href="{{ section.settings.checkout_link | default: '/cart' }}" class="add-on-checkout-link">
          {{ section.settings.checkout_text | default: '直接完成結帳' }}
        </a>
      </footer>
    {% endif %}
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const section = document.getElementById('{{ section.settings.section_anchor_id | default: "addon-products" }}');
  if (!section) return;

  const productCards = section.querySelectorAll('.product-card');
  
  productCards.forEach(card => {
    const specSelect = card.querySelector('.product-spec-select');
    const priceValueElement = card.querySelector('.price-value');
    const addToCartBtn = card.querySelector('.add-to-cart-btn');
    const btnText = addToCartBtn.querySelector('.btn-text');
    const btnLoader = addToCartBtn.querySelector('.btn-loader');

    function updatePriceAndVariantId() {
      if (specSelect && specSelect.options.length > 0) {
        // 有變體選擇器的情況
        const selectedOption = specSelect.options[specSelect.selectedIndex];
        const price = selectedOption.dataset.price;
        const variantId = selectedOption.dataset.variantId;
        
        if (priceValueElement) {
          priceValueElement.textContent = `NT$ ${price}`;
        }
        addToCartBtn.dataset.variantId = variantId;
      }
      // 沒有變體選擇器的情況，已經由 Liquid 預先設置 first_available_variant.id
    }

    if (specSelect) {
      specSelect.addEventListener('change', updatePriceAndVariantId);
    }

    if (addToCartBtn) {
      addToCartBtn.addEventListener('click', async (e) => {
        e.preventDefault();
        
        // 記住原始文字
        const originalText = btnText.textContent;
        
        if (addToCartBtn.disabled) return;

        const variantId = addToCartBtn.dataset.variantId;
        const quantitySelector = card.querySelector('.quantity-selector');
        const quantity = quantitySelector ? parseInt(quantitySelector.value) : 1;
        const productName = (specSelect && specSelect.dataset.productName) || card.querySelector('.product-name').textContent;
        const selectedSpec = specSelect && specSelect.options[specSelect.selectedIndex] ? specSelect.options[specSelect.selectedIndex].value : '預設規格';

        if (!variantId) {
          console.error('Variant ID is missing for product:', productName);
          console.log('Button dataset:', addToCartBtn.dataset);
          console.log('Product ID:', addToCartBtn.dataset.productId);
          showNotification('商品變體ID缺失，無法加入購物車', 'error');
          return;
        }
        
        console.log('Adding to cart:', {
          productName,
          variantId,
          quantity,
          selectedSpec
        });
        
        btnText.style.visibility = 'hidden';
        btnLoader.style.display = 'block';
        addToCartBtn.disabled = true;
        addToCartBtn.style.background = 'linear-gradient(45deg, #666, #999)';
        addToCartBtn.style.boxShadow = 'none';

        try {
          // 使用 Shopify AJAX API 加入購物車
          const formData = {
            id: variantId,
            quantity: quantity,
            properties: {
              '加購規格': selectedSpec
            }
          };

          const response = await fetch('/cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
              'Accept': 'application/json'
            },
            body: JSON.stringify(formData)
          });

          const result = await response.json();

          if (response.ok) {
            btnText.textContent = '{{ section.settings.added_to_cart_text | default: "已加入！" }}';
            
            addToCartBtn.classList.add('is-added');
            addToCartBtn.style.background = 'linear-gradient(45deg, #4CAF50, #66BB6A)';
            addToCartBtn.style.boxShadow = '0 4px 15px rgba(76, 175, 80, 0.3)';
            
            // 顯示成功通知
            showNotification(productName + ' 已成功加入購物車！');
            
            // 更新購物車計數器（如果存在）
            if (typeof window.updateCartCount === 'function') {
              window.updateCartCount();
            }
          } else {
            btnText.textContent = '加入失敗';
            
            addToCartBtn.classList.remove('is-added');
            addToCartBtn.style.background = 'linear-gradient(45deg, #f44336, #e57373)';
            addToCartBtn.style.boxShadow = '0 4px 15px rgba(244, 67, 54, 0.3)';
            console.error('Add to cart error:', result);
            
            // 顯示錯誤通知
            showNotification('加入購物車失敗，請稍後再試', 'error');
          }
        } catch (error) {
          btnText.textContent = '錯誤！';
          
          addToCartBtn.classList.remove('is-added');
          addToCartBtn.style.background = 'linear-gradient(45deg, #f44336, #e57373)';
          addToCartBtn.style.boxShadow = '0 4px 15px rgba(244, 67, 54, 0.3)';
          console.error('Add to cart error:', error);
          
          // 顯示錯誤通知
          showNotification('加入購物車失敗，請稍後再試', 'error');
        } finally {
          btnLoader.style.display = 'none';
          btnText.style.visibility = 'visible';
          setTimeout(() => {
            // 還原原始文字
            btnText.textContent = originalText;
            
            addToCartBtn.disabled = false;
            addToCartBtn.classList.remove('is-added');
            addToCartBtn.style.background = 'linear-gradient(45deg, var(--primary-orange), var(--secondary-orange))';
            addToCartBtn.style.boxShadow = '0 4px 15px rgba(240, 132, 24, 0.3)';
          }, 2000);
        }
      });
    }

    updatePriceAndVariantId();
  });

  // 顯示通知函數
  function showNotification(message, type = 'success') {
    // 移除現有通知
    const existingNotification = document.querySelector('.add-on-notification');
    if (existingNotification) {
      existingNotification.remove();
    }

    const notification = document.createElement('div');
    notification.className = 'add-on-notification ' + type;
    
    const isSuccess = type === 'success';
    notification.innerHTML = `
      <div class="add-on-notification-content">
        <div class="add-on-notification-message">${message}</div>
        ${isSuccess ? `<a href="/cart" class="add-on-notification-link">查看購物車</a>` : ''}
      </div>
      <button class="add-on-notification-close" onclick="this.parentNode.remove()">&times;</button>
    `;

    document.body.appendChild(notification);
    
    // 顯示動畫
    setTimeout(() => {
      notification.classList.add('show');
    }, 100);
    
    // 自動隱藏
    setTimeout(() => {
      if (notification.parentNode) {
        notification.classList.remove('show');
        setTimeout(() => {
          if (notification.parentNode) {
            notification.remove();
          }
        }, 300);
      }
    }, 5000);
  }

  // 滾動控制
  const carousels = section.querySelectorAll('.horizontal-scroll-container');
  carousels.forEach(carousel => {
    carousel.addEventListener('wheel', function(e) {
      if (e.deltaY !== 0) {
        e.preventDefault();
        carousel.scrollLeft += e.deltaY;
      }
    }, { passive: false });

    let isDown = false;
    let startX;
    let scrollLeft;

    carousel.addEventListener('mousedown', (e) => {
      isDown = true;
      carousel.style.cursor = 'grabbing';
      startX = e.pageX - carousel.offsetLeft;
      scrollLeft = carousel.scrollLeft;
    });

    carousel.addEventListener('mouseleave', () => {
      isDown = false;
      carousel.style.cursor = 'grab';
    });

    carousel.addEventListener('mouseup', () => {
      isDown = false;
      carousel.style.cursor = 'grab';
    });

    carousel.addEventListener('mousemove', (e) => {
      if (!isDown) return;
      e.preventDefault();
      const x = e.pageX - carousel.offsetLeft;
      const walk = (x - startX) * 2;
      carousel.scrollLeft = scrollLeft - walk;
    });
  });
});
</script>

