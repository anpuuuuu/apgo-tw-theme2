                      {% endif %}
                    {% endfor %}
                  </div>
                {% else %}
                  <!-- 輪播排列 -->
                  <div class="horizontal-scroll-container">
                    {% for i in (1..10) %}
                      {% assign product_key = 'product_' | append: i %}
                      {% assign product = block.settings[product_key] %}
                      {% if product != blank %}
                        {% assign product_obj = all_products[product] %}
                        {% if product_obj != blank %}
                          {% comment %} 商品找到，正常顯示 {% endcomment %}
                          <div class="product-card">
                            <div class="product-image-container">
                              <img src="{{ product_obj.featured_image | image_url: width: 400, height: 400, crop: 'center' }}" 
                                   alt="{{ product_obj.title }}圖片" 
                                   class="product-image"
                                   width="400"
                                   height="400"
                                   loading="lazy">
                            </div>
                            <div class="product-content">
                              <h3 class="product-name">{{ product_obj.title }}</h3>
                              
                              {% if section.settings.show_variant_selector and product_obj.variants.size > 1 %}
                                <div class="product-spec-select-wrapper">
                                  <label for="spec-{{ product_obj.id }}" class="sr-only">選擇規格</label>
                                  <select id="spec-{{ product_obj.id }}" class="product-spec-select" data-product-name="{{ product_obj.title }}">
                                    {% for variant in product_obj.variants %}
                                      <option value="{{ variant.title }}" 
                                              data-price="{{ variant.price | money_without_currency }}" 
                                              data-variant-id="{{ variant.id }}">
                                        {{ variant.title }} - {{ variant.price | money }}
                                      </option>
                                    {% endfor %}
                                  </select>
                                </div>
                              {% endif %}
                              
                              {% if section.settings.show_quantity_selector %}
                                <div class="quantity-selector-wrapper">
                                  <label for="qty-{{ product_obj.id }}" class="sr-only">選擇數量</label>
                                  <select id="qty-{{ product_obj.id }}" class="quantity-selector" data-product-id="{{ product_obj.id }}">
                                    {% for i in (1..10) %}
                                      <option value="{{ i }}">{{ i }}</option>
                                    {% endfor %}
                                  </select>
                                </div>
                              {% endif %}
                              
                              <div class="price-display-standalone">
                                <span class="price-value">{{ product_obj.price | money }}</span>
                              </div>
                              <div class="cta-buttons">
                                <a href="{{ product_obj.url }}" class="cta-btn learn-more-btn">
                                  <span class="desktop-text">{{ section.settings.learn_more_text | default: '了解更多' }}</span>
                                  <span class="mobile-text">詳情</span>
                                </a>
                                <button class="cta-btn add-to-cart-btn" data-product-id="{{ product_obj.id }}" {% unless section.settings.show_variant_selector and product_obj.variants.size > 1 %}data-variant-id="{{ product_obj.first_available_variant.id }}"{% endunless %}>
                                  <span class="btn-text">{{ section.settings.add_to_cart_text | default: '加入購物車' }}</span>
                                  <span class="btn-loader">
                                    <span class="spinner"></span>
