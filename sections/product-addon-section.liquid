                                  <label for="spec-{{ product_obj.id }}" class="sr-only">選擇規格</label>
                                  <select id="spec-{{ product_obj.id }}" class="product-spec-select" data-product-name="{{ product_obj.title }}">
                                    {% for variant in product_obj.variants %}
                                      <option value="{{ variant.title }}" 
                                              data-price="{{ variant.price | money_without_currency }}" 
                                              data-variant-id="{{ variant.id }}">
                                        {{ variant.title }} - {{ variant.price | money }}
