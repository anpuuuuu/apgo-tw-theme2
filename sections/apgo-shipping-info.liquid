{% comment %} Section: Shipping Info · 配送說明 · 立即可用 {% endcomment %}

<section class="apgo-section apgo-shipping" data-section-id="{{ section.id }}">
  <div class="apgo-container" style="padding: 20px 32px 40px;">
    <div style="display:grid; gap:12px;">
      {% for block in section.blocks %}
        <div style="display:grid; grid-template-columns:32px 1fr; gap:14px; padding:14px 0; border-bottom:1px solid var(--apgo-line);" {{ block.shopify_attributes }}>
          <span class="apgo-display" style="color:var(--apgo-sage); font-size:18px;">{{ block.settings.icon }}</span>
          <div>
            <strong style="font-size:14px;">{{ block.settings.title }}</strong>
            <div class="apgo-muted" style="font-size:12px; margin-top:2px;">{{ block.settings.description }}</div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "APGO · Shipping Info",
  "tag": "section",
  "blocks": [
    {
      "type": "row",
      "name": "配送 / 保證 / 認證",
      "settings": [
        { "type": "text", "id": "icon", "label": "符號", "default": "i" },
        { "type": "text", "id": "title", "label": "標題" },
        { "type": "text", "id": "description", "label": "說明" }
      ]
    }
  ],
  "max_blocks": 5,
  "presets": [
    {
      "name": "APGO · Shipping Info",
      "blocks": [
        { "type": "row", "settings": { "icon": "i", "title": "滿 NT$ 799 免運費", "description": "全台灣本島 · 3-5 個工作天到貨" }},
        { "type": "row", "settings": { "icon": "ii", "title": "30 天鑑賞期", "description": "未拆封可無條件退換" }},
        { "type": "row", "settings": { "icon": "iii", "title": "SGS 國家級檢驗", "description": "99.9% 抗菌率 · 八大零添加" }}
      ]
    }
  ]
}
{% endschema %}
