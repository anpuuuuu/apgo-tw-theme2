    "custom_liquid_t4jUXk": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "原子系列鍍膜適用範圍",
      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"zh-TW\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>APGO原子系列鍍膜適用範圍 - 汽車機車改色膜全方位防護</title>\n    <meta name=\"description\" content=\"APGO原子系列鍍膜適用於汽車、機車、改色包膜等各種材質表面，不分顏色不分材質的全方位防護，經8年實車測試驗證\">\n    <meta name=\"keywords\" content=\"原子鍍膜, 汽車鍍膜, 機車鍍膜, 改色膜鍍膜, 車漆保護, APGO鍍膜\">\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        :root {\n            --apgo-scope-primary: #f08418;\n            --apgo-scope-text-white: #ffffff;\n            --apgo-scope-text-gray: #cccccc;\n            --apgo-scope-text-light: #b0b0b0;\n            --apgo-scope-dark-bg: #000000;\n        }\n\n        /* 統一字體設定 - SEO與可讀性優化 */\n        body {\n            font-family: 'Microsoft JhengHei', 'PingFang TC', 'Hiragino Sans GB', 'Arial', sans-serif;\n            background: var(--apgo-scope-dark-bg);\n            color: var(--apgo-scope-text-white);\n            line-height: 1.6;\n            font-weight: 400;\n            font-size: 16px; /* 提升基礎可讀性 */\n        }\n\n        /* 適用範圍主區塊 */\n        .apgo-scope-section {\n            background: #000000;\n            padding: 40px 0;\n            position: relative;\n            overflow: hidden;\n        }\n\n        /* 背景裝飾 */\n        .apgo-scope-section::before {\n            content: '';\n            position: absolute;\n            top: 50%;\n            right: -20%;\n            width: 400px;\n            height: 400px;\n            background: radial-gradient(circle, rgba(240, 132, 24, 0.04) 0%, transparent 70%);\n            pointer-events: none;\n        }\n\n        .apgo-scope-container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 0 20px;\n            position: relative;\n            z-index: 1;\n        }\n\n        /* 標題區域 - SEO優化 */\n        .apgo-scope-header {\n            margin-bottom: 25px;\n            opacity: 0;\n            transform: translateY(15px);\n            animation: apgoScopeFadeIn 0.5s ease forwards;\n        }\n\n        @keyframes apgoScopeFadeIn {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        /* H2 區塊標題 - SEO優化 */\n        .apgo-scope-title {\n            font-size: 2rem; /* 符合規範 H2 標準 */\n            font-weight: 600;\n            color: var(--apgo-scope-primary);\n            margin-bottom: 12px;\n            letter-spacing: 0.5px;\n            line-height: 1.3;\n        }\n\n        /* H2 副標題 - SEO優化 */\n        .apgo-scope-subtitle {\n            font-size: 0.9rem; /* 副文字說明標準 */\n            color: var(--apgo-scope-text-gray);\n            max-width: 700px;\n            font-weight: 400;\n            line-height: 1.5;\n        }\n\n        /* 橫向滾動容器 */\n        .apgo-scope-scroll-container {\n            position: relative;\n            margin: 0 -20px;\n            padding: 0 20px;\n            overflow: hidden;\n        }\n\n        /* 橫向卡片容器 */\n        .apgo-scope-categories-row {\n            display: flex;\n            gap: 20px;\n            overflow-x: auto;\n            overflow-y: hidden;\n            padding: 10px 0 20px 0;\n            scroll-behavior: smooth;\n            -webkit-overflow-scrolling: touch;\n            scrollbar-width: thin;\n            scrollbar-color: #f08418 rgba(255, 255, 255, 0.1);\n            opacity: 0;\n            transform: translateY(20px);\n            animation: apgoScopeFadeIn 0.5s ease 0.2s forwards;\n        }\n\n        /* 滾動條樣式 */\n        .apgo-scope-categories-row::-webkit-scrollbar {\n            height: 6px;\n        }\n\n        .apgo-scope-categories-row::-webkit-scrollbar-track {\n            background: rgba(255, 255, 255, 0.1);\n            border-radius: 3px;\n        }\n\n        .apgo-scope-categories-row::-webkit-scrollbar-thumb {\n            background: #f08418;\n            border-radius: 3px;\n        }\n\n        /* 右側漸變提示 */\n        .apgo-scope-scroll-container::after {\n            content: '';\n            position: absolute;\n            top: 0;\n            right: 0;\n            width: 50px;\n            height: 100%;\n            background: linear-gradient(90deg, transparent 0%, #000000 100%);\n            pointer-events: none;\n            z-index: 2;\n        }\n\n        /* 類別卡片 - 橫向設計 */\n        .apgo-scope-category-card {\n            flex: 0 0 auto;\n            width: 320px;\n            background: rgba(255, 255, 255, 0.02);\n            backdrop-filter: blur(10px);\n            border: 1px solid rgba(255, 255, 255, 0.06);\n            border-radius: 16px;\n            padding: 20px;\n            transition: all 0.3s ease;\n            cursor: pointer;\n            position: relative;\n            display: flex;\n            flex-direction: column;\n        }\n\n        .apgo-scope-category-card:hover {\n            transform: translateY(-5px);\n            background: rgba(240, 132, 24, 0.06);\n            border-color: rgba(240, 132, 24, 0.2);\n            box-shadow: 0 10px 30px rgba(240, 132, 24, 0.15);\n        }\n\n        /* 卡片頂部標籤 */\n        .apgo-scope-card-badge {\n            position: absolute;\n            top: 15px;\n            right: 15px;\n            background: var(--apgo-scope-primary);\n            color: white;\n            font-size: 0.7rem; /* 11px - 統一小字體 */\n            padding: 4px 12px;\n            border-radius: 12px;\n            font-weight: 600;\n            text-transform: uppercase;\n            letter-spacing: 0.5px;\n        }\n\n        /* 圖片占位區域 */\n        .apgo-scope-image-area {\n            width: 100%;\n            height: 80px;\n            background: rgba(255, 255, 255, 0.03);\n            border-radius: 10px;\n            margin-bottom: 15px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            font-size: 0.875rem; /* 14px - 統一說明文字 */\n            color: var(--apgo-scope-text-gray);\n            overflow: hidden;\n            position: relative;\n        }\n\n        /* 圖片樣式 - SEO優化 */\n        .apgo-scope-image-area img {\n            width: 100%;\n            height: 100%;\n            object-fit: cover;\n            object-position: center;\n        }\n\n        /* H3 類別標題 - SEO優化 */\n        .apgo-scope-category-title {\n            font-size: 1.5rem; /* 符合規範 H3 標準 */\n            font-weight: 600;\n            color: var(--apgo-scope-primary);\n            margin-bottom: 8px;\n            letter-spacing: 0.3px;\n            line-height: 1.3;\n        }\n\n        /* 類別描述 - 可讀性優化 */\n        .apgo-scope-category-desc {\n            font-size: 0.875rem; /* 14px - 提升可讀性 */\n            color: var(--apgo-scope-text-light);\n            line-height: 1.5;\n            margin-bottom: 15px;\n            flex-grow: 1;\n        }\n\n        /* 適用項目標籤 */\n        .apgo-scope-tags {\n            display: flex;\n            flex-wrap: wrap;\n            gap: 6px;\n            margin-bottom: 12px;\n        }\n\n        .apgo-scope-tag {\n            background: rgba(240, 132, 24, 0.08);\n            border: 1px solid rgba(240, 132, 24, 0.15);\n            padding: 4px 10px;\n            border-radius: 8px;\n            font-size: 0.75rem; /* 12px - 統一標籤字體 */\n            color: var(--apgo-scope-text-white);\n            transition: all 0.3s ease;\n            white-space: nowrap;\n            font-weight: 500;\n        }\n\n        .apgo-scope-category-card:hover .apgo-scope-tag {\n            background: rgba(240, 132, 24, 0.12);\n            border-color: rgba(240, 132, 24, 0.3);\n        }\n\n        /* 展開更多按鈕 */\n        .apgo-scope-expand {\n            display: flex;\n            align-items: center;\n            justify-content: space-between;\n            color: var(--apgo-scope-primary);\n            font-size: 0.875rem; /* 14px - 統一按鈕文字 */\n            font-weight: 500;\n            padding-top: 10px;\n            border-top: 1px solid rgba(255, 255, 255, 0.05);\n            transition: all 0.3s ease;\n        }\n\n        .apgo-scope-category-card:hover .apgo-scope-expand {\n            border-top-color: rgba(240, 132, 24, 0.2);\n        }\n\n        .apgo-scope-expand-arrow {\n            transition: transform 0.3s ease;\n        }\n\n        .apgo-scope-category-card:hover .apgo-scope-expand-arrow {\n            transform: translateX(3px);\n        }\n\n        /* 底部說明 */\n        .apgo-scope-footer {\n            margin-top: 25px;\n            text-align: center;\n            opacity: 0;\n            transform: translateY(15px);\n            animation: apgoScopeFadeIn 0.5s ease 0.4s forwards;\n        }\n\n        .apgo-scope-guarantee {\n            display: inline-flex;\n            align-items: center;\n            gap: 10px;\n            font-size: 0.9rem; /* 14.4px - 提升保證說明可讀性 */\n            color: var(--apgo-scope-text-gray);\n            padding: 12px 24px;\n            background: rgba(240, 132, 24, 0.05);\n            border-radius: 20px;\n            border: 1px solid rgba(240, 132, 24, 0.1);\n            line-height: 1.5;\n        }\n\n        .apgo-scope-check {\n            color: var(--apgo-scope-primary);\n            font-weight: bold;\n        }\n\n        /* 安全提醒文字 - 可讀性優化 */\n        .apgo-scope-safety-note {\n            font-size: 0.8rem; /* 12.8px - 法律聲明標準尺寸 */\n            color: #999;\n            margin-top: 12px;\n            line-height: 1.5;\n            max-width: 800px;\n            margin-left: auto;\n            margin-right: auto;\n        }\n\n        /* 彈窗樣式 */\n        .apgo-scope-modal {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: rgba(0, 0, 0, 0.85);\n            backdrop-filter: blur(10px);\n            display: none;\n            align-items: center;\n            justify-content: center;\n            z-index: 1000;\n            opacity: 0;\n            transition: all 0.3s ease;\n        }\n\n        .apgo-scope-modal.apgo-scope-show {\n            display: flex;\n            opacity: 1;\n        }\n\n        .apgo-scope-modal-content {\n            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);\n            border-radius: 20px;\n            padding: 40px 30px;\n            max-width: 500px;\n            width: 90%;\n            max-height: 80vh;\n            overflow-y: auto;\n            border: 1px solid rgba(240, 132, 24, 0.3);\n            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.7);\n            transform: scale(0.9);\n            transition: all 0.3s ease;\n            position: relative;\n        }\n\n        .apgo-scope-modal.apgo-scope-show .apgo-scope-modal-content {\n            transform: scale(1);\n        }\n\n        /* 關閉按鈕 */\n        .apgo-scope-close-modal {\n            position: absolute;\n            top: 15px;\n            right: 15px;\n            background: rgba(255, 255, 255, 0.1);\n            border: none;\n            color: var(--apgo-scope-text-gray);\n            font-size: 1.5rem;\n            width: 35px;\n            height: 35px;\n            border-radius: 50%;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n\n        .apgo-scope-close-modal:hover {\n            background: var(--apgo-scope-primary);\n            color: white;\n            transform: rotate(90deg);\n        }\n\n        /* 彈窗內容 - 字體優化 */\n        .apgo-scope-modal-header {\n            margin-bottom: 25px;\n            text-align: center;\n        }\n\n        /* H4 彈窗標題 - SEO優化 */\n        .apgo-scope-modal-title {\n            font-size: 1.375rem; /* 22px - H4標準尺寸 */\n            color: var(--apgo-scope-primary);\n            margin-bottom: 10px;\n            font-weight: 600;\n            line-height: 1.3;\n        }\n\n        .apgo-scope-modal-subtitle {\n            font-size: 0.95rem; /* 15.2px - 副標題可讀性 */\n            color: var(--apgo-scope-text-gray);\n            line-height: 1.5;\n        }\n\n        .apgo-scope-modal-list {\n            background: rgba(255, 255, 255, 0.05);\n            border-radius: 15px;\n            padding: 20px;\n            margin-bottom: 20px;\n        }\n\n        .apgo-scope-modal-item {\n            padding: 10px 0;\n            border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n            color: var(--apgo-scope-text-white);\n            font-size: 0.95rem; /* 15.2px - 內容可讀性 */\n            display: flex;\n            align-items: center;\n            gap: 10px;\n            line-height: 1.5;\n        }\n\n        .apgo-scope-modal-item:last-child {\n            border-bottom: none;\n        }\n\n        .apgo-scope-modal-item::before {\n            content: '✓';\n            color: var(--apgo-scope-primary);\n            font-weight: bold;\n        }\n\n        .apgo-scope-modal-note {\n            background: rgba(240, 132, 24, 0.1);\n            border: 1px solid rgba(240, 132, 24, 0.3);\n            border-radius: 10px;\n            padding: 15px;\n            font-size: 0.875rem; /* 14px - 注意事項可讀性 */\n            color: var(--apgo-scope-text-gray);\n            line-height: 1.6;\n        }\n\n        /* 滾動條美化 */\n        .apgo-scope-modal-content::-webkit-scrollbar {\n            width: 6px;\n        }\n\n        .apgo-scope-modal-content::-webkit-scrollbar-track {\n            background: rgba(255, 255, 255, 0.1);\n            border-radius: 3px;\n        }\n\n        .apgo-scope-modal-content::-webkit-scrollbar-thumb {\n            background: var(--apgo-scope-primary);\n            border-radius: 3px;\n        }\n\n        /* 響應式設計 - 字體縮放優化 */\n        @media (max-width: 1024px) {\n            .apgo-scope-category-card {\n                width: 280px;\n            }\n        }\n\n        @media (max-width: 768px) {\n            .apgo-scope-section {\n                padding: 30px 0;\n            }\n\n            /* 手機版字體優化 */\n            .apgo-scope-title {\n                font-size: 1.6rem; /* H2 手機版標準 */\n            }\n\n            .apgo-scope-subtitle {\n                font-size: 0.85rem; /* 副文字手機版標準 */\n            }\n\n            .apgo-scope-category-card {\n                width: 260px;\n                padding: 18px;\n            }\n\n            .apgo-scope-image-area {\n                height: 70px;\n                margin-bottom: 12px;\n            }\n\n            .apgo-scope-category-title {\n                font-size: 1.3rem; /* H3 手機版標準 */\n            }\n\n            .apgo-scope-category-desc {\n                font-size: 0.8rem; /* 12.8px - 手機版描述 */\n            }\n\n            .apgo-scope-tag {\n                font-size: 0.9rem; /* H5 手機版標準 */\n                padding: 3px 8px;\n            }\n\n            .apgo-scope-guarantee {\n                font-size: 0.85rem; /* 13.6px - 手機版保證說明 */\n                padding: 10px 18px;\n            }\n\n            .apgo-scope-safety-note {\n                font-size: 0.75rem; /* 12px - 手機版法律聲明 */\n            }\n        }\n\n        @media (max-width: 480px) {\n            .apgo-scope-container {\n                padding: 0 15px;\n            }\n\n            .apgo-scope-category-card {\n                width: 240px;\n            }\n\n            .apgo-scope-title {\n                font-size: 1.4rem; /* H2 小螢幕標準 */\n            }\n        }\n    </style>\n</head>\n<body>\n    <!-- 適用範圍區塊 -->\n    <section class=\"apgo-scope-section\">\n        <div class=\"apgo-scope-container\">\n            <!-- 標題區域 - SEO優化 -->\n            <header class=\"apgo-scope-header\">\n                <h2 class=\"apgo-scope-title\">原子系列鍍膜適用範圍</h2>\n                <h2 class=\"apgo-scope-subtitle\">不分顏色、不分材質的全方位防護，適用汽車機車改色膜等各種表面</h2>\n            </header>\n\n            <!-- 橫向滾動容器 -->\n            <div class=\"apgo-scope-scroll-container\">\n                <div class=\"apgo-scope-categories-row\">\n                    <!-- 汽車材質 -->\n                    <article class=\"apgo-scope-category-card\" onclick=\"handleCarScope()\">\n                        <span class=\"apgo-scope-card-badge\">熱門</span>\n                        \n                        <div class=\"apgo-scope-image-area\">\n                            <img src=\"https://cdn.shopify.com/s/files/1/0760/8002/1755/files/car-paint-illustration.png?v=1234567890\" alt=\"汽車鍍膜適用材質示意圖\" />\n                        </div>\n                        \n                        <h3 class=\"apgo-scope-category-title\">汽車材質鍍膜</h3>\n                        <p class=\"apgo-scope-category-desc\">適用各種汽車表面材質，提供全面車漆保護</p>\n                        \n                        <div class=\"apgo-scope-tags\">\n                            <h5 class=\"apgo-scope-tag\">車身鈑金</h5>\n                            <h5 class=\"apgo-scope-tag\">汽車玻璃</h5>\n                            <h5 class=\"apgo-scope-tag\">塑膠件</h5>\n                            <h5 class=\"apgo-scope-tag\">鍍鉻件</h5>\n                            <h5 class=\"apgo-scope-tag\">鋁圈</h5>\n                        </div>\n                        \n                        <div class=\"apgo-scope-expand\">\n                            <span>查看所有適用材質</span>\n                            <span class=\"apgo-scope-expand-arrow\">→</span>\n                        </div>\n                    </article>\n\n                    <!-- 機車材質 -->\n                    <article class=\"apgo-scope-category-card\" onclick=\"handleMotoScope()\">\n                        <span class=\"apgo-scope-card-badge\">推薦</span>\n                        \n                        <div class=\"apgo-scope-image-area\">\n                            <img src=\"https://cdn.shopify.com/s/files/1/0760/8002/1755/files/motorcycle-paint-illustration.png?v=1234567890\" alt=\"機車鍍膜適用材質示意圖\" />\n                        </div>\n                        \n                        <h3 class=\"apgo-scope-category-title\">機車材質鍍膜</h3>\n                        <p class=\"apgo-scope-category-desc\">機車各部位材質專用，提供完整防護</p>\n                        \n                        <div class=\"apgo-scope-tags\">\n                            <h5 class=\"apgo-scope-tag\">車殼</h5>\n                            <h5 class=\"apgo-scope-tag\">儀表板</h5>\n                            <h5 class=\"apgo-scope-tag\">後照鏡</h5>\n                            <h5 class=\"apgo-scope-tag\">鋁圈</h5>\n                            <h5 class=\"apgo-scope-tag\">土除</h5>\n                        </div>\n                        \n                        <div class=\"apgo-scope-expand\">\n                            <span>查看所有適用材質</span>\n                            <span class=\"apgo-scope-expand-arrow\">→</span>\n                        </div>\n                    </article>\n\n                    <!-- 改色包膜 -->\n                    <article class=\"apgo-scope-category-card\" onclick=\"handleWrapScope()\">\n                        <span class=\"apgo-scope-card-badge\">專業</span>\n                        \n                        <div class=\"apgo-scope-image-area\">\n                            <img src=\"https://cdn.shopify.com/s/files/1/0760/8002/1755/files/wrap-film-illustration.png?v=1234567890\" alt=\"改色包膜鍍膜適用類型示意圖\" />\n                        </div>\n                        \n                        <h3 class=\"apgo-scope-category-title\">改色包膜鍍膜</h3>\n                        <p class=\"apgo-scope-category-desc\">各式膜料表面專用，維持膜料原有特性</p>\n                        \n                        <div class=\"apgo-scope-tags\">\n                            <h5 class=\"apgo-scope-tag\">犀牛皮</h5>\n                            <h5 class=\"apgo-scope-tag\">改色膜</h5>\n                            <h5 class=\"apgo-scope-tag\">車身膜</h5>\n                            <h5 class=\"apgo-scope-tag\">保護膜</h5>\n                            <h5 class=\"apgo-scope-tag\">包膜</h5>\n                        </div>\n                        \n                        <div class=\"apgo-scope-expand\">\n                            <span>查看所有膜料類型</span>\n                            <span class=\"apgo-scope-expand-arrow\">→</span>\n                        </div>\n                    </article>\n                </div>\n            </div>\n\n            <!-- 底部說明 -->\n            <footer class=\"apgo-scope-footer\">\n                <p class=\"apgo-scope-safety-note\">\n                    安全提醒：由於產品使表面滑順的特性，雖然所有材質皆可鍍膜，但不建議用在輪胎、腳踏板、坐墊、地板等安全相關物件，以免導致危險發生\n                </p>\n            </footer>\n        </div>\n    </section>\n\n    <!-- 材質詳情彈窗 -->\n    <div class=\"apgo-scope-modal\" id=\"apgoScopeModal\" role=\"dialog\" aria-labelledby=\"modalTitle\" aria-describedby=\"modalSubtitle\">\n        <div class=\"apgo-scope-modal-content\">\n            <button class=\"apgo-scope-close-modal\" onclick=\"closeScopeModal()\" aria-label=\"關閉彈窗\">×</button>\n            \n            <header class=\"apgo-scope-modal-header\">\n                <h4 class=\"apgo-scope-modal-title\" id=\"modalTitle\">標題</h4>\n                <p class=\"apgo-scope-modal-subtitle\" id=\"modalSubtitle\">副標題</p>\n            </header>\n            \n            <div class=\"apgo-scope-modal-list\" id=\"modalList\">\n                <!-- 動態內容將在這裡填入 -->\n            </div>\n            \n            <div class=\"apgo-scope-modal-note\" id=\"modalNote\" style=\"display: none;\">\n                <!-- 注意事項 -->\n            </div>\n        </div>\n    </div>\n\n    <script>\n        // 處理汽車類別點擊\n        function handleCarScope() {\n            const details = {\n                title: '汽車完整適用材質',\n                subtitle: '適用於各種汽車表面材質',\n                items: [\n                    '所有車身鈑金',\n                    '汽車玻璃（包括前檔風玻璃）',\n                    '後照鏡',\n                    '塑膠件',\n                    '鍍鉻件',\n                    '鋁圈（包括陽極處理）',\n                    '鋼琴烤漆',\n                    '防刮材質'\n                ]\n            };\n            showScopeModal(details);\n        }\n\n        // 處理機車類別點擊\n        function handleMotoScope() {\n            const details = {\n                title: '機車完整適用材質',\n                subtitle: '適用於各種機車表面材質',\n                items: [\n                    '所有車殼',\n                    '儀表板',\n                    '後照鏡',\n                    '防刮材質',\n                    '鋁圈',\n                    '前後土除',\n                    '擋泥板',\n                    '排氣管防燙蓋'\n                ]\n            };\n            showScopeModal(details);\n        }\n\n        // 處理改色膜點擊\n        function handleWrapScope() {\n            const details = {\n                title: '改色包膜完整適用類型',\n                subtitle: '適用於各式膜料表面',\n                items: [\n                    '犀牛皮（PPF保護膜）',\n                    '改色膜',\n                    '車身彩貼膜',\n                    '碳纖維膜',\n                    '電鍍膜',\n                    '消光膜',\n                    '亮光膜',\n                    '緞面膜',\n                    '拉絲膜',\n                    '變色龍膜',\n                    '隱形車衣',\n                    '局部保護膜'\n                ],\n                note: '注意：施工前確保膜料已完全貼合'\n            };\n            showScopeModal(details);\n        }\n\n        // 顯示彈窗\n        function showScopeModal(details) {\n            const modal = document.getElementById('apgoScopeModal');\n            const modalTitle = document.getElementById('modalTitle');\n            const modalSubtitle = document.getElementById('modalSubtitle');\n            const modalList = document.getElementById('modalList');\n            const modalNote = document.getElementById('modalNote');\n            \n            // 設置標題\n            modalTitle.textContent = details.title;\n            modalSubtitle.textContent = details.subtitle;\n            \n            // 生成列表\n            modalList.innerHTML = details.items.map(item => \n                `<div class=\"apgo-scope-modal-item\">${item}</div>`\n            ).join('');\n            \n            // 設置注意事項\n            if (details.note) {\n                modalNote.textContent = details.note;\n                modalNote.style.display = 'block';\n            } else {\n                modalNote.style.display = 'none';\n            }\n            \n            // 顯示彈窗\n            modal.classList.add('apgo-scope-show');\n            document.body.style.overflow = 'hidden';\n            \n            // 聚焦到彈窗以提升無障礙性\n            modal.focus();\n        }\n\n        // 關閉彈窗\n        function closeScopeModal() {\n            const modal = document.getElementById('apgoScopeModal');\n            modal.classList.remove('apgo-scope-show');\n            document.body.style.overflow = 'auto';\n        }\n\n        // 點擊彈窗外部關閉\n        document.getElementById('apgoScopeModal').addEventListener('click', function(e) {\n            if (e.target === this) {\n                closeScopeModal();\n            }\n        });\n\n        // ESC 鍵關閉彈窗\n        document.addEventListener('keydown', function(e) {\n            if (e.key === 'Escape') {\n                closeScopeModal();\n            }\n        });\n\n        // 監聽橫向滾動\n        const scrollContainer = document.querySelector('.apgo-scope-categories-row');\n        if (scrollContainer) {\n            scrollContainer.addEventListener('scroll', function() {\n                const scrollHint = document.querySelector('.apgo-scope-scroll-hint');\n                if (scrollHint) {\n                    // 滾動後隱藏提示\n                    if (this.scrollLeft > 50) {\n                        scrollHint.style.opacity = '0';\n                    } else {\n                        scrollHint.style.opacity = '0.7';\n                    }\n                }\n            });\n        }\n\n        // 觸控優化\n        document.querySelectorAll('.apgo-scope-category-card').forEach(card => {\n            card.addEventListener('touchstart', function() {\n                this.style.transform = 'scale(0.98)';\n            });\n            \n            card.addEventListener('touchend', function() {\n                this.style.transform = 'scale(1)';\n            });\n        });\n    </script>\n</body>\n</html>",
        "color_scheme": "scheme-a27d2d12-7174-40fe-a01c-a128174b4c26",
        "section_width": "full-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
