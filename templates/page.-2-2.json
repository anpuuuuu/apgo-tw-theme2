      "name": "30秒快速挑選合適的鍍膜",
      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"zh-TW\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>選購原子系列鍍膜頁-30秒快速挑選區塊</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        :root {\n            --primary-orange: #f08418;\n            --secondary-orange: #ff9a3c;\n            --text-white: #ffffff;\n            --text-gray: #cccccc;\n            --text-light-gray: #b0b0b0;\n            --dark-bg: #000000;\n            --card-bg: rgba(255, 255, 255, 0.03);\n        }\n\n        body {\n            font-family: 'Arial', 'Microsoft JhengHei', sans-serif;\n            background: var(--dark-bg);\n            color: var(--text-white);\n            overflow-x: hidden;\n        }\n\n        /* === 統一字體規範 === */\n        /* H2 - 區塊主標題 */\n        h2, .h2 {\n            font-size: 2rem;\n            font-weight: 600;\n            color: var(--text-white);\n            line-height: 1.3;\n            margin: 0;\n        }\n\n        /* H4 - 選項卡片標題 */\n        h4, .h4 {\n            font-size: 1.2rem;\n            font-weight: 600;\n            color: var(--text-white);\n            line-height: 1.3;\n            margin: 0;\n        }\n\n        /* 副文字說明 */\n        .text-secondary {\n            font-size: 0.9rem;\n            color: var(--text-gray);\n            line-height: 1.5;\n            font-weight: 400;\n        }\n\n        /* 小文字/標籤 */\n        .text-small {\n            font-size: 0.8rem;\n            color: var(--text-light-gray);\n            line-height: 1.4;\n            font-weight: 400;\n        }\n\n        /* 極小文字 */\n        .text-tiny {\n            font-size: 0.75rem;\n            color: var(--text-light-gray);\n            line-height: 1.3;\n            font-weight: 400;\n        }\n\n        /* 按鈕文字 */\n        .button-text {\n            font-size: 1rem;\n            font-weight: 600;\n            color: var(--text-white);\n        }\n\n        /* === 快速導購區塊 === */\n        .quick-guide-section {\n            background: var(--dark-bg);\n            padding: 40px 0 35px 0;\n            position: relative;\n            overflow: hidden;\n            border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n        }\n\n        /* 背景動態效果 */\n        .quick-guide-section::before {\n            content: '';\n            position: absolute;\n            top: -50%;\n            right: -30%;\n            width: 150%;\n            height: 200%;\n            background: radial-gradient(circle, rgba(240, 132, 24, 0.06) 0%, transparent 60%);\n            animation: guide-float-glow 12s ease-in-out infinite;\n            pointer-events: none;\n        }\n\n        @keyframes guide-float-glow {\n            0%, 100% { \n                transform: scale(1) rotate(0deg);\n                opacity: 0.5;\n            }\n            50% { \n                transform: scale(1.05) rotate(3deg);\n                opacity: 0.8;\n            }\n        }\n\n        .guide-container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 0 20px;\n            text-align: left;\n            position: relative;\n            z-index: 1;\n        }\n\n        /* 標題區域 */\n        .guide-header {\n            margin-bottom: 25px;\n            opacity: 0;\n            transform: translateY(15px);\n            animation: guide-fadeInUp 0.6s ease forwards;\n        }\n\n        @keyframes guide-fadeInUp {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        .guide-title {\n            /* 使用統一的 H2 樣式 */\n            margin-bottom: 8px;\n            color: var(--primary-orange);\n        }\n\n        .guide-subtitle {\n            /* 使用統一的副文字樣式 */\n            margin-bottom: 25px;\n        }\n\n        /* 橫向滾動選項容器 */\n        .guide-options {\n            display: flex;\n            gap: 15px;\n            overflow-x: auto;\n            overflow-y: hidden;\n            padding: 12px 0 18px 0;\n            scroll-behavior: smooth;\n            -webkit-overflow-scrolling: touch;\n            scrollbar-width: thin;\n            scrollbar-color: var(--primary-orange) rgba(255, 255, 255, 0.1);\n        }\n\n        /* 滾動條樣式 */\n        .guide-options::-webkit-scrollbar {\n            height: 4px;\n        }\n\n        .guide-options::-webkit-scrollbar-track {\n            background: rgba(255, 255, 255, 0.1);\n            border-radius: 2px;\n        }\n\n        .guide-options::-webkit-scrollbar-thumb {\n            background: var(--primary-orange);\n            border-radius: 2px;\n            transition: background 0.3s ease;\n        }\n\n        .guide-options::-webkit-scrollbar-thumb:hover {\n            background: var(--secondary-orange);\n        }\n\n        /* 選項卡片 */\n        .guide-option {\n            flex: 0 0 auto;\n            min-width: 180px;\n            background: rgba(255, 255, 255, 0.04);\n            backdrop-filter: blur(20px);\n            border-radius: 12px;\n            padding: 18px 15px;\n            border: 1px solid rgba(255, 255, 255, 0.08);\n            cursor: pointer;\n            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);\n            position: relative;\n            overflow: hidden;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: guide-slideUp 0.5s ease forwards;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            text-align: center;\n            height: 110px;\n        }\n\n        .guide-option:nth-child(1) { animation-delay: 0.1s; }\n        .guide-option:nth-child(2) { animation-delay: 0.15s; }\n        .guide-option:nth-child(3) { animation-delay: 0.2s; }\n        .guide-option:nth-child(4) { animation-delay: 0.25s; }\n\n        @keyframes guide-slideUp {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        /* 懸停效果 */\n        .guide-option:hover {\n            transform: translateY(-4px);\n            border-color: var(--primary-orange);\n            background: rgba(240, 132, 24, 0.12);\n            box-shadow: \n                0 8px 20px rgba(240, 132, 24, 0.25),\n                0 0 0 1px rgba(240, 132, 24, 0.3);\n        }\n\n        .guide-option:hover::before {\n            opacity: 1;\n        }\n\n        /* 光效背景 */\n        .guide-option::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            background: linear-gradient(135deg, \n                rgba(240, 132, 24, 0.1) 0%, \n                rgba(255, 154, 60, 0.05) 50%, \n                transparent 100%);\n            opacity: 0;\n            transition: opacity 0.3s ease;\n            border-radius: 12px;\n        }\n\n        /* 圖標樣式 */\n        .guide-icon {\n            /* 使用統一的極小文字樣式 */\n            font-weight: bold;\n            margin-bottom: 8px;\n            transition: all 0.3s ease;\n            opacity: 0.8;\n            position: relative;\n            z-index: 2;\n            color: var(--primary-orange);\n            background: rgba(240, 132, 24, 0.1);\n            padding: 4px 8px;\n            border-radius: 8px;\n            border: 1px solid rgba(240, 132, 24, 0.2);\n            letter-spacing: 0.5px;\n        }\n\n        .guide-option:hover .guide-icon {\n            transform: scale(1.05);\n            opacity: 1;\n            background: rgba(240, 132, 24, 0.2);\n            border-color: var(--primary-orange);\n            box-shadow: 0 2px 8px rgba(240, 132, 24, 0.3);\n        }\n\n        /* 選項標題 */\n        .guide-option-title {\n            /* 使用統一的 H4 樣式 */\n            margin-bottom: 6px;\n            transition: all 0.3s ease;\n            position: relative;\n            z-index: 2;\n        }\n\n        .guide-option:hover .guide-option-title {\n            color: var(--primary-orange);\n            text-shadow: 0 1px 4px rgba(240, 132, 24, 0.3);\n        }\n\n        /* 描述文字 */\n        .guide-option-description {\n            /* 使用統一的小文字樣式 */\n            line-height: 1.3;\n            transition: all 0.3s ease;\n            position: relative;\n            z-index: 2;\n        }\n\n        .guide-option:hover .guide-option-description {\n            color: #e0e0e0;\n        }\n\n        /* === 推薦結果彈窗 === */\n        .guide-modal {\n            position: fixed;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: rgba(0, 0, 0, 0.85);\n            backdrop-filter: blur(10px);\n            display: none;\n            align-items: center;\n            justify-content: center;\n            z-index: 1000;\n            opacity: 0;\n            transition: all 0.3s ease;\n        }\n\n        .guide-modal.show {\n            display: flex;\n            opacity: 1;\n        }\n\n        .modal-content {\n            background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);\n            border-radius: 20px;\n            padding: 40px 30px;\n            max-width: 450px;\n            width: 90%;\n            border: 1px solid rgba(240, 132, 24, 0.3);\n            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.7);\n            transform: scale(0.9);\n            transition: all 0.3s ease;\n            text-align: center;\n            position: relative;\n            overflow: hidden;\n        }\n\n        .guide-modal.show .modal-content {\n            transform: scale(1);\n        }\n\n        /* 關閉按鈕 */\n        .close-modal {\n            position: absolute;\n            top: 15px;\n            right: 15px;\n            background: rgba(255, 255, 255, 0.1);\n            border: none;\n            color: var(--text-gray);\n            font-size: 1.5rem;\n            width: 35px;\n            height: 35px;\n            border-radius: 50%;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n        }\n\n        .close-modal:hover {\n            background: var(--primary-orange);\n            color: white;\n            transform: rotate(90deg);\n        }\n\n        /* 推薦內容 */\n        .recommendation-header {\n            margin-bottom: 25px;\n        }\n\n        .recommendation-title {\n            /* 使用統一的 H2 樣式，但尺寸稍小 */\n            font-size: 1.5rem;\n            color: var(--primary-orange);\n            margin-bottom: 10px;\n            font-weight: 600;\n        }\n\n        .recommendation-subtitle {\n            /* 使用統一的副文字樣式 */\n        }\n\n        .recommended-product {\n            background: rgba(255, 255, 255, 0.05);\n            border-radius: 15px;\n            padding: 20px;\n            margin-bottom: 20px;\n            border: 1px solid rgba(240, 132, 24, 0.2);\n        }\n\n        .product-name {\n            /* 使用統一的 H4 樣式 */\n            margin-bottom: 8px;\n            font-weight: 600;\n        }\n\n        .product-highlight {\n            color: var(--primary-orange);\n            /* 使用統一的小文字樣式 */\n            margin-bottom: 10px;\n            font-weight: 600;\n        }\n\n        .product-reason {\n            /* 使用統一的副文字樣式 */\n            line-height: 1.5;\n        }\n\n        .view-product-btn {\n            background: linear-gradient(45deg, var(--primary-orange), var(--secondary-orange));\n            color: white;\n            border: none;\n            padding: 12px 30px;\n            border-radius: 25px;\n            /* 使用統一的按鈕文字樣式 */\n            cursor: pointer;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 15px rgba(240, 132, 24, 0.3);\n        }\n\n        .view-product-btn:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 6px 20px rgba(240, 132, 24, 0.4);\n        }\n\n        /* === 響應式設計 === */\n        @media (max-width: 1024px) {\n            .guide-options {\n                gap: 12px;\n            }\n            \n            .guide-option {\n                min-width: 160px;\n                padding: 16px 12px;\n                height: 100px;\n            }\n        }\n\n        @media (max-width: 768px) {\n            /* H2 手機版調整 */\n            h2, .h2 {\n                font-size: 1.6rem;\n            }\n\n            /* H4 手機版調整 */\n            h4, .h4 {\n                font-size: 1.1rem;\n            }\n\n            /* 其他文字手機版調整 */\n            .text-secondary {\n                font-size: 0.85rem;\n            }\n\n            .text-small {\n                font-size: 0.75rem;\n            }\n\n            .text-tiny {\n                font-size: 0.7rem;\n            }\n\n            .button-text {\n                font-size: 0.9rem;\n            }\n\n            /* 區塊間距調整 */\n            .quick-guide-section {\n                padding: 30px 0 25px 0;\n            }\n\n            .guide-container {\n                padding: 0 16px;\n            }\n\n            .guide-header {\n                margin-bottom: 20px;\n            }\n\n            .guide-subtitle {\n                margin-bottom: 20px;\n            }\n\n            .guide-options {\n                gap: 10px;\n                padding: 10px 0 15px 0;\n            }\n\n            .guide-option {\n                min-width: 140px;\n                padding: 14px 10px;\n                height: 90px;\n            }\n\n            .modal-content {\n                padding: 25px 18px;\n                margin: 0 12px;\n            }\n\n            .recommendation-title {\n                font-size: 1.2rem;\n            }\n        }\n\n        @media (max-width: 480px) {\n            /* 極小螢幕調整 */\n            h2, .h2 {\n                font-size: 1.4rem;\n            }\n\n            h4, .h4 {\n                font-size: 1rem;\n            }\n\n            .text-secondary {\n                font-size: 0.8rem;\n            }\n\n            .text-small {\n                font-size: 0.7rem;\n            }\n\n            .text-tiny {\n                font-size: 0.65rem;\n            }\n\n            .button-text {\n                font-size: 0.85rem;\n            }\n\n            .guide-options {\n                gap: 8px;\n            }\n\n            .guide-option {\n                min-width: 130px;\n                padding: 12px 8px;\n                height: 85px;\n            }\n        }\n\n        /* === 無障礙設計 === */\n        .guide-option:focus {\n            outline: 2px solid var(--primary-orange);\n            outline-offset: 2px;\n        }\n\n        /* 高對比模式支援 */\n        @media (prefers-contrast: high) {\n            .guide-option {\n                border: 1px solid var(--text-gray);\n            }\n            \n            .guide-option:hover {\n                border-color: var(--primary-orange);\n                background: rgba(240, 132, 24, 0.2);\n            }\n        }\n\n        /* 減少動畫模式支援 */\n        @media (prefers-reduced-motion: reduce) {\n            .guide-option,\n            .guide-option-title,\n            .guide-option-description,\n            .guide-icon {\n                transition: none;\n                animation: none;\n            }\n            \n            .guide-option:hover {\n                transform: none;\n            }\n            \n            .quick-guide-section::before {\n                animation: none;\n            }\n        }\n\n        /* === 結構化資料支援 === */\n        .sr-only {\n            position: absolute;\n            width: 1px;\n            height: 1px;\n            padding: 0;\n            margin: -1px;\n            overflow: hidden;\n            clip: rect(0, 0, 0, 0);\n            white-space: nowrap;\n            border: 0;\n        }\n    </style>\n</head>\n<body>\n    <!-- 快速導購區塊 -->\n    <section class=\"quick-guide-section\" role=\"region\" aria-labelledby=\"guide-title\">\n        <div class=\"guide-container\">\n            <header class=\"guide-header\">\n                <h2 id=\"guide-title\" class=\"guide-title\">30秒快速挑選合適的鍍膜</h2>\n                <p class=\"guide-subtitle text-secondary\">告訴我們您的需求，為您推薦最適合的鍍膜產品</p>\n            </header>\n            \n            <div class=\"guide-options\" role=\"group\" aria-label=\"鍍膜需求選項\">\n                <button class=\"guide-option\" \n                        data-type=\"new\" \n                        role=\"button\" \n                        aria-label=\"選擇新車保護方案\"\n                        tabindex=\"0\">\n                    <div class=\"guide-icon text-tiny\">NEW</div>\n                    <h4 class=\"guide-option-title\">新車保護</h4>\n                    <p class=\"guide-option-description text-small\">剛購買的新車，想要最佳保護</p>\n                </button>\n\n                <button class=\"guide-option\" \n                        data-type=\"old\" \n                        role=\"button\" \n                        aria-label=\"選擇舊車翻新方案\"\n                        tabindex=\"0\">\n                    <div class=\"guide-icon text-tiny\">SHINE</div>\n                    <h4 class=\"guide-option-title\">舊車翻新</h4>\n                    <p class=\"guide-option-description text-small\">使用一段時間，想要恢復光澤</p>\n                </button>\n\n                <button class=\"guide-option\" \n                        data-type=\"diy\" \n                        role=\"button\" \n                        aria-label=\"選擇DIY新手方案\"\n                        tabindex=\"0\">\n                    <div class=\"guide-icon text-tiny\">DIY</div>\n                    <h4 class=\"guide-option-title\">DIY新手</h4>\n                    <p class=\"guide-option-description text-small\">第一次自己施工，需要簡單易用</p>\n                </button>\n\n                <button class=\"guide-option\" \n                        data-type=\"pro\" \n                        role=\"button\" \n                        aria-label=\"選擇專業需求方案\"\n                        tabindex=\"0\">\n                    <div class=\"guide-icon text-tiny\">PRO</div>\n                    <h4 class=\"guide-option-title\">專業需求</h4>\n                    <p class=\"guide-option-description text-small\">追求最高等級的保護效果</p>\n                </button>\n            </div>\n        </div>\n    </section>\n\n    <!-- 推薦結果彈窗 -->\n    <div class=\"guide-modal\" id=\"guideModal\" role=\"dialog\" aria-labelledby=\"modal-title\" aria-hidden=\"true\">\n        <div class=\"modal-content\">\n            <button class=\"close-modal\" onclick=\"closeRecommendation()\" aria-label=\"關閉推薦視窗\">×</button>\n            \n            <header class=\"recommendation-header\">\n                <h3 id=\"modal-title\" class=\"recommendation-title\">為您推薦</h3>\n                <p class=\"recommendation-subtitle text-secondary\">根據您的需求，我們推薦以下產品</p>\n            </header>\n            \n            <div id=\"recommendedProduct\" class=\"recommended-product\">\n                <!-- 動態內容將在這裡填入 -->\n            </div>\n            \n            <button class=\"view-product-btn button-text\" onclick=\"scrollToProducts()\">查看產品詳情</button>\n        </div>\n    </div>\n\n    <script>\n        // 推薦產品數據\n        const recommendations = {\n            new: {\n                name: '鈦晶鍍膜',\n                reason: '新車需要最高等級的保護，鈦晶鍍膜提供180天持久保護，硬度和疏水性都是頂級水準，是新車的最佳選擇。',\n                highlight: '頂級保護 · 180天持久'\n            },\n            old: {\n                name: '原子極光鍍膜',\n                reason: '極光鍍膜專為恢復光澤設計，能有效改善舊車漆面，重現車輛原有的亮麗光澤，讓愛車煥然一新。',\n                highlight: '光澤復原 · 150天效果'\n            },\n            diy: {\n                name: '原子鍍膜',\n                reason: '操作簡單、價格親民，是DIY新手的理想選擇。即使沒有經驗也能輕鬆上手，享受自己動手的樂趣。',\n                highlight: '簡單易用 · 新手友善'\n            },\n            pro: {\n                name: '鈦晶鍍膜 或 原子極光鍍膜',\n                reason: '專業需求建議選擇鈦晶鍍膜的極致保護，或原子極光鍍膜的卓越光澤效果，兩款都能滿足專業級要求。',\n                highlight: '專業首選 · 頂級效果'\n            }\n        };\n\n        // 初始化導購選項\n        function initGuideOptions() {\n            const options = document.querySelectorAll('.guide-option');\n            \n            options.forEach(option => {\n                // 點擊事件\n                option.addEventListener('click', function() {\n                    handleOptionSelection(this);\n                });\n\n                // 鍵盤事件\n                option.addEventListener('keydown', function(e) {\n                    if (e.key === 'Enter' || e.key === ' ') {\n                        e.preventDefault();\n                        handleOptionSelection(this);\n                    }\n                });\n            });\n        }\n\n        // 處理選項選擇\n        function handleOptionSelection(element) {\n            const type = element.dataset.type;\n            \n            // 添加視覺回饋\n            if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {\n                element.style.transform = 'translateY(-6px) scale(0.98)';\n                setTimeout(() => {\n                    element.style.transform = '';\n                }, 200);\n            }\n            \n            // 顯示推薦結果\n            showRecommendation(type);\n            \n            // 發送分析事件 (如果有 GA)\n            if (typeof gtag !== 'undefined') {\n                gtag('event', 'guide_option_click', {\n                    'option_type': type,\n                    'event_category': 'user_interaction'\n                });\n            }\n        }\n\n        // 顯示推薦結果\n        function showRecommendation(type) {\n            const modal = document.getElementById('guideModal');\n            const productDiv = document.getElementById('recommendedProduct');\n            const recommendation = recommendations[type];\n            \n            if (!recommendation) {\n                console.error('找不到對應的推薦產品');\n                return;\n            }\n            \n            productDiv.innerHTML = `\n                <div class=\"product-name\">${recommendation.name}</div>\n                <div class=\"product-highlight text-small\">\n                    ${recommendation.highlight}\n                </div>\n                <div class=\"product-reason text-secondary\">${recommendation.reason}</div>\n            `;\n            \n            modal.classList.add('show');\n            modal.setAttribute('aria-hidden', 'false');\n            \n            // 防止背景滾動\n            document.body.style.overflow = 'hidden';\n            \n            // 焦點管理\n            const firstFocusable = modal.querySelector('.close-modal');\n            if (firstFocusable) {\n                firstFocusable.focus();\n            }\n        }\n\n        // 關閉推薦彈窗\n        function closeRecommendation() {\n            const modal = document.getElementById('guideModal');\n            modal.classList.remove('show');\n            modal.setAttribute('aria-hidden', 'true');\n            document.body.style.overflow = 'auto';\n            \n            // 返回焦點到觸發元素\n            const lastClickedOption = document.querySelector('.guide-option:focus');\n            if (lastClickedOption) {\n                lastClickedOption.focus();\n            }\n        }\n\n        // 滾動到產品區域\n        function scrollToProducts() {\n            closeRecommendation();\n            \n            // 尋找產品區域的多種可能選擇器\n            const productSelectors = [\n                '.apgo-products-container',\n                '.coating-showcase',\n                '[class*=\"product\"]',\n                '#products',\n                '.products-section'\n            ];\n            \n            let productsSection = null;\n            for (const selector of productSelectors) {\n                productsSection = document.querySelector(selector);\n                if (productsSection) break;\n            }\n            \n            if (productsSection) {\n                // 計算滾動位置，考慮導航欄高度\n                const navHeight = document.querySelector('.quick-navigation-section')?.offsetHeight || 0;\n                const targetPosition = productsSection.offsetTop - navHeight - 20;\n                \n                window.scrollTo({\n                    top: targetPosition,\n                    behavior: 'smooth'\n                });\n            } else {\n                // 如果找不到產品區域，滾動到頁面適當位置\n                window.scrollTo({\n                    top: window.innerHeight,\n                    behavior: 'smooth'\n                });\n            }\n            \n            // 發送分析事件\n            if (typeof gtag !== 'undefined') {\n                gtag('event', 'view_products_click', {\n                    'event_category': 'navigation'\n                });\n            }\n        }\n\n        // 事件監聽器\n        function setupEventListeners() {\n            // 點擊彈窗外部關閉\n            document.getElementById('guideModal').addEventListener('click', function(e) {\n                if (e.target === this) {\n                    closeRecommendation();\n                }\n            });\n\n            // ESC 鍵關閉彈窗\n            document.addEventListener('keydown', function(e) {\n                if (e.key === 'Escape') {\n                    const modal = document.getElementById('guideModal');\n                    if (modal.classList.contains('show')) {\n                        closeRecommendation();\n                    }\n                }\n            });\n\n            // 鍵盤導航支援\n            document.addEventListener('keydown', function(e) {\n                const options = document.querySelectorAll('.guide-option');\n                const currentFocus = document.activeElement;\n                const currentIndex = Array.from(options).indexOf(currentFocus);\n\n                if (currentIndex !== -1) {\n                    if (e.key === 'ArrowLeft' && currentIndex > 0) {\n                        e.preventDefault();\n                        options[currentIndex - 1].focus();\n                    } else if (e.key === 'ArrowRight' && currentIndex < options.length - 1) {\n                        e.preventDefault();\n                        options[currentIndex + 1].focus();\n                    }\n                }\n            });\n        }\n\n        // DOM 載入完成後執行\n        document.addEventListener('DOMContentLoaded', function() {\n            initGuideOptions();\n            setupEventListeners();\n        });\n\n        // 觸控滑動支援（移動設備）\n        let touchStartX = 0;\n        let touchStartY = 0;\n        let isScrolling = false;\n\n        const optionsContainer = document.querySelector('.guide-options');\n        if (optionsContainer) {\n            optionsContainer.addEventListener('touchstart', function(e) {\n                touchStartX = e.touches[0].clientX;\n                touchStartY = e.touches[0].clientY;\n                isScrolling = false;\n            }, { passive: true });\n\n            optionsContainer.addEventListener('touchmove', function(e) {\n                if (!touchStartX || !touchStartY) return;\n\n                const touchEndX = e.touches[0].clientX;\n                const touchEndY = e.touches[0].clientY;\n                const diffX = Math.abs(touchStartX - touchEndX);\n                const diffY = Math.abs(touchStartY - touchEndY);\n\n                // 水平滾動優先\n                if (!isScrolling && diffX > diffY) {\n                    isScrolling = true;\n                    e.preventDefault();\n                }\n            }, { passive: false });\n        }\n    </script>\n</body>\n</html>",
        "color_scheme": "scheme-a27d2d12-7174-40fe-a01c-a128174b4c26",
        "section_width": "full-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
