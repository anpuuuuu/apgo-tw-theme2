v class=\"top-accent\"></div>\n<div class=\"product-label text-tiny\">濕上</div>\n<div class=\"main-content\">\n<div class=\"visual-area\">\n<img src=\"https://cdn.shopify.com/s/files/1/0760/8002/1755/files/0.png?v=1750764774\" alt=\"原子微晶鍍膜產品圖片\" />\n</div>\n<div class=\"info-section\">\n<div class=\"title-area\">\n<h3 class=\"product-title\">原子微晶鍍膜</h3>\n<p class=\"product-intro text-small\">微晶結構，細緻保護，提升表面細膩度。</p>\n</div>\n<div class=\"specs-section\">\n<div class=\"spec-item\">\n<div class=\"spec-row\">\n<span class=\"spec-label text-tiny\">持久度</span>\n<span class=\"spec-data text-small\">70天</span>\n</div>\n<div class=\"meter-bg\">\n<div class=\"meter-fill\" style=\"width: 38%\"></div>\n</div>\n</div>\n<div class=\"spec-item\">\n<div class=\"spec-row\">\n<span class=\"spec-label text-tiny\">疏水度</span>\n<span class=\"spec-data text-small\">70%</span>\n</div>\n<div class=\"meter-bg\">\n<div class=\"meter-fill\" style=\"width: 70%\"></div>\n</div>\n</div>\n<div class=\"spec-item\">\n<div class=\"spec-row\">\n<span class=\"spec-label text-tiny\">耐洗次數</span>\n<span class=\"spec-data text-small\">15+次</span>\n</div>\n<div class=\"meter-bg\">\n<div class=\"meter-fill\" style=\"width: 50%\"></div>\n</div>\n</div>\n<div class=\"spec-item\">\n<div class=\"spec-row\">\n<span class=\"spec-label text-tiny\">光澤度</span>\n<span class=\"spec-data text-small\">70分</span>\n</div>\n<div class=\"meter-bg\">\n<div class=\"meter-fill\" style=\"width: 70%\"></div>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"cta-section\">\n<div class=\"simple-cta\">\n<div class=\"price-display\">\n<span class=\"price-range text-secondary\">NT$550</span>\n</div>\n<button class=\"add-to-cart-btn button-text\" onclick=\"showCrystalVariantModal()\">挑選</button>\n</div>\n</div>\n</div>\n</article>\n<article class=\"product-item\">\n<div class=\"product-card sealant-style\">\n<div class=\"top-accent\"></div>\n<div class=\"product-label text-tiny\">濕上</div>\n<div class=\"main-content\">\n<div class=\"visual-area\">\n<img src=\"https://cdn.shopify.com/s/files/1/0760/8002/1755/files/0_55123166-7e3a-4d9a-ba89-c74055380a83.png?v=1750764774\" alt=\"原子封體鍍膜產品圖片\" />\n</div>\n<div class=\"info-section\">\n<div class=\"title-area\">\n<h3 class=\"product-title\">原子封體鍍膜</h3>\n<p class=\"product-intro text-small\">封體技術，長效保護車漆，防止氧化。</p>\n</div>\n<div class=\"specs-section\">\n<div class=\"spec-item\">\n<div class=\"spec-row\">\n<span class=\"spec-label text-tiny\">持久度</span>\n<span class=\"spec-data text-small\">70天</span>\n</div>\n<div class=\"meter-bg\">\n<div class=\"meter-fill\" style=\"width: 38%\"></div>\n</div>\n</div>\n<div class=\"spec-item\">\n<div class=\"spec-row\">\n<span class=\"spec-label text-tiny\">疏水度</span>\n<span class=\"spec-data text-small\">65%</span>\n</div>\n<div class=\"meter-bg\">\n<div class=\"meter-fill\" style=\"width: 65%\"></div>\n</div>\n</div>\n<div class=\"spec-item\">\n<div class=\"spec-row\">\n<span class=\"spec-label text-tiny\">耐洗次數</span>\n<span class=\"spec-data text-small\">10+次</span>\n</div>\n<div class=\"meter-bg\">\n<div class=\"meter-fill\" style=\"width: 33%\"></div>\n</div>\n</div>\n<div class=\"spec-item\">\n<div class=\"spec-row\">\n<span class=\"spec-label text-tiny\">光澤度</span>\n<span class=\"spec-data text-small\">80分</span>\n</div>\n<div class=\"meter-bg\">\n<div class=\"meter-fill\" style=\"width: 80%\"></div>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"cta-section\">\n<div class=\"simple-cta\">\n<div class=\"price-display\">\n<span class=\"price-range text-secondary\">NT$550</span>\n</div>\n<button class=\"add-to-cart-btn button-text\" onclick=\"showSealantVariantModal()\">挑選</button>\n</div>\n</div>\n</div>\n</article>\n<article class=\"product-item\">\n<div class=\"product-card basic-style\">\n<div class=\"top-accent\"></div>\n<div class=\"product-label text-tiny\">濕上</div>\n<div class=\"main-content\">\n<div class=\"visual-area\">\n<img src=\"https://cdn.shopify.com/s/files/1/0760/8002/1755/files/0_6be40b97-0127-463c-aa3f-22644fe177e4.png?v=1750764774\" alt=\"原子鍍膜產品圖片\" />\n</div>\n<div class=\"info-section\">\n<div class=\"title-area\">\n<h3 class=\"product-title\">原子鍍膜</h3>\n<p class=\"product-intro text-small\">經典原子鍍膜，基礎防護與亮澤效果。</p>\n</div>\n<div class=\"specs-section\">\n<div class=\"spec-item\">\n<div class=\"spec-row\">\n<span class=\"spec-label text-tiny\">持久度</span>\n<span class=\"spec-data text-small\">30天</span>\n</div>\n<div class=\"meter-bg\">\n<div class=\"meter-fill\" style=\"width: 16%\"></div>\n</div>\n</div>\n<div class=\"spec-item\">\n<div class=\"spec-row\">\n<span class=\"spec-label text-tiny\">疏水度</span>\n<span class=\"spec-data text-small\">40%</span>\n</div>\n<div class=\"meter-bg\">\n<div class=\"meter-fill\" style=\"width: 40%\"></div>\n</div>\n</div>\n<div class=\"spec-item\">\n<div class=\"spec-row\">\n<span class=\"spec-label text-tiny\">耐洗次數</span>\n<span class=\"spec-data text-small\">8+次</span>\n</div>\n<div class=\"meter-bg\">\n<div class=\"meter-fill\" style=\"width: 26%\"></div>\n</div>\n</div>\n<div class=\"spec-item\">\n<div class=\"spec-row\">\n<span class=\"spec-label text-tiny\">光澤度</span>\n<span class=\"spec-data text-small\">60分</span>\n</div>\n<div class=\"meter-bg\">\n<div class=\"meter-fill\" style=\"width: 60%\"></div>\n</div>\n</div>\n</div>\n</div>\n</div>\n<div class=\"cta-section\">\n<div class=\"simple-cta\">\n<div class=\"price-display\">\n<span class=\"price-range text-secondary\">NT$399</span>\n</div>\n<button class=\"add-to-cart-btn button-text\" onclick=\"showBasicVariantModal()\">挑選</button>\n</div>\n</div>\n</div>\n</article>\n</div>\n</section>\n\n<!-- 彈窗 -->\n<div class=\"apgo-variant-modal\" id=\"titaniumModal\">\n<div class=\"apgo-modal-overlay\" onclick=\"closeTitaniumModal()\"></div>\n<div class=\"apgo-modal-content\">\n<div class=\"apgo-modal-header\">\n<h3>選擇鈦晶鍍膜規格</h3>\n<button class=\"apgo-modal-close\" onclick=\"closeTitaniumModal()\">&times;</button>\n</div>\n<div class=\"apgo-modal-body\">\n<div class=\"apgo-variant-options\">\n<div class=\"apgo-variant-choice\" onclick='addToCartFromModal(47298258206971,1,\"鈦晶鍍膜 300ml\")'>\n<div class=\"apgo-choice-info\">\n<h4>鈦晶鍍膜 300ml</h4>\n<p>適合完整車輛施工，提供全面保護</p>\n</div>\n<div class=\"apgo-choice-price\">NT$1,880</div>\n</div>\n<div class=\"apgo-variant-choice\" onclick='addToCartFromModal(47325922918651,1,\"鈦晶鍍膜 30ml 試用組\")'>\n<div class=\"apgo-choice-info\">\n<h4>鈦晶鍍膜 30ml 試用組</h4>\n<p>體驗產品效果，適合小範圍測試</p>\n</div>\n<div class=\"apgo-choice-price\">NT$388</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"apgo-variant-modal\" id=\"auroraModal\">\n<div class=\"apgo-modal-overlay\" onclick=\"closeAuroraModal()\"></div>\n<div class=\"apgo-modal-content\">\n<div class=\"apgo-modal-header\">\n<h3>選擇原子極光鍍膜規格</h3>\n<button class=\"apgo-modal-close\" onclick=\"closeAuroraModal()\">&times;</button>\n</div>\n<div class=\"apgo-modal-body\">\n<div class=\"apgo-variant-options\">\n<div class=\"apgo-variant-choice\" onclick='addToCartFromModal(47326502322427,1,\"原子極光鍍膜\")'>\n<div class=\"apgo-choice-info\">\n<h4>原子極光鍍膜</h4>\n<p>極光般亮澤，強化表面防護，提升美觀</p>\n</div>\n<div class=\"apgo-choice-price\">NT$1,480</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"apgo-variant-modal\" id=\"glazeModal\">\n<div class=\"apgo-modal-overlay\" onclick=\"closeGlazeModal()\"></div>\n<div class=\"apgo-modal-content\">\n<div class=\"apgo-modal-header\">\n<h3>選擇原子釉鍍膜規格</h3>\n<button class=\"apgo-modal-close\" onclick=\"closeGlazeModal()\">&times;</button>\n</div>\n<div class=\"apgo-modal-body\">\n<div class=\"apgo-variant-options\">\n<div class=\"apgo-variant-choice\" onclick='addToCartFromModal(47326489936123,1,\"原子釉鍍膜 200ml\")'>\n<div class=\"apgo-choice-info\">\n<h4>原子釉鍍膜 200ml</h4>\n<p>標準容量，適合一般車輛使用</p>\n</div>\n<div class=\"apgo-choice-price\">NT$880</div>\n</div>\n<div class=\"apgo-variant-choice\" onclick='addToCartFromModal(47326489968891,1,\"原子釉鍍膜補充包 300ml\")'>\n<div class=\"apgo-choice-info\">\n<h4>原子釉鍍膜補充包 300ml</h4>\n<p>大容量補充包，更經濟實惠</p>\n</div>\n<div class=\"apgo-choice-price\">NT$880</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"apgo-variant-modal\" id=\"crystalModal\">\n<div class=\"apgo-modal-overlay\" onclick=\"closeCrystalModal()\"></div>\n<div class=\"apgo-modal-content\">\n<div class=\"apgo-modal-header\">\n<h3>選擇原子微晶鍍膜規格</h3>\n<button class=\"apgo-modal-close\" onclick=\"closeCrystalModal()\">&times;</button>\n</div>\n<div class=\"apgo-modal-body\">\n<div class=\"apgo-variant-options\">\n<div class=\"apgo-variant-choice\" onclick='addToCartFromModal(47326480040187,1,\"原子微晶鍍膜 300ml\")'>\n<div class=\"apgo-choice-info\">\n<h4>原子微晶鍍膜 300ml</h4>\n<p>標準容量，提供細緻保護效果</p>\n</div>\n<div class=\"apgo-choice-price\">NT$550</div>\n</div>\n<div class=\"apgo-variant-choice\" onclick='addToCartFromModal(47326480072955,1,\"原子微晶鍍膜補充包 300ml\")'>\n<div class=\"apgo-choice-info\">\n<h4>原子微晶鍍膜補充包 300ml</h4>\n<p>補充包裝，持續享受微晶保護</p>\n</div>\n<div class=\"apgo-choice-price\">NT$550</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"apgo-variant-modal\" id=\"sealantModal\">\n<div class=\"apgo-modal-overlay\" onclick=\"closeSealantModal()\"></div>\n<div class=\"apgo-modal-content\">\n<div class=\"apgo-modal-header\">\n<h3>選擇原子封體鍍膜規格</h3>\n<button class=\"apgo-modal-close\" onclick=\"closeSealantModal()\">&times;</button>\n</div>\n<div class=\"apgo-modal-body\">\n<div class=\"apgo-variant-options\">\n<div class=\"apgo-variant-choice\" onclick='addToCartFromModal(47326472076539,1,\"原子封體鍍膜 300ml\")'>\n<div class=\"apgo-choice-info\">\n<h4>原子封體鍍膜 300ml</h4>\n<p>標準容量，長效保護車漆</p>\n</div>\n<div class=\"apgo-choice-price\">NT$550</div>\n</div>\n<div class=\"apgo-variant-choice\" onclick='addToCartFromModal(47326472109307,1,\"原子封體鍍膜補充包 300ml\")'>\n<div class=\"apgo-choice-info\">\n<h4>原子封體鍍膜補充包 300ml</h4>\n<p>補充包裝，持續長效保護</p>\n</div>\n<div class=\"apgo-choice-price\">NT$550</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"apgo-variant-modal\" id=\"basicModal\">\n<div class=\"apgo-modal-overlay\" onclick=\"closeBasicModal()\"></div>\n<div class=\"apgo-modal-content\">\n<div class=\"apgo-modal-header\">\n<h3>選擇原子鍍膜規格</h3>\n<button class=\"apgo-modal-close\" onclick=\"closeBasicModal()\">&times;</button>\n</div>\n<div class=\"apgo-modal-body\">\n<div class=\"apgo-variant-options\">\n<div class=\"apgo-variant-choice\" onclick='addToCartFromModal(47293805986043,1,\"原子鍍膜 300ml\")'>\n<div class=\"apgo-choice-info\">\n<h4>原子鍍膜 300ml</h4>\n<p>經典原子鍍膜，基礎防護與亮澤效果</p>\n</div>\n<div class=\"apgo-choice-price\">NT$399</div>\n</div>\n</div>\n</div>\n</div>\n</div>\n\n<script>\n// ===== 購物車管理類別 =====\nclass APGOCartManager {\n  constructor() {\n    this.isAdding = false;\n    this.cartRoute = '/cart/add.js';\n    this.cartInfoRoute = '/cart.js';\n  }\n\n  async addToCart(variantId, quantity = 1, productName = '商品', properties = {}) {\n    if (this.isAdding) return;\n    \n    this.isAdding = true;\n    \n    // 構建請求數據 - 使用正確的單一商品格式\n    const cartData = {\n      id: parseInt(variantId),\n      quantity: quantity,\n      properties: {\n        '_source': '商品卡片',\n        '_timestamp': new Date().toISOString(),\n        ...properties\n      }\n    };\n\n    try {\n      // 使用標準 Shopify API 路徑\n      const response = await fetch(this.cartRoute, {\n        method: 'POST',\n        headers: {\n          'Content-Type': 'application/json',\n          'Accept': 'application/json'\n        },\n        body: JSON.stringify(cartData)\n      });\n\n      if (response.ok) {\n        const data = await response.json();\n        \n        // 只在用戶主動操作時顯示通知\n        this.showNotification(productName + ' 已成功加入購物車！', 'success');\n        this.updateCartUI(true); // 允許顯示通知\n        \n        // 觸發自定義事件\n        document.dispatchEvent(new CustomEvent('cart:item-added', {\n          detail: { item: data, product: productName }\n        }));\n        \n        // Google Analytics 事件\n        if (typeof gtag !== 'undefined') {\n          gtag('event', 'add_to_cart', {\n            'currency': 'TWD',\n            'value': data.price / 100,\n            'items': [{\n              'item_id': variantId,\n              'item_name': productName,\n              'quantity': quantity\n            }]\n          });\n        }\n        \n        return { success: true, data: data };\n      } else {\n        const error = await response.json();\n        throw new Error(this.parseErrorMessage(error));\n      }\n      \n    } catch (error) {\n      console.error('Add to cart error:', error);\n      this.showNotification(error.message || '加入購物車失敗，請稍後再試', 'error');\n      return { success: false, error: error.message };\n    } finally {\n      this.isAdding = false;\n    }\n  }\n\n  parseErrorMessage(errorData) {\n    const message = errorData.description || '';\n    \n    if (message.includes('out of stock') || message.includes('sold out')) {\n      return '商品庫存不足，無法加入購物車';\n    } else if (message.includes('invalid')) {\n      return '商品選項無效，請重新選擇';\n    } else if (message.includes('limit')) {\n      return '超出購買數量限制';\n    }\n    \n    return message || '加入購物車失敗';\n  }\n\n  showNotification(message, type = 'info', autoShow = true) {\n    // 如果 autoShow 為 false，則不自動顯示通知（用於頁面載入時的靜默操作）\n    // 這適用於所有設備，包括手機版\n    if (!autoShow) return;\n    \n    // 移除現有通知\n    const existingNotification = document.querySelector('.apgo-notification');\n    if (existingNotification) {\n      existingNotification.remove();\n    }\n\n    const notification = document.createElement('div');\n    notification.className = 'apgo-notification ' + type;\n    \n    const isSuccess = type === 'success';\n    notification.innerHTML = `\n      <div class=\"apgo-notification-content\">\n        <div class=\"apgo-notification-message\">${message}</div>\n        ${isSuccess ? `<a href=\"/cart\" class=\"apgo-notification-link\">查看購物車</a>` : ''}\n      </div>\n      <button class=\"apgo-notification-close\" onclick=\"this.parentNode.remove()\">&times;</button>\n    `;\n\n    document.body.appendChild(notification);\n    \n    // 顯示動畫\n    setTimeout(() => {\n      notification.classList.add('show');\n    }, 100);\n    \n    // 自動隱藏\n    setTimeout(() => {\n      if (notification.parentNode) {\n        notification.classList.remove('show');\n        setTimeout(() => {\n          if (notification.parentNode) {\n            notification.remove();\n          }\n        }, 300);\n      }\n    }, 5000);\n  }\n\n  async updateCartUI(showNotifications = false) {\n    try {\n      const cart = await fetch(this.cartInfoRoute).then(response => response.json());\n      \n      // 更新購物車數量顯示\n      const cartCountElements = document.querySelectorAll('.cart-count, [data-cart-count]');\n      cartCountElements.forEach(element => {\n        element.textContent = cart.item_count;\n        element.style.display = cart.item_count > 0 ? 'block' : 'none';\n      });\n      \n      // 觸發購物車更新事件\n      document.dispatchEvent(new CustomEvent('cart:updated', { detail: cart }));\n      \n    } catch (error) {\n      console.error('Failed to update cart UI:', error);\n      // 只在允許顯示通知時才顯示錯誤訊息\n      if (showNotifications) {\n        this.showNotification('購物車更新失敗', 'error');\n      }\n    }\n  }\n}\n\n// 創建購物車管理實例\nconst cartManager = new APGOCartManager();\n\n// ===== 彈窗控制函數 =====\nfunction showTitaniumVariantModal() {\n  document.getElementById('titaniumModal').classList.add('show');\n  document.body.style.overflow = 'hidden';\n}\n\nfunction closeTitaniumModal() {\n  document.getElementById('titaniumModal').classList.remove('show');\n  document.body.style.overflow = 'auto';\n}\n\nfunction showAuroraVariantModal() {\n  document.getElementById('auroraModal').classList.add('show');\n  document.body.style.overflow = 'hidden';\n}\n\nfunction closeAuroraModal() {\n  document.getElementById('auroraModal').classList.remove('show');\n  document.body.style.overflow = 'auto';\n}\n\nfunction showGlazeVariantModal() {\n  document.getElementById('glazeModal').classList.add('show');\n  document.body.style.overflow = 'hidden';\n}\n\nfunction closeGlazeModal() {\n  document.getElementById('glazeModal').classList.remove('show');\n  document.body.style.overflow = 'auto';\n}\n\nfunction showCrystalVariantModal() {\n  document.getElementById('crystalModal').classList.add('show');\n  document.body.style.overflow = 'hidden';\n}\n\nfunction closeCrystalModal() {\n  document.getElementById('crystalModal').classList.remove('show');\n  document.body.style.overflow = 'auto';\n}\n\nfunction showSealantVariantModal() {\n  document.getElementById('sealantModal').classList.add('show');\n  document.body.style.overflow = 'hidden';\n}\n\nfunction closeSealantModal() {\n  document.getElementById('sealantModal').classList.remove('show');\n  document.body.style.overflow = 'auto';\n}\n\nfunction showBasicVariantModal() {\n  document.getElementById('basicModal').classList.add('show');\n  document.body.style.overflow = 'hidden';\n}\n\nfunction closeBasicModal() {\n  document.getElementById('basicModal').classList.remove('show');\n  document.body.style.overflow = 'auto';\n}\n\nfunction closeAllModals() {\n  closeTitaniumModal();\n  closeAuroraModal();\n  closeGlazeModal();\n  closeCrystalModal();\n  closeSealantModal();\n  closeBasicModal();\n}\n\n// ===== 從彈窗加入購物車函數 =====\nasync function addToCartFromModal(variantId, quantity, productName) {\n  const clickedChoice = event.currentTarget;\n  const originalContent = clickedChoice.innerHTML;\n  \n  // 防止重複點擊\n  if (clickedChoice.classList.contains('loading')) {\n    return;\n  }\n  \n  // 設置載入狀態 - 只在點擊後顯示\n  clickedChoice.classList.add('loading');\n  clickedChoice.style.opacity = '0.7';\n  clickedChoice.style.cursor = 'not-allowed';\n  clickedChoice.innerHTML = '<div>正在加入購物車...</div>';\n  \n  try {\n    const result = await cartManager.addToCart(variantId, quantity, productName);\n    \n    if (result.success) {\n      // 成功後關閉彈窗\n      closeAllModals();\n    }\n    \n  } catch (error) {\n    console.error('Modal add to cart error:', error);\n  } finally {\n    // 恢復原始狀態\n    clickedChoice.classList.remove('loading');\n    clickedChoice.style.opacity = '1';\n    clickedChoice.style.cursor = 'pointer';\n    clickedChoice.innerHTML = originalContent;\n  }\n}\n\n// ===== 滾動控制 =====\nfunction setupScrollControls() {\n  const carousel = document.querySelector('.carousel-wrapper');\n  if (!carousel) return;\n\n  // 滑鼠滾輪水平滾動\n  carousel.addEventListener('wheel', function(e) {\n    if (e.deltaY !== 0) {\n      e.preventDefault();\n      carousel.scrollLeft += e.deltaY;\n    }\n  });\n\n  // 滑鼠拖拽滾動\n  let isDown = false;\n  let startX;\n  let scrollLeft;\n\n  carousel.addEventListener('mousedown', (e) => {\n    isDown = true;\n    carousel.style.cursor = 'grabbing';\n    startX = e.pageX - carousel.offsetLeft;\n    scrollLeft = carousel.scrollLeft;\n  });\n\n  carousel.addEventListener('mouseleave', () => {\n    isDown = false;\n    carousel.style.cursor = 'grab';\n  });\n\n  carousel.addEventListener('mouseup', () => {\n    isDown = false;\n    carousel.style.cursor = 'grab';\n  });\n\n  carousel.addEventListener('mousemove', (e) => {\n    if (!isDown) return;\n    e.preventDefault();\n    const x = e.pageX - carousel.offsetLeft;\n    const walk = (x - startX) * 2;\n    carousel.scrollLeft = scrollLeft - walk;\n  });\n}\n\n// ===== 事件監聽設置 =====\nfunction setupEventListeners() {\n  // ESC 鍵關閉彈窗\n  document.addEventListener('keydown', function(e) {\n    if (e.key === 'Escape') {\n      closeAllModals();\n    }\n  });\n\n  // 點擊遮罩關閉彈窗\n  document.querySelectorAll('.apgo-modal-overlay').forEach(overlay => {\n    overlay.addEventListener('click', closeAllModals);\n  });\n}\n\n// ===== 初始化 =====\ndocument.addEventListener('DOMContentLoaded', function() {\n  setupScrollControls();\n  setupEventListeners();\n  \n  // 進度條動畫 - 延遲啟動避免干擾\n  setTimeout(() => {\n    const meterFills = document.querySelectorAll('.meter-fill');\n    meterFills.forEach(fill => {\n      const width = fill.style.width;\n      fill.style.width = '0%';\n      setTimeout(() => {\n        fill.style.width = width;\n      }, 100);\n    });\n  }, 500);\n\n  // 靜默更新購物車UI，在所有設備上都不顯示通知\n  cartManager.updateCartUI(false);\n});\n\n// 添加滾動樣式\nconst style = document.createElement('style');\nstyle.textContent = `\n  .carousel-wrapper {\n    cursor: grab;\n  }\n  .carousel-wrapper:active {\n    cursor: grabbing;\n  }\n`;\ndocument.head.appendChild(style);\n</script>\n</body>\n</html>",
