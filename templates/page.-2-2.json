      "settings": {
        "custom_liquid": "<style>\n/* CSS 變數 - 與您網站其他區塊保持一致 */\n:root {\n    --primary-orange: #f08418;\n    --secondary-orange: #ff9a3c;\n    --text-white: #ffffff;\n    --text-gray: #cccccc;\n    --text-light-gray: #b0b0b0;\n    --dark-bg: #000000;\n    --card-bg-light: rgba(255, 255, 255, 0.05); /* 更輕量的卡片背景 */\n    --card-border: rgba(255, 255, 255, 0.1); /* 卡片邊框 */\n}\n\n/* 只針對加購區塊內的元素重置樣式 */\n.add-on-section,\n.add-on-section * {\n    margin: 0;\n    padding: 0;\n    box-sizing: border-box;\n}\n\n/* 移除影響全域的樣式 */\n/* \nhtml {\n    scroll-behavior: smooth;\n}\nbody {\n    font-family: 'Inter', 'Noto Sans TC', sans-serif;\n    background: var(--dark-bg);\n    color: var(--text-white);\n}\n*/\n\n/* 只針對加購區塊的容器樣式 */\n.add-on-section .container {\n    max-width: 1200px;\n    margin: 0 auto;\n    padding: 0 20px;\n}\n\n/* === 統一字體規範 - 遵循您的規範文件 === */\n/* H1 - 頁面主標題（這裡用作區塊的最高級標題，但實際上頁面H1應唯一） */\n.add-on-section .h1-add-on {\n    font-size: 2.5rem;\n    font-weight: 700;\n    color: var(--primary-orange);\n    line-height: 1.2;\n    margin: 0;\n}\n/* H2 - 區塊主標題 */\n.add-on-section .h2-add-on {\n    font-size: 2rem;\n    font-weight: 600;\n    color: var(--text-white);\n    line-height: 1.3;\n    margin: 0;\n}\n/* H3 - 子區塊標題/產品名稱 */\n.add-on-section .h3-add-on {\n    font-size: 1.5rem;\n    font-weight: 600;\n    color: var(--text-white);\n    line-height: 1.3;\n    margin: 0;\n}\n/* 副文字說明 */\n.add-on-section .text-secondary-add-on {\n    font-size: 0.9rem;\n    color: var(--text-gray);\n    line-height: 1.5;\n    font-weight: 400;\n}\n/* 按鈕文字 */\n.add-on-section .button-text-add-on {\n    font-size: 1rem;\n    font-weight: 600;\n    color: var(--text-white);\n}\n/* 小文字 */\n.add-on-section .text-small-add-on {\n    font-size: 0.8rem;\n    color: var(--text-light-gray);\n    line-height: 1.4;\n    font-weight: 400;\n}\n\n/* 加購區塊整體樣式 */\n.add-on-section {\n    background: var(--dark-bg);\n    padding: 60px 0;\n    position: relative;\n    font-family: 'Inter', 'Noto Sans TC', sans-serif;\n    color: var(--text-white);\n}\n\n/* 主要標題區 */\n.add-on-section .add-on-header {\n    text-align: center;\n    margin-bottom: 40px;\n    padding: 0 20px;\n}\n.add-on-section .add-on-title {\n    /* 應用 h1-add-on 規範 */\n    font-size: 2.5rem;\n    font-weight: 700;\n    color: var(--primary-orange);\n    margin-bottom: 12px;\n    background: linear-gradient(45deg, var(--primary-orange), var(--secondary-orange));\n    -webkit-background-clip: text;\n    -webkit-text-fill-color: transparent;\n    background-clip: text;\n    letter-spacing: 0.05em;\n}\n.add-on-section .add-on-subtitle {\n    /* 應用 text-secondary-add-on 規範 */\n    font-size: 1.2rem; /* 稍大於 text-secondary-add-on, 接近 h5 */\n    color: var(--text-gray);\n    max-width: 700px;\n    margin: 0 auto;\n    line-height: 1.6;\n}\n.add-on-section .add-on-emphasis {\n    color: var(--primary-orange);\n    font-weight: bold;\n}\n\n/* 加購產品容器 */\n.add-on-section .add-on-products-wrapper {\n    padding-top: 20px;\n}\n.add-on-section .add-on-category-section {\n    margin-bottom: 40px;\n    position: relative;\n    overflow: hidden;\n}\n.add-on-section .add-on-category-header {\n    text-align: left;\n    margin-bottom: 30px;\n    padding: 0 20px;\n}\n.add-on-section .add-on-category-title {\n    /* 應用 h2-add-on 規範 */\n    font-size: 2rem;\n    font-weight: 600;\n    color: var(--text-white);\n    margin-bottom: 10px;\n}\n.add-on-section .add-on-category-subtitle {\n    /* 應用 text-secondary-add-on 規範 */\n    font-size: 0.95rem;\n    color: var(--text-light-gray);\n}\n\n/* 橫向滾動容器 */\n.add-on-section .horizontal-scroll-container {\n    display: flex;\n    overflow-x: auto;\n    overflow-y: hidden;\n    gap: 25px;\n    padding: 20px;\n    padding-bottom: 40px;\n    scroll-behavior: smooth;\n    -webkit-overflow-scrolling: touch;\n    scrollbar-width: thin;\n    scrollbar-color: var(--primary-orange) rgba(255, 255, 255, 0.1);\n    position: relative;\n    z-index: 1;\n}\n\n/* 滾動條美化 */\n.add-on-section .horizontal-scroll-container::-webkit-scrollbar {\n    height: 8px;\n}\n.add-on-section .horizontal-scroll-container::-webkit-scrollbar-track {\n    background: rgba(255, 255, 255, 0.1);\n    border-radius: 4px;\n}\n.add-on-section .horizontal-scroll-container::-webkit-scrollbar-thumb {\n    background: var(--primary-orange);\n    border-radius: 4px;\n    transition: background 0.3s ease;\n}\n.add-on-section .horizontal-scroll-container::-webkit-scrollbar-thumb:hover {\n    background: var(--secondary-orange);\n}\n\n/* 產品卡片 */\n.add-on-section .product-card {\n    flex-shrink: 0;\n    width: 320px;\n    background: var(--card-bg-light);\n    backdrop-filter: blur(10px);\n    border-radius: 16px;\n    border: 1px solid var(--card-border);\n    overflow: hidden;\n    transition: all 0.3s ease;\n    display: flex;\n    flex-direction: column;\n    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);\n    position: relative;\n}\n.add-on-section .product-card:hover {\n    transform: translateY(-8px);\n    border-color: var(--primary-orange);\n    box-shadow: 0 12px 30px rgba(240, 132, 24, 0.3);\n    background: rgba(240, 132, 24, 0.08);\n}\n.add-on-section .product-image-container {\n    background: rgba(255, 255, 255, 0.03);\n    padding: 20px;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    height: 200px;\n}\n.add-on-section .product-image {\n    max-height: 100%;\n    max-width: 100%;\n    object-fit: contain;\n}\n.add-on-section .product-content {\n    padding: 20px;\n    display: flex;\n    flex-direction: column;\n    flex-grow: 1;\n}\n.add-on-section .product-name {\n    /* 應用 h3-add-on 規範 */\n    font-size: 1.5rem;\n    font-weight: 600;\n    color: var(--text-white);\n    margin-bottom: 10px;\n    height: 40px;\n}\n.add-on-section .product-desc {\n    /* 應用 text-secondary-add-on 規範 */\n    font-size: 0.85rem;\n    color: var(--text-gray);\n    margin-bottom: 15px;\n    line-height: 1.5;\n    height: 50px;\n    overflow: hidden;\n    text-overflow: ellipsis;\n}\n.add-on-section .product-spec-select-wrapper {\n    margin-bottom: auto; /* 將選擇器推到上方，讓價格和按鈕在底部 */\n}\n.add-on-section .product-spec-select {\n    width: 100%;\n    padding: 12px;\n    font-size: 0.9rem;\n    border: 1px solid rgba(255, 255, 255, 0.2);\n    background: rgba(255, 255, 255, 0.1);\n    color: var(--text-white);\n    border-radius: 8px;\n    appearance: none;\n    background-image: url('data:image/svg+xml;charset=UTF-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20viewBox%3D%220%200%2020%2020%22%3E%3Cpath%20fill%3D%22%23cccccc%22%20d%3D%22M4.516%207.548c0.436-0.446%201.043-0.446%201.479%200l3.961%204.044%203.961-4.044c0.436-0.446%201.043-0.446%201.479%200s0.436%201.171%200%201.615l-4.706%204.807c-0.436%200.446-1.043%200.446-1.479%200l-4.706-4.807c-0.436-0.446-0.436-1.171%200-1.615z%22%3E%3C%2Fpath%3E%3C%2Fsvg%3E');\n    background-repeat: no-repeat;\n    background-position: right 12px center;\n    background-size: 12px;\n    outline: none;\n    transition: border-color 0.3s ease, box-shadow 0.3s ease;\n}\n.add-on-section .product-spec-select:focus {\n    border-color: var(--primary-orange);\n    box-shadow: 0 0 0 2px rgba(240, 132, 24, 0.4);\n}\n.add-on-section .product-spec-select option {\n    background-color: var(--dark-bg);\n    color: var(--text-white);\n}\n\n/* 價格區塊 - 調整為更低調的樣式 */\n.add-on-section .price-display-standalone {\n    text-align: left; /* 左對齊 */\n    margin-top: 10px; /* 與上方選擇器間距 */\n    margin-bottom: 15px; /* 與按鈕間距 */\n    padding-top: 8px; /* 確保與上方內容有足夠空間 */\n    border-top: 1px solid rgba(255, 255, 255, 0.05); /* 更細緻的分隔線 */\n}\n.add-on-section .price-display-standalone .price-value {\n    font-size: 1.2rem; /* 大幅縮小字體 */\n    font-weight: 500; /* 降低字重 */\n    color: var(--text-light-gray); /* 顏色更柔和 */\n    letter-spacing: normal; /* 移除自定義字距 */\n}\n\n/* 按鈕區塊 - 價格與按鈕現在分離 */\n.add-on-section .add-to-cart-button-wrapper {\n    margin-top: 0; /* 價格區塊已提供間距 */\n}\n.add-on-section .add-to-cart-btn {\n    display: block;\n    width: 100%;\n    padding: 14px 25px;\n    background: linear-gradient(45deg, var(--primary-orange), var(--secondary-orange));\n    color: var(--text-white);\n    text-decoration: none;\n    border: none;\n    border-radius: 10px;\n    cursor: pointer;\n    font-size: 1.05rem; /* 應用 button-text-add-on 規範 */\n    font-weight: 600;\n    transition: all 0.3s ease;\n    box-shadow: 0 4px 15px rgba(240, 132, 24, 0.3);\n    position: relative;\n    overflow: hidden;\n    text-align: center;\n    letter-spacing: 0.5px;\n}\n.add-on-section .add-to-cart-btn:hover {\n    transform: translateY(-3px);\n    box-shadow: 0 8px 25px rgba(240, 132, 24, 0.4);\n}\n.add-on-section .add-to-cart-btn.is-added {\n    background: linear-gradient(45deg, #4CAF50, #66BB6A); /* 綠色成功提示 */\n    box-shadow: 0 4px 15px rgba(76, 175, 80, 0.3);\n    cursor: default;\n}\n.add-on-section .add-to-cart-btn:disabled {\n    background: #666;\n    cursor: not-allowed;\n    transform: none;\n    box-shadow: none;\n    opacity: 0.7;\n}\n.add-on-section .add-to-cart-btn .btn-text, \n.add-on-section .add-to-cart-btn .btn-loader {\n    position: relative;\n    z-index: 1;\n}\n.add-on-section .add-to-cart-btn .btn-loader {\n    display: none;\n    margin: 0 auto;\n}\n.add-on-section .add-to-cart-btn .btn-loader .spinner {\n    display: inline-block;\n    width: 20px;\n    height: 20px;\n    border: 2px solid rgba(255, 255, 255, 0.3);\n    border-top-color: var(--text-white);\n    border-radius: 50%;\n    animation: add-on-spin 0.8s linear infinite;\n}\n@keyframes add-on-spin {\n    to { transform: rotate(360deg); }\n}\n\n/* 頁尾連結 */\n.add-on-section .add-on-footer {\n    text-align: center;\n    margin-top: 60px;\n    padding-bottom: 30px;\n}\n.add-on-section .add-on-footer-text {\n    /* 應用 text-secondary-add-on 規範 */\n    color: var(--text-gray);\n    font-size: 0.9rem;\n    margin-bottom: 10px;\n}\n.add-on-section .add-on-checkout-link {\n    display: inline-block;\n    color: var(--primary-orange);\n    font-weight: 600;\n    text-decoration: none;\n    font-size: 1.05rem; /* 應用 button-text-add-on 規範 */\n    transition: all 0.3s ease;\n    border-bottom: 2px solid transparent;\n}\n.add-on-section .add-on-checkout-link:hover {\n    color: var(--secondary-orange);\n    transform: translateX(5px);\n    border-color: var(--secondary-orange);\n}\n.add-on-section .add-on-checkout-link::after {\n    content: '→';\n    margin-left: 8px;\n    transition: margin-left 0.3s ease;\n}\n.add-on-section .add-on-checkout-link:hover::after {\n    margin-left: 12px;\n}\n\n/* 響應式設計 */\n@media (max-width: 768px) {\n    .add-on-section {\n        padding: 40px 0;\n    }\n    .add-on-section .add-on-title {\n        font-size: 2rem; /* 應用 h1-add-on 手機版規範 */\n    }\n    .add-on-section .add-on-subtitle {\n        font-size: 1rem; /* 應用 text-secondary-add-on 手機版規範 */\n    }\n    .add-on-section .add-on-header {\n        margin-bottom: 30px;\n    }\n    .add-on-section .add-on-category-title {\n        font-size: 1.6rem; /* 應用 h2-add-on 手機版規範 */\n    }\n    .add-on-section .add-on-category-subtitle {\n        font-size: 0.85rem; /* 應用 text-secondary-add-on 手機版規範 */\n    }\n    .add-on-section .add-on-category-section {\n        margin-bottom: 30px;\n    }\n    .add-on-section .horizontal-scroll-container {\n        gap: 15px;\n        padding: 15px;\n        padding-bottom: 30px;\n    }\n    .add-on-section .product-card {\n        width: 280px;\n        padding: 15px;\n    }\n    .add-on-section .product-image-container {\n        height: 180px;\n        padding: 15px;\n    }\n    .add-on-section .product-content {\n        padding: 15px;\n    }\n    .add-on-section .product-name {\n        font-size: 1.2rem; /* 應用 h3-add-on 手機版規範 */\n        height: auto;\n    }\n    .add-on-section .product-desc {\n        font-size: 0.8rem; /* 應用 text-small-add-on 手機版規範 */\n        height: auto;\n    }\n    .add-on-section .product-spec-select {\n        padding: 10px;\n        font-size: 0.85rem;\n    }\n    .add-on-section .price-display-standalone {\n        margin-top: 10px;\n        margin-bottom: 15px;\n    }\n    .add-on-section .price-display-standalone .price-value {\n        font-size: 1.2rem; /* 手機版價格 */\n    }\n    .add-on-section .add-to-cart-btn {\n        padding: 12px 20px;\n        font-size: 0.95rem; /* 應用 button-text-add-on 手機版規範 */\n    }\n    .add-on-section .add-on-footer {\n        margin-top: 40px;\n    }\n    .add-on-section .add-on-footer-text, \n    .add-on-section .add-on-checkout-link {\n        font-size: 0.85rem;\n    }\n}\n\n@media (max-width: 480px) {\n    .add-on-section .add-on-title {\n        font-size: 1.8rem; /* 應用 h1-add-on 極小螢幕規範 */\n    }\n    .add-on-section .add-on-subtitle {\n        font-size: 0.9rem; /* 應用 text-secondary-add-on 極小螢幕規範 */\n    }\n    .add-on-section .add-on-category-title {\n        font-size: 1.4rem; /* 應用 h2-add-on 極小螢幕規範 */\n    }\n    .add-on-section .product-card {\n        width: 250px;\n    }\n    .add-on-section .product-name {\n        font-size: 1.1rem; /* 應用 h3-add-on 極小螢幕規範 */\n    }\n    .add-on-section .product-desc {\n        font-size: 0.75rem; /* 應用 text-small-add-on 極小螢幕規範 */\n    }\n    .add-on-section .price-display-standalone .price-value {\n        font-size: 1.1rem; /* 極小螢幕價格 */\n    }\n}\n\n/* 螢幕閱讀器專用樣式 */\n.add-on-section .sr-only {\n    position: absolute;\n    width: 1px;\n    height: 1px;\n    padding: 0;\n    margin: -1px;\n    overflow: hidden;\n    clip: rect(0, 0, 0, 0);\n    white-space: nowrap;\n    border: 0;\n}\n</style>\n\n<script>\n// 確保 APGOCartManager 已定義在您的全域 JS 檔案中\n// 如果沒有，這裡提供一個簡易的替代品，但強烈建議您將 APGOCartManager 提取到全域 JS 檔案中\nif (typeof window.cartManager === 'undefined') {\n    console.warn(\"APGOCartManager is not defined. Providing a temporary fallback.\");\n    window.cartManager = {\n        async addToCart(variantId, quantity, productName, properties) {\n            console.log(`模擬加入購物車: ${productName}, ID: ${variantId}, 數量: ${quantity}, 屬性:`, properties);\n            // 模擬成功或失敗\n            return new Promise(resolve => {\n                setTimeout(() => {\n                    if (Math.random() > 0.1) { // 90% 成功\n                        resolve({ success: true, data: { product_title: productName, variant_id: variantId, quantity: quantity, price: 100 } });\n                    } else { // 10% 失敗\n                        resolve({ success: false, error: '模擬加入失敗' });\n                    }\n                }, 800); // 模擬網路延遲\n            });\n        },\n        showNotification(msg, type, autoShow) {\n            if (autoShow) {\n                // 這裡可以使用一個簡單的 alert 或更複雜的自定義通知UI\n                console.log(`通知 (${type}): ${msg}`);\n            }\n        },\n        updateCartUI() { console.log('模擬更新購物車UI'); }\n    };\n}\n\ndocument.addEventListener('DOMContentLoaded', () => {\n    const productCards = document.querySelectorAll('.product-card');\n    \n    productCards.forEach(card => {\n        const specSelect = card.querySelector('.product-spec-select');\n        const priceValueElement = card.querySelector('.price-value');\n        const addToCartBtn = card.querySelector('.add-to-cart-btn');\n        const btnText = addToCartBtn.querySelector('.btn-text');\n        const btnLoader = addToCartBtn.querySelector('.btn-loader');\n\n        function updatePriceAndVariantId() {\n            if (!specSelect) return;\n            const selectedOption = specSelect.options[specSelect.selectedIndex];\n            const price = selectedOption.dataset.price;\n            const variantId = selectedOption.dataset.variantId;\n            \n            if (priceValueElement) {\n                priceValueElement.textContent = `NT$ ${price}`;\n            }\n            addToCartBtn.dataset.variantId = variantId;\n        }\n\n        if (specSelect) {\n            specSelect.addEventListener('change', updatePriceAndVariantId);\n        }\n\n        if (addToCartBtn) {\n            addToCartBtn.addEventListener('click', async (e) => {\n                e.preventDefault();\n                \n                const currentText = btnText.textContent;\n                \n                if (addToCartBtn.disabled) return;\n\n                const variantId = addToCartBtn.dataset.variantId;\n                const quantity = 1;\n                const productName = specSelect.dataset.productName || card.querySelector('.product-name').textContent;\n                const selectedSpec = specSelect.options[specSelect.selectedIndex].value;\n\n                if (!variantId || variantId.includes('YOUR_VARIANT_ID_')) {\n                    cartManager.showNotification('請先更新產品變體ID', 'error', true);\n                    console.error('Variant ID is missing or placeholder for product:', productName);\n                    return;\n                }\n                \n                btnText.style.display = 'none';\n                btnLoader.style.display = 'block';\n                addToCartBtn.disabled = true;\n                addToCartBtn.style.background = 'linear-gradient(45deg, #666, #999)';\n                addToCartBtn.style.boxShadow = 'none';\n\n                try {\n                    const result = await cartManager.addToCart(variantId, quantity, productName, { '加購規格': selectedSpec });\n\n                    if (result.success) {\n                        btnText.textContent = '已加入！';\n                        addToCartBtn.classList.add('is-added');\n                        addToCartBtn.style.background = 'linear-gradient(45deg, #4CAF50, #66BB6A)';\n                        addToCartBtn.style.boxShadow = '0 4px 15px rgba(76, 175, 80, 0.3)';\n                    } else {\n                        btnText.textContent = '加入失敗';\n                        addToCartBtn.classList.remove('is-added');\n                        addToCartBtn.style.background = 'linear-gradient(45deg, #f44336, #e57373)';\n                        addToCartBtn.style.boxShadow = '0 4px 15px rgba(244, 67, 54, 0.3)';\n                    }\n                } catch (error) {\n                    btnText.textContent = '錯誤！';\n                    addToCartBtn.classList.remove('is-added');\n                    addToCartBtn.style.background = 'linear-gradient(45deg, #f44336, #e57373)';\n                    addToCartBtn.style.boxShadow = '0 4px 15px rgba(244, 67, 54, 0.3)';\n                    console.error('Add to cart error:', error);\n                } finally {\n                    btnLoader.style.display = 'none';\n                    btnText.style.display = 'block';\n                    setTimeout(() => {\n                        btnText.textContent = currentText;\n                        addToCartBtn.disabled = false;\n                        addToCartBtn.classList.remove('is-added');\n                        addToCartBtn.style.background = 'linear-gradient(45deg, var(--primary-orange), var(--secondary-orange))';\n                        addToCartBtn.style.boxShadow = '0 4px 15px rgba(240, 132, 24, 0.3)';\n                    }, 2000);\n                }\n            });\n        }\n\n        updatePriceAndVariantId();\n    });\n});\n\nfunction setupScrollControls() {\n    const carousels = document.querySelectorAll('.horizontal-scroll-container');\n    carousels.forEach(carousel => {\n        carousel.addEventListener('wheel', function(e) {\n            if (e.deltaY !== 0) {\n                e.preventDefault();\n                carousel.scrollLeft += e.deltaY;\n            }\n        }, { passive: false });\n\n        let isDown = false;\n        let startX;\n        let scrollLeft;\n\n        carousel.addEventListener('mousedown', (e) => {\n            isDown = true;\n            carousel.style.cursor = 'grabbing';\n            startX = e.pageX - carousel.offsetLeft;\n            scrollLeft = carousel.scrollLeft;\n        });\n\n        carousel.addEventListener('mouseleave', () => {\n            isDown = false;\n            carousel.style.cursor = 'grab';\n        });\n\n        carousel.addEventListener('mouseup', () => {\n            isDown = false;\n            carousel.style.cursor = 'grab';\n        });\n\n        carousel.addEventListener('mousemove', (e) => {\n            if (!isDown) return;\n            e.preventDefault();\n            const x = e.pageX - carousel.offsetLeft;\n            const walk = (x - startX) * 2;\n            carousel.scrollLeft = scrollLeft - walk;\n        });\n    });\n}\n\ndocument.addEventListener('DOMContentLoaded', function() {\n    setupScrollControls();\n});\n</script>",
        "color_scheme": "",
        "section_width": "full-width",
        "padding-block-start": 0,
        "padding-block-end": 0
      }
    },
    "custom_liquid_PtEgiC": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "安心保證區塊",
      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"zh-TW\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>APGO - 安心保證區塊 (最終版)</title>\n    <style>\n        /* 基礎重置與變數 - 確保與網站整體風格一致 */\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        :root {\n            --apgo-trust-primary-orange: #f08418;\n            --apgo-trust-secondary-orange: #ff9a3c;\n            --apgo-trust-text-white: #ffffff;\n            --apgo-trust-text-gray: #cccccc;\n            --apgo-trust-text-light-gray: #b0b0b0;\n            --apgo-trust-dark-bg: #000000;\n            --apgo-trust-card-bg: rgba(255, 255, 255, 0.06); /* 更輕量的卡片背景 */\n            --apgo-trust-card-border: rgba(240, 132, 24, 0.15); /* 卡片邊框 */\n        }\n\n        body {\n            font-family: 'Arial', 'Microsoft JhengHei', sans-serif;\n            background: var(--apgo-trust-dark-bg);\n            color: var(--apgo-trust-text-white);\n            overflow-x: hidden;\n        }\n\n        /* 安心保證區塊 */\n        .apgo-trust-section {\n            background: var(--apgo-trust-dark-bg);\n            padding: 80px 0;\n            position: relative;\n            overflow: hidden;\n            z-index: 5; /* 【主要修改】設置低於快速導覽(z-index: 10)的層級，避免覆蓋 */\n        }\n\n        /* 動態粒子背景效果 - 移除所有橘色光暈，保持透明或極低調的背景 */\n        .apgo-trust-section::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: \n                radial-gradient(circle at 20% 30%, rgba(255, 255, 255, 0.02) 0%, transparent 70%),\n                radial-gradient(circle at 80% 70%, rgba(255, 255, 255, 0.01) 0%, transparent 65%),\n                radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.01) 0%, transparent 60%);\n            pointer-events: none;\n        }\n\n        .apgo-trust-container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 0 20px;\n            position: relative;\n            z-index: 10;\n        }\n\n        /* 標題區域 - 左對齊帶Logo */\n        .apgo-trust-header {\n            display: flex;\n            align-items: center;\n            gap: 20px;\n            margin-bottom: 60px;\n            opacity: 0;\n            transform: translateY(30px);\n            animation: apgo-trust-fadeInUp 0.8s ease forwards;\n            position: relative;\n            z-index: 15;\n        }\n\n        @keyframes apgo-trust-fadeInUp {\n            to {\n                opacity: 1;\n                transform: translateY(0);\n            }\n        }\n\n        /* LOGO 樣式 */\n        .apgo-trust-logo {\n            flex-shrink: 0;\n            opacity: 0;\n            transform: translateY(20px);\n            animation: apgo-trust-fadeInUp 0.8s ease 0.3s forwards;\n        }\n\n        .apgo-trust-logo img {\n            height: 50px;\n            width: auto;\n            max-width: 180px;\n            object-fit: contain;\n            filter: brightness(1.1) contrast(1.1);\n            transition: all 0.3s ease;\n        }\n\n        .apgo-trust-logo img:hover {\n            filter: brightness(1.2) contrast(1.2);\n            transform: scale(1.05);\n        }\n\n        .apgo-trust-text-content {\n            flex: 1;\n        }\n\n        .apgo-trust-title {\n            font-size: 1.8rem; /* H2 級別 */\n            font-weight: 600;\n            margin-bottom: 12px;\n            color: var(--apgo-trust-primary-orange); /* 強調色 */\n            line-height: 1.2;\n        }\n\n        .apgo-trust-subtitle {\n            font-size: 0.9rem; /* text-secondary 級別 */\n            color: var(--apgo-trust-text-light-gray);\n            font-weight: 400;\n            max-width: 700px;\n            line-height: 1.5;\n        }\n\n        /* 保證卡片區域 - 改為橫向滾動 */\n        .apgo-trust-cards {\n            display: flex; /* 改為 flexbox */\n            gap: 25px; /* 卡片間距 */\n            overflow-x: auto; /* 啟用橫向滾動 */\n            overflow-y: hidden; /* 隱藏垂直滾動條 */\n            padding: 20px; /* 增加內邊距以顯示陰影 */\n            padding-bottom: 40px; /* 留給滾動條和陰影空間 */\n            scroll-behavior: smooth;\n            -webkit-overflow-scrolling: touch;\n            scrollbar-width: thin; /* Firefox */\n            scrollbar-color: var(--apgo-trust-primary-orange) rgba(255, 255, 255, 0.1); /* Firefox */\n            position: relative;\n            z-index: 1;\n            /* 移除 grid 相關屬性，確保不干擾 flex 佈局 */\n            grid-template-columns: none;\n        }\n\n        /* 滾動條美化 (與加購區塊保持一致) */\n        .apgo-trust-cards::-webkit-scrollbar {\n            height: 8px; /* WebKit */\n        }\n        .apgo-trust-cards::-webkit-scrollbar-track {\n            background: rgba(255, 255, 255, 0.1); /* WebKit */\n            border-radius: 4px;\n        }\n        .apgo-trust-cards::-webkit-scrollbar-thumb {\n            background: var(--apgo-trust-primary-orange); /* WebKit */\n            border-radius: 4px;\n            transition: background 0.3s ease;\n        }\n        .apgo-trust-cards::-webkit-scrollbar-thumb:hover {\n            background: var(--apgo-trust-secondary-orange);\n        }\n\n        /* 卡片本身 */\n        .apgo-trust-card {\n            flex-shrink: 0; /* 防止卡片縮小 */\n            width: 320px; /* 固定卡片寬度，可調整 */\n            background: var(--apgo-trust-card-bg);\n            backdrop-filter: blur(30px);\n            border-radius: 24px;\n            padding: 40px 20px;\n            border: 2px solid var(--apgo-trust-card-border);\n            background-clip: padding-box;\n            text-align: center;\n            cursor: pointer;\n            transition: all 0.6s cubic-bezier(0.4, 0, 0.2, 1);\n            position: relative;\n            overflow: hidden;\n            height: 300px; /* 調整高度以適應新佈局 */\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            opacity: 0;\n            transform: translateY(50px) scale(0.9);\n            animation: apgo-trust-cardUp 0.8s ease forwards;\n            box-shadow: \n                0 8px 32px rgba(240, 132, 24, 0.1),\n                inset 0 1px 0 rgba(255, 255, 255, 0.1);\n            z-index: 5;\n        }\n\n        .apgo-trust-card:nth-child(1) { animation-delay: 0.1s; }\n        .apgo-trust-card:nth-child(2) { animation-delay: 0.2s; }\n        .apgo-trust-card:nth-child(3) { animation-delay: 0.3s; }\n        .apgo-trust-card:nth-child(4) { animation-delay: 0.4s; }\n\n        @keyframes apgo-trust-cardUp {\n            to {\n                opacity: 1;\n                transform: translateY(0) scale(1);\n            }\n        }\n\n        /* 懸停效果 - 移除背景變色，強化邊框和陰影 */\n        .apgo-trust-card:hover {\n            transform: translateY(-15px) scale(1.05);\n            box-shadow: \n                0 25px 50px rgba(0, 0, 0, 0.3),\n                0 0 0 1px rgba(240, 132, 24, 0.6), /* 外層橘色邊框光效 */\n                0 8px 32px rgba(240, 132, 24, 0.3), /* 內部橘色陰影 */\n                inset 0 1px 0 rgba(255, 255, 255, 0.2);\n            border-color: rgba(240, 132, 24, 0.4); /* 邊框顏色改變 */\n            background: var(--apgo-trust-card-bg); /* 確保背景色不變 */\n            z-index: 15;\n        }\n\n        /* 動態邊框光效 - APGO橘色系 */\n        .apgo-trust-card::before {\n            content: '';\n            position: absolute;\n            top: -2px;\n            left: -2px;\n            right: -2px;\n            bottom: -2px;\n            background: linear-gradient(45deg, \n                #f08418, #ff9a3c, #ffb366, #f08418, \n                #e07315, #ff9a3c, #f08418);\n            background-size: 300% 300%;\n            border-radius: 26px;\n            z-index: -1;\n            opacity: 0.1; /* 固定低透明度，不隨hover變化 */\n            transition: opacity 0.4s ease; /* 保留過渡效果，但不會在hover時變亮 */\n            /* 移除 animation: apgo-border-flow 4s linear infinite; */\n        }\n\n        /* 移除 hover 時的 opacity 變化 */\n        .apgo-trust-card:hover::before {\n            opacity: 0.1; /* 確保懸停時也不會變亮 */\n        }\n\n        /* @keyframes apgo-border-flow { ... } 移除動畫定義 */\n\n        /* 30天退費 - 數字顏色改為橘色 */\n        .apgo-trust-mega-30 {\n            position: relative;\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            justify-content: center;\n            margin-bottom: 20px;\n        }\n\n        .apgo-trust-combined-display {\n            font-size: 4.2rem;\n            font-weight: 900;\n            font-family: 'Arial Black', 'Helvetica', sans-serif;\n            /* 將綠色漸層改為橘色漸層 */\n            background: linear-gradient(135deg, \n                var(--apgo-trust-primary-orange) 0%, \n                var(--apgo-trust-secondary-orange) 100%);\n            background-size: 300% 300%;\n            -webkit-background-clip: text;\n            -webkit-text-fill-color: transparent;\n            background-clip: text;\n            animation: apgo-mega-glow 4s ease-in-out infinite;\n            letter-spacing: -0.02em;\n            line-height: 0.9;\n            position: relative;\n            /* 調整陰影顏色以匹配橘色 */\n            filter: drop_shadow(0 10px 30px rgba(240, 132, 24, 0.4));\n            text-align: center;\n        }\n\n        @keyframes apgo-mega-glow {\n            0%, 100% { \n                background-position: 0% 50%;\n                transform: scale(1);\n            }\n            50% { \n                transform: scale(1.05);\n            }\n        }\n\n        /* 其他卡片的超級圖標容器 */\n        .apgo-trust-super-icon {\n            width: 100px;\n            height: 100px;\n            margin-bottom: 25px;\n            position: relative;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            transition: all 0.5s ease;\n            border-radius: 24px; /* 保持圓角 */\n            overflow: hidden; /* 確保內部光效不溢出 */\n            /* 統一為橘色漸層背景 */\n            background: linear-gradient(135deg, var(--apgo-trust-primary-orange), var(--apgo-trust-secondary-orange));\n        }\n\n        .apgo-trust-card:hover .apgo-trust-super-icon {\n            transform: scale(1.2) rotate(5deg);\n        }\n\n        /* 移除原有的 Emoji 內容 */\n        .apgo-support-icon::before,\n        .apgo-tutorial-icon::before,\n        .apgo-store-icon::before {\n            content: none; /* 移除 Emoji 內容 */\n        }\n\n        /* 新增簡潔的內置圖標 */\n        .apgo-support-icon::after,\n        .apgo-tutorial-icon::after,\n        .apgo-store-icon::after {\n            content: ''; /* 默認空，由各類別設定 */\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            transform: translate(-50%, -50%);\n            font-size: 2.5rem; /* 調整大小 */\n            color: rgba(255, 255, 255, 0.8); /* 白色半透明 */\n            font-weight: bold;\n            transition: all 0.3s ease;\n            z-index: 2; /* 確保在光效上方 */\n            font-family: 'Arial', sans-serif; /* 確保符號渲染良好 */\n            line-height: 1; /* 調整行高以居中 */\n        }\n\n        .apgo-trust-card:hover .apgo-support-icon::after,\n        .apgo-trust-card:hover .apgo-tutorial-icon::after,\n        .apgo-trust-card:hover .apgo-store-icon::after {\n            color: var(--apgo-trust-text-white); /* 懸停時純白色 */\n            transform: translate(-50%, -50%) scale(1.1);\n        }\n\n        /* 客服圖標樣式 */\n        .apgo-support-icon::after {\n            content: 'i'; /* 小寫 i 代表資訊/information */\n            font-size: 3rem; /* 確保 i 夠大 */\n        }\n\n        /* 教學圖標樣式 */\n        .apgo-tutorial-icon::after {\n            content: '▶'; /* 播放按鈕 */\n            font-size: 2.8rem; /* 調整大小以適應三角形 */\n        }\n\n        /* 門市圖標樣式 */\n        .apgo-store-icon::after {\n            content: '⦿'; /* 中心點圓圈代表位置 */\n            font-size: 3rem;\n        }\n\n        /* 圖標背景光效 (原有的 apgo-icon-shine 動畫) */\n        .apgo-support-icon::before,\n        .apgo-tutorial-icon::before,\n        .apgo-store-icon::before {\n            content: ''; /* 重新定義為空，只用於背景光效 */\n            position: absolute;\n            top: -50%;\n            left: -50%;\n            width: 200%;\n            height: 200%;\n            background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.1), transparent);\n            /* 移除 animation: apgo-icon-shine 3s ease-in-out infinite; */\n            z-index: 1; /* 確保在符號下方 */\n        }\n        /* 移除 animation-delay */\n\n\n        /* 標題樣式 */\n        .apgo-trust-card-title {\n            font-size: 1.2rem; /* H4 級別 */\n            font-weight: 700;\n            color: var(--apgo-trust-text-white);\n            margin-bottom: 10px;\n            transition: all 0.3s ease;\n            position: relative;\n            z-index: 2;\n            line-height: 1.3;\n        }\n\n        .apgo-trust-card:hover .apgo-trust-card-title {\n            color: var(--apgo-trust-primary-orange); /* 懸停時標題變橘色 */\n            text-shadow: 0 2px 8px rgba(240, 132, 24, 0.4);\n            transform: translateY(-2px);\n        }\n\n        /* 描述文字 */\n        .apgo-trust-card-desc {\n            font-size: 0.9rem; /* text-secondary 級別 */\n            color: var(--apgo-trust-text-light-gray);\n            line-height: 1.5;\n            transition: all 0.3s ease;\n            position: relative;\n            z-index: 2;\n        }\n\n        .apgo-trust-card:hover .apgo-trust-card-desc {\n            color: #f0f0f0; /* 懸停時描述文字變亮 */\n            transform: translateY(-2px);\n        }\n\n        /* 點擊提示 */\n        .apgo-trust-click-prompt {\n            font-size: 0.8rem;\n            color: var(--apgo-trust-text-light-gray); /* 預設為淺灰色 */\n            margin-top: 15px;\n            opacity: 0.8; /* 預設可見，但略微透明 */\n            transform: translateY(0); /* 預設在最終位置 */\n            transition: all 0.3s ease;\n            font-weight: bold;\n            letter-spacing: 0.5px;\n            display: flex;\n            align-items: center;\n            justify-content: center;\n            gap: 5px;\n        }\n\n        .apgo-trust-card:hover .apgo-trust-click-prompt {\n            opacity: 1; /* 懸停時完全不透明 */\n            color: var(--apgo-trust-secondary-orange); /* 懸停時變為橘色 */\n            transform: translateY(-2px); /* 懸停時輕微上移 */\n        }\n\n        /* 針對觸控設備的 active 狀態 */\n        .apgo-trust-card:active .apgo-trust-click-prompt {\n            transform: translateY(0px) scale(0.98); /* 點擊時輕微按下效果 */\n            color: var(--apgo-trust-primary-orange); /* 點擊時變為主橘色 */\n        }\n\n\n        /* 底部 CTA 區域 */\n        .apgo-trust-cta-section {\n            text-align: center;\n            margin-top: 60px;\n            opacity: 0;\n            transform: translateY(30px);\n            animation: apgo-trust-fadeInUp 0.8s ease 0.6s forwards;\n        }\n\n        .apgo-trust-cta-text {\n            font-size: 1.2rem; /* H4 級別 */\n            color: var(--apgo-trust-text-white);\n            margin-bottom: 25px;\n            line-height: 1.6;\n            max-width: 800px;\n            margin-left: auto;\n            margin-right: auto;\n        }\n\n        .apgo-trust-cta-button {\n            display: inline-block;\n            padding: 18px 50px;\n            background: linear-gradient(45deg, var(--apgo-trust-primary-orange), var(--apgo-trust-secondary-orange));\n            color: var(--apgo-trust-text-white);\n            text-decoration: none;\n            font-size: 1.2rem; /* button-text 級別 */\n            font-weight: bold;\n            border-radius: 50px;\n            transition: all 0.3s ease;\n            position: relative;\n            overflow: hidden;\n            box-shadow: 0 4px 15px rgba(240, 132, 24, 0.3);\n            letter-spacing: 1px;\n        }\n\n        .apgo-trust-cta-button::before {\n            content: '';\n            position: absolute;\n            top: 50%;\n            left: 50%;\n            width: 0;\n            height: 0;\n            background: rgba(255, 255, 255, 0.3);\n            border-radius: 50%;\n            transform: translate(-50%, -50%);\n            transition: width 0.6s ease, height 0.6s ease;\n        }\n\n        .apgo-trust-cta-button:hover {\n            transform: translateY(-3px);\n            box-shadow: 0 10px 30px rgba(240, 132, 24, 0.4);\n        }\n\n        .apgo-trust-cta-button:hover::before {\n            width: 300px;\n            height: 300px;\n        }\n\n        /* 彈窗樣式 */\n        .apgo-trust-modal{\n            position:fixed;\n            top:0;\n            left:0;\n            width:100%;\n            height:100%;\n            background:rgba(0,0,0,0.85);\n            backdrop-filter:blur(10px);\n            display:none; /* 預設隱藏 */\n            align-items:center;\n            justify-content:center;\n            z-index:10000;\n            opacity:0;\n            visibility:hidden; /* 預設隱藏 */\n            transition:opacity 0.3s ease, visibility 0.3s ease; /* 增加 visibility 過渡 */\n        }\n        .apgo-trust-modal.apgo-trust-show{\n            display:flex; /* 顯示為 flex */\n            opacity:1;\n            visibility:visible; /* 顯示 */\n        }\n        .apgo-trust-modal-content{background:linear-gradient(145deg,#1a1a1a,#2a2a2a);border-radius:20px;border:2px solid rgba(240,132,24,0.4);box-shadow:0 25px 50px rgba(0,0,0,0.8),0 0 0 1px rgba(255,255,255,0.1),inset 0 1px 0 rgba(255,255,255,0.1);max-width:550px;width:90%;padding:40px;text-align:center;transform:scale(0.8);transition:transform 0.4s ease;position:relative;overflow-y:auto;max-height:90vh}\n        .apgo-trust-modal.apgo-trust-show .apgo-trust-modal-content{transform:scale(1)}\n        .apgo-trust-close-modal{position:absolute;top:15px;right:15px;background:rgba(255,255,255,0.1);border:none;color:var(--apgo-trust-text-gray);font-size:1.5rem;width:35px;height:35px;border-radius:50%;cursor:pointer;transition:all 0.3s ease;display:flex;align-items:center;justify-content:center}\n        .apgo-trust-close-modal:hover{background:var(--apgo-trust-primary-orange);color:white;transform:rotate(90deg)}\n        .apgo-trust-modal-header{margin-bottom:25px;text-align:center}\n        .apgo-trust-modal-title{font-size:1.5rem;color:var(--apgo-trust-primary-orange);margin-bottom:10px;font-weight:600}\n        .apgo-trust-modal-subtitle{font-size:0.9rem;color:var(--apgo-trust-text-gray)}\n        .apgo-trust-modal-list{background:rgba(255,255,255,0.05);border-radius:15px;padding:20px;margin-bottom:20px;text-align:left}\n        .apgo-trust-modal-item{padding:10px 0;border-bottom:1px solid rgba(255,255,255,0.1);color:var(--apgo-trust-text-white);font-size:0.95rem;display:flex;align-items:flex-start;gap:10px}\n        .apgo-trust-modal-item:last-child{border-bottom:none}\n        .apgo-trust-modal-item::before{content:'✓';color:var(--apgo-trust-primary-orange);font-weight:bold;flex-shrink:0}\n        .apgo-trust-modal-note{background:rgba(240,132,24,0.1);border:1px solid rgba(240,132,24,0.3);border-radius:10px;padding:15px;font-size:0.85rem;color:var(--apgo-trust-text-gray);line-height:1.5;text-align:left}\n        \n        /* 彈窗圖片樣式 */\n        .apgo-modal-image-container {\n            margin-bottom: 25px;\n            text-align: center;\n        }\n        .apgo-modal-image {\n            max-width: 150px; /* 圖片最大寬度 */\n            height: auto;\n            border-radius: 12px; /* 圓角 */\n            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4); /* 陰影 */\n            border: 1px solid rgba(255, 255, 255, 0.1); /* 輕微邊框 */\n        }\n\n        /* 客服彈窗專用按鈕區塊 */\n        .apgo-support-buttons {\n            display: flex;\n            flex-direction: column;\n            gap: 15px;\n            margin-top: 30px;\n            padding-top: 20px;\n            border-top: 1px solid rgba(255, 255, 255, 0.1);\n            text-align: center; /* 確保內部按鈕和文字居中 */\n        }\n\n        .apgo-support-button-item {\n            display: flex;\n            flex-direction: column;\n            align-items: center;\n            gap: 5px;\n        }\n\n        .apgo-support-button {\n            display: inline-block;\n            padding: 12px 25px;\n            background: linear-gradient(45deg, var(--apgo-trust-primary-orange), var(--apgo-trust-secondary-orange)); /* 統一為橘色漸層 */\n            color: var(--apgo-trust-text-white);\n            text-decoration: none;\n            font-size: 1rem;\n            font-weight: bold;\n            border-radius: 30px;\n            transition: all 0.3s ease;\n            box-shadow: 0 4px 10px rgba(240, 132, 24, 0.3); /* 統一陰影 */\n            width: fit-content; /* 讓按鈕寬度適應內容 */\n            margin: 0 auto; /* 居中 */\n        }\n\n        .apgo-support-button:hover {\n            transform: translateY(-2px);\n            box-shadow: 0 6px 15px rgba(240, 132, 24, 0.4); /* 統一懸停陰影 */\n        }\n\n        .apgo-support-info-text {\n            font-size: 0.85rem;\n            color: var(--apgo-trust-text-gray);\n            line-height: 1.4;\n            max-width: 80%; /* 限制文字寬度 */\n            margin: 0 auto;\n        }\n\n\n        /* 響應式設計 */\n        @media (max-width: 1200px) {\n            .apgo-trust-cards {\n                /* 在較小桌機和大型平板上，可以考慮顯示更多列或調整間距 */\n                gap: 20px;\n                padding: 15px;\n                padding-bottom: 30px;\n            }\n            .apgo-trust-card {\n                width: 280px; /* 調整卡片寬度 */\n                height: 280px; /* 調整高度 */\n            }\n        }\n\n        @media (max-width: 768px) {\n            .apgo-trust-section {\n                padding: 60px 0;\n            }\n\n            .apgo-trust-container {\n                padding: 0 20px;\n            }\n\n            .apgo-trust-header {\n                flex-direction: column;\n                align-items: flex-start;\n                gap: 15px;\n            }\n\n            .apgo-trust-logo img {\n                height: 45px;\n                max-width: 160px;\n            }\n\n            .apgo-trust-title {\n                font-size: 1.5rem; /* H2 手機版 */\n            }\n\n            .apgo-trust-subtitle {\n                font-size: 0.85rem; /* text-secondary 手機版 */\n                padding: 0 10px;\n            }\n\n            .apgo-trust-cards {\n                /* 手機版橫向滾動 */\n                gap: 15px;\n                padding: 10px;\n                padding-bottom: 25px;\n            }\n\n            .apgo-trust-card {\n                width: 260px; /* 手機版卡片寬度 */\n                height: 260px; /* 手機版卡片高度 */\n                padding: 30px 15px;\n            }\n\n            .apgo-trust-mega-30 {\n                font-size: 3.2rem;\n            }\n\n            .apgo-trust-super-icon {\n                width: 80px;\n                height: 80px;\n                margin-bottom: 20px;\n            }\n\n            .apgo-support-icon::after,\n            .apgo-tutorial-icon::after,\n            .apgo-store-icon::after {\n                font-size: 2rem; /* 調整簡潔圖標大小 */\n            }\n\n            .apgo-trust-card-title {\n                font-size: 1.1rem; /* H4 手機版 */\n            }\n\n            .apgo-trust-card-desc {\n                font-size: 0.8rem; /* text-secondary 手機版 */\n            }\n\n            .apgo-trust-cta-text {\n                font-size: 1rem; /* H4 手機版 */\n                margin-bottom: 20px;\n            }\n\n            .apgo-trust-cta-button {\n                padding: 15px 40px;\n                font-size: 1rem; /* button-text 手機版 */\n            }\n        }\n\n        @media (max-width: 480px) {\n            .apgo-trust-header {\n                gap: 12px;\n            }\n\n            .apgo-trust-logo img {\n                height: 40px;\n                max-width: 140px;\n            }\n\n            .apgo-trust-card {\n                width: 240px; /* 極小螢幕卡片寬度 */\n                height: 240px; /* 極小螢幕卡片高度 */\n                padding: 25px 15px;\n            }\n\n            .apgo-trust-mega-30 {\n                font-size: 2.8rem;\n            }\n\n            .apgo-trust-super-icon {\n                width: 70px;\n                height: 70px;\n                margin-bottom: 15px;\n            }\n\n            .apgo-support-icon::after,\n            .apgo-tutorial-icon::after,\n            .apgo-store-icon::after {\n                font-size: 1.8rem; /* 極小螢幕簡潔圖標大小 */\n            }\n\n            .apgo-trust-card-title {\n                font-size: 1rem; /* H4 極小螢幕 */\n            }\n\n            .apgo-trust-card-desc {\n                font-size: 0.75rem; /* text-secondary 極小螢幕 */\n            }\n        }\n\n        /* 螢幕閱讀器專用樣式 */\n        .sr-only {\n            position: absolute;\n            width: 1px;\n            height: 1px;\n            padding: 0;\n            margin: -1px;\n            overflow: hidden;\n            clip: rect(0, 0, 0, 0);\n            white-space: nowrap;\n            border: 0;\n        }\n    </style>\n</head>\n<body>\n    <section class=\"apgo-trust-section\">\n        <div class=\"apgo-trust-container\">\n            <div class=\"apgo-trust-header\">\n                <div class=\"apgo-trust-logo\">\n                    <img src=\"https://cdn.shopify.com/s/files/1/0760/8002/1755/files/logo.png?v=1749123901\" alt=\"APGO 專業鍍膜專家\" />\n                </div>\n                <div class=\"apgo-trust-text-content\">\n                    <h2 class=\"apgo-trust-title\">安心購物保障</h2>\n                    <p class=\"apgo-trust-subtitle\">您的每一次選擇，APGO 都將提供最堅實的承諾與支援</p>\n                </div>\n            </div>\n\n            <div class=\"apgo-trust-cards\">\n                <div class=\"apgo-trust-card\" onclick=\"handleTrustCardClick('refund')\">\n                    <div class=\"apgo-trust-mega-30\">\n                        <div class=\"apgo-trust-combined-display\">30天</div>\n                    </div>\n                    <h3 class=\"apgo-trust-card-title\">無憂退費承諾</h3>\n                    <p class=\"apgo-trust-card-desc\">業界良心保證，讓您零風險試用</p>\n                    <span class=\"apgo-trust-click-prompt\">點擊查看詳情</span>\n                </div>\n\n                <div class=\"apgo-trust-card\" onclick=\"handleTrustCardClick('support')\">\n                    <div class=\"apgo-trust-super-icon apgo-support-icon\"></div>\n                    <h3 class=\"apgo-trust-card-title\">24h全天候線上客服</h3>\n                    <p class=\"apgo-trust-card-desc\">專業團隊即時支援，問題隨時解答</p>\n                    <span class=\"apgo-trust-click-prompt\">點擊查看詳情</span>\n                </div>\n\n                <div class=\"apgo-trust-card\" onclick=\"handleTrustCardClick('tutorial')\">\n                    <div class=\"apgo-trust-super-icon apgo-tutorial-icon\"></div>\n                    <h3 class=\"apgo-trust-card-title\">手把手教學影片</h3>\n                    <p class=\"apgo-trust-card-desc\">新手也能變專家，輕鬆打造完美效果</p>\n                    <span class=\"apgo-trust-click-prompt\">點擊查看詳情</span>\n                </div>\n\n                <div class=\"apgo-trust-card\" onclick=\"handleTrustCardClick('stores')\">\n                    <div class=\"apgo-trust-super-icon apgo-store-icon\"></div>\n                    <h3 class=\"apgo-trust-card-title\">全台服務據點</h3>\n                    <p class=\"apgo-trust-card-desc\">近距離體驗專業，售後服務更安心</p>\n                    <span class=\"apgo-trust-click-prompt\">點擊查看詳情</span>\n                </div>\n            </div>\n\n            <div class=\"apgo-trust-cta-section\">\n                <p class=\"apgo-trust-cta-text\">\n                    我們深信，提供最優質的產品與最完善的服務，才是品牌長久經營的基石。<br>\n                    選擇 APGO，讓您的愛車，從此無懼挑戰！\n                </p>\n                <a href=\"/collections/all\" class=\"apgo-trust-cta-button\">立即選購，親身體驗 APGO 承諾！</a>\n            </div>\n        </div>\n    </section>\n\n    <div class=\"apgo-trust-modal\" id=\"apgoTrustModal\">\n        <div class=\"apgo-trust-modal-content\">\n            <button class=\"apgo-trust-close-modal\" onclick=\"closeTrustModal()\">×</button>\n            \n            <div class=\"apgo-trust-modal-header\">\n                <h3 class=\"apgo-trust-modal-title\" id=\"modalTitle\">標題</h3>\n                <p class=\"apgo-trust-modal-subtitle\" id=\"modalSubtitle\">副標題</p>\n            </div>\n            \n            <div class=\"apgo-modal-image-container\">\n                <img id=\"modalImage\" src=\"\" alt=\"彈窗視覺圖片\" class=\"apgo-modal-image\">\n            </div>\n\n            <div class=\"apgo-trust-modal-list\" id=\"modalList\">\n                </div>\n            \n            <div class=\"apgo-trust-modal-note\" id=\"modalNote\" style=\"display: none;\">\n                </div>\n            \n            <div class=\"apgo-support-buttons\" id=\"supportButtonsContainer\" style=\"display: none;\">\n                <div class=\"apgo-support-button-item\">\n                    <a href=\"https://line.me/ti/p/@apgo\" target=\"_blank\" class=\"apgo-support-button\">官方LINE</a>\n                    <p class=\"apgo-support-info-text\">如果無法連結請直接輸入ID <span style=\"color: var(--apgo-trust-primary-orange); font-weight: bold;\">@APGO</span></p>\n                </div>\n                <div class=\"apgo-support-button-item\">\n                    <a href=\"tel:0229030101\" class=\"apgo-support-button\">電話</a>\n                    <p class=\"apgo-support-info-text\">02-29030101 工作日09:00-18:00回覆</p>\n                </div>\n                <div class=\"apgo-support-button-item\">\n                    <a href=\"/contact\" target=\"_blank\" class=\"apgo-support-button\">線上表單</a>\n                    <p class=\"apgo-support-info-text\">在工作日會盡快回覆</p>\n                </div>\n            </div>\n        </div>\n    </div>\n\n    <script>\n        // 購物車管理類別 (簡化版本，假設全局 APGOCartManager 可用)\n        // 如果您的 APGOCartManager 已經在全局載入，可以移除此備用定義\n        if (typeof window.APGOCartManager === 'undefined') {\n            console.warn(\"APGOCartManager is not defined. Providing a temporary fallback.\");\n            window.APGOCartManager = {\n                showNotification: function(message, type = 'info') {\n                    const existing = document.querySelector('.apgo-notification');\n                    if (existing) existing.remove();\n\n                    const notification = document.createElement('div');\n                    notification.className = 'apgo-notification ' + type;\n                    notification.innerHTML = `\n                        <div class=\"apgo-notification-content\">\n                            <div class=\"apgo-notification-message\">${message}</div>\n                        </div>\n                        <button class=\"apgo-notification-close\" onclick=\"this.parentNode.remove()\">&times;</button>\n                    `;\n                    document.body.appendChild(notification);\n                    setTimeout(() => notification.classList.add('show'), 100);\n                    setTimeout(() => {\n                        if (notification.parentNode) {\n                            notification.classList.remove('show');\n                            setTimeout(() => notification.remove(), 300);\n                        }\n                    }, 5000);\n                }\n            };\n        }\n\n        // 彈窗數據與內容\n        const trustDetailsData = {\n            refund: {\n                title: '30天無憂退費承諾',\n                subtitle: '業界良心保證，讓您零風險試用',\n                modalImage: null, // 圖片已移除\n                items: [\n                    '在您收到APGO產品後的**30天內，不管有沒有使用**，皆可申請退費。',\n                    '**未開封**商品：享**全額退費**，確保您零風險體驗。',\n                    '**已使用**商品：仍可退**全額**，讓您安心試用。',\n                    '**專人協助**：全程由專業客服引導，退費過程簡單透明，無需擔心繁瑣流程。'\n                ],\n                note: null,\n                buttons: null // 無按鈕\n            },\n            support: {\n                title: '24h全天候線上客服', // 更新文字\n                subtitle: '專業團隊即時支援，問題隨時解答',\n                modalImage: null, // 圖片已移除\n                items: [\n                    '我們的專業客服團隊，全年無休，為您提供**7天24小時**的即時線上支援，確保您的問題隨時被解答。',\n                    '**多管道支援**：透過LINE、電話 或線上表單，隨時聯繫。' // 簡化，因為下方有按鈕\n                ],\n                note: null,\n                buttons: [ // 新增按鈕數據\n                    { type: 'line', text: '官方LINE', link: 'https://line.me/ti/p/@apgo', info: '如果無法連結請直接輸入ID <span style=\"color: var(--apgo-trust-primary-orange); font-weight: bold;\">@APGO</span>' },\n                    { type: 'phone', text: '電話', link: 'tel:0229030101', info: '02-29030101 工作日09:00-18:00回覆' },\n                    { type: 'form', text: '線上表單', link: '/contact', info: '在工作日會盡快回覆' }\n                ]\n            },\n            tutorial: {\n                title: '手把手教學，新手也能變專家',\n                subtitle: '最完整、最詳細的施工教學影片系列',\n                modalImage: null, // 圖片已移除\n                items: [\n                    'APGO提供從**零基礎到進階**，最完整、最詳細的**施工教學影片系列**。',\n                    '**步驟分解**：每段影片都將複雜的施工流程拆解為簡單步驟，讓您一看就懂、一學就會。',\n                    '**實境操作示範**：由APGO專業技師親自示範，涵蓋各種車款與材質的施工技巧。',\n                    '**常見問題Q&A**：針對新手常犯錯誤與疑慮，提供即時解決方案。'\n                    // 移除專屬社群支援和見證奇蹟\n                ],\n                note: null,\n                buttons: null // 無按鈕\n            },\n            stores: {\n                title: '全台服務據點，近距離體驗專業',\n                subtitle: '便利的實體服務據點，提供面對面服務',\n                modalImage: null, // 圖片已移除\n                items: [\n                    'APGO目前在**新北市新莊區鳳山街56巷3號**設有服務門市，為您提供面對面的專業諮詢與服務。',\n                    '未來我們將持續拓展更多服務據點，為全台車主提供更便捷的服務。',\n                    '您可在此體驗產品、獲得專業技師的現場指導，並享受完善的售後服務。'\n                ],\n                note: '請注意門市營業時間，建議前往前先致電確認。', // 簡化注意事項\n                buttons: null // 無按鈕\n            }\n        };\n\n        // 處理信任卡片點擊事件\n        function handleTrustCardClick(type) {\n            console.log('點擊卡片:', type); // 偵錯訊息\n            const details = trustDetailsData[type];\n            if (!details) {\n                console.error('找不到對應的信任詳情:', type);\n                return;\n            }\n            showTrustDetails(details.title, details.subtitle, details.items, details.note, details.modalImage, details.buttons);\n        }\n\n        // 顯示信任詳情彈窗\n        function showTrustDetails(title, subtitle, items, note, modalImageUrl, buttonsData) {\n            console.log('呼叫 showTrustDetails 函數'); // 偵錯訊息\n            const modal = document.getElementById('apgoTrustModal');\n            if (!modal) {\n                console.error('錯誤：找不到彈窗元素 #apgoTrustModal'); // 偵錯訊息\n                return;\n            }\n            const modalTitle = modal.querySelector('#modalTitle');\n            const modalSubtitle = modal.querySelector('#modalSubtitle');\n            const modalImage = modal.querySelector('#modalImage'); // 獲取圖片元素\n            const modalList = modal.querySelector('#modalList');\n            const modalNote = modal.querySelector('#modalNote');\n            const supportButtonsContainer = modal.querySelector('#supportButtonsContainer'); // 獲取按鈕容器\n            \n            modalTitle.textContent = title;\n            modalSubtitle.textContent = subtitle;\n            \n            // 設定彈窗圖片\n            if (modalImageUrl) {\n                modalImage.src = modalImageUrl;\n                modalImage.alt = title + ' 視覺圖';\n                modalImage.style.display = 'block'; // 顯示圖片\n            } else {\n                modalImage.style.display = 'none'; // 隱藏圖片\n            }\n\n            modalList.innerHTML = items.map(item => \n                `<div class=\"apgo-trust-modal-item\">${item}</div>`\n            ).join('');\n            \n            if (note) {\n                modalNote.innerHTML = note;\n                modalNote.style.display = 'block';\n            } else {\n                modalNote.style.display = 'none';\n            }\n\n            // 處理客服按鈕顯示\n            if (buttonsData && supportButtonsContainer) {\n                supportButtonsContainer.innerHTML = ''; // 清空舊內容\n                buttonsData.forEach(button => {\n                    const buttonItem = document.createElement('div');\n                    buttonItem.className = 'apgo-support-button-item';\n                    buttonItem.innerHTML = `\n                        <a href=\"${button.link}\" ${button.type === 'line' || button.type === 'form' ? 'target=\"_blank\"' : ''} class=\"apgo-support-button\">${button.text}</a>\n                        ${button.info ? `<p class=\"apgo-support-info-text\">${button.info}</p>` : ''}\n                    `;\n                    supportButtonsContainer.appendChild(buttonItem);\n                });\n                supportButtonsContainer.style.display = 'flex'; // 顯示容器\n            } else if (supportButtonsContainer) {\n                supportButtonsContainer.style.display = 'none'; // 隱藏容器\n            }\n            \n            modal.classList.add('apgo-trust-show'); // 添加顯示 class\n            document.body.style.overflow = 'hidden';\n            console.log('彈窗應已可見。Class \"apgo-trust-show\" 已添加。'); // 偵錯訊息\n\n            // 確保彈窗內容滾動到頂部\n            modal.querySelector('.apgo-trust-modal-content').scrollTop = 0;\n        }\n\n        // 關閉彈窗\n        function closeTrustModal() {\n            console.log('呼叫 closeTrustModal 函數'); // 偵錯訊息\n            const modal = document.getElementById('apgoTrustModal');\n            if (modal) {\n                modal.classList.remove('apgo-trust-show'); // 移除顯示 class\n                document.body.style.overflow = 'auto';\n                console.log('彈窗應已隱藏。Class \"apgo-trust-show\" 已移除。'); // 偵錯訊息\n            }\n        }\n\n        // 頁面載入動畫增強版\n        document.addEventListener('DOMContentLoaded', () => {\n            const observerOptions = {\n                threshold: 0.1,\n                rootMargin: '0px 0px -100px 0px'\n            };\n\n            const observer = new IntersectionObserver((entries) => {\n                entries.forEach(entry => {\n                    if (entry.isIntersecting) {\n                        const cards = entry.target.querySelectorAll('.apgo-trust-card');\n                        cards.forEach((card, index) => {\n                            setTimeout(() => {\n                                card.style.opacity = '1';\n                                card.style.transform = 'translateY(0) scale(1)';\n                            }, index * 150);\n                        });\n                        // 確保標題也觸發動畫\n                        const header = entry.target.querySelector('.apgo-trust-header');\n                        if (header) {\n                            header.style.opacity = '1';\n                            header.style.transform = 'translateY(0)';\n                        }\n                        const ctaSection = entry.target.querySelector('.apgo-trust-cta-section');\n                        if (ctaSection) {\n                            ctaSection.style.opacity = '1';\n                            ctaSection.style.transform = 'translateY(0)';\n                        }\n                        observer.unobserve(entry.target); // 只觸發一次\n                    }\n                });\n            }, observerOptions);\n\n            const section = document.querySelector('.apgo-trust-section');\n            if (section) {\n                observer.observe(section);\n            }\n\n            // 點擊彈窗外部關閉\n            const modal = document.getElementById('apgoTrustModal');\n            if (modal) {\n                modal.addEventListener('click', (e) => {\n                    if (e.target === modal) {\n                        closeTrustModal();\n                    }\n                });\n            }\n\n            // ESC 鍵關閉彈窗\n            document.addEventListener('keydown', (e) => {\n                if (e.key === 'Escape') {\n                    if (modal && modal.classList.contains('apgo-trust-show')) {\n                        closeTrustModal();\n                    }\n                }\n            });\n        });\n\n        // 視差滾動效果（如果需要）\n        window.addEventListener('scroll', () => {\n            const section = document.querySelector('.apgo-trust-section');\n            if (section) {\n                const rect = section.getBoundingClientRect();\n                // 只有當區塊在視窗內時才計算視差\n                if (rect.top < window.innerHeight && rect.bottom > 0) {\n                    const scrolled = window.pageYOffset;\n                    const sectionTop = section.offsetTop;\n                    const relativeScroll = scrolled - sectionTop + window.innerHeight / 2; // 調整視差基準點\n                    const parallaxSpeed = 0.1; // 調整視差速度\n                    const yPos = -(relativeScroll * parallaxSpeed);\n                    \n                    // 應用到 ::before 偽元素，如果它作為背景\n                    // 由於偽元素難以直接從 JS 控制 transform，這裡僅作示意\n                    // 實際應用中，可能會將背景元素獨立出來\n                }\n            }\n        });\n    </script>\n</body>\n</html>",
