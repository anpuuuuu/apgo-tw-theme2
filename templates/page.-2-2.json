ms:center;margin-bottom:6px;position:relative;z-index:2}\n.spec-label{color:#aaa;font-weight:400;text-transform:uppercase;letter-spacing:0.5px}\n.spec-data{font-weight:700;color:var(--text-white);background:linear-gradient(45deg,var(--primary-orange),var(--secondary-orange));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}\n.meter-bg{height:6px;background:#0a0a0a;border-radius:6px;overflow:visible;position:relative;box-shadow:inset 0 1px 3px rgba(0,0,0,0.8),0 1px 0 rgba(255,255,255,0.05)}\n.meter-fill{height:100%;border-radius:6px;position:relative;overflow:hidden;transition:width 1s cubic-bezier(0.4,0,0.2,1);box-shadow:0 2px 6px rgba(240,132,24,0.4),inset 0 1px 0 rgba(255,255,255,0.3)}\n.spec-item:nth-child(1) .meter-fill{background:linear-gradient(90deg,var(--primary-orange) 0%,var(--secondary-orange) 100%)}\n.spec-item:nth-child(2) .meter-fill{background:linear-gradient(90deg,var(--primary-orange) 0%,#ffa847 100%)}\n.spec-item:nth-child(3) .meter-fill{background:linear-gradient(90deg,#ff7a18 0%,#ffaa3c 100%)}\n.spec-item:nth-child(4) .meter-fill{background:linear-gradient(90deg,var(--primary-orange) 0%,#ff8f3c 100%)}\n.meter-fill::before{content:'';position:absolute;top:0;left:-100%;width:100%;height:100%;background:linear-gradient(90deg,transparent 0%,rgba(255,255,255,0.4) 50%,transparent 100%);animation:shine 3s ease-in-out infinite}\n@keyframes shine{0%{left:-100%}100%{left:200%}}\n.cta-section{width:100%;height:110px;padding:15px;background:rgba(240,132,24,0.08);border:1px solid rgba(240,132,24,0.2);border-radius:12px;backdrop-filter:blur(10px);margin-top:auto;flex-shrink:0;display:flex;flex-direction:column;gap:10px}\n.simple-cta{display:flex;flex-direction:column;gap:12px;height:100%;justify-content:center}\n.price-display{text-align:center}\n.price-range{color:var(--primary-orange);font-weight:600}\n.add-to-cart-btn{background:linear-gradient(45deg,var(--primary-orange),var(--secondary-orange));color:var(--text-white);