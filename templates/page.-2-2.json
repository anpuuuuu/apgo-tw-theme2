city:1;visibility:visible}\n.apgo-modal-overlay{position:absolute;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.8);backdrop-filter:blur(4px)}\n.apgo-modal-content{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);background:#1a1a1a;border-radius:16px;border:1px solid rgba(240,132,24,0.3);box-shadow:0 20px 60px rgba(0,0,0,0.7);max-width:450px;width:90%;overflow:hidden}\n.apgo-modal-header{padding:20px 20px 15px;border-bottom:1px solid rgba(240,132,24,0.2);display:flex;justify-content:space-between;align-items:center}\n.apgo-modal-header h3{color:var(--primary-orange);font-size:1.2rem;font-weight:600;margin:0}\n.apgo-modal-close{background:transparent;border:none;color:#ccc;font-size:1.5rem;cursor:pointer;padding:0;width:24px;height:24px;display:flex;align-items:center;justify-content:center;border-radius:50%;transition:all 0.3s ease}\n.apgo-modal-close:hover{background:rgba(240,132,24,0.1);color:var(--primary-orange)}\n.apgo-modal-body{padding:20px}\n.apgo-variant-options{display:flex;flex-direction:column;gap:15px}\n.apgo-variant-choice{display:flex;align-items:center;justify-content:space-between;padding:16px;background:rgba(240,132,24,0.05);border:2px solid rgba(240,132,24,0.2);border-radius:12px;cursor:pointer;transition:all 0.3s ease;position:relative;overflow:hidden}\n.apgo-variant-choice:hover{background:rgba(240,132,24,0.1);border-color:rgba(240,132,24,0.4);transform:translateY(-2px)}\n.apgo-variant-choice.loading{cursor:not-allowed;opacity:0.7}\n.apgo-choice-info h4{color:var(--primary-orange);font-size:1rem;font-weight:600;margin-bottom:4px}\n.apgo-choice-info p{color:#b0b0b0;font-size:0.85rem;margin:0;line-height:1.4}\n.apgo-choice-price{color:var(--text-white);font-size:1.1rem;font-weight:700;background:linear-gradient(45deg,var(--primary-orange),var(--secondary-orange));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}\n.apgo-notification{position:fixed;top:80px;right:20px;max-width:350px;padding:16px 18px;border-radius:12px;box-shadow:0 12px 32px rgba(0,0,0,0.6),0 4px 16px rgba(0,0,0,0.4);z-index:99999;transform:translateX(120%);transition:all 0.3s cubic-bezier(0.16,1,0.3,1);background:linear-gradient(135deg,#1a1a1a 0%,#2d2d2d 100%);border:1px solid rgba(240,132,24,0.3);display:flex;align-items:flex-start;gap:12px;opacity:0}\n.apgo-notification.show{transform:translateX(0);opacity:1}\n.apgo-notification-content{flex:1;display:flex;flex-direction:column;gap:8px}\n.apgo-notification-message{color:var(--text-white);font-size:0.9rem;font-weight:500;line-height:1.4}\n.apgo-notification-link{background:linear-gradient(45deg,var(--primary-orange),var(--secondary-orange));color:var(--text-white);text-decoration:none;padding:8px 16px;border-radius:6px;font-size:0.85rem;font-weight:600;text-align:center;transition:all 0.3s ease;display:inline-block}\n.apgo-notification-link:hover{transform:translateY(-1px);box-shadow:0 4px 12px rgba(240,132,24,0.3)}\n.apgo-notification-close{background:transparent;border:none;color:inherit;font-size:1.2rem;cursor:pointer;padding:0;opacity:0.7;transition:opacity 0.3s ease;width:20px;height:20px;display:flex;align-items:center;justify-content:center}\n.apgo-notification-close:hover{opacity:1}\n.sr-only{position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}\n@media (max-width:768px){\nh2,.h2{font-size:1.6rem}\nh3,.h3{font-size:1.3rem}\n.text-secondary{font-size:0.85rem}\n.text-small{font-size:0.75rem}\n.text-tiny{font-size:0.7rem}\n.button-text{font-size:0.9rem}\n.products-header{padding:30px 20px 15px 20px;margin:0 auto;width:100%}\n.products-container{padding:15px 20px 50px 20px}\n.carousel-wrapper{scrollbar-width:thin;scrollbar-color:var(--primary-orange) rgba(255,255,255,0.2);padding-bottom:15px}\n.carousel-wrapper::-webkit-scrollbar{height:6px;-webkit-appearance:none}\n.carousel-wrapper::-webkit-scrollbar-track{background:rgba(255,255,255,0.2);border-rad