      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"zh-TW\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>選購原子系列鍍膜頁-主視覺區塊</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        :root {\n            --primary-orange: #f08418;\n            --secondary-orange: #ff9a3c;\n            --text-white: #ffffff;\n            --text-gray: #cccccc;\n            --text-light-gray: #b0b0b0;\n            --dark-bg: #000000;\n            --card-bg: rgba(255, 255, 255, 0.03);\n        }\n\n        body {\n            font-family: 'Arial', 'Microsoft JhengHei', sans-serif;\n            background: var(--dark-bg);\n            color: var(--text-white);\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 0 20px;\n        }\n\n        /* === 統一字體規範 === */\n        /* H1 - 頁面主標題 */\n        h1, .h1 {\n            font-size: 2.5rem;\n            font-weight: 700;\n            color: var(--primary-orange);\n            line-height: 1.2;\n            margin: 0;\n        }\n\n        /* 副標題/描述文字 */\n        .text-secondary {\n            font-size: 0.9rem;\n            color: var(--text-gray);\n            line-height: 1.5;\n            font-weight: 400;\n        }\n\n        /* 連結文字 */\n        .link-text {\n            font-size: 0.9rem;\n            font-weight: 600;\n            color: var(--primary-orange);\n            text-decoration: none;\n            transition: all 0.3s ease;\n            display: inline-flex;\n            align-items: center;\n            gap: 6px;\n        }\n\n        .link-text:hover {\n            color: var(--secondary-orange);\n            text-decoration: underline;\n        }\n\n        /* 小標籤文字 */\n        .text-small {\n            font-size: 0.8rem;\n            color: var(--text-gray);\n            line-height: 1.4;\n            font-weight: 400;\n        }\n\n        /* === 主視覺區塊 === */\n        .main-visual-section {\n            background: var(--dark-bg);\n            padding: 40px 0 30px 0;\n            position: relative;\n            overflow: hidden;\n        }\n\n        /* 準備支援未來的背景圖片 */\n        .main-visual-section::before {\n            content: '';\n            position: absolute;\n            top: 0;\n            left: 0;\n            right: 0;\n            bottom: 0;\n            /* 未來可加入背景圖片 */\n            /* background-image: url('path-to-your-image.jpg'); */\n            /* background-size: cover; */\n            /* background-position: center; */\n            /* opacity: 0.3; */\n            z-index: 0;\n        }\n\n        .main-visual-content {\n            position: relative;\n            z-index: 2;\n        }\n\n        /* 頁面標題區域 */\n        .page-title-area {\n            margin-bottom: 25px;\n        }\n\n        .page-title {\n            /* 使用統一的 H1 樣式 */\n            margin-bottom: 12px;\n            /* 為未來圖片替換做準備 */\n            position: relative;\n        }\n\n        /* 當使用圖片替代文字時的準備樣式 */\n        .page-title.image-title {\n            /* 隱藏文字，顯示背景圖片 */\n            text-indent: -9999px;\n            background-image: url('path-to-title-image.png');\n            background-size: contain;\n            background-repeat: no-repeat;\n            background-position: left center;\n            height: 80px; /* 根據實際圖片調整 */\n            width: 100%;\n            max-width: 600px; /* 限制最大寬度 */\n        }\n\n        .page-subtitle {\n            /* 副標題，未來可能也會被圖片替換 */\n            opacity: 0.9;\n        }\n\n        /* === 購物協助區塊 === */\n        .shopping-assistance-section {\n            background: var(--dark-bg);\n            padding: 20px 0 30px 0;\n        }\n\n        .assistance-options {\n            display: flex;\n            justify-content: flex-start;\n            gap: 20px;\n            flex-direction: column;\n            align-items: flex-start;\n        }\n\n        .assistance-card {\n            background: transparent;\n            border: none;\n            padding: 0;\n            text-align: left;\n            transition: all 0.3s ease;\n            width: auto;\n            display: block;\n        }\n\n        .assistance-card:hover .card-link {\n            color: var(--secondary-orange);\n            text-decoration: underline;\n        }\n\n        .card-subtitle {\n            /* 使用統一的小標籤樣式 */\n            margin-bottom: 4px;\n        }\n\n        .card-link {\n            /* 使用統一的連結樣式 */\n        }\n\n        .card-icon {\n            font-size: 0.9rem;\n            opacity: 0.9;\n            transition: transform 0.3s ease;\n        }\n\n        .assistance-card:hover .card-icon {\n            transform: scale(1.1);\n        }\n\n        /* === 響應式設計 === */\n        @media (max-width: 768px) {\n            /* H1 手機版調整 */\n            h1, .h1 {\n                font-size: 2rem;\n            }\n\n            /* 其他文字手機版調整 */\n            .text-secondary {\n                font-size: 0.85rem;\n            }\n\n            .link-text {\n                font-size: 0.85rem;\n            }\n\n            .text-small {\n                font-size: 0.75rem;\n            }\n\n            /* 區塊間距調整 */\n            .main-visual-section {\n                padding: 30px 0 20px 0;\n            }\n\n            .container {\n                padding: 0 15px;\n            }\n\n            .page-title-area {\n                margin-bottom: 20px;\n            }\n\n            .shopping-assistance-section {\n                padding: 15px 0 25px 0;\n            }\n\n            .assistance-options {\n                gap: 15px;\n            }\n\n            /* 圖片標題手機版調整 */\n            .page-title.image-title {\n                height: 60px;\n                max-width: 100%;\n            }\n        }\n\n        @media (max-width: 480px) {\n            /* 極小螢幕調整 */\n            h1, .h1 {\n                font-size: 1.8rem;\n            }\n\n            .text-secondary {\n                font-size: 0.8rem;\n            }\n\n            .link-text {\n                font-size: 0.8rem;\n            }\n\n            .text-small {\n                font-size: 0.7rem;\n            }\n\n            .page-title.image-title {\n                height: 50px;\n            }\n        }\n\n        /* === 載入動畫 === */\n        .fade-in-up {\n            opacity: 0;\n            transform: translateY(30px);\n            transition: all 0.8s ease;\n        }\n\n        .fade-in-up.animate {\n            opacity: 1;\n            transform: translateY(0);\n        }\n\n        .fade-in-left {\n            opacity: 0;\n            transform: translateX(-30px);\n            transition: all 0.6s ease;\n        }\n\n        .fade-in-left.animate {\n            opacity: 1;\n            transform: translateX(0);\n        }\n\n        /* === SEO 優化樣式 === */\n        /* 確保所有重要文字都可被搜尋引擎讀取 */\n        .sr-only {\n            position: absolute;\n            width: 1px;\n            height: 1px;\n            padding: 0;\n            margin: -1px;\n            overflow: hidden;\n            clip: rect(0, 0, 0, 0);\n            white-space: nowrap;\n            border: 0;\n        }\n\n        /* 結構化資料支援 */\n        .breadcrumb {\n            font-size: 0.75rem;\n            color: var(--text-light-gray);\n            margin-bottom: 15px;\n        }\n\n        .breadcrumb a {\n            color: var(--text-light-gray);\n            text-decoration: none;\n        }\n\n        .breadcrumb a:hover {\n            color: var(--primary-orange);\n        }\n    </style>\n</head>\n<body>\n    <!-- 結構化資料 (麵包屑導航) -->\n    <nav class=\"breadcrumb container\" aria-label=\"麵包屑導航\">\n        <a href=\"/\">首頁</a> &gt; \n        <span>選購原子系列鍍膜</span>\n    </nav>\n\n    <!-- 主視覺區塊 -->\n    <section class=\"main-visual-section\" role=\"banner\">\n        <div class=\"container\">\n            <div class=\"main-visual-content\">\n                <!-- 頁面標題區域 -->\n                <header class=\"page-title-area\">\n                    <!-- H1 主標題 - 唯一且最重要 -->\n                    <h1 class=\"page-title fade-in-up\">選購原子系列鍍膜</h1>\n                    \n                    <!-- 當使用圖片替代文字時，保留文字版本給 SEO -->\n                    <!-- \n                    <h1 class=\"page-title image-title fade-in-up\">選購原子系列鍍膜</h1>\n                    <span class=\"sr-only\">選購原子系列鍍膜 - APGO專業汽車鍍膜</span>\n                    -->\n                </header>\n            </div>\n        </div>\n    </section>\n\n    <!-- 購物協助區塊 -->\n    <section class=\"shopping-assistance-section\" role=\"complementary\">\n        <div class=\"container\">\n            <div class=\"assistance-options\">\n                <!-- 諮詢專員 -->\n                <div class=\"assistance-card fade-in-left\">\n                    <div class=\"card-subtitle text-small\">需要專業建議？</div>\n                    <a href=\"#\" class=\"card-link link-text\" onclick=\"handleConsultClick()\" role=\"button\">\n                        <span class=\"card-icon\" aria-hidden=\"true\">💬</span>\n                        洽詢專員\n                    </a>\n                </div>\n\n                <!-- 找門市 -->\n                <div class=\"assistance-card fade-in-left\">\n                    <div class=\"card-subtitle text-small\">想要實體體驗？</div>\n                    <a href=\"#\" class=\"card-link link-text\" onclick=\"handleStoreClick()\" role=\"button\">\n                        <span class=\"card-icon\" aria-hidden=\"true\">📍</span>\n                        尋找門市\n                    </a>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <script>\n        // 專員諮詢功能\n        function handleConsultClick() {\n            // 這裡可以替換為實際的諮詢連結或功能\n            console.log('開啟專員諮詢服務');\n            // window.open('https://line.me/ti/p/@your-line-id', '_blank');\n            \n            // 臨時提示\n            alert('即將為您開啟專員諮詢服務！');\n        }\n\n        // 實體店鋪查詢功能\n        function handleStoreClick() {\n            // 這裡可以替換為實際的店鋪查詢功能\n            console.log('開啟店鋪查詢功能');\n            // window.open('/stores', '_blank');\n            \n            // 臨時提示\n            alert('即將為您開啟店鋪查詢功能！');\n        }\n\n        // 載入動畫控制\n        document.addEventListener('DOMContentLoaded', function() {\n            // 標題載入動畫\n            const titleElements = document.querySelectorAll('.fade-in-up');\n            titleElements.forEach((element, index) => {\n                setTimeout(() => {\n                    element.classList.add('animate');\n                }, 200 + (index * 150));\n            });\n            \n            // 協助選項載入動畫\n            const assistanceCards = document.querySelectorAll('.fade-in-left');\n            assistanceCards.forEach((card, index) => {\n                setTimeout(() => {\n                    card.classList.add('animate');\n                }, 600 + (index * 200));\n            });\n        });\n\n        // 圖片標題切換功能 (未來使用)\n        function switchToImageTitle(imagePath) {\n            const title = document.querySelector('.page-title');\n            title.classList.add('image-title');\n            title.style.backgroundImage = `url('${imagePath}')`;\n            \n            // 添加 SEO 友好的隱藏文字\n            if (!document.querySelector('.sr-only')) {\n                const srText = document.createElement('span');\n                srText.className = 'sr-only';\n                srText.textContent = title.textContent + ' - APGO專業汽車鍍膜';\n                title.parentNode.appendChild(srText);\n            }\n        }\n\n        // 監聽視窗大小變化，確保響應式正常運作\n        window.addEventListener('resize', function() {\n            // 可在此處添加響應式相關的 JavaScript 邏輯\n        });\n    </script>\n</body>\n</html>",
