      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"zh-TW\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"/>\n  <title>鍍膜產品展示 - 圖片左側版</title>\n  <style>\n    * {\n      margin: 0;\n      padding: 0;\n      box-sizing: border-box;\n    }\n    body {\n      font-family: 'Arial', 'Microsoft JhengHei', sans-serif;\n      background: #000000;\n      color: #ffffff;\n      overflow-x: hidden;\n    }\n    \n    /* 標題區域樣式 */\n    .apgo-coating-header {\n      text-align: center;\n      padding: 30px 20px 15px 20px;\n    }\n    \n    .apgo-main-heading {\n      font-size: 1.8rem;\n      font-weight: 600;\n      color: #f08418;\n      margin-bottom: 12px;\n      line-height: 1.2;\n    }\n    \n    .apgo-subtitle-text {\n      font-size: 0.9rem;\n      color: #b0b0b0;\n      line-height: 1.5;\n      max-width: 700px;\n      margin: 0 auto;\n    }\n    \n    .apgo-products-container {\n      padding: 15px 20px 50px 20px;\n      position: relative;\n      width: 100%;\n      max-width: 100vw;\n    }\n    .apgo-carousel-wrapper {\n      display: flex;\n      gap: 30px;\n      overflow-x: auto !important;\n      overflow-y: hidden !important;\n      padding: 15px 0 30px 0;\n      scroll-behavior: smooth;\n      -webkit-overflow-scrolling: touch;\n      /* 強制顯示滾動條 */\n      scrollbar-width: thin !important;\n      scrollbar-color: #f08418 rgba(255, 255, 255, 0.1) !important;\n    }\n    \n    /* WebKit 瀏覽器滾動條 - 提高優先級 */\n    .apgo-products-container .apgo-carousel-wrapper.apgo-custom-scrollbar::-webkit-scrollbar {\n      height: 8px !important;\n      display: block !important;\n    }\n    .apgo-products-container .apgo-carousel-wrapper.apgo-custom-scrollbar::-webkit-scrollbar-track {\n      background: rgba(255, 255, 255, 0.1) !important;\n      border-radius: 4px !important;\n    }\n    .apgo-products-container .apgo-carousel-wrapper.apgo-custom-scrollbar::-webkit-scrollbar-thumb {\n      background: #f08418 !important;\n      border-radius: 4px !important;\n    }\n    .apgo-products-container .apgo-carousel-wrapper.apgo-custom-scrollbar::-webkit-scrollbar-thumb:hover {\n      background: #ff9a3c !important;\n    }\n    \n    /* 右邊漸層提示 - 讓用戶知道還有更多內容 */\n    .apgo-products-container::after {\n      content: '';\n      position: absolute;\n      top: 15px;\n      right: 0;\n      width: 30px;\n      height: calc(100% - 100px);\n      background: linear-gradient(90deg, transparent 0%, rgba(0, 0, 0, 0.8) 100%);\n      pointer-events: none;\n      z-index: 5;\n    }\n    \n    /* 滾動指示器 - 強制樣式 */\n    .apgo-scroll-guide {\n      position: absolute !important;\n      bottom: 15px !important;\n      left: 50% !important;\n      transform: translateX(-50%) !important;\n      color: #f08418 !important;\n      font-size: 0.7rem !important;\n      text-align: center !important;\n      z-index: 10 !important;\n      opacity: 0.8 !important;\n      display: flex !important;\n      flex-direction: column !important;\n      align-items: center !important;\n      justify-content: center !important;\n      width: 180px !important;\n    }\n    \n    .apgo-scroll-hint {\n      margin-bottom: 6px !important;\n      color: #f08418 !important;\n      font-size: 0.7rem !important;\n      text-align: center !important;\n      display: block !important;\n      width: 100% !important;\n      line-height: 1.2 !important;\n    }\n    \n    .apgo-dot-indicators {\n      display: flex !important;\n      gap: 6px !important;\n      justify-content: center !important;\n      align-items: center !important;\n      margin: 0 auto !important;\n      width: 100% !important;\n    }\n    \n    .apgo-dot {\n      width: 6px !important;\n      height: 6px !important;\n      border-radius: 50% !important;\n      background: rgba(240, 132, 24, 0.3) !important;\n      transition: all 0.3s ease !important;\n      display: block !important;\n      flex-shrink: 0 !important;\n    }\n    \n    .apgo-dot.apgo-active {\n      background: #f08418 !important;\n      transform: scale(1.2) !important;\n    }\n    \n    .apgo-item-wrapper {\n      flex: 0 0 auto;\n      width: 420px;\n      height: 400px;\n      position: relative;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n    }\n    .apgo-coating-card {\n      position: relative;\n      width: 100%;\n      height: 100%;\n      background: #1a1a1a !important;\n      border-radius: 16px;\n      padding: 24px;\n      border: 1px solid #333333;\n      box-shadow: 0 8px 24px rgba(0, 0, 0, 0.5);\n      transition: all 0.3s ease;\n      display: flex;\n      flex-direction: row;\n      align-items: stretch;\n    }\n    \n    .apgo-coating-card:hover {\n      box-shadow: 0 12px 32px rgba(240, 132, 24, 0.3);\n      transform: translateY(-4px);\n    }\n    \n    .apgo-top-accent {\n      position: absolute;\n      top: 0;\n      left: 50%;\n      transform: translateX(-50%);\n      width: 85%;\n      height: 4px;\n      background: linear-gradient(90deg, #f08418, #ff9a3c);\n      border-radius: 16px;\n      z-index: 1;\n    }\n    \n    .apgo-label {\n      position: absolute;\n      top: 16px;\n      right: 16px;\n      background: #f08418;\n      color: white;\n      padding: 1px 12px;\n      border-radius: 15px;\n      font-size: 0.8rem;\n      font-weight: bold;\n      z-index: 10;\n    }\n\n    .apgo-visual-area {\n      width: 160px;\n      height: 100%;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      overflow: hidden;\n      flex-shrink: 0;\n    }\n\n    .apgo-visual-area img {\n      width: auto;\n      height: 90%;\n      max-width: 100%;\n      object-fit: contain;\n      display: block;\n      filter: drop-shadow(0 8px 16px rgba(0, 0, 0, 0.3));\n    }\n\n    .apgo-info-section {\n      flex: 1;\n      display: flex;\n      flex-direction: column;\n      padding-left: 20px;\n      justify-content: center;\n      height: 100%;\n      position: relative;\n    }\n\n    .apgo-action-area {\n      text-align: center;\n      margin-top: 15px;\n    }\n\n    .apgo-try-button {\n      display: block;\n      width: 100%;\n      background: linear-gradient(45deg, #f08418, #ff9a3c);\n      color: white;\n      text-decoration: none;\n      padding: 8px 12px !important;\n      border-radius: 12px;\n      font-size: 0.85rem !important;\n      font-weight: bold;\n      cursor: pointer;\n      transition: all 0.3s ease;\n      box-shadow: 0 2px 6px rgba(240, 132, 24, 0.3);\n      border: none;\n      text-align: center;\n    }\n\n    .apgo-try-button:hover {\n      background: linear-gradient(45deg, #ff9a3c, #f08418);\n      transform: translateY(-1px);\n      box-shadow: 0 3px 10px rgba(240, 132, 24, 0.4);\n    }\n    \n    .apgo-coating-title {\n      font-size: 1.2rem !important;\n      font-weight: 600;\n      color: #f08418;\n      margin-bottom: 8px;\n    }\n    \n    /* 各產品專屬效果 */\n    /* 鈦晶鍍膜 - 極光漸變效果 */\n    .apgo-titanium-style .apgo-coating-title {\n      background: linear-gradient(45deg, #4FC3F7, #81E6F3, #4DD0E1);\n      -webkit-background-clip: text;\n      -webkit-text-fill-color: transparent;\n      background-clip: text;\n      animation: apgo-titanium-glow 3s ease-in-out infinite;\n    }\n    \n    @keyframes apgo-titanium-glow {\n      0%, 100% { \n        background: linear-gradient(45deg, #4FC3F7, #81E6F3, #4DD0E1);\n        -webkit-background-clip: text;\n        background-clip: text;\n      }\n      50% { \n        background: linear-gradient(45deg, #81E6F3, #4DD0E1, #4FC3F7);\n        -webkit-background-clip: text;\n        background-clip: text;\n      }\n    }\n    \n    /* 原子極光鍍膜 - 星形閃爍效果 */\n    .apgo-aurora-style .apgo-coating-title {\n      color: #4DD0E1 !important;\n      position: relative;\n    }\n    \n    .apgo-aurora-style .apgo-coating-title::before {\n      content: '✦';\n      position: absolute;\n      top: -5px;\n      right: -8px;\n      font-size: 0.7rem;\n      color: #4DD0E1;\n      animation: apgo-star-sparkle 2s ease-in-out infinite;\n    }\n    \n    @keyframes apgo-star-sparkle {\n      0%, 100% { \n        opacity: 0.3;\n        transform: scale(0.8);\n      }\n      50% { \n        opacity: 1;\n        transform: scale(1.2);\n      }\n    }\n    \n    /* 原子釉鍍膜 - 釉面光澤效果（維持不變） */\n    .apgo-glaze-style .apgo-coating-title {\n      color: #66BB6A !important;\n      position: relative;\n      overflow: hidden;\n    }\n    \n    .apgo-glaze-style .apgo-coating-title::after {\n      content: '';\n      position: absolute;\n      top: 0;\n      left: -100%;\n      width: 100%;\n      height: 100%;\n      background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.4), transparent);\n      animation: apgo-glaze-shine 4s ease-in-out infinite;\n    }\n    \n    @keyframes apgo-glaze-shine {\n      0% { left: -100%; }\n      20% { left: 100%; }\n      100% { left: 100%; }\n    }\n    \n    /* 原子微晶鍍膜 - 蠟筆風格點綴 */\n    .apgo-crystal-style .apgo-coating-title {\n      color: #81C784 !important;\n      position: relative;\n    }\n    \n    .apgo-crystal-style .apgo-coating-title::before {\n      content: '●';\n      position: absolute;\n      top: -3px;\n      left: -18px;\n      font-size: 0.5rem;\n      color: #A5D6A7;\n      animation: apgo-crystal-dot1 3s ease-in-out infinite;\n    }\n    \n    .apgo-crystal-style .apgo-coating-title::after {\n      content: '●';\n      position: absolute;\n      bottom: -3px;\n      right: -18px;\n      font-size: 0.7rem;\n      color: #66BB6A;\n      animation: apgo-crystal-dot2 3s ease-in-out infinite 1.5s;\n    }\n    \n    @keyframes apgo-crystal-dot1 {\n      0%, 100% { \n        opacity: 0.4;\n        transform: translateY(0) scale(0.8);\n      }\n      50% { \n        opacity: 0.8;\n        transform: translateY(-2px) scale(1.1);\n      }\n    }\n    \n    @keyframes apgo-crystal-dot2 {\n      0%, 100% { \n        opacity: 0.5;\n        transform: translateY(0) scale(0.9);\n      }\n      50% { \n 