    "custom_liquid_cB9f7w": {
      "type": "custom-liquid",
      "name": "t:names.custom_liquid",
      "settings": {
        "custom_liquid": "<!DOCTYPE html>\n<html lang=\"zh-TW\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>選購原子系列鍍膜 - APGO</title>\n    <style>\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        :root {\n            --primary-orange: #f08418;\n            --text-white: #ffffff;\n            --text-gray: #cccccc;\n            --text-light-gray: #b0b0b0;\n            --dark-bg: #000000;\n            --card-bg: rgba(255, 255, 255, 0.03);\n        }\n\n        body {\n            font-family: 'Arial', 'Microsoft JhengHei', sans-serif;\n            background: var(--dark-bg);\n            color: var(--text-white);\n        }\n\n        .container {\n            max-width: 1200px;\n            margin: 0 auto;\n            padding: 0 20px;\n        }\n\n        /* 1. 頁面標題區塊 */\n        .page-title-section {\n            background: var(--dark-bg);\n            padding: 40px 0 20px 0;\n        }\n\n        .page-title {\n            font-size: 2.5rem;\n            font-weight: bold;\n            color: var(--primary-orange);\n            text-align: left;\n            margin: 0;\n            line-height: 1.2;\n        }\n\n        /* 2. 快速導航選單區塊 */\n        .quick-guide-section {\n            background: var(--dark-bg);\n            padding: 20px 0;\n            border-bottom: 1px solid rgba(255, 255, 255, 0.1);\n        }\n\n        .guide-menu {\n            display: flex;\n            justify-content: flex-start;\n            gap: 0;\n            flex-wrap: nowrap;\n            overflow-x: auto;\n            padding: 0 20px;\n        }\n\n        .guide-item {\n            background: transparent;\n            border: none;\n            padding: 10px 15px;\n            text-align: center;\n            cursor: pointer;\n            transition: all 0.3s ease;\n            min-width: 120px;\n        }\n\n        .guide-item:hover {\n            transform: translateY(-2px);\n        }\n\n        .guide-item:hover .guide-title {\n            color: var(--primary-orange);\n        }\n\n        .guide-title {\n            font-size: 0.9rem;\n            font-weight: 600;\n            color: var(--text-white);\n            margin-bottom: 0;\n        }\n\n        /* 3. 購物協助區塊 */\n        .shopping-assistance-section {\n            background: var(--dark-bg);\n            padding: 20px 0;\n        }\n\n        .assistance-options {\n            display: flex;\n            justify-content: flex-start;\n            gap: 15px;\n            flex-direction: column;\n            align-items: flex-start;\n        }\n\n        .assistance-card {\n            background: transparent;\n            border: none;\n            padding: 0;\n            text-align: left;\n            transition: all 0.3s ease;\n            width: auto;\n            display: block;\n        }\n\n        .assistance-card:hover .card-link {\n            color: #ff9a3c;\n            text-decoration: underline;\n        }\n\n        .card-subtitle {\n            font-size: 0.8rem;\n            color: var(--text-gray);\n            margin-bottom: 4px;\n            font-weight: normal;\n        }\n\n        .card-link {\n            font-size: 0.9rem;\n            font-weight: 600;\n            color: var(--primary-orange);\n            text-decoration: none;\n            transition: all 0.3s ease;\n            position: relative;\n            display: inline-flex;\n            align-items: center;\n            gap: 6px;\n        }\n\n        .card-link:hover {\n            color: #ff9a3c;\n            text-decoration: underline;\n        }\n\n        .card-icon {\n            font-size: 0.9rem;\n            opacity: 0.9;\n        }\n\n        /* 響應式設計 */\n        @media (max-width: 768px) {\n            .page-title-section {\n                padding: 30px 0 15px 0;\n            }\n\n            .page-title {\n                font-size: 2rem;\n            }\n\n            .container {\n                padding: 0 15px;\n            }\n\n            .quick-guide-section {\n                padding: 15px 0;\n            }\n\n            .guide-menu {\n                padding: 0 10px;\n                justify-content: flex-start;\n            }\n\n            .guide-item {\n                padding: 8px 12px;\n                min-width: 100px;\n            }\n\n            .guide-title {\n                font-size: 0.8rem;\n            }\n\n            .shopping-assistance-section {\n                padding: 15px 0;\n            }\n\n            .assistance-options {\n                gap: 12px;\n            }\n\n            .card-subtitle {\n                font-size: 0.75rem;\n            }\n\n            .card-link {\n                font-size: 0.85rem;\n                gap: 5px;\n            }\n\n            .card-icon {\n                font-size: 0.85rem;\n            }\n        }\n\n        @media (max-width: 480px) {\n            .page-title-section {\n                padding: 25px 0 12px 0;\n            }\n\n            .page-title {\n                font-size: 1.6rem;\n            }\n\n            .quick-guide-section {\n                padding: 12px 0;\n            }\n\n            .guide-menu {\n                padding: 0 5px;\n                justify-content: flex-start;\n            }\n\n            .guide-item {\n                padding: 6px 10px;\n                min-width: 80px;\n            }\n\n            .guide-title {\n                font-size: 0.7rem;\n            }\n\n            .assistance-options {\n                gap: 10px;\n            }\n\n            .card-subtitle {\n                font-size: 0.7rem;\n            }\n\n            .card-link {\n                font-size: 0.8rem;\n                gap: 4px;\n            }\n\n            .card-icon {\n                font-size: 0.8rem;\n            }\n        }\n    </style>\n</head>\n<body>\n    <!-- 1. 頁面標題區塊 -->\n    <section class=\"page-title-section\">\n        <div class=\"container\">\n            <h1 class=\"page-title\">選購原子系列鍍膜</h1>\n        </div>\n    </section>\n\n    <!-- 2. 購物協助區塊 -->\n    <section class=\"shopping-assistance-section\">\n        <div class=\"container\">\n            <div class=\"assistance-options\">\n                <!-- 購物協助區塊 -->\n                <div class=\"assistance-card\">\n                    <div class=\"card-subtitle\">需要購物協助嗎？</div>\n                    <a href=\"#\" class=\"card-link\" onclick=\"handleConsultClick(); return false;\">\n                        <span class=\"card-icon\">💬</span>\n                        洽詢APGO專員服務\n                    </a>\n                </div>\n\n                <!-- 實體門市區塊 -->\n                <div class=\"assistance-card\">\n                    <div class=\"card-subtitle\">前往APGO實體門市</div>\n                    <a href=\"#\" class=\"card-link\" onclick=\"handleStoreClick(); return false;\">\n                        <span class=\"card-icon\">📍</span>\n                        尋找附近的實體門市\n                    </a>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <!-- 3. 快速導航選單區塊 -->\n    <section class=\"quick-guide-section\">\n        <div class=\"container\">\n            <div class=\"guide-menu\">\n                <!-- 各種鍍膜 -->\n                <div class=\"guide-item\" data-section=\"products\">\n                    <h3 class=\"guide-title\">各種鍍膜</h3>\n                </div>\n\n                <!-- 選擇幫助 -->\n                <div class=\"guide-item\" data-section=\"guide\">\n                    <h3 class=\"guide-title\">選擇幫助</h3>\n                </div>\n\n                <!-- 適用範圍 -->\n                <div class=\"guide-item\" data-section=\"scope\">\n                    <h3 class=\"guide-title\">適用範圍</h3>\n                </div>\n\n                <!-- 活動專區 -->\n                <div class=\"guide-item\" data-section=\"promotion\">\n                    <h3 class=\"guide-title\">活動專區</h3>\n                </div>\n\n                <!-- 配件專區 -->\n                <div class=\"guide-item\" data-section=\"accessories\">\n                    <h3 class=\"guide-title\">配件專區</h3>\n                </div>\n            </div>\n        </div>\n    </section>\n\n    <script>\n        // 快速跳轉功能\n        document.querySelectorAll('.guide-item').forEach(item => {\n            item.addEventListener('click', function() {\n                const section = this.dataset.section;\n                const title = this.querySelector('.guide-title').textContent;\n                \n                // 添加點擊效果\n                this.style.transform = 'translateY(-3px) scale(0.98)';\n                setTimeout(() => {\n                    this.style.transform = 'translateY(-3px) scale(1)';\n                }, 150);\n                \n                // 跳轉到對應區塊\n                scrollToSection(section, title);\n            });\n        });\n\n        // 跳轉到對應區塊\n        function scrollToSection(sectionName, title) {\n            let targetElement = null;\n            \n            // 根據不同的 section 名稱找到對應的元素\n            switch(sectionName) {\n                case 'products':\n                    targetElement = document.querySelector('#products') || \n                                  document.querySelector('.products-section') || \n                                  document.querySelector('.coating-showcase');\n                    break;\n                case 'guide':\n                    targetElement = document.querySelector('#guide') || \n                                  document.querySelector('.guide-section') || \n                                  document.querySelector('.comparison-table');\n                    break;\n                case 'scope':\n                    targetElement = document.querySelector('#scope') || \n                                  document.querySelector('.scope-section') || \n                                  document.querySelector('.scope-grid');\n                    break;\n                case 'promotion':\n                    targetElement = document.querySelector('#promotion') || \n                                  document.querySelector('.promotion-section') || \n                                  document.querySelector('.promotion-card');\n                    break;\n                case 'accessories':\n                    targetElement = document.querySelector('#accessories') || \n                                  document.querySelector('.addon-section') || \n                                  document.querySelector('.accessories-section');\n                    break;\n            }\n            \n            if (targetElement) {\n                // 平滑滾動到目標區塊\n                targetElement.scrollIntoView({\n                    behavior: 'smooth',\n                    block: 'start'\n                });\n                \n                // 可選：添加高亮效果\n                highlightSection(targetElement);\n            } else {\n                // 如果找不到對應區塊，顯示提示\n                console.log(`正在跳轉到：${title} 區塊`);\n                alert(`${title} 區塊載入中，請稍後再試。`);\n            }\n        }\n\n        // 高亮顯示目標區塊\n        function highlightSection(element) {\n            const originalBorder = element.style.border;\n            const originalBoxShadow = element.style.boxShadow;\n            \n            // 添加高亮效果\n            element.style.border = '2px solid #f08418';\n            element.style.boxShadow = '0 0 20px rgba(240, 132, 24, 0.3)';\n            element.style.transition = 'all 0.3s ease';\n            \n            // 2秒後移除高亮\n            setTimeout(() => {\n                element.style.border = originalBorder;\n                element.style.boxShadow = originalBoxShadow;\n            }, 2000);\n        }\n\n        // 專員諮詢功能\n        function handleConsultClick() {\n            // 這裡可以替換為實際的諮詢連結或功能\n            alert('即將為您開啟專員諮詢服務！');\n            // window.open('https://line.me/ti/p/@your-line-id', '_blank');\n        }\n\n        // 實體店鋪查詢功能\n        function handleStoreClick() {\n            // 這裡可以替換為實際的店鋪查詢功能\n            alert('即將為您開啟店鋪查詢功能！');\n            // window.open('/stores', '_blank');\n        }\n\n        // 鍵盤快捷鍵支援\n        document.addEventListener('keydown', function(e) {\n            const items = document.querySelectorAll('.guide-item');\n            \n            // 數字鍵 1-5 快速跳轉\n            if (e.key >= '1' && e.key <= '5') {\n                const index = parseInt(e.key) - 1;\n                if (items[index]) {\n                    items[index].click();\n                }\n            }\n        });\n\n        // 滾動觸發動畫\n        const observerOptions = {\n            threshold: 0.2,\n            rootMargin: '0px 0px -50px 0px'\n        };\n\n        const observer = new IntersectionObserver((entries) => {\n            entries.forEach(entry => {\n                if (entry.isIntersecting) {\n                    const items = entry.target.querySelectorAll('.guide-item');\n                    items.forEach((item, index) => {\n                        setTimeout(() => {\n                            item.style.opacity = '1';\n                            item.style.transform = 'translateY(0)';\n                        }, index * 100);\n                    });\n                }\n            });\n        }, observerOptions);\n\n        // 監聽動畫\n        document.addEventListener('DOMContentLoaded', () => {\n            const section = document.querySelector('.quick-guide-section');\n            const items = document.querySelectorAll('.guide-item');\n            \n            // 初始化動畫狀態\n            items.forEach(item => {\n                item.style.opacity = '0';\n                item.style.transform = 'translateY(20px)';\n                item.style.transition = 'all 0.5s ease';\n            });\n            \n            observer.observe(section);\n        });\n    </script>\n</body>\n</html>",
