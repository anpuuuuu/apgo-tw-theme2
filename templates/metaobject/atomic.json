x !important;\n        bottom: 8px !important;\n        font-size: 0.65rem !important;\n        width: 160px !important;\n        color: #f08418 !important;\n      }\n      \n      .apgo-scroll-hint {\n        font-size: 0.65rem !important;\n        color: #f08418 !important;\n        margin-bottom: 5px !important;\n      }\n      \n      .apgo-item-wrapper {\n        width: 380px;\n        height: 420px;\n      }\n      .apgo-coating-card {\n        padding: 16px;\n        border-radius: 12px;\n        background: #1a1a1a !important;\n      }\n      .apgo-visual-area {\n        width: 140px;\n        height: 100%;\n      }\n      \n      .apgo-info-section {\n        padding-left: 12px;\n        justify-content: center;\n      }\n      .apgo-coating-title {\n        font-size: 1rem;\n      }\n      .apgo-coating-intro {\n        font-size: 0.75rem;\n        margin-bottom: 8px;\n      }\n      .apgo-specs-list {\n        gap: 5px;\n      }\n      .apgo-spec-label, .apgo-spec-data {\n        font-size: 0.7rem;\n      }\n      .apgo-action-area {\n        margin-top: 20px;\n      }\n      \n      .apgo-try-button {\n        padding: 10px 8px !important;\n        font-size: 15px !important;\n        border-radius: 10px !important;\n      }\n    }\n    \n    /* 桌面版隱藏滾動指示器 */\n    @media (min-width: 769px) {\n      .apgo-scroll-guide {\n        display: flex !important;\n      }\n    }\n  </style>\n  <script>\n    // 產品 ID 配置 - 只需要替換為您的實際產品 ID\n    const apgoProductMapping = {\n      'apgo-titanium': '9034349379835',  // 請替換為您實際的產品 ID\n      'apgo-aurora': 'YOUR_PRODUCT_ID_2', \n      'apgo-glaze': 'YOUR_PRODUCT_ID_3',\n      'apgo-crystal': 'YOUR_PRODUCT_ID_4',\n      'apgo-sealant': 'YOUR_PRODUCT_ID_5',\n      'apgo-basic': 'YOUR_PRODUCT_ID_6'\n    };\n\n    // 使用產品 ID 直接跳轉到產品頁面\n    function navigateToProduct(productKey) {\n      const productId = apgoProductMapping[productKey];\n      if (productId) {\n        // 先取得產品資料來獲取正確的 handle\n        fetch(`/products/${productId}.js`)\n          .then(response => response.json())\n          .then(product => {\n            // 直接跳轉到產品頁面\n            window.location.href = `/products/${product.handle}`;\n          })\n          .catch(error => {\n            console.error('跳轉失敗:', error);\n            // 備用方案：使用產品 ID 進行搜尋\n            window.location.href = `/search?q=id:${productId}`;\n          });\n      } else {\n        console.error('找不到產品 ID:', productKey);\n      }\n    }\n\n    // 滾動指示器邏輯\n    document.addEventListener('DOMContentLoaded', function() {\n      const carousel = document.getElementById('apgoCarousel');\n      const indicators = document.querySelectorAll('.apgo-dot');\n      \n      if (carousel && indicators.length > 0) {\n        // 更新滾動指示器\n        function updateCarouselIndicator() {\n          const scrollLeft = carousel.scrollLeft;\n          const scrollWidth = carousel.scrollWidth - carousel.clientWidth;\n          const scrollPercentage = scrollLeft / scrollWidth;\n          \n          // 根據滾動位置計算當前應該高亮的點\n          const activeIndex = Math.round(scrollPercentage * (indicators.length - 1));\n          \n          indicators.forEach((dot, index) => {\n            if (index === activeIndex) {\n              dot.classList.add('apgo-active');\n            } else {\n              dot.classList.remove('apgo-active');\n            }\n          });\n        }\n        \n        // 監聽滾動事件\n        carousel.addEventListener('scroll', updateCarouselIndicator);\n        \n        // 初始化\n        updateCarouselIndicator();\n      }\n    });\n  </script>\n</head>\n<body>\n  <!-- 標題區域 -->\n  <div class=\"apgo-coating-header\">\n    <h1 class=\"apgo-main-heading\">專業鍍膜產品系列</h1>\n    <p class=\"apgo-subtitle-text\">APGO研發的鍍膜皆不分任何車色、不分任何材質，開始挑選專屬自己的鍍膜吧</p>\n  </div>\n\n  <section class=\"apgo-products-container\">\n    <div class=\"apgo-carousel-wrapper apgo-custom-scrollbar\" id=\"apgoCarousel\">\n      <!-- 鈦晶鍍膜 -->\n      <div class=\"apgo-item-wrapper\">\n        <div cla